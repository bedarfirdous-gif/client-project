@api_router.put("/expenses/{expense_id}")
async def update_expense(expense_id: str, request: ExpenseUpdate, user: dict = Depends(get_current_user)):
    """Update an existing expense"""
    tenant_id = get_tenant_id(user)
    
    expense = await db.expenses.find_one({"id": expense_id, "tenant_id": tenant_id})
    if not expense:
        raise HTTPException(status_code=404, detail="Expense not found")
    
    update_data = {k: v for k, v in request.dict().items() if v is not None}
    
    if "category" in update_data:
        if update_data["category"] not in EXPENSE_CATEGORIES:
            raise HTTPException(status_code=400, detail="Invalid category")
        update_data["category_name"] = EXPENSE_CATEGORIES[update_data["category"]]["name"]
    
    if "store_id" in update_data and update_data["store_id"]:
        store = await db.stores.find_one({"id": update_data["store_id"], "tenant_id": tenant_id})
        update_data["store_name"] = store.get("name") if store else None
    
    update_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    update_data["updated_by"] = user.get("id")
    update_data["updated_by_name"] = user.get("name")
    
    await db.expenses.update_one(
        {"id": expense_id, "tenant_id": tenant_id},
        {"$set": update_data}
    )
    
    updated = await db.expenses.find_one({"id": expense_id}, {"_id": 0})
    return updated


@api_router.delete("/expenses/{expense_id}")
async def delete_expense(expense_id: str, user: dict = Depends(get_current_user)):
    """Delete an expense (soft delete to recycle bin)"""
    tenant_id = get_tenant_id(user)
    
    expense = await db.expenses.find_one({"id": expense_id, "tenant_id": tenant_id}, {"_id": 0})
    if not expense:
        raise HTTPException(status_code=404, detail="Expense not found")
    
    # Move to recycle bin
    recycle_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "original_id": expense_id,
        "item_type": "expense",
        "item_data": expense,
        "deleted_by": user.get("id"),
        "deleted_by_name": user.get("name"),
        "deleted_at": datetime.now(timezone.utc).isoformat(),
        "auto_delete_at": (datetime.now(timezone.utc) + timedelta(days=30)).isoformat(),
        "is_permanently_deleted": False
    }
    
    await db.recycle_bin.insert_one(recycle_doc)
    await db.expenses.delete_one({"id": expense_id, "tenant_id": tenant_id})
    
    return {"message": "Expense moved to recycle bin", "recycle_id": recycle_doc["id"]}


@api_router.get("/expenses/budgets")
async def get_expense_budgets(user: dict = Depends(get_current_user)):
    """Get expense budgets per category"""
    tenant_id = get_tenant_id(user)
    
    budgets = await db.expense_budgets.find(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ).to_list(None)
    
    # Merge with default categories
    result = {}
    for cat_id, cat_info in EXPENSE_CATEGORIES.items():
        budget = next((b for b in budgets if b.get("category") == cat_id), None)
        result[cat_id] = {
            **cat_info,
            "monthly_budget": budget.get("monthly_budget", 0) if budget else 0,
            "alert_threshold": budget.get("alert_threshold", 80) if budget else 80
        }
    
    return {"budgets": result}


