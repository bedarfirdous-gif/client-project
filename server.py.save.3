@api_router.get("/ledger-management/ledgers")
async def get_ledgers(
    group_id: str = None,
    search: str = None,
    ledger_type: str = None,
    active_only: bool = True,
    limit: int = 500,
    user: dict = Depends(get_current_user)
):
    """Get all ledgers with optional filters"""
    tenant_id = get_tenant_id(user)
    
    query = {"tenant_id": tenant_id, "is_deleted": {"$ne": True}}
    
    if group_id:
        query["group_id"] = group_id
    
    if search:
        query["$or"] = [
            {"name": {"$regex": search, "$options": "i"}},
            {"contact_person": {"$regex": search, "$options": "i"}},
            {"phone": {"$regex": search, "$options": "i"}},
            {"gstin": {"$regex": search, "$options": "i"}}
        ]
    
    if ledger_type:
        query["ledger_type"] = ledger_type
    
    if active_only:
        query["is_active"] = True
    
    ledgers = await db.ledgers.find(query, {"_id": 0}).sort("name", 1).limit(limit).to_list(limit)
    
    # Calculate current balance for each ledger
    for ledger in ledgers:
        # Get all transactions for this ledger
        transactions = await db.ledger_transactions.find({
            "tenant_id": tenant_id,
            "ledger_id": ledger["id"]
        }).to_list(10000)
        
        total_debit = sum(t.get("debit", 0) for t in transactions)
        total_credit = sum(t.get("credit", 0) for t in transactions)
        
        opening = ledger.get("opening_balance", 0)
        if ledger.get("opening_balance_type") == "cr":
            opening = -opening
        
        ledger["current_balance"] = opening + total_debit - total_credit
        ledger["total_debit"] = total_debit
        ledger["total_credit"] = total_credit
    
    return {"ledgers": ledgers, "total": len(ledgers)}


