# --- Role Cloning ---
@api_router.post("/rbac/roles/{role_id}/clone")
async def clone_role(role_id: str, request: dict = Body(...), user: dict = Depends(get_current_user)):
    """
    Clone an existing role with a new name
    
    Request Body:
    {
        "new_name": "Cloned Role Name"
    }
    """
    if user.get("role") not in ["admin", "superadmin"] and not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    
    # Get original role
    original = await db.roles.find_one({"id": role_id, "tenant_id": tenant_id}, {"_id": 0})
    if not original:
        raise HTTPException(status_code=404, detail="Role not found")
    
    # Create clone
    cloned_role = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "name": request.get("new_name", f"{original['name']} (Copy)"),
        "description": f"Cloned from {original['name']}",
        "permissions": original.get("permissions", {}),
        "cloned_from": role_id,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get("id")
    }
    
    await db.roles.insert_one(cloned_role)
    del cloned_role["_id"]
    return cloned_role


