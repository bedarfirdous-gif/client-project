def get_size_from_measurements(category: str, measurements: dict) -> dict:
    """Determine size based on category and body measurements"""
    chart = CATEGORY_SIZE_CHARTS.get(category, CATEGORY_SIZE_CHARTS.get("tops"))
    
    chest = measurements.get("chest", 0)
    waist = measurements.get("waist", 0)
    hip = measurements.get("hip", 0)
    
    best_size = None
    best_score = float('inf')
    fit_details = {}
    
    for size, size_measurements in chart["measurements"].items():
        score = 0
        fits = {}
        
        # Check each measurement
        if "chest" in size_measurements and chest > 0:
            range_min, range_max = size_measurements["chest"]
            if range_min <= chest <= range_max:
                fits["chest"] = "perfect"
            elif chest < range_min:
                fits["chest"] = "loose"
                score += abs(range_min - chest)
            else:
                fits["chest"] = "tight"
                score += abs(chest - range_max)
        
        if "waist" in size_measurements and waist > 0:
            range_min, range_max = size_measurements["waist"]
            if range_min <= waist <= range_max:
                fits["waist"] = "perfect"
            elif waist < range_min:
                fits["waist"] = "loose"
                score += abs(range_min - waist)
            else:
                fits["waist"] = "tight"
                score += abs(waist - range_max)
        
        if "hip" in size_measurements and hip > 0:
            range_min, range_max = size_measurements["hip"]
            if range_min <= hip <= range_max:
                fits["hip"] = "perfect"
            elif hip < range_min:
                fits["hip"] = "loose"
                score += abs(range_min - hip)
            else:
                fits["hip"] = "tight"
                score += abs(hip - range_max)
        
        if score < best_score:
            best_score = score
            best_size = size
            fit_details = fits
    
    # Default to middle size if no measurements
    if not best_size:
        sizes = chart["sizes"]
        best_size = sizes[len(sizes) // 2]
    
    return {
        "size": best_size,
        "fit_analysis": fit_details,
        "confidence": max(60, 100 - best_score) if best_score < 40 else 50
    }


