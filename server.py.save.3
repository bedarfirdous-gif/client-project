@api_router.put("/backup-settings")
async def update_backup_settings(request: BackupSettings, user: dict = Depends(get_current_user)):
    """Update backup settings"""
    if not is_superadmin(user) and user.get("role") not in ["admin", "owner", "manager"]:
        raise HTTPException(status_code=403, detail="Admin or Manager only")
    
    tenant_id = get_tenant_id(user)
    settings_data = request.model_dump()
    settings_data["tenant_id"] = tenant_id
    settings_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    
    # Calculate next backup time
    if request.auto_backup_enabled:
        now = datetime.now(timezone.utc)
        backup_time = datetime.strptime(request.backup_time, "%H:%M").time()
        next_backup = datetime.combine(now.date(), backup_time, tzinfo=timezone.utc)
        if next_backup <= now:
            next_backup += timedelta(days=1)
        settings_data["next_backup"] = next_backup.isoformat()
    
    await db.backup_settings.update_one(
        {"tenant_id": tenant_id},
        {"$set": settings_data},
        upsert=True
    )
    
    return settings_data

