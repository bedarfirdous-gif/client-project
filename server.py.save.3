        "agreements": agreements,
        "employment_duration": None  # Can calculate from date_of_joining
    }

@api_router.post("/employees")
async def create_employee(request: EmployeeCreate, user: dict = Depends(require_permission("employees"))):
    tenant_id = get_tenant_id(user)
    
    # Validate unique employee_code
    existing = await db.employees.find_one({
        "tenant_id": tenant_id,
        "employee_code": request.employee_code
    })
    if existing:
        raise HTTPException(status_code=400, detail=f"Employee code '{request.employee_code}' already exists")
    
    # Validate unique email if provided
    if request.email:
        existing_email = await db.employees.find_one({
            "tenant_id": tenant_id,
            "email": request.email,
            "is_active": True
        })
        if existing_email:
            raise HTTPException(status_code=400, detail=f"Email '{request.email}' is already registered")
    
    employee_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        **request.model_dump(),
        "is_active": True,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "updated_at": datetime.now(timezone.utc).isoformat()
    }
    await db.employees.insert_one(employee_doc)
    del employee_doc["_id"]
    return employee_doc

@api_router.put("/employees/{employee_id}")
async def update_employee(employee_id: str, request: EmployeeCreate, user: dict = Depends(require_permission("employees"))):
    tenant_id = get_tenant_id(user)
    
    # Check employee exists
    existing = await db.employees.find_one({"tenant_id": tenant_id, "id": employee_id})
    if not existing:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Validate unique employee_code (if changed)
    if request.employee_code != existing.get("employee_code"):
        code_exists = await db.employees.find_one({
            "tenant_id": tenant_id,
            "employee_code": request.employee_code,
            "id": {"$ne": employee_id}
        })
        if code_exists:
            raise HTTPException(status_code=400, detail=f"Employee code '{request.employee_code}' already exists")
    
    update_data = request.model_dump()
    update_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    
    await db.employees.update_one({"id": employee_id}, {"$set": update_data})
    employee = await db.employees.find_one({"id": employee_id}, {"_id": 0})
    return employee

@api_router.delete("/employees/{employee_id}")
async def delete_employee(employee_id: str, user: dict = Depends(get_current_user)):
    """Soft delete employee - moves to recycle bin. Admins have full delete access."""
    tenant_id = get_tenant_id(user)
    
    # Admins can delete any employee
    if not is_admin_or_higher(user):
        permissions = user.get("permissions", {})
        if not permissions.get("employees", {}).get("delete", False):
            raise HTTPException(status_code=403, detail="Permission denied. Admin access required for delete.")
    
    # Find the employee first
    employee = await db.employees.find_one(
        {"tenant_id": tenant_id, "id": employee_id},
        {"_id": 0}
    )
    
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Move to recycle bin
    deleted_item = {
        "id": str(uuid.uuid4()),
        "original_id": employee_id,
        "item_type": "employee",
        "item_data": employee,
        "deleted_by": user.get("id"),
        "deleted_by_name": user.get("name"),
        "deleted_at": datetime.now(timezone.utc).isoformat(),
        "tenant_id": tenant_id,
        "auto_delete_at": (datetime.now(timezone.utc) + timedelta(days=30)).isoformat(),
        "is_permanently_deleted": False
    }
    
    await db.recycle_bin.insert_one(deleted_item)
    
    # Mark employee as deleted (soft delete)
    await db.employees.update_one(
        {"tenant_id": tenant_id, "id": employee_id}, 
        {"$set": {
            "is_active": False, 
            "is_deleted": True,
            "deleted_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": "Employee moved to Recycle Bin", "recycle_bin_id": deleted_item["id"]}

@api_router.post("/employees/{employee_id}/reactivate")
