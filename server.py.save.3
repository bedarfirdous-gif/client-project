@api_router.post("/items/import/preview")
async def preview_items_import(file: UploadFile = File(...), user: dict = Depends(require_permission("items"))):
    """Preview items from uploaded Excel/CSV file before importing"""
    import io
    import csv
    
    try:
        content = await file.read()
        items = []
        
        if file.filename.endswith('.csv'):
            # Parse CSV
            decoded = content.decode('utf-8')
            reader = csv.DictReader(io.StringIO(decoded))
            for row in reader:
                items.append({
                    "name": row.get('name', '').strip(),
                    "sku": row.get('sku', '').strip(),
                    "category": row.get('category', '').strip(),
                    "brand": row.get('brand', '').strip(),
                    "hsn_code": row.get('hsn_code', '').strip(),
                    "gst_rate": float(row.get('gst_rate', 0) or 0),
                    "mrp": float(row.get('mrp', 0) or 0),
                    "selling_price": float(row.get('selling_price', 0) or 0),
                    "cost_price": float(row.get('cost_price', 0) or 0),
                    "unit": row.get('unit', 'pcs').strip(),
                    "min_stock_alert": int(row.get('min_stock_alert', 0) or 0),
                    "description": row.get('description', '').strip()
                })
        else:
            # Parse Excel using openpyxl
            import openpyxl
            wb = openpyxl.load_workbook(io.BytesIO(content))
            ws = wb.active
            
            headers = [cell.value.lower().strip() if cell.value else '' for cell in ws[1]]
            
            for row in ws.iter_rows(min_row=2, values_only=True):
                row_dict = dict(zip(headers, row))
                if row_dict.get('name'):
                    items.append({
                        "name": str(row_dict.get('name', '')).strip(),
                        "sku": str(row_dict.get('sku', '')).strip() if row_dict.get('sku') else '',
                        "category": str(row_dict.get('category', '')).strip() if row_dict.get('category') else '',
                        "brand": str(row_dict.get('brand', '')).strip() if row_dict.get('brand') else '',
                        "hsn_code": str(row_dict.get('hsn_code', '')).strip() if row_dict.get('hsn_code') else '',
                        "gst_rate": float(row_dict.get('gst_rate', 0) or 0),
                        "mrp": float(row_dict.get('mrp', 0) or 0),
                        "selling_price": float(row_dict.get('selling_price', 0) or 0),
                        "cost_price": float(row_dict.get('cost_price', 0) or 0),
                        "unit": str(row_dict.get('unit', 'pcs')).strip() if row_dict.get('unit') else 'pcs',
                        "min_stock_alert": int(row_dict.get('min_stock_alert', 0) or 0),
                        "description": str(row_dict.get('description', '')).strip() if row_dict.get('description') else ''
                    })
        
        return {"items": items, "count": len(items)}
    except Exception as e:
        logger.error(f"Import preview error: {e}")
        raise HTTPException(status_code=400, detail=f"Failed to parse file: {str(e)}")

