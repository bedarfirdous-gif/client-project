@api_router.get("/reports/sales/export/excel")
async def export_sales_to_excel(
    payment_type: str = "all",
    from_date: str = None,
    to_date: str = None,
    store_id: str = None,
    user: dict = Depends(get_current_user)
):
    """Export sales report to Excel (XLSX)"""
    from fastapi.responses import StreamingResponse
    
    role = user.get("role", "").lower()
    if not user.get("is_superadmin") and role not in ["superadmin", "admin", "manager"]:
        raise HTTPException(status_code=403, detail="Manager access required")
    
    tenant_id = user.get("tenant_id", "default")
    
    # Default to last 30 days
    if not from_date:
        from_date = (datetime.now() - timedelta(days=30)).strftime("%Y-%m-%d")
    if not to_date:
        to_date = datetime.now().strftime("%Y-%m-%d")
    
    try:
        # Get the data based on payment type
        if payment_type == "all":
            data = await sales_reports_system.get_all_sales_summary(
                tenant_id, from_date, to_date, store_id
            )
            # Get detailed sales list
            cash = await sales_reports_system.get_cash_sales_report(tenant_id, from_date, to_date, store_id)
            credit = await sales_reports_system.get_credit_sales_report(tenant_id, from_date, to_date, store_id)
            upi = await sales_reports_system.get_sales_by_payment_type(tenant_id, "upi", from_date, to_date, store_id)
            card = await sales_reports_system.get_sales_by_payment_type(tenant_id, "card", from_date, to_date, store_id)
            bank = await sales_reports_system.get_sales_by_payment_type(tenant_id, "bank_transfer", from_date, to_date, store_id)
            
            all_sales = (
                cash.get("sales", []) + 
                credit.get("sales", []) + 
                upi.get("sales", []) + 
                card.get("sales", []) + 
                bank.get("sales", [])
            )
        else:
            data = await sales_reports_system.get_sales_by_payment_type(
                tenant_id, payment_type, from_date, to_date, store_id
            )
            all_sales = data.get("sales", [])
        
        # Generate Excel
        excel_buffer = sales_reports_system.generate_excel_report(
            all_sales,
            payment_type,
            from_date,
            to_date,
            data.get("by_payment_type", {}) if payment_type == "all" else {}
        )
        
        filename = f"sales_report_{payment_type}_{from_date}_to_{to_date}.xlsx"
        
        return StreamingResponse(
            iter([excel_buffer.getvalue()]),
            media_type="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            headers={"Content-Disposition": f"attachment; filename={filename}"}
        )
    except Exception as e:
