@api_router.put("/ecommerce/store-slug")
async def update_store_slug(
    data: dict = Body(...),
    user: dict = Depends(get_current_user)
):
    """Update custom store slug for subdomain URL"""
    tenant_id = get_tenant_id(user)
    new_slug = data.get("slug", "").strip().lower()
    
    if not new_slug:
        raise HTTPException(status_code=400, detail="Store slug is required")
    
    # Validate slug format (alphanumeric, hyphens only, 3-30 chars)
    import re
    if not re.match(r'^[a-z0-9][a-z0-9-]{1,28}[a-z0-9]$', new_slug):
        raise HTTPException(
            status_code=400, 
            detail="Slug must be 3-30 characters, alphanumeric and hyphens only, cannot start/end with hyphen"
        )
    
    # Reserved slugs
    reserved_slugs = ['admin', 'api', 'www', 'app', 'store', 'shop', 'mail', 'ftp', 'blog', 'help', 'support', 'test', 'demo', 'staging', 'dev', 'prod']
    if new_slug in reserved_slugs:
        raise HTTPException(status_code=400, detail=f"'{new_slug}' is a reserved slug and cannot be used")
    
    # Check uniqueness across all tenants
    existing = await db.tenants.find_one({"slug": new_slug, "id": {"$ne": tenant_id}})
    if existing:
        raise HTTPException(status_code=400, detail=f"Slug '{new_slug}' is already taken by another store")
    
    # Update tenant with new slug
    await db.tenants.update_one(
        {"id": tenant_id},
        {"$set": {
            "slug": new_slug,
            "custom_slug": True,
            "slug_updated_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    # Generate new store URL
    store_url = f"{new_slug}.bijnisbooks.com"
    
    return {
        "message": "Store slug updated successfully",
        "slug": new_slug,
        "store_url": store_url,
        "dns_instructions": {
            "type": "CNAME",
            "host": new_slug,
            "value": "stores.bijnisbooks.com",
            "ttl": 3600,
            "note": "Add this CNAME record to your DNS settings if you have a custom domain"
        }
    }


@api_router.get("/ecommerce/check-slug/{slug}")
async def check_slug_availability(
    slug: str,
    user: dict = Depends(get_current_user)
):
    """Check if a store slug is available"""
    tenant_id = get_tenant_id(user)
    slug = slug.strip().lower()
    
    # Validate format
    import re
    if not re.match(r'^[a-z0-9][a-z0-9-]{1,28}[a-z0-9]$', slug):
        return {"available": False, "reason": "Invalid format. Use 3-30 alphanumeric characters and hyphens."}
    
    # Check reserved
    reserved_slugs = ['admin', 'api', 'www', 'app', 'store', 'shop', 'mail', 'ftp', 'blog', 'help', 'support', 'test', 'demo', 'staging', 'dev', 'prod']
    if slug in reserved_slugs:
        return {"available": False, "reason": "This slug is reserved"}
    
    # Check if taken by another tenant
    existing = await db.tenants.find_one({"slug": slug, "id": {"$ne": tenant_id}})
    if existing:
        return {"available": False, "reason": "This slug is already taken"}
    
    return {"available": True, "slug": slug, "preview_url": f"{slug}.bijnisbooks.com"}


