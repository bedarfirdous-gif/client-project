@api_router.put("/purchase-returns/{return_id}/status")
async def update_purchase_return_status(
    return_id: str,
    status: str = Query(...),
    user: dict = Depends(get_current_user)
):
    tenant_id = get_tenant_id(user)
    
    # Get the return first
    return_doc = await db.purchase_returns.find_one({"id": return_id, "tenant_id": tenant_id})
    if not return_doc:
        raise HTTPException(status_code=404, detail="Purchase return not found")
    
    # If approving the return, deduct stock from central_stock and create ledger entry
    if status == "approved" and return_doc.get("status") != "approved":
        inv_service = get_inventory_service()
        store_id = return_doc.get("store_id", "default")
        
        for item in return_doc.get("items", []):
            variant_id = item.get("variant_id")
            quantity = item.get("quantity", 0)
            item_id = item.get("item_id", "")
            
            if variant_id and quantity > 0:
                try:
                    # Deduct from central_stock
                    await inv_service.deduct_stock(
                        tenant_id=tenant_id,
                        item_id=item_id,
                        variant_id=variant_id,
                        quantity=quantity,
                        movement_type=MovementType.RETURN,
                        warehouse_id=store_id,
                        notes=f"Purchase return: {return_doc.get('return_number', return_id)}",
                        performed_by=user.get("id"),
                        allow_negative=True
                    )
                    
                    # Also update legacy inventory
                    await db.inventory.update_one(
                        {"variant_id": variant_id, "store_id": store_id, "tenant_id": tenant_id},
                        {"$inc": {"quantity": -quantity}}
                    )
                except Exception as e:
                    logger.error(f"Failed to deduct stock for purchase return: {e}")
        
        # Create supplier ledger entry for purchase return
        supplier_id = return_doc.get("supplier_id")
        return_amount = return_doc.get("return_amount", 0)
        
        if supplier_id and return_amount > 0:
            try:
                # Get supplier info to find linked ledger
                supplier = await db.suppliers.find_one({"id": supplier_id, "tenant_id": tenant_id})
                
                if supplier:
                    ledger_id = supplier.get("ledger_id")
                    
                    # If supplier doesn't have a ledger, create one
                    if not ledger_id:
                        ledger_id = str(uuid.uuid4())
                        new_ledger = {
                            "id": ledger_id,
                            "tenant_id": tenant_id,
                            "name": supplier.get("name", "Unknown Supplier"),
                            "type": "Sundry Creditors",
                            "group": "Current Liabilities",
                            "opening_balance": 0,
                            "current_balance": 0,
                            "created_at": datetime.now(timezone.utc).isoformat(),
                            "is_deleted": False
                        }
                        await db.ledgers.insert_one(new_ledger)
                        await db.suppliers.update_one(
                            {"id": supplier_id, "tenant_id": tenant_id},
                            {"$set": {"ledger_id": ledger_id}}
                        )
                    
                    # Create ledger entry for purchase return (debit the supplier - reduces liability)
                    entry_id = str(uuid.uuid4())
                    ledger_entry = {
                        "id": entry_id,
                        "tenant_id": tenant_id,
                        "ledger_id": ledger_id,
                        "date": datetime.now(timezone.utc).strftime("%Y-%m-%d"),
                        "voucher_type": "Debit Note",
                        "voucher_number": return_doc.get("return_number", f"PR-{return_id[:8]}"),
                        "description": f"Purchase Return - {return_doc.get('return_number', '')}",
                        "reference": return_id,
                        "reference_type": "purchase_return",
                        "debit": return_amount,  # Debit reduces liability (supplier owes us)
                        "credit": 0,
                        "balance": 0,  # Will be calculated
                        "created_at": datetime.now(timezone.utc).isoformat(),
                        "created_by": user.get("id")
                    }
                    await db.ledger_entries.insert_one(ledger_entry)
                    
                    # Update ledger balance (reduce the creditor balance)
                    await db.ledgers.update_one(
                        {"id": ledger_id, "tenant_id": tenant_id},
                        {"$inc": {"current_balance": -return_amount}}
                    )
                    
                    logger.info(f"Created supplier ledger entry for purchase return {return_id}, amount: {return_amount}")
            except Exception as e:
                logger.error(f"Failed to create supplier ledger entry for purchase return: {e}")
    
    result = await db.purchase_returns.update_one(
        {"id": return_id, "tenant_id": tenant_id},
        {"$set": {"status": status, "updated_at": datetime.now(timezone.utc).isoformat()}}
    )
    if result.modified_count == 0:
        raise HTTPException(status_code=404, detail="Purchase return not found or not updated")
    return {"message": "Status updated", "status": status}

