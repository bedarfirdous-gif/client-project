@api_router.get("/trash")
async def get_trash(user: dict = Depends(get_current_user)):
    """Get all items in trash"""
    tenant_id = get_tenant_id(user)
    
    # Get items deleted within last 30 days
    cutoff = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()
    
    trash_items = await db.trash.find(
        {"tenant_id": tenant_id, "deleted_at": {"$gte": cutoff}},
        {"_id": 0}
    ).sort("deleted_at", -1).to_list(1000)
    
    return trash_items

@api_router.post("/trash/{item_id}/restore")
async def restore_from_trash(item_id: str, user: dict = Depends(get_current_user)):
    """Restore item from trash"""
    tenant_id = get_tenant_id(user)
    
    trash_item = await db.trash.find_one({"id": item_id, "tenant_id": tenant_id})
    
    if not trash_item:
        raise HTTPException(status_code=404, detail="Item not found in trash")
    
    # Restore to original collection
    original_data = trash_item.get("original_data", {})
    collection = trash_item.get("collection")
    
    if collection and original_data:
        original_data["tenant_id"] = tenant_id
        await db[collection].insert_one(original_data)
    
    # Remove from trash
    await db.trash.delete_one({"id": item_id, "tenant_id": tenant_id})
    
    return {"message": "Item restored successfully"}

@api_router.delete("/trash/{item_id}")
async def permanent_delete(item_id: str, user: dict = Depends(get_current_user)):
    """Permanently delete item from trash"""
    tenant_id = get_tenant_id(user)
    
    result = await db.trash.delete_one({"id": item_id, "tenant_id": tenant_id})
    
    if result.deleted_count == 0:
        raise HTTPException(status_code=404, detail="Item not found in trash")
    
    return {"message": "Item permanently deleted"}

@api_router.delete("/trash/empty")
async def empty_trash(user: dict = Depends(get_current_user)):
    """Empty all items in trash"""
    if not is_superadmin(user) and user.get("role") not in ["admin", "owner"]:
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    
    result = await db.trash.delete_many({"tenant_id": tenant_id})
    
    return {"message": f"Deleted {result.deleted_count} items from trash"}


