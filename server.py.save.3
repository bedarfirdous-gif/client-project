        query["date"] = {**query.get("date", {}), "$lte": end_date}
    if customer_id:
        query["customer_id"] = customer_id
    
    # Get all sales invoices
    invoices = await db.invoices.find(query, {"_id": 0}).sort("date", -1).to_list(None)
    
    # Format entries
    entries = []
    total_amount = 0
    total_gst = 0
    total_gross = 0
    
    for inv in invoices:
        amount = inv.get("subtotal", 0) or inv.get("taxable_amount", 0) or 0
        gst = inv.get("total_gst", 0) or inv.get("gst_amount", 0) or 0
        gross = inv.get("total", 0) or inv.get("total_amount", 0) or (amount + gst)
        
        total_amount += amount
        total_gst += gst
        total_gross += gross
        
        entries.append({
            "id": inv.get("id"),
            "date": inv.get("date"),
            "invoice_number": inv.get("invoice_number"),
            "customer_id": inv.get("customer_id"),
            "customer_name": inv.get("customer_name") or inv.get("customer", {}).get("name", "Walk-in"),
            "amount": amount,
            "gst": gst,
            "total": gross,
            "payment_status": inv.get("payment_status", "paid"),
            "payment_method": inv.get("payment_method", "cash"),
            "items_count": len(inv.get("items", []))
        })
    
    return {
        "entries": entries,
        "summary": {
            "total_invoices": len(entries),
            "total_amount": total_amount,
            "total_gst": total_gst,
            "total_gross": total_gross
        }
    }

