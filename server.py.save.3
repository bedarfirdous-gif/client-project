@api_router.post("/admin/restore-backup")
async def restore_backup(user: dict = Depends(get_current_user)):
    if not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Admin only")
    
    backup_file = ROOT_DIR.parent / "backup_full_b9b454bf_20260201_032030.json"
    if not backup_file.exists():
        raise HTTPException(status_code=404, detail="Backup file not found")
    
    with open(backup_file, 'r') as f:
        data = json.load(f)
    
    collections = data.get("collections", {})
    restored = {}
    
    # CRITICAL: Exclude users collection from restore to prevent losing superadmin
    # Also preserve certain critical collections
    protected_collections = {'users', 'sessions', 'login_history', 'api_keys'}
    
    for name, records in collections.items():
        if records and name not in protected_collections:
            collection = db[name]
            # Clear existing data
            await collection.delete_many({})
            # Insert backup data
            await collection.insert_many(records)
            restored[name] = len(records)
        elif name in protected_collections:
            restored[name] = "SKIPPED (protected)"
    
    return {"message": "Backup restored", "restored": restored}

# ============== SYSTEM MAINTENANCE ==============

@api_router.post("/system/cleanup")
async def system_cleanup(user: dict = Depends(get_current_user)):
    """Clean up system resources and reset stuck processes"""
    tenant_id = get_tenant_id(user)
    
    cleanup_results = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "user_id": user.get("id"),
        "user_name": user.get("name"),
        "actions": []
    }
    
    try:
        # 1. Clear old notifications (older than 30 days)
        thirty_days_ago = (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()
        old_notifications = await db.notifications.delete_many({
            "tenant_id": tenant_id,
            "created_at": {"$lt": thirty_days_ago}
        })
        cleanup_results["actions"].append({
            "action": "clear_old_notifications",
            "deleted": old_notifications.deleted_count
        })
        
        # 2. Clear old audit logs (older than 90 days)
        ninety_days_ago = (datetime.now(timezone.utc) - timedelta(days=90)).isoformat()
        old_audit = await db.audit_logs.delete_many({
            "tenant_id": tenant_id,
            "created_at": {"$lt": ninety_days_ago}
        })
        cleanup_results["actions"].append({
            "action": "clear_old_audit_logs",
            "deleted": old_audit.deleted_count
        })
        
        # 3. Clear expired sessions
        expired_sessions = await db.sessions.delete_many({
            "tenant_id": tenant_id,
            "expires_at": {"$lt": datetime.now(timezone.utc).isoformat()}
        })
        cleanup_results["actions"].append({
            "action": "clear_expired_sessions",
            "deleted": expired_sessions.deleted_count
        })
        
        # 4. Reset stuck processing orders (older than 24 hours)
        one_day_ago = (datetime.now(timezone.utc) - timedelta(hours=24)).isoformat()
        stuck_orders = await db.sales_orders.update_many(
            {
                "tenant_id": tenant_id,
                "status": "processing",
                "updated_at": {"$lt": one_day_ago}
            },
            {"$set": {"status": "pending", "updated_at": datetime.now(timezone.utc).isoformat()}}
        )
        cleanup_results["actions"].append({
            "action": "reset_stuck_orders",
            "modified": stuck_orders.modified_count
        })
        
        # 5. Clear orphaned temp files (if any temp file collection exists)
        try:
            temp_files = await db.temp_files.delete_many({
                "tenant_id": tenant_id,
                "created_at": {"$lt": thirty_days_ago}
            })
            cleanup_results["actions"].append({
                "action": "clear_temp_files",
                "deleted": temp_files.deleted_count
            })
        except:
            pass
        
        # 6. Log the cleanup action
        await db.system_logs.insert_one({
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "type": "system_cleanup",
            "user_id": user.get("id"),
            "user_name": user.get("name"),
            "results": cleanup_results,
            "created_at": datetime.now(timezone.utc).isoformat()
        })
        
        cleanup_results["success"] = True
        cleanup_results["message"] = "System cleanup completed successfully"
        
    except Exception as e:
        cleanup_results["success"] = False
        cleanup_results["error"] = str(e)
        
    return cleanup_results

@api_router.get("/system/health")
async def get_system_health(user: dict = Depends(get_current_user)):
    """Get system health status"""
    tenant_id = get_tenant_id(user)
    
    try:
        # Check database connectivity
        db_status = "healthy"
        try:
            await db.command("ping")
        except:
            db_status = "unhealthy"
        
        # Get counts
        users_count = await db.users.count_documents({"tenant_id": tenant_id})
        items_count = await db.items.count_documents({"tenant_id": tenant_id})
        sales_count = await db.sales.count_documents({"tenant_id": tenant_id})
        
        # Get recent errors from system logs
        one_hour_ago = (datetime.now(timezone.utc) - timedelta(hours=1)).isoformat()
        recent_errors = await db.system_logs.count_documents({
            "tenant_id": tenant_id,
            "type": {"$in": ["error", "crash"]},
            "created_at": {"$gte": one_hour_ago}
        })
        
        status = "healthy"
        if recent_errors >= 5:
            status = "warning"
        if recent_errors >= 10 or db_status != "healthy":
            status = "critical"
        
        return {
            "status": status,
            "database": db_status,
            "counts": {
                "users": users_count,
                "items": items_count,
                "sales": sales_count
            },
            "recent_errors": recent_errors,
            "timestamp": datetime.now(timezone.utc).isoformat()
        }
        
    except Exception as e:
        return {
            "status": "error",
            "error": str(e),
            "timestamp": datetime.now(timezone.utc).isoformat()
        }

