            headers = [cell.value.lower().strip() if cell.value else '' for cell in ws[1]]
            for row in ws.iter_rows(min_row=2, values_only=True):
                row_dict = dict(zip(headers, row))
                if row_dict.get('name'):
                    items_data.append(row_dict)
        
        imported = 0
        errors = []
        
        for idx, row in enumerate(items_data):
            try:
                item_id = str(uuid.uuid4())
                variant_id = str(uuid.uuid4())
                
                name = str(row.get('name', '')).strip()
                sku = str(row.get('sku', '')).strip() if row.get('sku') else f"{name[:3].upper()}-{str(uuid.uuid4())[:4].upper()}"
                
                # Create item
                item_doc = {
                    "id": item_id,
                    "tenant_id": tenant_id,
                    "name": name,
                    "sku": sku,
                    "category": str(row.get('category', '')).strip() if row.get('category') else '',
                    "brand": str(row.get('brand', '')).strip() if row.get('brand') else '',
                    "hsn_code": str(row.get('hsn_code', '')).strip() if row.get('hsn_code') else '',
                    "gst_rate": float(row.get('gst_rate', 0) or 0),
                    "mrp": float(row.get('mrp', 0) or 0),
                    "selling_price": float(row.get('selling_price', 0) or 0),
                    "cost_price": float(row.get('cost_price', 0) or 0),
                    "unit": str(row.get('unit', 'pcs')).strip() if row.get('unit') else 'pcs',
                    "min_stock_alert": int(row.get('min_stock_alert', 0) or 0),
                    "description": str(row.get('description', '')).strip() if row.get('description') else '',
                    "images": [],
                    "created_at": now,
                    "updated_at": now
                }
                
                await db.items.insert_one(item_doc)
                
                # Create default variant
                variant_doc = {
                    "id": variant_id,
                    "tenant_id": tenant_id,
                    "item_id": item_id,
                    "sku": sku,
                    "selling_price": float(row.get('selling_price', 0) or 0),
                    "cost_price": float(row.get('cost_price', 0) or 0),
                    "mrp": float(row.get('mrp', 0) or 0),
                    "current_stock": 0,
                    "attributes": {},
                    "created_at": now
                }
                await db.variants.insert_one(variant_doc)
                
                # Create initial central_stock record
                central_stock_doc = {
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "item_id": item_id,
                    "variant_id": variant_id,
                    "warehouse_id": None,
                    "quantity": 0,
                    "created_at": now,
                    "updated_at": now
                }
                await db.central_stock.insert_one(central_stock_doc)
                
                imported += 1
                
            except Exception as e:
                errors.append({"row": idx + 2, "name": str(row.get('name', '')), "error": str(e)})
        
        logger.info(f"Bulk import completed: {imported} items imported, {len(errors)} errors")
        
        return {
            "imported": imported,
            "total": len(items_data),
            "errors": errors[:10]  # Return first 10 errors only
        }
        
    except Exception as e:
        logger.error(f"Import error: {e}")
        raise HTTPException(status_code=400, detail=f"Import failed: {str(e)}")

@api_router.post("/suppliers/import")
async def import_suppliers(file: UploadFile = File(...), user: dict = Depends(require_permission("suppliers"))):
    """Import suppliers from uploaded Excel/CSV file"""
    import io
    import csv
    
    tenant_id = get_tenant_id(user)
    now = datetime.now(timezone.utc).isoformat()
    
    try:
        content = await file.read()
        suppliers_data = []
        
        if file.filename.endswith('.csv'):
            decoded = content.decode('utf-8')
            reader = csv.DictReader(io.StringIO(decoded))
            for row in reader:
                if row.get('name', '').strip():
                    suppliers_data.append(row)
        else:
            import openpyxl
            wb = openpyxl.load_workbook(io.BytesIO(content))
            ws = wb.active
            headers = [cell.value.lower().strip() if cell.value else '' for cell in ws[1]]
            for row in ws.iter_rows(min_row=2, values_only=True):
                row_dict = dict(zip(headers, row))
                if row_dict.get('name'):
                    suppliers_data.append(row_dict)
        
        imported = 0
        errors = []
        
        for idx, row in enumerate(suppliers_data):
            try:
                supplier_id = str(uuid.uuid4())
                ledger_id = str(uuid.uuid4())
                
                name = str(row.get('name', '')).strip()
                
                # Create ledger under Sundry Creditors
                ledger_doc = {
                    "id": ledger_id,
                    "tenant_id": tenant_id,
                    "name": name,
                    "group_id": "sundry_creditors",
                    "ledger_type": "liability",
                    "ledger_nature": "credit",
                    "opening_balance": float(row.get('opening_balance', 0) or 0),
                    "opening_balance_type": "Cr",
                    "phone": str(row.get('phone', '')).strip() if row.get('phone') else '',
                    "email": str(row.get('email', '')).strip() if row.get('email') else '',
                    "gstin": str(row.get('gst_number', '')).strip() if row.get('gst_number') else '',
                    "state": str(row.get('state', '')).strip() if row.get('state') else '',
                    "address": str(row.get('address', '')).strip() if row.get('address') else '',
                    "is_active": True,
                    "linked_supplier_id": supplier_id,
                    "created_at": now,
                    "updated_at": now,
                    "is_deleted": False
                }
                await db.ledgers.insert_one(ledger_doc)
                
                # Create supplier
                supplier_doc = {
                    "id": supplier_id,
                    "tenant_id": tenant_id,
                    "ledger_id": ledger_id,
                    "name": name,
                    "contact_person": str(row.get('contact_person', '')).strip() if row.get('contact_person') else '',
                    "phone": str(row.get('phone', '')).strip() if row.get('phone') else '',
                    "email": str(row.get('email', '')).strip() if row.get('email') else '',
                    "gst_number": str(row.get('gst_number', '')).strip() if row.get('gst_number') else '',
                    "address": str(row.get('address', '')).strip() if row.get('address') else '',
                    "city": str(row.get('city', '')).strip() if row.get('city') else '',
                    "state": str(row.get('state', '')).strip() if row.get('state') else '',
                    "pincode": str(row.get('pincode', '')).strip() if row.get('pincode') else '',
                    "created_at": now
                }
                await db.suppliers.insert_one(supplier_doc)
                
                imported += 1
                
            except Exception as e:
                errors.append({"row": idx + 2, "name": str(row.get('name', '')), "error": str(e)})
        
        logger.info(f"Supplier bulk import: {imported} imported, {len(errors)} errors")
        
        return {
            "imported": imported,
            "total": len(suppliers_data),
            "errors": errors[:10]
        }
        
    except Exception as e:
        logger.error(f"Supplier import error: {e}")
        raise HTTPException(status_code=400, detail=f"Import failed: {str(e)}")

