    if start_date:
        purchase_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in purchase_query:
            purchase_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            purchase_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    purchases = await db.purchase_invoices.find(purchase_query, {"_id": 0}).to_list(10000)
    for purchase in purchases:
        ledger_entries.append({
            "date": purchase.get("created_at"),
            "reference": purchase.get("invoice_number", ""),
            "description": f"Purchase from {purchase.get('supplier_name', 'Supplier')}",
            "account_code": "5000",
            "account_name": "Cost of Goods Sold",
            "debit": purchase.get("total_amount", 0),
            "credit": 0,
            "type": "purchase"
        })
        if purchase.get("payment_status") == "paid":
            ledger_entries.append({
                "date": purchase.get("created_at"),
                "reference": purchase.get("invoice_number", ""),
                "description": f"Payment for purchase {purchase.get('invoice_number', '')}",
                "account_code": "1000",
                "account_name": "Cash",
                "debit": 0,
                "credit": purchase.get("total_amount", 0),
                "type": "purchase"
            })
        else:
            ledger_entries.append({
                "date": purchase.get("created_at"),
                "reference": purchase.get("invoice_number", ""),
                "description": f"Payable for purchase {purchase.get('invoice_number', '')}",
                "account_code": "2000",
                "account_name": "Accounts Payable",
                "debit": 0,
                "credit": purchase.get("total_amount", 0),
                "type": "purchase"
            })
    
    # Payroll transactions
    payroll_query = {"tenant_id": tenant_id, "status": "paid"}
    if start_date and end_date:
        payroll_query["$or"] = [
            {"pay_period_start": {"$gte": start_date, "$lte": end_date}},
            {"pay_period_end": {"$gte": start_date, "$lte": end_date}}
        ]
    payroll = await db.payroll.find(payroll_query, {"_id": 0}).to_list(10000)
    for pay in payroll:
        ledger_entries.append({
            "date": pay.get("paid_at") or pay.get("created_at"),
            "reference": pay.get("id", ""),
            "description": f"Salary payment to {pay.get('employee_name', 'Employee')}",
            "account_code": "5100",
            "account_name": "Salaries & Wages",
            "debit": pay.get("net_pay", 0),
            "credit": 0,
            "type": "payroll"
        })
        ledger_entries.append({
            "date": pay.get("paid_at") or pay.get("created_at"),
            "reference": pay.get("id", ""),
            "description": f"Salary payment to {pay.get('employee_name', 'Employee')}",
            "account_code": "1000",
            "account_name": "Cash",
            "debit": 0,
            "credit": pay.get("net_pay", 0),
            "type": "payroll"
        })
    
    # Filter by account_code if specified
    if account_code:
        ledger_entries = [e for e in ledger_entries if e["account_code"] == account_code]
    
    # Sort by date
    ledger_entries.sort(key=lambda x: x["date"] if x["date"] else "")
    
    # Calculate running balance for each account
    account_balances = {}
    for entry in ledger_entries:
        code = entry["account_code"]
        if code not in account_balances:
            account_balances[code] = 0
        account_balances[code] += entry["debit"] - entry["credit"]
        entry["running_balance"] = round(account_balances[code], 2)
        entry["debit"] = round(entry["debit"], 2)
        entry["credit"] = round(entry["credit"], 2)
    
    return {
        "period": {"start_date": start_date, "end_date": end_date, "store_id": store_id},
        "account_filter": account_code,
        "entries": ledger_entries,
        "summary": {
            "total_entries": len(ledger_entries),
            "total_debits": round(sum(e["debit"] for e in ledger_entries), 2),
            "total_credits": round(sum(e["credit"] for e in ledger_entries), 2),
            "accounts_affected": list(set(e["account_code"] for e in ledger_entries))
        }
    }


@api_router.get("/accounting/ar-aging")
async def get_ar_aging_report(
    as_of_date: str = "",
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Generate Accounts Receivable Aging Report"""
    tenant_id = get_tenant_id(user)
    
    # Use current date if not specified
    if not as_of_date:
        as_of_date = datetime.now(timezone.utc).isoformat()
    
    as_of = datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))
    
    # Get all unpaid/partially paid invoices
    invoice_query = {
        "tenant_id": tenant_id,
        "status": {"$in": ["sent", "partial", "overdue"]}
    }
    if store_id:
        invoice_query["store_id"] = store_id
    
    invoices = await db.invoices.find(invoice_query, {"_id": 0}).to_list(10000)
    
    # Get customers for names
    customers = await db.customers.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(10000)
    customer_map = {c["id"]: c for c in customers}
    
    # Aging buckets
    aging_buckets = {
        "current": {"min": 0, "max": 30, "total": 0, "count": 0, "invoices": []},
        "31_60": {"min": 31, "max": 60, "total": 0, "count": 0, "invoices": []},
        "61_90": {"min": 61, "max": 90, "total": 0, "count": 0, "invoices": []},
        "over_90": {"min": 91, "max": 9999, "total": 0, "count": 0, "invoices": []}
    }
    
    customer_aging = {}
    
    for inv in invoices:
        balance = inv.get("balance_due", 0) or (inv.get("total_amount", 0) - inv.get("amount_paid", 0))
        if balance <= 0:
            continue
            
        # Calculate days outstanding
        due_date_str = inv.get("due_date") or inv.get("created_at")
        if due_date_str:
            try:
                if isinstance(due_date_str, str):
                    due_date = datetime.fromisoformat(due_date_str.replace('Z', '+00:00'))
                else:
                    due_date = due_date_str
                days_outstanding = (as_of - due_date).days
            except:
                days_outstanding = 0
        else:
            days_outstanding = 0
        
        # Get customer info
        customer_id = inv.get("customer_id", "")
        customer = customer_map.get(customer_id, {})
        customer_name = customer.get("name") or inv.get("customer_name", "Unknown")
        
        invoice_data = {
            "invoice_number": inv.get("invoice_number", ""),
            "customer_id": customer_id,
            "customer_name": customer_name,
            "invoice_date": inv.get("created_at"),
            "due_date": inv.get("due_date"),
            "total_amount": inv.get("total_amount", 0),
            "amount_paid": inv.get("amount_paid", 0),
            "balance_due": round(balance, 2),
            "days_outstanding": max(0, days_outstanding)
        }
        
        # Add to appropriate bucket
        if days_outstanding <= 30:
            bucket = "current"
        elif days_outstanding <= 60:
            bucket = "31_60"
        elif days_outstanding <= 90:
            bucket = "61_90"
        else:
            bucket = "over_90"
        
        aging_buckets[bucket]["total"] += balance
        aging_buckets[bucket]["count"] += 1
        aging_buckets[bucket]["invoices"].append(invoice_data)
        
        # Add to customer aging
        if customer_id not in customer_aging:
            customer_aging[customer_id] = {
                "customer_id": customer_id,
                "customer_name": customer_name,
                "current": 0,
                "31_60": 0,
                "61_90": 0,
                "over_90": 0,
                "total": 0
            }
        customer_aging[customer_id][bucket] += balance
        customer_aging[customer_id]["total"] += balance
    
    # Round totals
    for bucket in aging_buckets.values():
        bucket["total"] = round(bucket["total"], 2)
    
    for customer in customer_aging.values():
        for key in ["current", "31_60", "61_90", "over_90", "total"]:
            customer[key] = round(customer[key], 2)
    
    total_receivables = sum(b["total"] for b in aging_buckets.values())
    
    return {
        "as_of_date": as_of_date,
        "store_id": store_id,
        "aging_buckets": aging_buckets,
        "customer_aging": sorted(customer_aging.values(), key=lambda x: x["total"], reverse=True),
        "summary": {
            "total_receivables": round(total_receivables, 2),
            "total_invoices": sum(b["count"] for b in aging_buckets.values()),
            "total_customers": len(customer_aging),
            "current_percentage": round((aging_buckets["current"]["total"] / total_receivables * 100) if total_receivables > 0 else 0, 1),
            "overdue_percentage": round(((aging_buckets["31_60"]["total"] + aging_buckets["61_90"]["total"] + aging_buckets["over_90"]["total"]) / total_receivables * 100) if total_receivables > 0 else 0, 1)
        }
    }


@api_router.get("/accounting/ap-aging")
async def get_ap_aging_report(
    as_of_date: str = "",
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Generate Accounts Payable Aging Report"""
    tenant_id = get_tenant_id(user)
    
    if not as_of_date:
        as_of_date = datetime.now(timezone.utc).isoformat()
    
    as_of = datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))
    
    # Get all unpaid/partially paid purchase invoices
    purchase_query = {
        "tenant_id": tenant_id,
        "payment_status": {"$in": ["unpaid", "partial", "pending"]}
    }
    if store_id:
        purchase_query["store_id"] = store_id
    
    purchases = await db.purchase_invoices.find(purchase_query, {"_id": 0}).to_list(10000)
    
    # Get suppliers for names
    suppliers = await db.suppliers.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(10000)
    supplier_map = {s["id"]: s for s in suppliers}
    
    # Aging buckets
    aging_buckets = {
        "current": {"min": 0, "max": 30, "total": 0, "count": 0, "invoices": []},
        "31_60": {"min": 31, "max": 60, "total": 0, "count": 0, "invoices": []},
        "61_90": {"min": 61, "max": 90, "total": 0, "count": 0, "invoices": []},
        "over_90": {"min": 91, "max": 9999, "total": 0, "count": 0, "invoices": []}
    }
    
    supplier_aging = {}
    
    for purchase in purchases:
        balance = purchase.get("total_amount", 0) - purchase.get("amount_paid", 0)
        if balance <= 0:
            continue
        
        # Calculate days outstanding
        due_date_str = purchase.get("due_date") or purchase.get("invoice_date") or purchase.get("created_at")
        if due_date_str:
            try:
                if isinstance(due_date_str, str):
                    due_date = datetime.fromisoformat(due_date_str.replace('Z', '+00:00'))
                else:
                    due_date = due_date_str
                days_outstanding = (as_of - due_date).days
            except:
                days_outstanding = 0
        else:
            days_outstanding = 0
        
        # Get supplier info
        supplier_id = purchase.get("supplier_id", "")
        supplier = supplier_map.get(supplier_id, {})
        supplier_name = supplier.get("name") or purchase.get("supplier_name", "Unknown")
        
        invoice_data = {
            "invoice_number": purchase.get("invoice_number", ""),
            "supplier_id": supplier_id,
            "supplier_name": supplier_name,
            "invoice_date": purchase.get("invoice_date") or purchase.get("created_at"),
            "due_date": purchase.get("due_date"),
            "total_amount": purchase.get("total_amount", 0),
            "amount_paid": purchase.get("amount_paid", 0),
            "balance_due": round(balance, 2),
            "days_outstanding": max(0, days_outstanding)
        }
        
        # Add to appropriate bucket
        if days_outstanding <= 30:
            bucket = "current"
        elif days_outstanding <= 60:
            bucket = "31_60"
        elif days_outstanding <= 90:
            bucket = "61_90"
        else:
            bucket = "over_90"
        
        aging_buckets[bucket]["total"] += balance
        aging_buckets[bucket]["count"] += 1
        aging_buckets[bucket]["invoices"].append(invoice_data)
        
        # Add to supplier aging
        if supplier_id not in supplier_aging:
            supplier_aging[supplier_id] = {
                "supplier_id": supplier_id,
                "supplier_name": supplier_name,
                "current": 0,
                "31_60": 0,
                "61_90": 0,
                "over_90": 0,
                "total": 0
            }
        supplier_aging[supplier_id][bucket] += balance
        supplier_aging[supplier_id]["total"] += balance
    
    # Round totals
    for bucket in aging_buckets.values():
        bucket["total"] = round(bucket["total"], 2)
    
    for supplier in supplier_aging.values():
        for key in ["current", "31_60", "61_90", "over_90", "total"]:
            supplier[key] = round(supplier[key], 2)
    
    total_payables = sum(b["total"] for b in aging_buckets.values())
    
    return {
        "as_of_date": as_of_date,
        "store_id": store_id,
        "aging_buckets": aging_buckets,
        "supplier_aging": sorted(supplier_aging.values(), key=lambda x: x["total"], reverse=True),
        "summary": {
            "total_payables": round(total_payables, 2),
            "total_invoices": sum(b["count"] for b in aging_buckets.values()),
            "total_suppliers": len(supplier_aging),
            "current_percentage": round((aging_buckets["current"]["total"] / total_payables * 100) if total_payables > 0 else 0, 1),
            "overdue_percentage": round(((aging_buckets["31_60"]["total"] + aging_buckets["61_90"]["total"] + aging_buckets["over_90"]["total"]) / total_payables * 100) if total_payables > 0 else 0, 1)
        }
    }


@api_router.get("/accounting/expense-report")
async def get_expense_report(
    start_date: str = "",
    end_date: str = "",
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Generate Expense Report by Category"""
    tenant_id = get_tenant_id(user)
    
    # Build date query
    date_query = {"tenant_id": tenant_id}
    if start_date:
        date_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in date_query:
            date_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            date_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    if store_id:
        date_query["store_id"] = store_id
    
    # Expense categories with their data
    expense_categories = {
        "purchases": {
            "name": "Purchases & Inventory",
            "icon": "Package",
            "color": "blue",
            "total": 0,
            "transactions": []
        },
        "payroll": {
            "name": "Salaries & Wages",
            "icon": "Users",
            "color": "purple",
            "total": 0,
            "transactions": []
        },
        "refunds": {
            "name": "Sales Returns & Refunds",
            "icon": "RotateCcw",
            "color": "red",
            "total": 0,
            "transactions": []
        },
        "taxes": {
            "name": "Taxes & GST",
            "icon": "Receipt",
            "color": "orange",
            "total": 0,
            "transactions": []
        },
        "other": {
            "name": "Other Expenses",
            "icon": "MoreHorizontal",
            "color": "gray",
            "total": 0,
            "transactions": []
        }
    }
    
    # Get purchase expenses
    purchase_query = {"tenant_id": tenant_id}
    if start_date:
        purchase_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in purchase_query:
            purchase_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            purchase_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    purchases = await db.purchase_invoices.find(purchase_query, {"_id": 0}).to_list(10000)
    for p in purchases:
        amount = p.get("total_amount", 0)
        expense_categories["purchases"]["total"] += amount
        expense_categories["purchases"]["transactions"].append({
            "date": p.get("created_at"),
            "description": f"Purchase from {p.get('supplier_name', 'Supplier')}",
            "reference": p.get("invoice_number", ""),
            "amount": amount
        })
    
    # Get payroll expenses
    payroll_query = {"tenant_id": tenant_id, "status": "paid"}
    if start_date and end_date:
        payroll_query["$or"] = [
            {"pay_period_start": {"$gte": start_date, "$lte": end_date}},
            {"pay_period_end": {"$gte": start_date, "$lte": end_date}}
        ]
    
    payroll = await db.payroll.find(payroll_query, {"_id": 0}).to_list(10000)
    for pay in payroll:
        amount = pay.get("net_pay", 0)
        expense_categories["payroll"]["total"] += amount
        expense_categories["payroll"]["transactions"].append({
            "date": pay.get("paid_at") or pay.get("created_at"),
            "description": f"Salary - {pay.get('employee_name', 'Employee')}",
            "reference": pay.get("id", ""),
            "amount": amount
        })
    
    # Get refunds/returns
    returns_query = {"tenant_id": tenant_id}
    if start_date:
        returns_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in returns_query:
            returns_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            returns_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    sales_returns = await db.sales_returns.find(returns_query, {"_id": 0}).to_list(10000)
    for ret in sales_returns:
        amount = ret.get("refund_amount", 0)
        expense_categories["refunds"]["total"] += amount
        expense_categories["refunds"]["transactions"].append({
            "date": ret.get("created_at"),
            "description": f"Return - {ret.get('reason', 'Sales Return')}",
            "reference": ret.get("return_number", ""),
            "amount": amount
        })
    
    # Calculate taxes paid (from purchases)
    total_purchase_tax = sum(p.get("tax_amount", 0) or p.get("gst_amount", 0) for p in purchases)
    if total_purchase_tax > 0:
        expense_categories["taxes"]["total"] = total_purchase_tax
        expense_categories["taxes"]["transactions"].append({
            "date": end_date or datetime.now(timezone.utc).isoformat(),
            "description": "Input GST/Tax on Purchases",
            "reference": "Aggregated",
            "amount": total_purchase_tax
        })
    
    # Round totals
    for cat in expense_categories.values():
        cat["total"] = round(cat["total"], 2)
        cat["transaction_count"] = len(cat["transactions"])
        for t in cat["transactions"]:
            t["amount"] = round(t["amount"], 2)
    
    total_expenses = sum(cat["total"] for cat in expense_categories.values())
    
    # Calculate category percentages
    for cat in expense_categories.values():
        cat["percentage"] = round((cat["total"] / total_expenses * 100) if total_expenses > 0 else 0, 1)
    
    # Monthly breakdown
    monthly_breakdown = {}
    for cat_key, cat in expense_categories.items():
        for t in cat["transactions"]:
            if t["date"]:
                try:
                    if isinstance(t["date"], str):
                        date_obj = datetime.fromisoformat(t["date"].replace('Z', '+00:00'))
                    else:
                        date_obj = t["date"]
                    month_key = date_obj.strftime("%Y-%m")
                    if month_key not in monthly_breakdown:
                        monthly_breakdown[month_key] = {
                            "month": month_key,
                            "purchases": 0,
                            "payroll": 0,
                            "refunds": 0,
                            "taxes": 0,
                            "other": 0,
                            "total": 0
                        }
                    monthly_breakdown[month_key][cat_key] += t["amount"]
                    monthly_breakdown[month_key]["total"] += t["amount"]
                except:
                    pass
    
    # Sort monthly breakdown by date
    sorted_months = sorted(monthly_breakdown.values(), key=lambda x: x["month"])
    
    return {
        "period": {"start_date": start_date, "end_date": end_date, "store_id": store_id},
        "categories": expense_categories,
        "monthly_breakdown": sorted_months,
        "summary": {
            "total_expenses": round(total_expenses, 2),
            "total_transactions": sum(cat["transaction_count"] for cat in expense_categories.values()),
            "largest_category": max(expense_categories.items(), key=lambda x: x[1]["total"])[0] if total_expenses > 0 else None,
            "average_monthly": round(total_expenses / max(len(sorted_months), 1), 2)
        }
    }


