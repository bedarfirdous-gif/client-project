@api_router.put("/sales-returns/{return_id}/status")
async def update_sales_return_status(return_id: str, body: dict = Body(...), user: dict = Depends(require_permission("returns"))):
    """Update the status of a sales return"""
    tenant_id = get_tenant_id(user)
    status = body.get("status")
    if status not in ["pending", "approved", "rejected", "completed"]:
        raise HTTPException(status_code=400, detail="Invalid status")
    
    return_doc = await db.sales_returns.find_one({"id": return_id})
    if not return_doc:
        raise HTTPException(status_code=404, detail="Return not found")
    
    update_data = {
        "status": status,
        "updated_at": datetime.now(timezone.utc).isoformat()
    }
    
    restock_alerts = []
    
    if status == "approved":
        update_data["approved_by"] = user.get("name")
        update_data["approved_at"] = datetime.now(timezone.utc).isoformat()
        
        # Create Restock Alerts for returned items
        # This helps track items that were returned for quality issues
        for item in return_doc.get("return_items", []):
            reason = return_doc.get("reason", "")
            # Create restock alert if item was returned due to quality issues
            if reason in ["Defective/Damaged Product", "Wrong Item Delivered", "Quality Not As Expected"]:
                restock_alert = {
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "type": "restock_quality",
                    "title": f"Quality Issue: {item.get('item_name', 'Unknown Item')}",
                    "message": f"Item returned due to: {reason}. Quantity: {item.get('quantity', 1)}. Consider inspection before restocking.",
                    "severity": "high" if reason == "Defective/Damaged Product" else "medium",
                    "item_id": item.get("item_id"),
                    "item_name": item.get("item_name"),
                    "variant_id": item.get("variant_id"),
                    "return_id": return_id,
                    "return_number": return_doc.get("return_number"),
                    "return_reason": reason,
                    "quantity": item.get("quantity", 1),
                    "action_required": "inspect_before_restock",
                    "read": False,
                    "created_at": datetime.now(timezone.utc).isoformat()
                }
                await db.restock_alerts.insert_one(restock_alert)
                restock_alerts.append({
                    "item_name": item.get("item_name"),
                    "reason": reason,
                    "quantity": item.get("quantity", 1)
                })
                
    elif status == "rejected":
        update_data["rejected_by"] = user.get("name")
        update_data["rejected_at"] = datetime.now(timezone.utc).isoformat()
    
    await db.sales_returns.update_one(
        {"id": return_id},
        {"$set": update_data}
    )
    
    result = {"message": f"Return status updated to {status}"}
    if restock_alerts:
        result["restock_alerts"] = restock_alerts
        result["alert_message"] = f"Created {len(restock_alerts)} restock alert(s) for quality inspection"
    
    return result

