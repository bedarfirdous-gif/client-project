@api_router.get("/tasks/{task_id}/pdf")
async def generate_task_pdf(task_id: str, user: dict = Depends(get_current_user)):
    """Generate PDF for a single task"""
    from reportlab.lib.pagesizes import A4
    from reportlab.lib import colors
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle
    from reportlab.lib.units import inch
    import io
    
    try:
        tenant_id = get_tenant_id(user)
        task = await task_management_system.get_task(tenant_id, task_id)
        if not task:
            raise HTTPException(status_code=404, detail="Task not found")
        
        # Create PDF in memory
        buffer = io.BytesIO()
        doc = SimpleDocTemplate(buffer, pagesize=A4, rightMargin=50, leftMargin=50, topMargin=50, bottomMargin=50)
        
        styles = getSampleStyleSheet()
        title_style = ParagraphStyle('Title', parent=styles['Heading1'], fontSize=18, spaceAfter=20)
        heading_style = ParagraphStyle('Heading', parent=styles['Heading2'], fontSize=12, spaceAfter=10, textColor=colors.HexColor('#2563eb'))
        normal_style = styles['Normal']
        
        elements = []
        
        # Title
        elements.append(Paragraph(f"Task Report: {task.get('task_id', '')}", title_style))
        elements.append(Spacer(1, 12))
        
        # Task Details Table
        assigned_names = []
        if task.get('assigned_employees'):
            assigned_names = [emp.get('name', '') for emp in task.get('assigned_employees', [])]
        elif task.get('assigned_to_name'):
            assigned_names = [task.get('assigned_to_name')]
        
        data = [
            ['Field', 'Value'],
            ['Task ID', task.get('task_id', '-')],
            ['Title', task.get('title', '-')],
            ['Department', task.get('department', '-')],
            ['Assigned To', ', '.join(assigned_names) if assigned_names else '-'],
            ['Priority', task.get('priority', '-')],
            ['Type', task.get('task_type', '-')],
            ['Status', task.get('status', '-')],
            ['Progress', f"{task.get('completion_percentage', 0)}%"],
            ['Rating', f"{task.get('rating', 0)}/5 Stars" if task.get('rating') else 'Not Rated'],
            ['Start Date', task.get('start_date', '-') or '-'],
            ['Due Date', task.get('due_date', '-') or '-'],
            ['Estimated Hours', str(task.get('estimated_hours', 0))],
        ]
        
        table = Table(data, colWidths=[2*inch, 4*inch])
        table.setStyle(TableStyle([
            ('BACKGROUND', (0, 0), (-1, 0), colors.HexColor('#2563eb')),
            ('TEXTCOLOR', (0, 0), (-1, 0), colors.whitesmoke),
            ('ALIGN', (0, 0), (-1, -1), 'LEFT'),
            ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, -1), 10),
            ('BOTTOMPADDING', (0, 0), (-1, 0), 12),
            ('BACKGROUND', (0, 1), (-1, -1), colors.HexColor('#f8fafc')),
            ('GRID', (0, 0), (-1, -1), 1, colors.HexColor('#e2e8f0')),
            ('ROWBACKGROUNDS', (0, 1), (-1, -1), [colors.white, colors.HexColor('#f8fafc')]),
        ]))
        elements.append(table)
        elements.append(Spacer(1, 20))
        
        # Description
        if task.get('description'):
            elements.append(Paragraph("Description", heading_style))
            elements.append(Paragraph(task.get('description', ''), normal_style))
            elements.append(Spacer(1, 12))
        
        # Remarks
        if task.get('remarks'):
            elements.append(Paragraph("Remarks", heading_style))
            elements.append(Paragraph(task.get('remarks', ''), normal_style))
        
        # Footer
        elements.append(Spacer(1, 30))
        footer_style = ParagraphStyle('Footer', parent=styles['Normal'], fontSize=8, textColor=colors.gray)
        from datetime import datetime
        elements.append(Paragraph(f"Generated on: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}", footer_style))
        
        doc.build(elements)
        buffer.seek(0)
        
        return StreamingResponse(
            buffer,
            media_type="application/pdf",
            headers={"Content-Disposition": f"attachment; filename=Task_{task_id}.pdf"}
        )
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Failed to generate task PDF: {e}")
        raise HTTPException(status_code=500, detail=str(e))


