# Background task for AI image generation
async def generate_product_ai_images(item_id: str, item_name: str, tenant_id: str):
    """Generate 4 AI images for a product in the background"""
    import asyncio
    
    try:
        # Update status to generating
        await db.items.update_one(
            {"id": item_id},
            {"$set": {"ai_images_status": "generating"}}
        )
        
        api_key = os.environ.get("EMERGENT_LLM_KEY")
        if not api_key:
            await db.items.update_one(
                {"id": item_id},
                {"$set": {"ai_images_status": "failed", "ai_images_error": "AI service not configured"}}
            )
            return
        
       # # from emergentintegrations.llm.openai.image_generation import OpenAIImageGeneration
        
        image_types = {
            "front": f"Professional front view product photography of {item_name}, clean white studio background, centered composition, high resolution commercial photo",
            "side": f"Professional side angle view of {item_name}, showing dimensions and shape, clean white background, studio lighting",
            "lifestyle": f"Lifestyle product photography of {item_name} being used/worn, natural setting, warm ambient lighting, premium lifestyle feel",
            "closeup": f"Extreme close-up detail shot of {item_name}, showing texture, material quality and craftsmanship, macro photography style"
        }
        
        image_gen = OpenAIImageGeneration(api_key=api_key)
        ai_images = {}
        
        for img_type, prompt in image_types.items():
            try:
                images = await image_gen.generate_images(
                    prompt=prompt,
                    model="gpt-image-1",
                    number_of_images=1
                )
                
                if images and len(images) > 0:
                    # Save image to file
                    file_id = str(uuid.uuid4())
                    filename = f"ai_{img_type}_{file_id}.png"
                    filepath = UPLOAD_DIR / filename
                    
                    async with aiofiles.open(filepath, 'wb') as f:
                        await f.write(images[0])
                    
                    ai_images[img_type] = f"/api/uploads/images/{filename}"
                    
                    # Update database with each image as it's generated
                    await db.items.update_one(
                        {"id": item_id},
                        {"$set": {f"ai_images.{img_type}": ai_images[img_type]}}
                    )
                    
            except Exception as e:
                print(f"Failed to generate {img_type} image for {item_id}: {e}")
                continue
            
            # Small delay between generations to avoid rate limits
            await asyncio.sleep(1)
        
        # Update final status
        status = "complete" if len(ai_images) > 0 else "failed"
        await db.items.update_one(
            {"id": item_id},
            {"$set": {"ai_images_status": status}}
        )
        
    except Exception as e:
        print(f"AI image generation failed for {item_id}: {e}")
        await db.items.update_one(
            {"id": item_id},
            {"$set": {"ai_images_status": "failed", "ai_images_error": str(e)}}
        )

