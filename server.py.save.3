    }
    """
    if user.get("role") not in ["admin", "superadmin"] and not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    user_ids = request.get("user_ids", [])
    new_permissions = request.get("permissions", {})
    mode = request.get("mode", "replace")
    
    updated_count = 0
    for uid in user_ids:
        if mode == "replace":
            await db.users.update_one(
                {"id": uid, "tenant_id": tenant_id},
                {"$set": {"permissions": new_permissions, "updated_at": datetime.now(timezone.utc).isoformat()}}
            )
        else:  # merge
            existing = await db.users.find_one({"id": uid}, {"permissions": 1})
            merged = {**(existing.get("permissions", {})), **new_permissions}
            await db.users.update_one(
                {"id": uid, "tenant_id": tenant_id},
                {"$set": {"permissions": merged, "updated_at": datetime.now(timezone.utc).isoformat()}}
            )
        updated_count += 1
    
    return {"message": f"Updated permissions for {updated_count} users", "updated_count": updated_count}


# --- User Permission Check ---
@api_router.get("/rbac/check-permission")
async def check_user_permission(
    module: str,
    action: str,
    target_user_id: str = None,
    user: dict = Depends(get_current_user)
):
    """
    Check if a user has a specific permission
    
    Query Parameters:
    - module: The module to check (e.g., "sales", "inventory")
    - action: The action to check (e.g., "view", "create", "edit", "delete")
    - target_user_id: Check for another user (admin only)
    """
    check_user = user
    
    if target_user_id and target_user_id != user.get("id"):
        if user.get("role") not in ["admin", "superadmin"] and not is_superadmin(user):
            raise HTTPException(status_code=403, detail="Cannot check other users' permissions")
        check_user = await db.users.find_one({"id": target_user_id}, {"_id": 0})
        if not check_user:
            raise HTTPException(status_code=404, detail="User not found")
    
    # Super admin has all permissions
    if is_superadmin(check_user):
        return {"has_permission": True, "reason": "superadmin"}
    
    # Admin has all permissions for their tenant
    if check_user.get("role") == "admin":
        return {"has_permission": True, "reason": "admin"}
    
    # Check specific permissions
    permissions = check_user.get("permissions", {})
    module_perms = permissions.get(module, [])
    
    has_permission = action in module_perms or "all" in module_perms
    
    return {
        "has_permission": has_permission,
        "user_id": check_user.get("id"),
        "module": module,
        "action": action,
        "user_permissions": module_perms
    }


