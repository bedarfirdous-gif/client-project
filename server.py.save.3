# Get usage stats (unified - uses new system with fallback)
@api_router.get("/billing/usage")
async def get_usage_stats(user: dict = Depends(require_permission("billing"))):
    """Get current usage vs plan limits - uses new centralized system"""
    tenant_id = get_tenant_id(user)
    
    # Try new subscription system first
    new_subscription = await subscription_system.get_tenant_subscription(tenant_id)
    
    if new_subscription:
        plan_limits = new_subscription.get("limits", {})
        # Ensure all required fields exist
        plan_limits.setdefault("stores", 1)
        plan_limits.setdefault("products", 100)
        plan_limits.setdefault("users", 2)
        plan_limits.setdefault("customers", 100)
        plan_limits.setdefault("sales_per_month", 500)
    else:
        # Fallback to legacy subscription
        subscription = await db.subscriptions.find_one(
            {"tenant_id": tenant_id, "status": {"$in": ["active", "trialing"]}},
            {"_id": 0}
        )
        
        plan_id = subscription.get("plan", "free") if subscription else "free"
        plan_limits = SUBSCRIPTION_PLANS.get(plan_id, SUBSCRIPTION_PLANS["free"])["limits"]
    
    # Calculate current usage
    stores_count = await db.stores.count_documents({"tenant_id": tenant_id})
    products_count = await db.items.count_documents({"tenant_id": tenant_id})
    users_count = await db.users.count_documents({"tenant_id": tenant_id})
    customers_count = await db.customers.count_documents({"tenant_id": tenant_id})
    
    # Sales this month
    month_start = datetime.now(timezone.utc).replace(day=1, hour=0, minute=0, second=0, microsecond=0)
    sales_this_month = await db.sales.count_documents({
        "tenant_id": tenant_id,
        "created_at": {"$gte": month_start.isoformat()}
    })
    
    def format_limit(current, limit):
        if limit == -1:
            return {"current": current, "limit": "Unlimited", "percentage": 0, "exceeded": False}
        percentage = (current / limit * 100) if limit > 0 else 0
        return {"current": current, "limit": limit, "percentage": min(percentage, 100), "exceeded": current > limit}
    
    plan_code = new_subscription.get("plan_code", "free") if new_subscription else "free"
    
    return {
        "plan": plan_code,
        "usage": {
            "stores": format_limit(stores_count, plan_limits.get("stores", 1)),
            "products": format_limit(products_count, plan_limits.get("products", 100)),
            "users": format_limit(users_count, plan_limits.get("users", 2)),
            "customers": format_limit(customers_count, plan_limits.get("customers", 100)),
            "sales_this_month": format_limit(sales_this_month, plan_limits.get("sales_per_month", 500))
        }
    }

# Create checkout session for subscription (unified - supports both old and new plans)
@api_router.post("/billing/checkout")
async def create_checkout_session(
    plan_id: str = Body(...),
    origin_url: str = Body(...),
    user: dict = Depends(require_permission("billing"))
):
    """Create Stripe checkout session for subscription upgrade - supports both plan systems"""
    if not STRIPE_API_KEY:
        raise HTTPException(status_code=500, detail="Stripe not configured")
    
    # First try to get plan from new master system
    master_plan = await subscription_system.get_plan(plan_id)
    
    if master_plan:
        plan_name = master_plan.get("name")
        plan_price = master_plan.get("base_price", 0)
        plan_currency = master_plan.get("currency", "INR").lower()
        master_plan_id = master_plan.get("id")
    elif plan_id in SUBSCRIPTION_PLANS:
        # Fallback to legacy plans
        legacy_plan = SUBSCRIPTION_PLANS[plan_id]
        plan_name = legacy_plan["name"]
        plan_price = legacy_plan["price"]
        plan_currency = legacy_plan["currency"]
        master_plan_id = None
    else:
        raise HTTPException(status_code=400, detail="Invalid plan")
    
    if plan_price == 0:
        raise HTTPException(status_code=400, detail="Cannot checkout for free plan")
    
    tenant_id = get_tenant_id(user)
    
    # Build URLs from frontend origin
    success_url = f"{origin_url}/billing?session_id={{CHECKOUT_SESSION_ID}}&status=success"
    cancel_url = f"{origin_url}/billing?status=cancelled"
    
    try:
        # Initialize Stripe checkout
        webhook_url = f"{origin_url.replace('localhost:3000', 'localhost:8001')}/api/webhook/stripe"
        stripe_checkout = StripeCheckout(api_key=STRIPE_API_KEY, webhook_url=webhook_url)
        
        # Create checkout request
        checkout_request = CheckoutSessionRequest(
            amount=plan_price,
            currency=plan_currency,
            success_url=success_url,
            cancel_url=cancel_url,
            metadata={
                "tenant_id": tenant_id,
                "user_id": user.get("id"),
                "user_email": user.get("email"),
                "plan_id": plan_id,
                "master_plan_id": master_plan_id,
                "plan_name": plan_name,
                "type": "subscription"
            }
        )
        
        # Create session
        session: CheckoutSessionResponse = await stripe_checkout.create_checkout_session(checkout_request)
        
        # Store transaction record
        transaction = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "user_id": user.get("id"),
            "user_email": user.get("email"),
            "session_id": session.session_id,
            "plan_id": plan_id,
            "master_plan_id": master_plan_id,
            "plan_name": plan_name,
            "amount": plan_price,
            "currency": plan_currency,
            "status": "pending",
            "payment_status": "initiated",
            "type": "subscription",
            "created_at": datetime.now(timezone.utc).isoformat()
        }
        await db.payment_transactions.insert_one(transaction)
        
        return {
            "checkout_url": session.url,
            "session_id": session.session_id
        }
        
    except Exception as e:
        logger.error(f"Stripe checkout error: {e}")
        raise HTTPException(status_code=500, detail=f"Failed to create checkout session: {str(e)}")

# Check payment status
@api_router.get("/billing/checkout/status/{session_id}")
async def check_checkout_status(
    session_id: str,
    user: dict = Depends(require_permission("billing"))
):
    """Check payment status and activate subscription if paid"""
    if not STRIPE_API_KEY:
        raise HTTPException(status_code=500, detail="Stripe not configured")
    
    tenant_id = get_tenant_id(user)
    
    # Get transaction
    transaction = await db.payment_transactions.find_one({
        "session_id": session_id,
        "tenant_id": tenant_id
    })
    
    if not transaction:
        raise HTTPException(status_code=404, detail="Transaction not found")
    
    # If already processed, return current status
    if transaction.get("payment_status") == "paid":
        return {
            "status": "complete",
            "payment_status": "paid",
            "plan": transaction.get("plan_id"),
            "message": "Subscription already activated"
        }
    
    try:
        # Check with Stripe
        webhook_url = "https://example.com/webhook"  # Placeholder, not used for status check
        stripe_checkout = StripeCheckout(api_key=STRIPE_API_KEY, webhook_url=webhook_url)
        
        checkout_status: CheckoutStatusResponse = await stripe_checkout.get_checkout_status(session_id)
        
        # Update transaction
        await db.payment_transactions.update_one(
            {"session_id": session_id},
            {"$set": {
                "status": checkout_status.status,
                "payment_status": checkout_status.payment_status,
                "updated_at": datetime.now(timezone.utc).isoformat()
            }}
        )
        
        # If paid, activate subscription
        if checkout_status.payment_status == "paid":
            plan_id = transaction.get("plan_id")
            
            # Deactivate old subscription
            await db.subscriptions.update_many(
                {"tenant_id": tenant_id, "status": "active"},
                {"$set": {"status": "cancelled", "cancelled_at": datetime.now(timezone.utc).isoformat()}}
            )
            
            # Create new subscription
            now = datetime.now(timezone.utc)
            subscription = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "plan": plan_id,
                "status": "active",
                "payment_session_id": session_id,
                "current_period_start": now.isoformat(),
                "current_period_end": (now + timedelta(days=30)).isoformat(),
                "created_at": now.isoformat()
            }
            await db.subscriptions.insert_one(subscription)
            
            # Update user's plan
            await db.users.update_one(
                {"tenant_id": tenant_id, "role": "admin"},
                {"$set": {"plan": plan_id, "plan_updated_at": now.isoformat()}}
            )
            
            # Log to audit
            await db.billing_audit.insert_one({
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "action": "subscription_activated",
                "plan": plan_id,
                "amount": transaction.get("amount"),
                "session_id": session_id,
                "timestamp": now.isoformat()
            })
            
            return {
                "status": "complete",
                "payment_status": "paid",
                "plan": plan_id,
                "message": f"Successfully upgraded to {SUBSCRIPTION_PLANS[plan_id]['name']} plan!"
            }
        
        return {
            "status": checkout_status.status,
            "payment_status": checkout_status.payment_status,
            "message": "Payment pending or processing"
        }
        
    except Exception as e:
        logger.error(f"Status check error: {e}")
        raise HTTPException(status_code=500, detail=f"Failed to check status: {str(e)}")

# Stripe webhook handler
@api_router.post("/webhook/stripe")
async def stripe_webhook(request: Request):
    """Handle Stripe webhook events"""
    try:
        body = await request.body()
        signature = request.headers.get("Stripe-Signature")
        
        if not STRIPE_API_KEY:
            return {"status": "skipped", "reason": "Stripe not configured"}
        
        webhook_url = str(request.base_url) + "api/webhook/stripe"
        stripe_checkout = StripeCheckout(api_key=STRIPE_API_KEY, webhook_url=webhook_url)
        
        webhook_response = await stripe_checkout.handle_webhook(body, signature)
        
        if webhook_response.payment_status == "paid":
            # Find and update transaction
            transaction = await db.payment_transactions.find_one({"session_id": webhook_response.session_id})
            
            if transaction and transaction.get("payment_status") != "paid":
                await db.payment_transactions.update_one(
                    {"session_id": webhook_response.session_id},
                    {"$set": {
                        "payment_status": "paid",
                        "status": "complete",
                        "webhook_received_at": datetime.now(timezone.utc).isoformat()
                    }}
                )
                
                # Activate subscription
                tenant_id = transaction.get("tenant_id")
                plan_id = transaction.get("plan_id")
                
                if tenant_id and plan_id:
                    now = datetime.now(timezone.utc)
                    
                    # Deactivate old subscriptions
                    await db.subscriptions.update_many(
                        {"tenant_id": tenant_id, "status": "active"},
                        {"$set": {"status": "cancelled"}}
                    )
                    
                    # Create new subscription
                    await db.subscriptions.insert_one({
                        "id": str(uuid.uuid4()),
                        "tenant_id": tenant_id,
                        "plan": plan_id,
                        "status": "active",
                        "payment_session_id": webhook_response.session_id,
                        "current_period_start": now.isoformat(),
                        "current_period_end": (now + timedelta(days=30)).isoformat(),
                        "created_at": now.isoformat()
                    })
                    
                    # Update admin plan
                    await db.users.update_one(
                        {"tenant_id": tenant_id, "role": "admin"},
                        {"$set": {"plan": plan_id}}
                    )
        
        return {"status": "processed", "event_type": webhook_response.event_type}
        
    except Exception as e:
        logger.error(f"Webhook error: {e}")
        return {"status": "error", "message": str(e)}

