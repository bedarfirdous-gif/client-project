@api_router.post("/superadmin/plan-requests/{request_id}/approve")
async def approve_plan_request(
    request_id: str,
    user: dict = Depends(require_permission("all_subscriptions"))
):
    """SuperAdmin: Approve a plan upgrade request (after payment confirmed)"""
    
    # Find the request
    upgrade_request = await db.plan_upgrade_requests.find_one({"id": request_id})
    if not upgrade_request:
        raise HTTPException(status_code=404, detail="Upgrade request not found")
    
    if upgrade_request["status"] != "pending":
        raise HTTPException(status_code=400, detail=f"Request already {upgrade_request['status']}")
    
    now = datetime.now(timezone.utc).isoformat()
    tenant_id = upgrade_request["tenant_id"]
    admin_id = upgrade_request["admin_id"]
    new_plan = upgrade_request["to_plan"]
    
    # Get plan data
    plans = await get_subscription_plans_data()
    new_plan_data = plans.get(new_plan, {})
    
    # Update the admin's plan
    await db.users.update_one(
        {"id": admin_id},
        {"$set": {
            "plan": new_plan,
            "plan_changed_at": now,
            "plan_billing_cycle": upgrade_request.get("billing_cycle", "year")
        }}
    )
    
    # Update subscription
    await db.subscriptions.update_one(
        {"tenant_id": tenant_id},
        {"$set": {
            "tenant_id": tenant_id,
            "plan": new_plan,
            "price": upgrade_request["amount_due"],
            "interval": upgrade_request.get("billing_cycle", "year"),
            "status": "active",
            "updated_at": now,
            "current_period_start": now,
            "current_period_end": (datetime.now(timezone.utc) + timedelta(days=365)).isoformat()
        }},
        upsert=True
    )
    
    # Update request status
    await db.plan_upgrade_requests.update_one(
        {"id": request_id},
        {"$set": {
            "status": "approved",
            "payment_status": "paid",
            "approved_by": user.get("id"),
            "approved_by_name": user.get("name", "SuperAdmin"),
            "approved_at": now
        }}
    )
    
    # Record plan change
    plan_change_record = {
        "id": str(uuid.uuid4()),
        "admin_id": admin_id,
        "tenant_id": tenant_id,
        "from_plan": upgrade_request["from_plan"],
        "to_plan": new_plan,
        "is_upgrade": upgrade_request["is_upgrade"],
        "proration_amount": upgrade_request["proration_amount"],
        "billing_cycle": upgrade_request.get("billing_cycle", "year"),
        "created_at": now,
        "effective_date": now,
        "approved_by": user.get("id"),
        "request_id": request_id
    }
    await db.plan_changes.insert_one(plan_change_record)
    
    # Log to audit
    await db.billing_audit.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "action": "plan_upgrade_approved",
        "from_plan": upgrade_request["from_plan"],
        "to_plan": new_plan,
        "amount": upgrade_request["amount_due"],
        "approved_by": user.get("id"),
        "timestamp": now
    })
    
    return {
        "success": True,
        "message": f"Plan upgrade approved. {upgrade_request['admin_name'] or upgrade_request['admin_email']} has been upgraded to {new_plan_data.get('name', new_plan)}.",
        "tenant_id": tenant_id,
        "new_plan": new_plan
    }

