@api_router.post("/inventory/central/migrate")
async def migrate_stock_data(user: dict = Depends(get_current_user)):
    """Migrate existing stock data to central_stock table (one-time operation)"""
    if not is_superadmin(user) and user.get("role") != "admin":
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    inv_service = get_inventory_service()
    
    # First migrate from variants
    result = await inv_service.migrate_existing_stock(tenant_id)
    
    # Also migrate from inventory collection
    inventories = await db.inventory.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(10000)
    migrated_inventory = 0
    
    for inv in inventories:
        variant_id = inv.get("variant_id")
        if not variant_id:
            continue
        
        # Check if already migrated
        existing = await db.central_stock.find_one({
            "tenant_id": tenant_id,
            "variant_id": variant_id,
            "warehouse_id": inv.get("store_id")
        })
        
        if existing:
            continue
        
        # Get item_id from variant
        variant = await db.variants.find_one({"id": variant_id}, {"_id": 0, "item_id": 1})
        item_id = variant.get("item_id") if variant else ""
        
        # Create central_stock entry
        await db.central_stock.insert_one({
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "item_id": item_id,
            "variant_id": variant_id,
            "warehouse_id": inv.get("store_id"),
            "quantity": inv.get("quantity", 0),
            "created_at": datetime.now(timezone.utc).isoformat(),
            "updated_at": datetime.now(timezone.utc).isoformat()
        })
        migrated_inventory += 1
    
    return {
        "success": True,
        "migrated_from_variants": result.get("migrated", 0),
        "skipped_variants": result.get("skipped", 0),
        "migrated_from_inventory": migrated_inventory,
        "message": "Stock data migrated to centralized system"
    }


# Super Admin Dashboard Stats
@api_router.get("/superadmin/dashboard")
async def get_superadmin_dashboard(user: dict = Depends(require_superadmin)):
    """Get super admin dashboard with all tenant stats"""
    
    # Get all admin users (tenants)
    admins = await db.users.find(
        {"role": "admin"},
        {"_id": 0, "password": 0}
    ).to_list(10000)
    
    # Get unique tenant IDs
    tenant_ids = list(set([a.get("tenant_id") for a in admins if a.get("tenant_id")]))
    
    # Aggregate stats across all tenants
    total_sales = 0
    total_orders = 0
    total_customers = 0
    total_items = 0
    total_stores = 0
    total_employees = 0
    
    tenant_stats = []
    
    for tenant_id in tenant_ids:
        if not tenant_id or tenant_id == "superadmin":
            continue
            
        # Get tenant's admin info
        admin = next((a for a in admins if a.get("tenant_id") == tenant_id), None)
        if not admin:
            continue
        
        # Count stats for this tenant
        sales_count = await db.sales.count_documents({"tenant_id": tenant_id})
        sales_pipeline = [
            {"$match": {"tenant_id": tenant_id, "status": {"$ne": "cancelled"}}},
            {"$group": {"_id": None, "total": {"$sum": "$total"}}}
        ]
        sales_result = await db.sales.aggregate(sales_pipeline).to_list(1)
        tenant_sales = sales_result[0]["total"] if sales_result else 0
        
        customers_count = await db.customers.count_documents({"tenant_id": tenant_id})
        items_count = await db.items.count_documents({"tenant_id": tenant_id})
        stores_count = await db.stores.count_documents({"tenant_id": tenant_id})
        employees_count = await db.employees.count_documents({"tenant_id": tenant_id})
        
        total_sales += tenant_sales
        total_orders += sales_count
        total_customers += customers_count
        total_items += items_count
        total_stores += stores_count
        total_employees += employees_count
        
        tenant_stats.append({
            "tenant_id": tenant_id,
            "admin_id": admin.get("id"),
            "admin_name": admin.get("name"),
            "admin_email": admin.get("email"),
            "business_name": admin.get("business_name", "Unnamed Business"),
            "plan": admin.get("plan", "free"),
            "is_active": admin.get("is_active", True),
            "created_at": admin.get("created_at"),
            "last_login": admin.get("last_login"),
            "stats": {
                "sales": tenant_sales,
                "orders": sales_count,
                "customers": customers_count,
                "items": items_count,
                "stores": stores_count,
                "employees": employees_count
            }
        })
    
    # Sort by sales descending
    tenant_stats.sort(key=lambda x: x["stats"]["sales"], reverse=True)
    
    return {
        "summary": {
            "total_admins": len(admins),
            "active_admins": len([a for a in admins if a.get("is_active", True)]),
            "total_tenants": len(tenant_ids) - 1,  # Exclude superadmin tenant
            "total_sales": total_sales,
            "total_orders": total_orders,
            "total_customers": total_customers,
            "total_items": total_items,
            "total_stores": total_stores,
            "total_employees": total_employees
        },
        "tenants": tenant_stats[:50],  # Top 50 by sales
        "recent_admins": sorted(admins, key=lambda x: x.get("created_at", ""), reverse=True)[:10]
    }

# List all admin users
@api_router.get("/superadmin/admins")
async def list_admins(
    skip: int = 0,
    limit: int = 50,
    search: str = "",
    status: str = "all",
    user: dict = Depends(require_superadmin)
):
    """List all admin users with their business info"""
    
    query = {"role": "admin"}
    
    if status == "active":
        query["is_active"] = True
    elif status == "inactive":
        query["is_active"] = False
    
    if search:
        query["$or"] = [
            {"name": {"$regex": search, "$options": "i"}},
            {"email": {"$regex": search, "$options": "i"}},
            {"business_name": {"$regex": search, "$options": "i"}}
        ]
    
    total = await db.users.count_documents(query)
    admins = await db.users.find(
        query,
        {"_id": 0, "password": 0}
    ).sort("created_at", -1).skip(skip).limit(limit).to_list(limit)
    
    # Enrich with stats and add subscription_plan alias
    for admin in admins:
        tenant_id = admin.get("tenant_id")
        # Add subscription_plan alias for frontend compatibility
        admin["subscription_plan"] = admin.get("plan", "free")
        if tenant_id:
            admin["stats"] = {
                "users": await db.users.count_documents({"tenant_id": tenant_id}),
                "stores": await db.stores.count_documents({"tenant_id": tenant_id}),
                "sales": await db.sales.count_documents({"tenant_id": tenant_id})
            }
    
    return {"admins": admins, "total": total}

# Create new admin (new tenant)
@api_router.post("/superadmin/admins")
async def create_admin(
    admin_data: AdminCreate,
    user: dict = Depends(require_superadmin)
):
    """Create a new admin user with their own tenant"""
    
    # Check if email exists
    existing = await db.users.find_one({"email": admin_data.email.lower()})
    if existing:
        raise HTTPException(status_code=400, detail="Email already registered")
    
    # Generate unique tenant ID
    tenant_id = f"tenant_{str(uuid.uuid4())[:8]}"
    admin_id = str(uuid.uuid4())
    now = datetime.now(timezone.utc).isoformat()
    
    # Create admin user
    admin_doc = {
        "id": admin_id,
        "email": admin_data.email.lower(),
        "password": hash_password(admin_data.password),
        "name": admin_data.name,
        "role": "admin",
        "tenant_id": tenant_id,
        "is_active": True,
        "permissions": DEFAULT_ROLE_PERMISSIONS["admin"],
        "business_name": admin_data.business_name,
        "business_type": admin_data.business_type,
        "phone": admin_data.phone,
        "address": admin_data.address,
        "plan": admin_data.plan,
        "created_at": now,
        "created_by": user.get("id"),
        "created_by_name": user.get("name")
    }
    
    await db.users.insert_one(admin_doc)
    
    # Create default store for the new tenant
    default_store = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "name": f"{admin_data.business_name} - Main Store",
        "code": "MAIN",
        "address": admin_data.address or "",
        "phone": admin_data.phone or "",
        "is_active": True,
        "created_at": now
    }
    await db.stores.insert_one(default_store)
    
    # Log the creation
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "admin_created",
        "admin_id": admin_id,
        "admin_email": admin_data.email,
        "tenant_id": tenant_id,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now,
        "details": {"business_name": admin_data.business_name, "plan": admin_data.plan}
    })
    
    del admin_doc["_id"]
    del admin_doc["password"]
    
    return {
        "message": "Admin created successfully",
        "admin": admin_doc,
        "tenant_id": tenant_id
    }

