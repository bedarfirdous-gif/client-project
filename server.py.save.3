# Custom Stitching Requests
@api_router.post("/fabrics/custom-stitch-request")
async def create_custom_stitch_request(request: CustomStitchRequest, user: dict = Depends(get_current_user)):
    """Create a custom stitching request"""
    tenant_id = get_tenant_id(user)
    
    # Get fabric details
    fabric = await db.fabrics.find_one({"id": request.fabric_id, "tenant_id": tenant_id}, {"_id": 0})
    if not fabric:
        raise HTTPException(status_code=404, detail="Fabric not found")
    
    # Calculate estimated price
    fabric_cost = fabric.get("price_per_meter", 0) * 2.5  # Approx 2.5 meters per garment
    stitching_cost = {
        "tops": 500,
        "bottoms": 600,
        "dresses": 1000,
        "outerwear": 1500,
        "ethnic": 800
    }.get(request.clothing_type, 500)
    
    urgency_multiplier = {"normal": 1, "express": 1.5, "urgent": 2}.get(request.urgency, 1)
    
    estimated_price = (fabric_cost + stitching_cost) * request.quantity * urgency_multiplier
    estimated_days = {"normal": 7, "express": 3, "urgent": 1}.get(request.urgency, 7)
    
    stitch_request = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "user_id": user.get("id"),
        **request.model_dump(),
        "fabric_name": fabric.get("name"),
        "fabric_image": fabric.get("image_url"),
        "estimated_price": round(estimated_price, 2),
        "estimated_delivery_days": estimated_days,
        "status": "pending",  # pending, confirmed, in_progress, completed, cancelled
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    await db.custom_stitch_requests.insert_one(stitch_request)
    stitch_request.pop("_id", None)
    
    return stitch_request


