@api_router.post("/superadmin/god-mode/force-logout")
async def god_mode_force_logout(
    user_id: str = Body(None),
    tenant_id: str = Body(None),
    all_users: bool = Body(False),
    user: dict = Depends(require_superadmin)
):
    """Emergency: Force logout user(s) by invalidating sessions"""
    
    query = {}
    if all_users:
        query = {"role": {"$ne": "superadmin"}}  # Don't logout super admin
    elif tenant_id:
        query = {"tenant_id": tenant_id}
    elif user_id:
        query = {"user_id": user_id}
    else:
        raise HTTPException(status_code=400, detail="Specify user_id, tenant_id, or all_users")
    
    # Delete sessions
    result = await db.user_sessions.delete_many(query)
    
    # Log action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "god_mode_force_logout",
        "target": "all" if all_users else (tenant_id or user_id),
        "sessions_terminated": result.deleted_count,
        "performed_by": user.get("id"),
        "timestamp": datetime.now(timezone.utc).isoformat()
    })
    
    return {"message": f"Terminated {result.deleted_count} sessions"}

@api_router.post("/superadmin/god-mode/freeze-tenant")
async def god_mode_freeze_tenant(
    tenant_id: str = Body(..., embed=True),
    user: dict = Depends(require_superadmin)
):
    """Emergency: Freeze a tenant - all users lose access"""
    
    # Update all users in tenant
    result = await db.users.update_many(
        {"tenant_id": tenant_id},
        {"$set": {
            "is_frozen": True,
            "frozen_at": datetime.now(timezone.utc).isoformat(),
            "frozen_by": user.get("id")
        }}
