@api_router.get("/tiered-discounts/calculate")
async def calculate_tiered_discount(
    cart_total: float = 0,
    item_quantity: int = 0,
    category_id: str = "",
    store_id: str = "",
    apply_on: str = "pos",  # pos, online, invoice
    user: dict = Depends(get_current_user)
):
    """Calculate tiered discount based on cart total or quantity with centralized discount support"""
    tenant_id = get_tenant_id(user)
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    # Get applicable tiered discounts
    query = {
        "tenant_id": tenant_id,
        "active": True,
        "valid_from": {"$lte": today},
        "valid_until": {"$gte": today}
    }
    
    if category_id:
        query["$or"] = [
            {"applicable_category_ids": {"$in": [category_id]}},
            {"applicable_category_ids": {"$size": 0}}
        ]
    
    discounts = await db.tiered_discounts.find(query, {"_id": 0}).to_list(100)
    
    # Filter discounts based on centralized settings
    applicable_discounts = []
    for d in discounts:
        # Check if discount applies to this channel (pos/online/invoice)
        discount_apply_on = d.get("apply_on", ["pos", "online", "invoice"])
        if apply_on not in discount_apply_on:
            continue
        
        # Check if auto_apply is enabled
        if not d.get("auto_apply", True):
            continue
        
        # Check store applicability
        is_global = d.get("is_global", True)
        applicable_stores = d.get("applicable_store_ids", [])
        excluded_stores = d.get("excluded_store_ids", [])
        
        if store_id:
            if store_id in excluded_stores:
                continue
            if not is_global and applicable_stores and store_id not in applicable_stores:
                continue
        
        applicable_discounts.append(d)
    
    if not applicable_discounts:
        return {"discount_amount": 0, "applied_tier": None, "discount_name": None, "auto_applied": True}
    
    best_discount = 0
    applied_tier = None
    discount_name = None
    
    for d in applicable_discounts:
        discount_type = d.get("discount_type", "cart_total")
        tiers = sorted(d.get("tiers", []), key=lambda x: x.get("min", 0), reverse=True)
        
        check_value = cart_total if discount_type == "cart_total" else item_quantity
        
        for tier in tiers:
            if check_value >= tier.get("min", 0):
                if tier.get("is_percent"):
                    tier_discount = cart_total * tier.get("discount", 0) / 100
                else:
                    tier_discount = tier.get("discount", 0)
                
                if tier_discount > best_discount:
                    best_discount = tier_discount
                    applied_tier = tier
                    discount_name = d.get("name")
                break
    
    return {
        "discount_amount": best_discount,
        "applied_tier": applied_tier,
        "discount_name": discount_name,
        "auto_applied": True
    }

# ============== COMBINED DISCOUNT CALCULATOR ==============

class DiscountCalculationRequest(BaseModel):
    cart_items: List[Dict[str, Any]]
    cart_total: float = 0
    voucher_code: str = ""
    customer_id: str = ""
    store_id: str = ""
    apply_on: str = "pos"  # pos, online, invoice

@api_router.post("/discounts/calculate-all")
async def calculate_all_discounts(
    request: DiscountCalculationRequest,
    user: dict = Depends(get_current_user)
):
    """Calculate all applicable discounts for a cart with centralized discount support
    Returns the best combination of auto-applied discounts
    """
    tenant_id = get_tenant_id(user)
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    # Extract request data
    cart_items = request.cart_items
    cart_total = request.cart_total
    voucher_code = request.voucher_code
    customer_id = request.customer_id
    store_id = request.store_id
    apply_on = request.apply_on
    
    result = {
        "original_total": cart_total,
        "item_discounts": [],
        "bogo_discounts": [],
        "tiered_discount": None,
        "voucher_discount": None,
        "total_discount": 0,
        "final_total": cart_total,
        "auto_applied": True,
        "store_id": store_id,
        "apply_on": apply_on
    }
    
    # Helper function to check if discount applies to this store and channel
    def is_discount_applicable(d):
        # Check channel
        discount_apply_on = d.get("apply_on", ["pos", "online", "invoice"])
        if apply_on not in discount_apply_on:
            return False
        
        # Check auto_apply
        if not d.get("auto_apply", True):
            return False
        
        # Check store applicability
        is_global = d.get("is_global", True)
        applicable_stores = d.get("applicable_store_ids", [])
        excluded_stores = d.get("excluded_store_ids", [])
        
        if store_id:
            if store_id in excluded_stores:
                return False
            if not is_global and applicable_stores and store_id not in applicable_stores:
                return False
        
        return True
    
    # 1. Item-level discounts
    item_discount_total = 0
    
    # Get all active item discounts for this tenant
    all_item_discounts = await db.item_discounts.find({
        "tenant_id": tenant_id,
        "active": True,
        "valid_from": {"$lte": today},
        "valid_until": {"$gte": today}
    }, {"_id": 0}).to_list(100)
    
    for item in cart_items:
        for d in all_item_discounts:
            # Check centralized settings first
            if not is_discount_applicable(d):
                continue
            
            # Check if this discount applies to this item
            discount_item_id = d.get("item_id")
            discount_variant_id = d.get("variant_id")
            discount_category_id = d.get("category_id")
            discount_brand_id = d.get("brand_id")
            
            # Determine if discount applies to this cart item
            is_applicable = False
            
            # Check if it's a GLOBAL discount (all targeting fields are None/null)
            is_global_discount = (
                (discount_item_id is None or discount_item_id == "") and 
                (discount_variant_id is None or discount_variant_id == "") and 
                (discount_category_id is None or discount_category_id == "") and 
                (discount_brand_id is None or discount_brand_id == "")
            )
            
            if is_global_discount:
                # Global discount applies to all items
                is_applicable = True
            else:
                # Item-specific discount - check if any targeting field matches
                cart_item_id = item.get("item_id", "")
                cart_variant_id = item.get("variant_id", "")
                cart_category_id = item.get("category_id", "")
                cart_brand_id = item.get("brand_id", "")
                
                if discount_item_id and discount_item_id == cart_item_id:
                    is_applicable = True
                elif discount_variant_id and discount_variant_id == cart_variant_id:
                    is_applicable = True
                elif discount_category_id and discount_category_id == cart_category_id:
                    is_applicable = True
                elif discount_brand_id and discount_brand_id == cart_brand_id:
                    is_applicable = True
            
            if not is_applicable:
                continue
            
            # Calculate discount amount
            if d.get("discount_type") == "percentage":
                discount = item.get("price", 0) * item.get("quantity", 1) * d.get("discount_value", 0) / 100
            else:
                discount = d.get("discount_value", 0) * item.get("quantity", 1)
            
            item_discount_total += discount
            result["item_discounts"].append({
                "item_id": item.get("item_id"),
                "discount": discount,
                "discount_name": d.get("name") or d.get("description"),
                "description": d.get("description"),
                "is_global": is_global_discount,
                "auto_applied": d.get("auto_apply", True)
            })
    
    # 2. BOGO discounts (with centralized filtering)
    bogo_result = await calculate_bogo(cart_items, user, store_id, apply_on)
    result["bogo_discounts"] = bogo_result.get("free_items", [])
    bogo_discount_total = bogo_result.get("discount_amount", 0)
    
    # 3. Tiered discount (with centralized filtering)
    tiered_result = await calculate_tiered_discount(
        cart_total, 
        sum(i.get("quantity", 0) for i in cart_items), 
        "", 
        store_id,
        apply_on,
        user
    )
    if tiered_result.get("discount_amount", 0) > 0:
        result["tiered_discount"] = tiered_result
    tiered_discount_total = tiered_result.get("discount_amount", 0)
    
    # 4. Voucher discount
    voucher_discount_total = 0
    if voucher_code:
        try:
            voucher_result = await validate_voucher(voucher_code, cart_total, user)
            voucher_discount_total = voucher_result.get("calculated_discount", 0)
            result["voucher_discount"] = {
                "code": voucher_code,
                "discount": voucher_discount_total
            }
        except:
            pass
    
    # Calculate totals
    result["total_discount"] = item_discount_total + bogo_discount_total + tiered_discount_total + voucher_discount_total
    result["final_total"] = max(0, cart_total - result["total_discount"])
    
    return result

