@api_router.get("/ecommerce/blog/seo-dashboard")
async def get_blog_seo_dashboard(user: dict = Depends(get_current_user)):
    """Get SEO dashboard stats for the blog"""
    tenant_id = get_tenant_id(user)
    
    # Get all published posts
    posts = await db.blog_posts.find(
        {"tenant_id": tenant_id, "status": "published", "is_deleted": {"$ne": True}},
        {"_id": 0, "id": 1, "title": 1, "slug": 1, "seo_score": 1, "views": 1, "created_at": 1}
    ).to_list(None)
    
    total_posts = len(posts)
    avg_seo_score = sum(p.get("seo_score", 0) for p in posts) / max(total_posts, 1)
    total_views = sum(p.get("views", 0) for p in posts)
    
    # Get posts by SEO score range
    high_seo = len([p for p in posts if p.get("seo_score", 0) >= 80])
    medium_seo = len([p for p in posts if 50 <= p.get("seo_score", 0) < 80])
    low_seo = len([p for p in posts if p.get("seo_score", 0) < 50])
    
    # Top performing posts
    top_posts = sorted(posts, key=lambda x: x.get("views", 0), reverse=True)[:5]
    
    # Posts needing optimization
    needs_optimization = sorted([p for p in posts if p.get("seo_score", 0) < 70], 
                                key=lambda x: x.get("seo_score", 0))[:5]
    
    return {
        "stats": {
            "total_posts": total_posts,
            "avg_seo_score": round(avg_seo_score, 1),
            "total_views": total_views,
            "high_seo_posts": high_seo,
            "medium_seo_posts": medium_seo,
            "low_seo_posts": low_seo
        },
        "top_posts": top_posts,
        "needs_optimization": needs_optimization
    }


# Public Blog Endpoints (for storefront)
@api_router.get("/storefront/{tenant_slug}/blog")
async def get_public_blog_posts(
    tenant_slug: str,
    category: Optional[str] = Query(None),
    tag: Optional[str] = Query(None),
    skip: int = Query(0, ge=0),
    limit: int = Query(10, le=50)
):
    """Get published blog posts for public storefront"""
    tenant = await db.tenants.find_one(
        {"$or": [{"slug": tenant_slug}, {"id": tenant_slug}]},
        {"_id": 0, "id": 1}
    )
    
    if not tenant:
        raise HTTPException(status_code=404, detail="Store not found")
    
    tenant_id = tenant.get("id")
    
    query = {
        "tenant_id": tenant_id,
        "status": "published",
        "is_deleted": {"$ne": True}
    }
    
    if category:
        query["category"] = category
    if tag:
        query["tags"] = tag
    
    posts = await db.blog_posts.find(
        query,
        {"_id": 0, "id": 1, "title": 1, "slug": 1, "excerpt": 1, "featured_image": 1, 
         "category": 1, "tags": 1, "created_at": 1, "views": 1}
    ).sort("created_at", -1).skip(skip).limit(limit).to_list(limit)
    
    total = await db.blog_posts.count_documents(query)
    
    # Get categories with counts
    categories = await db.blog_posts.aggregate([
        {"$match": {"tenant_id": tenant_id, "status": "published", "is_deleted": {"$ne": True}}},
        {"$group": {"_id": "$category", "count": {"$sum": 1}}},
        {"$sort": {"count": -1}}
    ]).to_list(None)
    
    return {
        "posts": posts,
        "total": total,
        "categories": [{"name": c["_id"], "count": c["count"]} for c in categories if c["_id"]]
    }


@api_router.get("/storefront/{tenant_slug}/blog/{post_slug}")
async def get_public_blog_post(tenant_slug: str, post_slug: str):
    """Get a single published blog post for public viewing"""
    tenant = await db.tenants.find_one(
        {"$or": [{"slug": tenant_slug}, {"id": tenant_slug}]},
        {"_id": 0, "id": 1}
    )
    
    if not tenant:
        raise HTTPException(status_code=404, detail="Store not found")
    
    tenant_id = tenant.get("id")
    
    post = await db.blog_posts.find_one(
        {"tenant_id": tenant_id, "slug": post_slug, "status": "published", "is_deleted": {"$ne": True}},
        {"_id": 0}
    )
    
    if not post:
        raise HTTPException(status_code=404, detail="Blog post not found")
    
    # Increment view count
    await db.blog_posts.update_one(
        {"id": post["id"]},
        {"$inc": {"views": 1}}
    )
    
    # Get related posts
    related = await db.blog_posts.find(
        {
            "tenant_id": tenant_id,
            "status": "published",
            "is_deleted": {"$ne": True},
            "id": {"$ne": post["id"]},
            "$or": [
                {"category": post.get("category")},
                {"tags": {"$in": post.get("tags", [])}}
            ]
        },
        {"_id": 0, "id": 1, "title": 1, "slug": 1, "excerpt": 1, "featured_image": 1}
    ).limit(3).to_list(3)
    
    post["views"] = post.get("views", 0) + 1
    post["related_posts"] = related
    
    return post


@api_router.get("/ecommerce/orders")
async def list_ecommerce_orders(
    user: dict = Depends(get_current_user),
    status: Optional[str] = Query(None),
    start_date: Optional[str] = Query(None),
    end_date: Optional[str] = Query(None),
    skip: int = Query(0, ge=0),
    limit: int = Query(50, le=200)
):
    """List e-commerce orders for admin"""
    tenant_id = get_tenant_id(user)
    
    query = {"tenant_id": tenant_id}
    
    if status:
        query["status"] = status
    
    if start_date:
        query["created_at"] = {"$gte": start_date}
    
    if end_date:
        if "created_at" in query:
            query["created_at"]["$lte"] = end_date + "T23:59:59"
        else:
            query["created_at"] = {"$lte": end_date + "T23:59:59"}
    
    orders = await db.ecommerce_orders.find(query, {"_id": 0}).sort("created_at", -1).skip(skip).limit(limit).to_list(limit)
    total = await db.ecommerce_orders.count_documents(query)
    
    # Get stats
    stats = {
        "total_orders": total,
        "pending": await db.ecommerce_orders.count_documents({"tenant_id": tenant_id, "status": "pending"}),
        "confirmed": await db.ecommerce_orders.count_documents({"tenant_id": tenant_id, "status": "confirmed"}),
        "shipped": await db.ecommerce_orders.count_documents({"tenant_id": tenant_id, "status": "shipped"}),
        "delivered": await db.ecommerce_orders.count_documents({"tenant_id": tenant_id, "status": "delivered"}),
    }
    
    return {
        "orders": orders,
        "total": total,
        "stats": stats,
        "skip": skip,
        "limit": limit
    }


@api_router.put("/ecommerce/orders/{order_id}/status")
async def update_order_status(
    order_id: str,
    status: str = Query(...),
    tracking_number: str = Query(None),
    user: dict = Depends(get_current_user)
):
    """Update e-commerce order status"""
    tenant_id = get_tenant_id(user)
    
    valid_statuses = ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled", "refunded"]
    if status not in valid_statuses:
        raise HTTPException(status_code=400, detail=f"Invalid status. Valid: {valid_statuses}")
    
    order = await db.ecommerce_orders.find_one({"id": order_id, "tenant_id": tenant_id})
    if not order:
        raise HTTPException(status_code=404, detail="Order not found")
    
    update_data = {
        "status": status,
        "updated_at": datetime.now(timezone.utc).isoformat(),
        "updated_by": user.get("id")
    }
    
    if tracking_number:
        update_data["tracking_number"] = tracking_number
    
    if status == "shipped":
        update_data["shipped_at"] = datetime.now(timezone.utc).isoformat()
    elif status == "delivered":
        update_data["delivered_at"] = datetime.now(timezone.utc).isoformat()
        if order.get("payment_method") == "cod":
            update_data["payment_status"] = "paid"
            update_data["paid_at"] = datetime.now(timezone.utc).isoformat()
    elif status == "cancelled":
        # Release stock
        for item in order.get("items", []):
            await db.items.update_one(
                {"id": item["item_id"], "tenant_id": tenant_id},
                {"$inc": {"stock_quantity": item["quantity"], "reserved_stock": -item.get("quantity", 0)}}
            )
    
    await db.ecommerce_orders.update_one(
        {"id": order_id},
        {"$set": update_data}
    )
    
    return {"message": f"Order status updated to {status}", "order_id": order_id}


@api_router.get("/ecommerce/dashboard")
async def get_ecommerce_dashboard(user: dict = Depends(get_current_user)):
    """Get e-commerce dashboard stats"""
    tenant_id = get_tenant_id(user)
    
    today = datetime.now(timezone.utc)
    month_start = today.replace(day=1, hour=0, minute=0, second=0, microsecond=0).isoformat()
    
    # Get orders this month
    month_orders = await db.ecommerce_orders.find({
        "tenant_id": tenant_id,
        "created_at": {"$gte": month_start},
        "status": {"$ne": "cancelled"}
    }, {"_id": 0}).to_list(None)
    
    total_revenue = sum(o.get("total_amount", 0) for o in month_orders if o.get("payment_status") == "paid")
    total_orders = len(month_orders)
    avg_order_value = total_revenue / total_orders if total_orders > 0 else 0
    
    # Recent orders
    recent_orders = await db.ecommerce_orders.find(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ).sort("created_at", -1).limit(10).to_list(10)
    
    # Top products
    pipeline = [
        {"$match": {"tenant_id": tenant_id, "payment_status": "paid"}},
        {"$unwind": "$items"},
        {"$group": {
            "_id": "$items.item_id",
            "name": {"$first": "$items.name"},
            "total_sold": {"$sum": "$items.quantity"},
            "revenue": {"$sum": {"$multiply": ["$items.price", "$items.quantity"]}}
        }},
        {"$sort": {"total_sold": -1}},
        {"$limit": 5}
    ]
    top_products = await db.ecommerce_orders.aggregate(pipeline).to_list(5)
    
    return {
        "monthly_revenue": round(total_revenue, 2),
        "monthly_orders": total_orders,
        "avg_order_value": round(avg_order_value, 2),
        "pending_orders": len([o for o in month_orders if o.get("status") == "pending"]),
        "recent_orders": recent_orders,
        "top_products": top_products
    }


