# ============== WEBSOCKET ==============

from websocket_manager import manager, broadcast_event, EventType

@app.websocket("/ws/{user_id}")
async def websocket_endpoint(websocket: WebSocket, user_id: str, token: str = "", tenant_id: str = "", user_name: str = ""):
    """WebSocket endpoint for real-time notifications"""
    # Validate token
    try:
        if token:
            payload = jwt.decode(token, SECRET_KEY, algorithms=[ALGORITHM])
            if payload.get("sub") != user_id:
                await websocket.close(code=4001)
                return
    except JWTError:
        await websocket.close(code=4001)
        return
    
    await manager.connect(websocket, tenant_id or "default", user_id, user_name)
    
    try:
        while True:
            # Keep connection alive and handle incoming messages
            data = await websocket.receive_text()
            try:
                message = json.loads(data)
                # Handle ping/pong for keepalive
                if message.get("type") == "ping":
                    await websocket.send_json({"type": "pong"})
            except:
                pass
    except WebSocketDisconnect:
        manager.disconnect(tenant_id or "default", user_id)
        # Broadcast user offline
        await manager.broadcast_to_tenant(tenant_id or "default", {
            "type": "user_offline",
            "data": {
                "user_id": user_id,
                "user_name": user_name,
                "timestamp": datetime.now(timezone.utc).isoformat()
            }
        })


