# ============== COMBINED DISCOUNTS ENDPOINT (for offline caching) ==============

@api_router.get("/discounts")
async def list_all_discounts(
    active_only: bool = True,
    user: dict = Depends(require_permission("discount_manager"))
):
    """Get all discounts (item-level and tiered) for offline caching
    
    This endpoint combines item-discounts and tiered-discounts into a single
    response for efficient offline caching in the POS system.
    """
    tenant_id = get_tenant_id(user)
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    # Build query for active discounts
    query = {"tenant_id": tenant_id}
    if active_only:
        query["active"] = True
        query["valid_from"] = {"$lte": today}
        query["valid_until"] = {"$gte": today}
    
    # Get item-level discounts
    item_discounts = await db.item_discounts.find(query, {"_id": 0}).to_list(1000)
    for d in item_discounts:
        d["discount_source"] = "item"
    
    # Get tiered discounts
    tiered_discounts = await db.tiered_discounts.find(query, {"_id": 0}).to_list(100)
    for d in tiered_discounts:
        d["discount_source"] = "tiered"
    
    # Combine and return
    all_discounts = item_discounts + tiered_discounts
    return all_discounts

