            f"₹{e.get('amount', 0):,.2f}" if e.get('credit_account') else '-',
            f"₹{e.get('amount', 0):,.2f}"
        ] for e in entries]
        summary = {"total_entries": len(entries)}
        
    elif ledger_type == 'debtors':
        entries = await db.debtor_ledger.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(None)
