async def get_blog_post(post_id: str, user: dict = Depends(get_current_user)):
    """Get a specific blog post"""
    tenant_id = get_tenant_id(user)
    
    post = await db.blog_posts.find_one(
        {"id": post_id, "tenant_id": tenant_id, "is_deleted": {"$ne": True}},
        {"_id": 0}
    )
    
    if not post:
        raise HTTPException(status_code=404, detail="Blog post not found")
    
    return post


@api_router.put("/ecommerce/blog/posts/{post_id}")
async def update_blog_post(
    post_id: str,
    post: BlogPostUpdate,
    user: dict = Depends(get_current_user)
):
    """Update a blog post"""
    tenant_id = get_tenant_id(user)
    
    existing = await db.blog_posts.find_one(
        {"id": post_id, "tenant_id": tenant_id, "is_deleted": {"$ne": True}}
    )
    
    if not existing:
        raise HTTPException(status_code=404, detail="Blog post not found")
    
    update_data = {k: v for k, v in post.dict().items() if v is not None}
    update_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    update_data["updated_by"] = user.get("id")
    
    await db.blog_posts.update_one(
        {"id": post_id, "tenant_id": tenant_id},
        {"$set": update_data}
    )
    
    updated_post = await db.blog_posts.find_one({"id": post_id}, {"_id": 0})
    return {"message": "Blog post updated", "post": updated_post}


@api_router.delete("/ecommerce/blog/posts/{post_id}")
async def delete_blog_post(post_id: str, user: dict = Depends(get_current_user)):
    """Delete a blog post (soft delete)"""
    tenant_id = get_tenant_id(user)
    
    result = await db.blog_posts.update_one(
        {"id": post_id, "tenant_id": tenant_id},
        {"$set": {"is_deleted": True, "deleted_at": datetime.now(timezone.utc).isoformat()}}
    )
    
    if result.modified_count == 0:
        raise HTTPException(status_code=404, detail="Blog post not found")
    
    return {"message": "Blog post deleted"}


@api_router.post("/ecommerce/blog/ai-generate")
async def ai_generate_blog_post(
    request: Request,
    user: dict = Depends(get_current_user)
):
    """Generate an SEO-optimized blog post using AI"""
    tenant_id = get_tenant_id(user)
    data = await request.json()
    
    topic = data.get("topic", "")
    keywords = data.get("keywords", [])
    tone = data.get("tone", "professional")  # professional, casual, friendly
    length = data.get("length", "medium")  # short, medium, long
    include_product_links = data.get("include_product_links", True)
    
    if not topic:
        raise HTTPException(status_code=400, detail="Topic is required")
    
    # Get store info for context
    invoice_settings = await db.user_invoice_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
    store_name = invoice_settings.get("company_name", "Our Store") if invoice_settings else "Our Store"
    
    # Get some products to potentially link in the blog
    products = []
    if include_product_links:
        products = await db.items.find(
            {"tenant_id": tenant_id, "show_in_ecommerce": {"$ne": False}, "current_stock": {"$gt": 0}},
            {"_id": 0, "name": 1, "description": 1, "selling_price": 1}
        ).limit(5).to_list(5)
    
    products_context = ""
    if products:
        products_context = "\n\nRelated products to mention:\n" + "\n".join([f"- {p['name']}: {p.get('description', '')[:100]}" for p in products])
    
    # Build AI prompt
    length_guide = {"short": "300-500", "medium": "600-900", "long": "1000-1500"}
    
    prompt = f"""Write an SEO-optimized blog post for "{store_name}" online store.

Topic: {topic}
Target Keywords: {', '.join(keywords) if keywords else 'related to the topic'}
Tone: {tone}
Word Count: {length_guide.get(length, '600-900')} words
{products_context}

Create a blog post with:
1. An engaging, keyword-rich title (H1)
2. A compelling meta description (150-160 characters)
3. Well-structured content with H2 and H3 subheadings
4. Natural keyword placement throughout
5. A call-to-action at the end
6. If products are mentioned, integrate them naturally

Return the response in this exact JSON format:
{{
    "title": "Blog post title",
    "meta_title": "SEO title (60 chars max)",
    "meta_description": "SEO description (155 chars max)",
    "excerpt": "Brief summary (2-3 sentences)",
    "content": "Full HTML content with proper heading tags",
    "tags": ["tag1", "tag2", "tag3"],
    "seo_score": 85
}}"""
    
    try:
        # Use Gemini for content generation
        # from emergentintegrations.llm.gemini import GeminiChat
        
        chat = GeminiChat(
            api_key=os.environ.get("EMERGENT_LLM_KEY"),
            model="gemini-2.0-flash"
        )
        
        response = await chat.send_message(prompt)
        
        # Parse AI response
        import json
        try:
            # Try to extract JSON from the response
            json_match = re.search(r'\{[\s\S]*\}', response)
            if json_match:
                ai_content = json.loads(json_match.group())
            else:
                raise ValueError("No JSON found in response")
        except json.JSONDecodeError:
            # Fallback: create structured content from raw response
            ai_content = {
                "title": topic,
                "meta_title": topic[:60],
                "meta_description": f"Learn about {topic} at {store_name}",
                "excerpt": response[:200],
                "content": f"<p>{response}</p>",
                "tags": keywords[:5] if keywords else [topic.lower()],
                "seo_score": 70
            }
        
        # Generate slug
        slug = re.sub(r'[^a-z0-9]+', '-', ai_content.get("title", topic).lower()).strip('-')
        
        # Check for duplicate slug
        existing = await db.blog_posts.find_one({"tenant_id": tenant_id, "slug": slug, "is_deleted": {"$ne": True}})
        if existing:
            slug = f"{slug}-{str(uuid.uuid4())[:8]}"
        
        # Save the generated post as draft
        post_doc = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "title": ai_content.get("title", topic),
            "slug": slug,
            "content": ai_content.get("content", ""),
            "excerpt": ai_content.get("excerpt", ""),
            "category": "ai-generated",
            "tags": ai_content.get("tags", []),
            "featured_image": None,
            "meta_title": ai_content.get("meta_title", ""),
            "meta_description": ai_content.get("meta_description", ""),
            "status": "draft",
            "ai_generated": True,
            "ai_topic": topic,
            "ai_keywords": keywords,
            "seo_score": ai_content.get("seo_score", 75),
            "views": 0,
            "created_by": user.get("id"),
            "created_at": datetime.now(timezone.utc).isoformat(),
            "updated_at": datetime.now(timezone.utc).isoformat(),
            "is_deleted": False
        }
        
        await db.blog_posts.insert_one(post_doc)
        
        return {
            "message": "AI blog post generated successfully",
            "post": {k: v for k, v in post_doc.items() if k != "_id"}
        }
        
    except Exception as e:
        logger.error(f"AI blog generation failed: {e}")
        raise HTTPException(status_code=500, detail=f"AI generation failed: {str(e)}")


