@api_router.get("/analytics/dashboard")
async def get_analytics_dashboard(
    date_range: str = Query("7d", regex="^(7d|30d|90d|1y)$"),
    user: dict = Depends(get_current_user)
):
    """Get comprehensive analytics dashboard data"""
    tenant_id = get_tenant_id(user)
    
    # Calculate date range
    now = datetime.now(timezone.utc)
    if date_range == "7d":
        days = 7
    elif date_range == "30d":
        days = 30
    elif date_range == "90d":
        days = 90
    else:  # 1y
        days = 365
    
    start_date = (now - timedelta(days=days)).isoformat()
    
    # Get sales in date range
    sales = await db.sales.find({
        "tenant_id": tenant_id,
        "created_at": {"$gte": start_date}
    }, {"_id": 0}).to_list(10000)
    
    # Calculate sales trend by day
    sales_by_day = {}
    for sale in sales:
        day = sale.get("created_at", "")[:10]
        if day not in sales_by_day:
            sales_by_day[day] = {"revenue": 0, "orders": 0, "profit": 0}
        sales_by_day[day]["revenue"] += sale.get("total_amount", 0)
        sales_by_day[day]["orders"] += 1
        # Estimate profit as 30% of revenue (simplified)
        sales_by_day[day]["profit"] += sale.get("total_amount", 0) * 0.3
    
    sales_trend = []
    for i in list(range(days)):
        date = (now - timedelta(days=days-1-i)).strftime("%Y-%m-%d")
        date_display = (now - timedelta(days=days-1-i)).strftime("%b %d")
        day_data = sales_by_day.get(date, {"revenue": 0, "orders": 0, "profit": 0})
        sales_trend.append({
            "date": date_display,
            "revenue": day_data["revenue"],
            "orders": day_data["orders"],
            "profit": int(day_data["profit"])
        })
    
    # Get top products
    product_sales = {}
    for sale in sales:
        for item in sale.get("items", []):
            item_id = item.get("item_id", item.get("name", "Unknown"))
            name = item.get("name", "Unknown")
            if item_id not in product_sales:
                product_sales[item_id] = {"name": name, "sales": 0, "revenue": 0}
            product_sales[item_id]["sales"] += item.get("quantity", 1)
            product_sales[item_id]["revenue"] += item.get("quantity", 1) * item.get("price", 0)
    
    top_products = sorted(product_sales.values(), key=lambda x: x["revenue"], reverse=True)[:5]
    
    # Get revenue by category
    categories = await db.categories.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(100)
    category_map = {c["id"]: c["name"] for c in categories}
    
    items = await db.items.find({"tenant_id": tenant_id}, {"_id": 0, "id": 1, "category_id": 1}).to_list(10000)
    item_category = {i["id"]: category_map.get(i.get("category_id"), "Others") for i in items}
    
    category_revenue = {}
    for sale in sales:
        for item in sale.get("items", []):
            cat = item_category.get(item.get("item_id"), "Others")
            if cat not in category_revenue:
                category_revenue[cat] = 0
            category_revenue[cat] += item.get("quantity", 1) * item.get("price", 0)
    
    revenue_by_category = [{"name": k, "value": v} for k, v in category_revenue.items()]
    
    # Customer growth
    customers = await db.customers.find({
        "tenant_id": tenant_id,
        "created_at": {"$gte": start_date}
    }, {"_id": 0, "created_at": 1}).to_list(10000)
    
    all_customers_count = await db.customers.count_documents({"tenant_id": tenant_id})
    
    customer_by_day = {}
    for c in customers:
        day = c.get("created_at", "")[:10]
        customer_by_day[day] = customer_by_day.get(day, 0) + 1
    
    customer_growth = []
    running_total = all_customers_count - len(customers)
    for i in list(range(days)):
        date = (now - timedelta(days=days-1-i)).strftime("%Y-%m-%d")
        date_display = (now - timedelta(days=days-1-i)).strftime("%b %d")
        new_today = customer_by_day.get(date, 0)
        running_total += new_today
        customer_growth.append({
            "date": date_display,
            "newCustomers": new_today,
            "totalCustomers": running_total
        })
    
    # Payment methods distribution
    payment_counts = {}
    for sale in sales:
        method = sale.get("payment_method", "cash")
        payment_counts[method] = payment_counts.get(method, 0) + 1
    
    total_payments = sum(payment_counts.values()) or 1
    payment_methods = [
        {"name": k.capitalize(), "value": round(v / total_payments * 100)}
        for k, v in payment_counts.items()
    ]
    
    # Hourly distribution (from today's sales)
    today = now.strftime("%Y-%m-%d")
    today_sales = [s for s in sales if s.get("created_at", "").startswith(today)]
    
    hourly = {}
    for sale in today_sales:
        hour = sale.get("created_at", "")[11:13]
        if hour:
            hourly[hour] = hourly.get(hour, 0) + 1
    
    hourly_distribution = [
        {"hour": f"{h}:00", "sales": hourly.get(str(h).zfill(2), 0)}
        for h in list(range(9, 21))  # 9 AM to 9 PM
    ]
    
    # Summary
    total_revenue = sum(s.get("total_amount", 0) for s in sales)
    total_orders = len(sales)
    avg_order_value = total_revenue / total_orders if total_orders > 0 else 0
    new_customers = len(customers)
    
    # Calculate growth (compare to previous period)
    prev_start = (now - timedelta(days=days*2)).isoformat()
    prev_end = start_date
    prev_sales = await db.sales.find({
        "tenant_id": tenant_id,
        "created_at": {"$gte": prev_start, "$lt": prev_end}
    }, {"_id": 0, "total_amount": 1}).to_list(10000)
    
    prev_revenue = sum(s.get("total_amount", 0) for s in prev_sales)
    prev_orders = len(prev_sales)
    
    revenue_growth = ((total_revenue - prev_revenue) / prev_revenue * 100) if prev_revenue > 0 else 0
    orders_growth = ((total_orders - prev_orders) / prev_orders * 100) if prev_orders > 0 else 0
    
    return {
        "salesTrend": sales_trend,
        "topProducts": top_products,
        "revenueByCategory": revenue_by_category,
        "customerGrowth": customer_growth,
        "paymentMethods": payment_methods,
        "hourlyDistribution": hourly_distribution,
        "summary": {
            "totalRevenue": int(total_revenue),
            "totalOrders": total_orders,
            "avgOrderValue": int(avg_order_value),
            "totalCustomers": all_customers_count,
            "newCustomers": new_customers,
            "topSellingCategory": max(category_revenue, key=category_revenue.get) if category_revenue else "N/A",
            "revenueGrowth": round(revenue_growth, 1),
            "ordersGrowth": round(orders_growth, 1)
        }
    }


