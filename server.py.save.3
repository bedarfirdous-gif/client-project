@api_router.post("/employees/{employee_id}/upgrade")
async def upgrade_employee(employee_id: str, upgrade: EmployeeUpgrade, user: dict = Depends(require_permission("payroll"))):
    """Upgrade employee designation and salary"""
    tenant_id = get_tenant_id(user)
    
    employee = await db.employees.find_one({"id": employee_id, "tenant_id": tenant_id})
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Store previous values for history
    previous_designation = employee.get("designation", "")
    salary_info_prev = employee.get("salary_info") or {}
    previous_salary = salary_info_prev.get("basic_salary", employee.get("salary", 0))
    
    # Create upgrade record
    upgrade_record = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "employee_name": employee.get("name"),
        "previous_designation": previous_designation,
        "new_designation": upgrade.designation,
        "previous_salary": previous_salary,
        "new_salary": upgrade.basic_salary,
        "effective_date": upgrade.effective_date or datetime.now(timezone.utc).strftime("%Y-%m-%d"),
        "reason": upgrade.reason,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get("id"),
        "created_by_name": user.get("name", "")
    }
    
    await db.employee_upgrades.insert_one(upgrade_record)
    
    # Update employee record
    salary_info = employee.get("salary_info") or {}
    salary_info["basic_salary"] = upgrade.basic_salary
    
    await db.employees.update_one(
        {"id": employee_id, "tenant_id": tenant_id},
        {"$set": {
            "designation": upgrade.designation,
            "salary_info": salary_info,
            "salary": upgrade.basic_salary,  # For backward compatibility
            "updated_at": datetime.now(timezone.utc).isoformat(),
            "updated_by": user.get("id")
        }}
    )
    
    # Also update salary structure if exists
    await db.salary_structures.update_many(
        {"employee_id": employee_id, "is_active": True},
        {"$set": {"basic_salary": upgrade.basic_salary}}
    )
    
    del upgrade_record["_id"]
    return {
        "message": f"Employee upgraded successfully. New designation: {upgrade.designation}, New salary: ₹{upgrade.basic_salary}",
        "upgrade": upgrade_record
    }

