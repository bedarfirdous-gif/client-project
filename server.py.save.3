async def _parse_ai_response(response: str, source_type: str):
    """Parse AI response and normalize items"""
    try:
        response_text = response.strip()
        if response_text.startswith("```json"):
            response_text = response_text[7:]
        if response_text.startswith("```"):
            response_text = response_text[3:]
        if response_text.endswith("```"):
            response_text = response_text[:-3]
        response_text = response_text.strip()
        
        items = json.loads(response_text)
        
        normalized_items = []
        for item in items:
            normalized_items.append({
                'name': str(item.get('name', '')).strip(),
                'sku': str(item.get('sku', '')).strip(),
                'category': str(item.get('category', '')).strip(),
                'brand': str(item.get('brand', '')).strip(),
                'size': str(item.get('size', '')).strip(),
                'color': str(item.get('color', '')).strip(),
                'mrp': float(item.get('mrp', 0) or 0),
                'selling_price': float(item.get('selling_price', item.get('price', 0)) or 0),
                'cost_price': float(item.get('cost_price', item.get('selling_price', 0)) or 0),
                'quantity': int(item.get('quantity', item.get('qty', 1)) or 1),
                'min_stock_alert': 5,
                'gst_rate': float(item.get('gst_rate', 18) or 18),
                'hsn_code': str(item.get('hsn_code', '')).strip(),
            })
        
        return {
            "success": True,
            "items": normalized_items,
            "source_type": source_type,
            "stats": {
                "total_extracted": len(normalized_items),
                "valid": len(normalized_items),
                "new": len(normalized_items),
                "update": 0,
                "errors": 0
            },
            "ai_powered": True
        }
    except json.JSONDecodeError:
        logger.error(f"Failed to parse AI response: {response[:500]}")
        raise HTTPException(status_code=500, detail="AI could not extract items. Try a clearer image or different document type.")


