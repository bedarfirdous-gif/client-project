    # Enrich suppliers with their linked ledger info
    for supplier in suppliers:
        if supplier.get("ledger_id"):
            ledger = await db.ledgers.find_one(
                {"id": supplier["ledger_id"], "tenant_id": tenant_id, "is_deleted": {"$ne": True}},
                {"_id": 0, "id": 1, "name": 1, "opening_balance": 1, "opening_balance_type": 1}
