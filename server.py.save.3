# ============== AI INVOICE SCANNER ==============

@api_router.post("/ai/scan-invoice")
async def scan_invoice_with_ai(
    file: UploadFile = File(...),
    user: dict = Depends(get_current_user)
):
    """
    AI-powered invoice scanner that extracts:
    - Supplier name and details
    - Invoice date and number
    - Item details (name, quantity, rate, GST, etc.)
    Uses Gemini model for file analysis (required for file attachment support)
    """
    # from emergentintegrations.llm.chat import LlmChat, UserMessage, FileContentWithMimeType
    import tempfile
    
    tenant_id = get_tenant_id(user)
    
    # Validate file type
    allowed_types = ['image/jpeg', 'image/png', 'image/webp', 'image/gif', 'application/pdf']
    if file.content_type not in allowed_types:
        raise HTTPException(
            status_code=400, 
            detail=f"Unsupported file type: {file.content_type}. Allowed types: jpeg, png, webp, gif, pdf"
        )
    
    # Save uploaded file temporarily
    temp_dir = tempfile.mkdtemp()
    try:
        # Determine file extension
        ext_map = {
            'image/jpeg': '.jpg',
            'image/png': '.png',
            'image/webp': '.webp',
            'image/gif': '.gif',
            'application/pdf': '.pdf'
        }
        file_ext = ext_map.get(file.content_type, '.bin')
        temp_file_path = os.path.join(temp_dir, f"invoice{file_ext}")
        
        # Write file to temp location
        with open(temp_file_path, 'wb') as temp_file:
            shutil.copyfileobj(file.file, temp_file)
        
        # Initialize LLM Chat with Gemini (required for file attachments)
        api_key = os.environ.get('EMERGENT_LLM_KEY')
        if not api_key:
            raise HTTPException(status_code=500, detail="LLM API key not configured")
        
        chat = LlmChat(
            api_key=api_key,
            session_id=f"invoice-scan-{uuid.uuid4()}",
            system_message="""You are an expert invoice parser. Analyze the provided invoice image or document and extract structured data.
            
Return a JSON object with the following structure:
{
    "supplier_name": "string - name of the supplier/vendor",
    "supplier_address": "string - full address if available",
    "supplier_phone": "string - phone number if available",
    "supplier_gst": "string - GST number if available",
    "invoice_number": "string - invoice/bill number",
    "invoice_date": "string - date in YYYY-MM-DD format",
    "items": [
        {
            "name": "string - item/product name",
            "description": "string - any additional description",
            "quantity": number,
            "rate": number - price per unit,
            "gst_percent": number - GST percentage (0, 5, 12, 18, or 28),
            "amount": number - total amount for this item
        }
    ],
    "subtotal": number - sum before tax,
    "tax_amount": number - total tax/GST amount,
    "discount": number - any discount applied,
    "total_amount": number - final total,
    "notes": "string - any additional notes or terms"
}

Important:
- Extract all visible items from the invoice
- Use 0 for missing numeric values
- Use empty string for missing text values
- Parse Indian currency format (₹) correctly
- Identify GST rates from CGST/SGST breakdowns
- Return ONLY the JSON object, no other text"""
        ).with_model("gemini", "gemini-2.5-flash")
        
        # Create file attachment
        file_content = FileContentWithMimeType(
            file_path=temp_file_path,
            mime_type=file.content_type
        )
        
        # Send message with file attachment
        user_message = UserMessage(
            text="Please analyze this invoice and extract all the details. Return ONLY a valid JSON object.",
            file_contents=[file_content]
        )
        
        response = await chat.send_message(user_message)
        
        # Parse the response - extract JSON from the response
        response_text = response.strip()
        
        # Try to extract JSON from markdown code blocks if present
        if '```json' in response_text:
            json_start = response_text.find('```json') + 7
            json_end = response_text.find('```', json_start)
            response_text = response_text[json_start:json_end].strip()
        elif '```' in response_text:
            json_start = response_text.find('```') + 3
            json_end = response_text.find('```', json_start)
            response_text = response_text[json_start:json_end].strip()
        
        # Helper function to repair common JSON issues from LLM output
        def repair_json(json_str: str) -> str:
            import re
            
            # Remove any text that looks like garbage/streaming artifacts between JSON tokens
            # Handles cases like "amount": 4990\n        queue        },
            json_str = re.sub(r'(\d+)\s*[a-zA-Z_]+\s*([},\]])', r'\1\2', json_str)
            
            # Remove trailing commas before } or ] (with possible whitespace/newlines)
            json_str = re.sub(r',(\s*[}\]])', r'\1', json_str)
            # Remove trailing commas after values and before the next line (fix incomplete objects)
            json_str = re.sub(r',(\s*,)', r',', json_str)  # Remove duplicate commas
            json_str = re.sub(r'}\s*,\s*,', '},', json_str)  # Fix },, -> },
            json_str = re.sub(r',\s*{', ', {', json_str)  # Normalize comma before {
            
            # Remove incomplete/truncated objects at the end
            # Find the last complete object by looking for incomplete key-value pairs
            lines = json_str.split('\n')
            valid_lines = []
            last_complete_line = 0
            
            for i, line in enumerate(lines):
                stripped = line.strip()
                # Skip empty lines
                if not stripped:
                    valid_lines.append(line)
                    continue
                    
                valid_lines.append(line)
                
                # Check if line ends with a complete value (}, ], number, "string", true/false/null)
                if re.search(r'[}\]\d"]$|true$|false$|null$', stripped):
                    last_complete_line = i
            
            # If JSON seems truncated, only keep lines up to last complete one
            json_str = '\n'.join(valid_lines)
            
            # Clean up trailing comma if present
            json_str = re.sub(r',(\s*)$', r'\1', json_str)
            
            # Try to fix truncated JSON by ensuring proper bracket closure
            open_braces = json_str.count('{')
            close_braces = json_str.count('}')
            open_brackets = json_str.count('[')
            close_brackets = json_str.count(']')
            
            if open_braces > close_braces or open_brackets > close_brackets:
                # Need to close arrays before objects
                for _ in range(open_brackets - close_brackets):
                    json_str += ']'
                for _ in range(open_braces - close_braces):
                    json_str += '}'
            
            return json_str
        
        try:
            extracted_data = json.loads(response_text)
        except json.JSONDecodeError as e:
            # Try to repair the JSON
            logger.warning(f"Attempting to repair malformed JSON from AI: {str(e)}")
            try:
                repaired_json = repair_json(response_text)
                extracted_data = json.loads(repaired_json)
                logger.info("Successfully repaired malformed JSON from AI")
            except json.JSONDecodeError:
                logger.error(f"Failed to parse AI response even after repair: {response_text}")
                raise HTTPException(
                    status_code=500, 
                    detail=f"Failed to parse invoice data from AI response. Raw: {response_text[:500]}"
                )
        
        # Try to match supplier with existing suppliers
        supplier_match = None
        if extracted_data.get("supplier_name"):
            supplier_name = extracted_data["supplier_name"].lower()
            suppliers = await db.suppliers.find(
                {"tenant_id": tenant_id},
                {"_id": 0, "id": 1, "name": 1, "phone": 1, "gst_number": 1}
            ).to_list(1000)
            
            for s in suppliers:
                if supplier_name in s.get("name", "").lower():
                    supplier_match = s
                    break
        
        # Log the scan for analytics
        scan_log = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "user_id": user.get("id"),
            "file_type": file.content_type,
            "file_name": file.filename,
            "extracted_data": extracted_data,
            "supplier_matched": supplier_match is not None,
            "created_at": datetime.now(timezone.utc).isoformat()
        }
        await db.invoice_scans.insert_one(scan_log)
        
        return {
            "success": True,
            "extracted_data": extracted_data,
            "supplier_match": supplier_match,
            "message": "Invoice scanned successfully"
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Invoice scan error: {str(e)}\n{traceback.format_exc()}")
        raise HTTPException(status_code=500, detail=f"Failed to scan invoice: {str(e)}")
    finally:
        # Clean up temp files
        try:
            shutil.rmtree(temp_dir)
        except:
            pass



