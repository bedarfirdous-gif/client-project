# ============== CUSTOMER BULK IMPORT ==============

@api_router.post("/customers/import/upload")
async def upload_customers_file(
    file: UploadFile = File(...),
    source: str = Form("manual_upload"),
    direct_import: bool = Form(False),
    user: dict = Depends(require_permission("customer_import"))
):
    """Upload a file for customer import (Excel, CSV, JSON, PDF, Image)"""
    tenant_id = get_tenant_id(user)
    
    # Determine file type
    filename = file.filename.lower()
    file_data = await file.read()
    
    if filename.endswith(('.xlsx', '.xls')):
        file_type = FileType.EXCEL
    elif filename.endswith('.csv'):
        file_type = FileType.CSV
    elif filename.endswith('.json'):
        file_type = FileType.JSON
    elif filename.endswith('.pdf'):
        file_type = FileType.PDF
    elif filename.endswith(('.jpg', '.jpeg', '.png', '.webp')):
        file_type = FileType.IMAGE
    else:
        raise HTTPException(status_code=400, detail="Unsupported file type. Supported: Excel, CSV, JSON, PDF, JPG, PNG")
    
    # Determine import source
    try:
        import_source = ImportSource(source)
    except ValueError:
        import_source = ImportSource.MANUAL_UPLOAD
    
    result = await customer_import_system.create_import_batch(
        tenant_id=tenant_id,
        user_id=user.get("id", user.get("user_id")),
        source=import_source,
        file_data=file_data,
        file_type=file_type,
        filename=file.filename,
        direct_import=direct_import
    )
    
    if not result.get("success"):
        raise HTTPException(status_code=400, detail=result.get("error", "Import failed"))
    
    return result

@api_router.post("/customers/import/scan")
async def scan_document_for_customers(
    image_data: str = Body(..., embed=True),
    source: str = Body("smart_scanner", embed=True),
    direct_import: bool = Body(False, embed=True),
    user: dict = Depends(require_permission("customer_import"))
):
    """Scan an image/document for customer data (camera or uploaded image as base64)"""
    tenant_id = get_tenant_id(user)
    
    try:
        # Decode base64 image
        if ',' in image_data:
            # Handle data URL format
            image_data = image_data.split(',')[1]
        
        file_data = base64.b64decode(image_data)
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"Invalid image data: {str(e)}")
    
    try:
        import_source = ImportSource(source)
    except ValueError:
        import_source = ImportSource.SMART_SCANNER
    
    result = await customer_import_system.create_import_batch(
        tenant_id=tenant_id,
        user_id=user.get("id", user.get("user_id")),
        source=import_source,
        file_data=file_data,
        file_type=FileType.IMAGE,
        filename=f"scan_{datetime.now(timezone.utc).strftime('%Y%m%d_%H%M%S')}.jpg",
        direct_import=direct_import
    )
    
    if not result.get("success"):
        raise HTTPException(status_code=400, detail=result.get("error", "Scan failed"))
    
    return result

