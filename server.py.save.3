@api_router.delete("/invoices/{invoice_id}")
async def delete_invoice(invoice_id: str, user: dict = Depends(get_current_user)):
    """Soft delete invoice - moves to recycle bin. Admins have full delete access."""
    tenant_id = get_tenant_id(user)
    
    # Admins can delete any invoice, others need specific permission
    if not is_admin_or_higher(user):
        # Check if user has sales permission for non-admins
        permissions = user.get("permissions", {})
        if not permissions.get("sales", {}).get("delete", False):
            raise HTTPException(status_code=403, detail="Permission denied. Admin access required for delete.")
    
    # Find the invoice first
    invoice = await db.invoices.find_one(
        {"id": invoice_id, "tenant_id": tenant_id},
        {"_id": 0}
    )
    
    if not invoice:
        raise HTTPException(status_code=404, detail="Invoice not found")
    
    # Move to recycle bin
    deleted_item = {
        "id": str(uuid.uuid4()),
        "original_id": invoice_id,
        "item_type": "invoice",
        "item_data": invoice,
        "deleted_by": user.get("id"),
        "deleted_by_name": user.get("name"),
        "deleted_at": datetime.now(timezone.utc).isoformat(),
        "tenant_id": tenant_id,
        "auto_delete_at": (datetime.now(timezone.utc) + timedelta(days=30)).isoformat(),
        "is_permanently_deleted": False
    }
    
    await db.recycle_bin.insert_one(deleted_item)
    
    # Mark invoice as deleted (soft delete)
    await db.invoices.update_one(
        {"id": invoice_id, "tenant_id": tenant_id}, 
        {"$set": {
            "is_deleted": True,
            "deleted_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": "Invoice moved to Recycle Bin", "recycle_bin_id": deleted_item["id"]}


@api_router.put("/invoices/{invoice_id}/status")
async def update_invoice_status(invoice_id: str, request: dict, user: dict = Depends(get_current_user)):
    """Update invoice status"""
    invoice = await db.invoices.find_one({"id": invoice_id})
    if not invoice:
        raise HTTPException(status_code=404, detail="Invoice not found")
    
    status = request.get("status")
    if status not in ["draft", "sent", "paid", "partial", "overdue", "cancelled"]:
        raise HTTPException(status_code=400, detail="Invalid status")
    
    update_data = {
        "status": status,
        "updated_at": datetime.now(timezone.utc).isoformat()
    }
    
    # If marking as paid, set amount_paid = total
    if status == "paid":
        total = invoice.get("total", invoice.get("total_amount", 0))
        update_data["amount_paid"] = total
        update_data["balance_due"] = 0
    
    await db.invoices.update_one({"id": invoice_id}, {"$set": update_data})
    
    return {"message": f"Invoice status updated to {status}"}


@api_router.post("/invoices/{invoice_id}/payments")
async def record_invoice_payment(invoice_id: str, request: dict, user: dict = Depends(get_current_user)):
    """Record a payment for an invoice"""
    invoice = await db.invoices.find_one({"id": invoice_id})
    if not invoice:
        raise HTTPException(status_code=404, detail="Invoice not found")
    
    amount = request.get("amount", 0)
    if amount <= 0:
        raise HTTPException(status_code=400, detail="Invalid payment amount")
    
    payment = {
        "id": str(uuid.uuid4()),
        "amount": amount,
        "method": request.get("method", "cash"),
        "reference": request.get("reference", ""),
        "date": request.get("date", datetime.now(timezone.utc).strftime("%Y-%m-%d")),
        "notes": request.get("notes", ""),
        "recorded_by": user.get("id"),
        "recorded_by_name": user.get("name"),
        "recorded_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Calculate new totals
    payments = invoice.get("payments", [])
    payments.append(payment)
    total_paid = sum(p.get("amount", 0) for p in payments)
    total = invoice.get("total", invoice.get("total_amount", 0))
    balance = max(0, total - total_paid)
    
    # Determine status
    if balance <= 0:
        status = "paid"
    elif total_paid > 0:
        status = "partial"
    else:
        status = invoice.get("status", "sent")
    
    await db.invoices.update_one(
        {"id": invoice_id},
        {"$set": {
            "payments": payments,
            "amount_paid": total_paid,
            "balance_due": balance,
            "status": status,
            "updated_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": "Payment recorded", "amount_paid": total_paid, "balance_due": balance, "status": status}


