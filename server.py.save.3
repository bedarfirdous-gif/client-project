@api_router.post("/orchestrator/communication/handoff")
async def trigger_error_handoff(
    error_id: str = Body(...),
    from_agent: str = Body(...),
    to_agent: str = Body(...),
    reason: str = Body("Manual handoff by admin"),
    user: dict = Depends(get_current_user)
):
    """Manually trigger an error handoff between agents"""
    role = user.get("role", "").lower()
    if not user.get("is_superadmin") and role not in ["superadmin", "admin"]:
        raise HTTPException(status_code=403, detail="Admin access required")
    
    try:
        # Get error details
        error = await central_orchestrator.get_error_by_id(error_id)
        if not error:
            raise HTTPException(status_code=404, detail="Error not found")
        
        result = await central_orchestrator.send_inter_agent_message(
            from_agent=from_agent,
            to_agent=to_agent,
            message_type="handoff",
            content={
                "error_type": error.get("error_type"),
                "error_message": error.get("error_message"),
                "reason": reason,
                "previous_attempts": error.get("fix_attempts", 0),
                "triggered_by": user.get("name", "Admin")
            },
            error_id=error_id,
            priority="high"
        )
        return {"success": True, "handoff": result}
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Failed to trigger handoff: {e}")
        raise HTTPException(status_code=500, detail=str(e))


