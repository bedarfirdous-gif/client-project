@api_router.get("/storefront/{tenant_slug}/products")
async def get_storefront_products(
    tenant_slug: str,
    category_id: Optional[str] = Query(None),
    search: Optional[str] = Query(None),
    min_price: Optional[float] = Query(None),
    max_price: Optional[float] = Query(None),
    sort_by: str = Query("newest"),  # newest, price_low, price_high, popular
    skip: int = Query(0, ge=0),
    limit: int = Query(20, le=100)
):
    """Get products for public storefront"""
    tenant = await db.tenants.find_one(
        {"$or": [{"slug": tenant_slug}, {"id": tenant_slug}]},
        {"_id": 0, "id": 1}
    )
    
    if not tenant:
        raise HTTPException(status_code=404, detail="Store not found")
    
    tenant_id = tenant.get("id")
    
    # Build query - only show items marked for e-commerce
    query = {
        "tenant_id": tenant_id,
        "is_active": {"$ne": False},
        "show_in_ecommerce": {"$ne": False},  # Show by default if not explicitly disabled
        "stock_quantity": {"$gt": 0}
    }
    
    if category_id:
        query["category_id"] = category_id
    
    if search:
        query["$or"] = [
            {"name": {"$regex": search, "$options": "i"}},
            {"description": {"$regex": search, "$options": "i"}},
            {"sku": {"$regex": search, "$options": "i"}}
        ]
    
    if min_price is not None:
        query["selling_price"] = {"$gte": min_price}
    
    if max_price is not None:
        if "selling_price" in query:
            query["selling_price"]["$lte"] = max_price
        else:
            query["selling_price"] = {"$lte": max_price}
    
    # Sort options
    sort_options = {
        "newest": [("created_at", -1)],
        "price_low": [("selling_price", 1)],
        "price_high": [("selling_price", -1)],
        "popular": [("total_sold", -1)],
        "name": [("name", 1)]
    }
    sort = sort_options.get(sort_by, [("created_at", -1)])
    
    # Fetch items
    items = await db.items.find(
        query,
        {"_id": 0, "cost_price": 0, "supplier_id": 0}  # Hide sensitive fields
    ).sort(sort).skip(skip).limit(limit).to_list(limit)
    
    total = await db.items.count_documents(query)
    
    return {
        "products": items,
        "total": total,
        "skip": skip,
        "limit": limit
    }


