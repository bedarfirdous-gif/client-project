@api_router.post("/accounting-vouchers")
async def create_accounting_voucher(voucher: VoucherCreate, user: dict = Depends(require_permission("ledger"))):
    """Create a new accounting voucher"""
    tenant_id = get_tenant_id(user)
    
    # Validate voucher type
    if voucher.voucher_type not in VOUCHER_TYPES:
        raise HTTPException(status_code=400, detail=f"Invalid voucher type. Valid types: {list(VOUCHER_TYPES.keys())}")
    
    # Validate line items
    if not voucher.line_items or len(voucher.line_items) < 1:
        raise HTTPException(status_code=400, detail="At least one line item is required")
    
    # Validate debit = credit
    total_debit = sum(item.debit for item in voucher.line_items)
    total_credit = sum(item.credit for item in voucher.line_items)
    
    if abs(total_debit - total_credit) > 0.01:
        raise HTTPException(status_code=400, detail=f"Debit ({total_debit}) must equal Credit ({total_credit})")
    
    # Validate all ledgers exist
    for item in voucher.line_items:
        # Check predefined groups first
        if item.ledger_id not in PREDEFINED_LEDGER_GROUPS:
            ledger = await db.ledgers.find_one({
                "id": item.ledger_id,
                "tenant_id": tenant_id,
                "is_deleted": {"$ne": True}
            })
            if not ledger:
                raise HTTPException(status_code=400, detail=f"Ledger not found: {item.ledger_id}")
    
    # Generate voucher number
    voucher_number, sequence = await generate_voucher_number(tenant_id, voucher.voucher_type)
    
    voucher_id = str(uuid.uuid4())
    now = datetime.now(timezone.utc).isoformat()
    
    new_voucher = {
        "id": voucher_id,
        "tenant_id": tenant_id,
        "voucher_number": voucher_number,
        "voucher_type": voucher.voucher_type,
        "voucher_type_name": VOUCHER_TYPES[voucher.voucher_type]["name"],
        "sequence": sequence,
        "date": voucher.date,
        "line_items": [item.dict() for item in voucher.line_items],
        "total_debit": total_debit,
        "total_credit": total_credit,
        "narration": voucher.narration,
        "reference_number": voucher.reference_number,
        "reference_date": voucher.reference_date,
        "reference_doc_type": voucher.reference_doc_type,
        "reference_doc_id": voucher.reference_doc_id,
        # GST fields (for Sales/Purchase vouchers)
        "party_gstin": voucher.party_gstin if voucher.voucher_type in ["sales", "purchase"] else "",
        "place_of_supply": voucher.place_of_supply if voucher.voucher_type in ["sales", "purchase"] else "",
        "supply_type": voucher.supply_type if voucher.voucher_type in ["sales", "purchase"] else "",
        "status": "pending",  # All vouchers start as pending
        "created_by": user.get("id"),
        "created_by_name": user.get("name", user.get("email", "")),
        "created_at": now,
        "updated_at": now,
        "is_deleted": False,
        "posted_to_ledger": False
    }
    
    await db.vouchers.insert_one(new_voucher)
    new_voucher.pop("_id", None)
    
    logger.info(f"Voucher created: {voucher_number} ({voucher.voucher_type}) - Status: pending")
    
    return {"message": "Voucher created successfully", "voucher": new_voucher}


@api_router.put("/accounting-vouchers/{voucher_id}")
async def update_accounting_voucher(voucher_id: str, voucher: VoucherCreate, user: dict = Depends(require_permission("ledger"))):
    """Update a pending accounting voucher"""
    tenant_id = get_tenant_id(user)
    
    existing = await db.vouchers.find_one({
        "id": voucher_id,
        "tenant_id": tenant_id,
        "is_deleted": {"$ne": True}
    })
    
    if not existing:
        raise HTTPException(status_code=404, detail="Voucher not found")
    
    if existing.get("status") != "pending":
        raise HTTPException(status_code=400, detail="Can only edit pending vouchers")
    
    # Validate debit = credit
    total_debit = sum(item.debit for item in voucher.line_items)
    total_credit = sum(item.credit for item in voucher.line_items)
    
    if abs(total_debit - total_credit) > 0.01:
        raise HTTPException(status_code=400, detail=f"Debit ({total_debit}) must equal Credit ({total_credit})")
    
    update_data = {
        "voucher_type": voucher.voucher_type,
        "voucher_type_name": VOUCHER_TYPES.get(voucher.voucher_type, {}).get("name", ""),
        "date": voucher.date,
        "line_items": [item.dict() for item in voucher.line_items],
        "total_debit": total_debit,
        "total_credit": total_credit,
        "narration": voucher.narration,
        "reference_number": voucher.reference_number,
        "reference_date": voucher.reference_date,
        "updated_at": datetime.now(timezone.utc).isoformat()
    }
    
    await db.vouchers.update_one(
        {"id": voucher_id, "tenant_id": tenant_id},
        {"$set": update_data}
    )
    
    return {"message": "Voucher updated successfully"}


