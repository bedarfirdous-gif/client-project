@api_router.post("/accounting-vouchers/{voucher_id}/approve")
async def approve_accounting_voucher(voucher_id: str, user: dict = Depends(require_permission("ledger"))):
    """Approve a pending accounting voucher and post to ledgers"""
    tenant_id = get_tenant_id(user)
    
    voucher = await db.vouchers.find_one({
        "id": voucher_id,
        "tenant_id": tenant_id,
        "is_deleted": {"$ne": True}
    })
    
    if not voucher:
        raise HTTPException(status_code=404, detail="Voucher not found")
    
    if voucher.get("status") != "pending":
        raise HTTPException(status_code=400, detail=f"Voucher is already {voucher.get('status')}")
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Post to ledger transactions
    for item in voucher.get("line_items", []):
        transaction = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "ledger_id": item.get("ledger_id"),
            "date": voucher.get("date"),
            "particulars": item.get("narration") or voucher.get("narration", ""),
            "voucher_type": voucher.get("voucher_type_name"),
            "voucher_number": voucher.get("voucher_number"),
            "voucher_id": voucher_id,
            "debit": item.get("debit", 0),
            "credit": item.get("credit", 0),
            "narration": voucher.get("narration", ""),
            "created_by": user.get("id"),
            "created_at": now
        }
        await db.ledger_transactions.insert_one(transaction)
    
    # Update voucher status
    await db.vouchers.update_one(
        {"id": voucher_id, "tenant_id": tenant_id},
        {"$set": {
            "status": "approved",
            "approved_by": user.get("id"),
            "approved_by_name": user.get("name", user.get("email", "")),
            "approved_at": now,
            "posted_to_ledger": True,
            "updated_at": now
        }}
    )
    
    # Record approval
    await db.voucher_approvals.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "voucher_id": voucher_id,
        "action": "approved",
        "user_id": user.get("id"),
        "user_name": user.get("name", user.get("email", "")),
        "remarks": "",
        "created_at": now
    })
    
    logger.info(f"Voucher approved: {voucher.get('voucher_number')} by {user.get('email')}")
    
    return {"message": "Voucher approved and posted to ledgers"}


