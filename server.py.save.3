class CheckoutItem(BaseModel):
    item_id: str
    variant_id: Optional[str] = None
    name: str
    size: Optional[str] = None
    color: Optional[str] = None
    price: float
    quantity: int = 1

class CheckoutRequest(BaseModel):
    tenant_id: str
    customer_name: str
    customer_phone: str
    customer_email: Optional[str] = ""
    shipping_address: Optional[str] = ""
    items: List[CheckoutItem]
    payment_method: str = "cod"  # cod, online, upi
    notes: Optional[str] = ""

@api_router.post("/public/checkout")
async def public_checkout(checkout: CheckoutRequest):
    """
    Public checkout endpoint for e-commerce orders.
    Creates a sales order that can be processed by the store admin.
    """
    try:
        # Validate tenant exists
        tenant = await db.tenants.find_one({"id": checkout.tenant_id})
        if not tenant:
            # Try finding by user_id
            user = await db.users.find_one({"id": checkout.tenant_id})
            if user:
                checkout.tenant_id = user.get("tenant_id", checkout.tenant_id)
        
        # Calculate totals
        subtotal = sum(item.price * item.quantity for item in checkout.items)
        tax_amount = subtotal * 0.18  # Default 18% GST
        total = subtotal + tax_amount
        
        # Generate order number
        order_count = await db.ecommerce_orders.count_documents({"tenant_id": checkout.tenant_id})
        order_number = f"ORD-{order_count + 1:05d}"
        
        # Create order
        order = {
            "id": str(uuid.uuid4()),
            "order_number": order_number,
            "tenant_id": checkout.tenant_id,
            "customer": {
                "name": checkout.customer_name,
                "phone": checkout.customer_phone,
                "email": checkout.customer_email,
                "shipping_address": checkout.shipping_address
            },
            "items": [item.dict() for item in checkout.items],
            "subtotal": subtotal,
            "tax_amount": tax_amount,
            "total": total,
            "payment_method": checkout.payment_method,
            "payment_status": "pending",
            "order_status": "pending",
            "notes": checkout.notes,
            "source": "ecommerce",
            "created_at": datetime.now(timezone.utc).isoformat(),
            "updated_at": datetime.now(timezone.utc).isoformat()
        }
        
        await db.ecommerce_orders.insert_one(order)
        
        # Return order confirmation (exclude _id)
        order.pop("_id", None)
        
        return {
            "success": True,
            "message": "Order placed successfully",
            "order": {
                "id": order["id"],
                "order_number": order["order_number"],
                "total": total,
                "payment_method": checkout.payment_method,
                "status": "pending"
            }
        }
        
    except Exception as e:
        logger.error(f"Checkout error: {str(e)}")
        raise HTTPException(status_code=500, detail=f"Failed to process order: {str(e)}")


