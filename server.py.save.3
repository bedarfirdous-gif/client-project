import socket

class PrinterRequest(BaseModel):
    ip: str
    port: int = 9100
    data: str

@api_router.post("/printer/print")
async def print_to_network_printer(request: PrinterRequest, user: dict = Depends(get_current_user)):
    """Send print data to network thermal printer"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(10)
        sock.connect((request.ip, request.port))
        sock.send(request.data.encode('utf-8'))
        sock.close()
        return {"success": True, "message": "Print job sent"}
    except socket.timeout:
        raise HTTPException(status_code=504, detail="Printer connection timeout")
    except ConnectionRefusedError:
        raise HTTPException(status_code=503, detail="Printer connection refused")
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Print failed: {str(e)}")


