@api_router.put("/employment-agreements/{agreement_id}")
async def update_employment_agreement(
    agreement_id: str, 
    data: dict, 
    user: dict = Depends(get_current_user)
):
    """Update an employment agreement"""
    tenant_id = get_tenant_id(user)
    
    existing = await db.employment_agreements.find_one(
        {"tenant_id": tenant_id, "id": agreement_id}
    )
    
    if not existing:
        raise HTTPException(status_code=404, detail="Agreement not found")
    
    # Don't allow editing if already signed
    if existing.get("status") == "signed":
        raise HTTPException(status_code=400, detail="Cannot edit a signed agreement")
    
    update_data = {k: v for k, v in data.items() if k not in ["id", "tenant_id", "created_at"]}
    update_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    
    await db.employment_agreements.update_one(
        {"tenant_id": tenant_id, "id": agreement_id},
        {"$set": update_data}
    )
    
    return {"message": "Agreement updated successfully"}

