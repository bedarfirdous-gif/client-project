@api_router.get("/billing/estimate-change")
async def estimate_plan_change(
    new_plan: str,
    user: dict = Depends(require_permission("billing"))
):
    """Estimate cost/credit for plan change"""
    tenant_id = get_tenant_id(user)
    
    admin = await db.users.find_one({"tenant_id": tenant_id, "role": "admin"})
    current_plan = admin.get("plan", "free") if admin else "free"
    
    plans = await get_subscription_plans_data()
    if new_plan not in plans:
        raise HTTPException(status_code=400, detail="Invalid plan")
    
    current_price = plans.get(current_plan, {}).get("price", 0)
    new_price = plans[new_plan].get("price", 0)
    
    # Get subscription to calculate remaining days
    subscription = await db.subscriptions.find_one({"tenant_id": tenant_id})
    if subscription and subscription.get("current_period_end"):
        end_date = datetime.fromisoformat(subscription["current_period_end"].replace("Z", "+00:00"))
        days_remaining = max(0, (end_date - datetime.now(timezone.utc)).days)
    else:
        days_remaining = 30
    
    is_upgrade = new_price > current_price
    
    if is_upgrade:
        proration = (new_price - current_price) * (days_remaining / 30)
        message = f"You will be charged ₹{round(proration, 2)} for the remaining {days_remaining} days"
    else:
        credit = (current_price - new_price) * (days_remaining / 30)
        proration = -credit
        message = f"You will receive ₹{round(credit, 2)} credit for the remaining {days_remaining} days"
    
    return {
        "current_plan": current_plan,
        "new_plan": new_plan,
        "current_price": current_price,
        "new_price": new_price,
        "days_remaining": days_remaining,
        "proration_amount": round(proration, 2),
        "is_upgrade": is_upgrade,
        "message": message,
        "new_features": plans[new_plan].get("features", [])
    }

