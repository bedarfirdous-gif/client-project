@api_router.get("/vouchers/validate/{code}")
async def validate_voucher(code: str, amount: float = 0, user: dict = Depends(require_permission("vouchers"))):
    tenant_id = get_tenant_id(user)
    
    voucher = await db.vouchers.find_one({
        "tenant_id": tenant_id,
        "code": code.upper(),
        "active": True
    }, {"_id": 0})
    
    if not voucher:
        raise HTTPException(status_code=404, detail="Invalid voucher code")
    
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    if voucher.get("valid_from", "") > today or voucher.get("valid_until", "") < today:
        raise HTTPException(status_code=400, detail="Voucher expired or not yet valid")
    
    if voucher.get("used_count", 0) >= voucher.get("usage_limit", 1):
        raise HTTPException(status_code=400, detail="Voucher usage limit reached")
    
    if amount < voucher.get("min_purchase", 0):
        raise HTTPException(status_code=400, detail=f"Minimum purchase of ₹{voucher.get('min_purchase')} required")
    
    # Calculate discount based on voucher type
    voucher_type = voucher.get("voucher_type", "gift")
    
    if voucher_type == "tiered":
        # Tiered discount - find applicable tier
        tiers = sorted(voucher.get("tiers", []), key=lambda x: x.get("min_amount", 0), reverse=True)
        discount = 0
        for tier in tiers:
            if amount >= tier.get("min_amount", 0):
                if tier.get("is_percent"):
                    discount = amount * tier.get("discount", 0) / 100
                else:
                    discount = tier.get("discount", 0)
                break
    elif voucher.get("is_percentage"):
        discount = amount * voucher.get("value", 0) / 100
        if voucher.get("max_discount") and discount > voucher.get("max_discount"):
            discount = voucher.get("max_discount")
    else:
        discount = voucher.get("value", 0)
    
    return {**voucher, "calculated_discount": discount}

