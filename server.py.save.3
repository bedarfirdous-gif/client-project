    notes: str = Body(None),
    delivery_date: str = Body(None),
    user: dict = Depends(get_current_user)
):
    """Update online order details - customer info, delivery, notes"""
    order = await db.online_orders.find_one({"id": order_id})
    if not order:
        raise HTTPException(status_code=404, detail="Order not found")
    
    # Only allow editing pending or confirmed orders
    if order.get("status") not in ["pending", "confirmed"]:
        raise HTTPException(status_code=400, detail="Cannot edit order in current status")
    
    update_data = {"updated_at": datetime.now(timezone.utc).isoformat()}
    
    if customer is not None:
        update_data["customer"] = {
            **order.get("customer", {}),
            **customer
        }
    if notes is not None:
        update_data["notes"] = notes
    if delivery_date is not None:
        update_data["delivery_date"] = delivery_date
    
    await db.online_orders.update_one({"id": order_id}, {"$set": update_data})
    
    return {"message": "Order updated successfully"}


