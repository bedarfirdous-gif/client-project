# ============== SMART SCANNER (Legacy/Alternative) ==============

@api_router.post("/smart-scanner/document-v2")
async def scan_document_v2(
    file: UploadFile = File(...),
    store_id: str = Form(None),
    document_type: str = Form("auto"),
    user: dict = Depends(get_current_user)
):
    """Scan a document (invoice, receipt, etc.) using AI to extract items"""
    import base64
    import asyncio
    
    tenant_id = get_tenant_id(user)
    
    # Read file content
    content = await file.read()
    file_extension = file.filename.split('.')[-1].lower() if file.filename else ''
    
    # Check file size (max 10MB)
    if len(content) > 10 * 1024 * 1024:
        raise HTTPException(status_code=400, detail="File too large. Maximum size is 10MB.")
    
    # Check if it's an image or PDF
    supported_formats = ['jpg', 'jpeg', 'png', 'webp', 'gif']
    if file_extension not in supported_formats:
        raise HTTPException(
            status_code=400, 
            detail=f"Please upload an image file (JPG, PNG, WEBP). Supported formats: {', '.join(supported_formats)}"
        )
    
    try:
        # from emergentintegrations.llm.openai import OpenAILLM
        
        EMERGENT_LLM_KEY = os.environ.get("EMERGENT_LLM_KEY")
        if not EMERGENT_LLM_KEY:
            raise HTTPException(status_code=500, detail="AI service not configured")
        
        # Compress image if too large (reduce base64 size)
        if len(content) > 2 * 1024 * 1024:
            # For large images, we'll still process but warn
            print(f"Large image detected: {len(content)} bytes")
        
        # Encode image to base64
        image_base64 = base64.b64encode(content).decode('utf-8')
        
        # Determine mime type
        mime_types = {'jpg': 'jpeg', 'jpeg': 'jpeg', 'png': 'png', 'webp': 'webp', 'gif': 'gif'}
        mime_type = mime_types.get(file_extension, 'jpeg')
        image_url = f"data:image/{mime_type};base64,{image_base64}"
        
        # Optimized prompt for faster extraction
        extraction_prompt = """Extract product items from this invoice/document image.
Return a JSON array with each item having: name, sku, quantity, mrp, selling_price, cost_price, brand, category, size, color, hsn_code, gst_rate.
Use null for missing fields. Only include product items, not totals/taxes.
Return ONLY the JSON array, no explanation."""

        llm = OpenAILLM(api_key=EMERGENT_LLM_KEY)
        
        # Add timeout for the API call
        try:
            response = await asyncio.wait_for(
                llm.generate_response_with_image_async(
                    user_prompt=extraction_prompt,
                    image_url=image_url,
                    model="gpt-5.2",  # Use latest recommended model
                    max_tokens=2000,
                    temperature=0.1
                ),
                timeout=120.0  # 120 second timeout for larger images
            )
        except asyncio.TimeoutError:
            raise HTTPException(status_code=408, detail="AI processing timed out. Please try with a smaller/clearer image.")
        
        # Parse the response
        import json
        import re
        
        # Try to extract JSON from the response
        response_text = response.strip()
        
        # Remove markdown code blocks if present
        if response_text.startswith('```'):
            response_text = re.sub(r'^```(?:json)?\n?', '', response_text)
            response_text = re.sub(r'\n?```$', '', response_text)
        
        try:
            items = json.loads(response_text)
        except json.JSONDecodeError:
            # Try to find JSON array in the response
            json_match = re.search(r'\[[\s\S]*\]', response_text)
            if json_match:
                items = json.loads(json_match.group())
            else:
                items = []
        
        if not isinstance(items, list):
            items = [items] if items else []
        
        # Clean and validate items
        cleaned_items = []
        for item in items:
            if isinstance(item, dict) and item.get('name'):
                cleaned_item = {
                    'name': str(item.get('name', '')).strip(),
                    'sku': str(item.get('sku', '')).strip() if item.get('sku') else '',
                    'quantity': int(item.get('quantity', 1)) if item.get('quantity') else 1,
                    'mrp': float(item.get('mrp', 0)) if item.get('mrp') else 0,
                    'selling_price': float(item.get('selling_price', 0)) if item.get('selling_price') else 0,
                    'cost_price': float(item.get('cost_price', 0)) if item.get('cost_price') else 0,
                    'brand': str(item.get('brand', '')).strip() if item.get('brand') else '',
                    'category': str(item.get('category', '')).strip() if item.get('category') else '',
                    'size': str(item.get('size', '')).strip() if item.get('size') else '',
                    'color': str(item.get('color', '')).strip() if item.get('color') else '',
                    'hsn_code': str(item.get('hsn_code', '')).strip() if item.get('hsn_code') else '',
                    'gst_rate': float(item.get('gst_rate', 0)) if item.get('gst_rate') else 0,
                }
                cleaned_items.append(cleaned_item)
        
        return {
            "success": True,
            "items": cleaned_items,
            "stats": {
                "total_items": len(cleaned_items),
                "document_type": document_type,
                "filename": file.filename
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        error_msg = str(e)
        print(f"AI document scan error: {error_msg}")
        
        # Provide user-friendly error messages
        if "502" in error_msg or "BadGateway" in error_msg:
            raise HTTPException(
                status_code=503, 
                detail="AI service is temporarily busy. Please try again in a few seconds."
            )
        elif "rate" in error_msg.lower() or "limit" in error_msg.lower():
            raise HTTPException(
                status_code=429, 
                detail="Too many requests. Please wait a moment and try again."
            )
        elif "timeout" in error_msg.lower():
            raise HTTPException(
                status_code=408, 
                detail="Request timed out. Please try with a smaller or clearer image."
            )
        else:
            raise HTTPException(
                status_code=500, 
                detail="Failed to analyze document. Please try again or use a different image."
            )


