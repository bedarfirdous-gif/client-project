@api_router.get("/ecommerce/business-customers")
async def list_business_customers(
    user: dict = Depends(get_current_user),
    status: Optional[str] = Query(None),
    business_type: Optional[str] = Query(None),
    search: Optional[str] = Query(None),
    skip: int = Query(0, ge=0),
    limit: int = Query(50, le=200)
):
    """List all business customers"""
    tenant_id = get_tenant_id(user)
    
    query = {"tenant_id": tenant_id}
    
    if status:
        query["status"] = status
    
    if business_type:
        query["business_type"] = business_type
    
    if search:
        query["$or"] = [
            {"business_name": {"$regex": search, "$options": "i"}},
            {"contact_name": {"$regex": search, "$options": "i"}},
            {"email": {"$regex": search, "$options": "i"}},
            {"phone": {"$regex": search, "$options": "i"}}
        ]
    
    customers = await db.business_customers.find(query, {"_id": 0}).sort("created_at", -1).skip(skip).limit(limit).to_list(limit)
    total = await db.business_customers.count_documents(query)
    
    # Get stats
    stats = {
        "total": total,
        "active": await db.business_customers.count_documents({"tenant_id": tenant_id, "status": "active"}),
        "pending": await db.business_customers.count_documents({"tenant_id": tenant_id, "status": "pending"}),
        "total_credit_utilized": 0
    }
    
    # Calculate total credit utilized
    credit_pipeline = [
        {"$match": {"tenant_id": tenant_id}},
        {"$group": {"_id": None, "total": {"$sum": "$credit_utilized"}}}
    ]
    credit_result = await db.business_customers.aggregate(credit_pipeline).to_list(1)
    if credit_result:
        stats["total_credit_utilized"] = credit_result[0].get("total", 0)
    
    return {
        "customers": customers,
        "total": total,
        "stats": stats
    }


