@api_router.get("/size-prediction/analytics")
async def get_size_analytics(user: dict = Depends(get_current_user)):
    """Get size analytics for better inventory planning"""
    tenant_id = get_tenant_id(user)
    
    # Aggregate size distribution from sales
    pipeline = [
        {"$match": {"tenant_id": tenant_id}},
        {"$unwind": "$items"},
        {"$group": {
            "_id": "$items.size",
            "count": {"$sum": "$items.quantity"},
            "revenue": {"$sum": {"$multiply": ["$items.price", "$items.quantity"]}}
        }},
        {"$sort": {"count": -1}}
    ]
    
    size_stats = await db.sales.aggregate(pipeline).to_list(20)
    
    # Get return rates by size
    return_pipeline = [
        {"$match": {"tenant_id": tenant_id}},
        {"$unwind": "$items"},
        {"$group": {
            "_id": "$items.size",
            "return_count": {"$sum": 1}
        }}
    ]
    
    return_stats = await db.returns.aggregate(return_pipeline).to_list(20)
    return_map = {r["_id"]: r["return_count"] for r in return_stats}
    
    # Calculate return rates
    for stat in size_stats:
        size = stat["_id"]
        returns = return_map.get(size, 0)
        stat["returns"] = returns
        stat["return_rate"] = round((returns / stat["count"] * 100), 1) if stat["count"] > 0 else 0
    
    # Get most popular sizes by category
    category_pipeline = [
        {"$match": {"tenant_id": tenant_id}},
        {"$unwind": "$items"},
        {"$group": {
            "_id": {"category": "$items.category", "size": "$items.size"},
            "count": {"$sum": "$items.quantity"}
        }},
        {"$sort": {"count": -1}}
    ]
    
    category_sizes = await db.sales.aggregate(category_pipeline).to_list(100)
    
    # Organize by category
    by_category = {}
    for item in category_sizes:
        cat = item["_id"].get("category") or "general"
        size = item["_id"].get("size")
        if size:
            if cat not in by_category:
                by_category[cat] = []
            by_category[cat].append({"size": size, "count": item["count"]})
    
    return {
        "overall_size_distribution": size_stats,
        "by_category": by_category,
        "recommendations": [
            "Stock more of top 3 selling sizes",
            "Review sizing for items with >15% return rate",
            "Consider expanding size range if XS or XXXL shows demand"
        ]
    }


