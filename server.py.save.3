# Helper function to get available modules for a plan
def get_modules_for_plan(plan: str) -> Dict[str, Any]:
    """Get all modules available for a specific plan"""
    result = {}
    for category_key, category in MODULE_CATEGORIES.items():
        modules = {}
        for module_key, module in category["modules"].items():
            if plan in module["plans"]:
                modules[module_key] = {
                    **module,
                    "enabled": True,
                    "available": True
                }
            else:
                modules[module_key] = {
                    **module,
                    "enabled": False,
                    "available": False,
                    "upgrade_required": True
                }
        if modules:
            result[category_key] = {
                "name": category["name"],
                "icon": category["icon"],
                "modules": modules
            }
    return result

