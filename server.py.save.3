# Super Admin: Get admins needing upgrades (80%+ usage)
@api_router.get("/superadmin/admins-needing-upgrades")
async def get_admins_needing_upgrades(
    user: dict = Depends(require_superadmin)
):
    """Get admins who have exceeded or are approaching their plan limits"""
    
    # Get all admin users
    admins = await db.users.find(
        {"role": "admin"},
        {"_id": 0, "password": 0}
    ).to_list(10000)
    
    admins_needing_upgrade = []
    
    for admin in admins:
        tenant_id = admin.get("tenant_id")
        if not tenant_id or tenant_id == "superadmin":
            continue
        
        # Get current plan
        subscription = await db.subscriptions.find_one(
            {"tenant_id": tenant_id, "status": {"$in": ["active", "trialing"]}},
            {"_id": 0}
        )
        
        plan_id = subscription.get("plan", "free") if subscription else "free"
        plan_limits = SUBSCRIPTION_PLANS.get(plan_id, SUBSCRIPTION_PLANS["free"])["limits"]
        
        # Calculate current usage
        stores_count = await db.stores.count_documents({"tenant_id": tenant_id})
        products_count = await db.items.count_documents({"tenant_id": tenant_id})
        users_count = await db.users.count_documents({"tenant_id": tenant_id})
        customers_count = await db.customers.count_documents({"tenant_id": tenant_id})
        
        # Sales this month
        month_start = datetime.now(timezone.utc).replace(day=1, hour=0, minute=0, second=0, microsecond=0)
        sales_this_month = await db.sales.count_documents({
            "tenant_id": tenant_id,
            "created_at": {"$gte": month_start.isoformat()}
        })
        
        # Check if any limit is exceeded or at 80%+
        usage_alerts = []
        exceeded_count = 0
        warning_count = 0
        
        def check_limit(name, current, limit):
            nonlocal exceeded_count, warning_count
            if limit == -1:  # Unlimited
                return None
            percentage = (current / limit * 100) if limit > 0 else 0
            if current > limit:
                exceeded_count += 1
                return {"metric": name, "current": current, "limit": limit, "percentage": min(percentage, 100), "status": "exceeded"}
            elif percentage >= 80:
                warning_count += 1
                return {"metric": name, "current": current, "limit": limit, "percentage": percentage, "status": "warning"}
            return None
        
        alerts = [
            check_limit("Stores", stores_count, plan_limits["stores"]),
            check_limit("Products", products_count, plan_limits["products"]),
            check_limit("Users", users_count, plan_limits["users"]),
            check_limit("Customers", customers_count, plan_limits["customers"]),
            check_limit("Sales/Month", sales_this_month, plan_limits["sales_per_month"])
        ]
        
        usage_alerts = [a for a in alerts if a is not None]
        
        # Only include admins with warnings or exceeded limits
        if usage_alerts:
            # Determine recommended plan
            recommended_plan = None
            if plan_id == "free":
                recommended_plan = "basic"
            elif plan_id == "basic":
                recommended_plan = "pro"
            elif plan_id == "pro":
                recommended_plan = "enterprise"
            
            admins_needing_upgrade.append({
                "admin_id": admin.get("id"),
                "admin_name": admin.get("name"),
                "admin_email": admin.get("email"),
                "business_name": admin.get("business_name"),
                "current_plan": plan_id,
                "current_plan_name": SUBSCRIPTION_PLANS.get(plan_id, {}).get("name", "Free"),
                "recommended_plan": recommended_plan,
                "recommended_plan_name": SUBSCRIPTION_PLANS.get(recommended_plan, {}).get("name") if recommended_plan else None,
                "recommended_plan_price": SUBSCRIPTION_PLANS.get(recommended_plan, {}).get("price") if recommended_plan else None,
                "exceeded_count": exceeded_count,
                "warning_count": warning_count,
                "usage_alerts": usage_alerts,
                "urgency": "critical" if exceeded_count > 0 else "warning",
                "last_login": admin.get("last_login"),
                "created_at": admin.get("created_at")
            })
    
    # Sort by urgency (critical first) then by exceeded count
    admins_needing_upgrade.sort(key=lambda x: (-1 if x["urgency"] == "critical" else 0, -x["exceeded_count"], -x["warning_count"]))
    
    # Calculate summary
    critical_count = len([a for a in admins_needing_upgrade if a["urgency"] == "critical"])
    warning_count = len([a for a in admins_needing_upgrade if a["urgency"] == "warning"])
    
    # Potential revenue if all upgrade
    potential_revenue = sum(
        (SUBSCRIPTION_PLANS.get(a["recommended_plan"], {}).get("price", 0) - SUBSCRIPTION_PLANS.get(a["current_plan"], {}).get("price", 0))
        for a in admins_needing_upgrade if a["recommended_plan"]
    )
    
    return {
        "summary": {
            "total_needing_upgrade": len(admins_needing_upgrade),
            "critical": critical_count,
            "warning": warning_count,
            "potential_monthly_revenue": potential_revenue
        },
        "admins": admins_needing_upgrade
    }

# Super Admin: Change admin plan
@api_router.put("/superadmin/admins/{admin_id}/plan")
async def change_admin_plan(
    admin_id: str,
    plan_id: str = Body(..., embed=True),
    user: dict = Depends(require_superadmin)
):
    """Manually change an admin's subscription plan"""
    
    if plan_id not in SUBSCRIPTION_PLANS:
        raise HTTPException(status_code=400, detail="Invalid plan")
    
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    tenant_id = admin.get("tenant_id")
    now = datetime.now(timezone.utc)
    
    # Deactivate old subscription
    await db.subscriptions.update_many(
        {"tenant_id": tenant_id, "status": "active"},
        {"$set": {"status": "cancelled", "cancelled_at": now.isoformat()}}
    )
    
    # Create new subscription
    await db.subscriptions.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "plan": plan_id,
        "status": "active",
        "manually_set_by": user.get("id"),
        "current_period_start": now.isoformat(),
        "current_period_end": (now + timedelta(days=30)).isoformat(),
        "created_at": now.isoformat()
    })
    
    # Update admin with both plan and subscription_plan for compatibility
    await db.users.update_one(
        {"id": admin_id},
        {"$set": {"plan": plan_id, "subscription_plan": plan_id, "plan_updated_at": now.isoformat()}}
    )
    
    # Audit log
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "plan_changed",
        "admin_id": admin_id,
        "admin_email": admin.get("email"),
        "new_plan": plan_id,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now.isoformat()
    })
    
    return {"message": f"Plan changed to {SUBSCRIPTION_PLANS[plan_id]['name']}", "plan": plan_id}



