@api_router.post("/accounting/receipts")
async def create_receipt(
    customer_id: str = Body(...),
    amount: float = Body(...),
    payment_mode: str = Body("cash"),
    invoice_id: str = Body(None),
    notes: str = Body(""),
    date: str = Body(None),
    user: dict = Depends(get_current_user)
):
    """Record a receipt (money received from customer)"""
    tenant_id = get_tenant_id(user)
    
    # Get customer details
    customer = await db.customers.find_one({"id": customer_id, "tenant_id": tenant_id}, {"_id": 0, "name": 1})
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    receipt_id = str(uuid.uuid4())
    receipt_date = date or datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    # Generate receipt number
    count = await db.central_ledger.count_documents({"tenant_id": tenant_id, "entry_type": "receipt"})
    receipt_number = f"RCP-{datetime.now().strftime('%y%m')}-{count+1:04d}"
    
    # Process receipt accounting
    await process_receipt_accounting(
        tenant_id=tenant_id,
        receipt_id=receipt_id,
        receipt_number=receipt_number,
        customer_id=customer_id,
        customer_name=customer.get("name"),
        amount=amount,
        payment_mode=payment_mode,
        date=receipt_date,
        invoice_id=invoice_id
    )
    
    # If invoice_id provided, update invoice payment status
    if invoice_id:
        invoice = await db.invoices.find_one({"id": invoice_id})
        if invoice:
            new_paid = (invoice.get("amount_paid", 0) or 0) + amount
            new_balance = max(0, (invoice.get("total_amount", 0) or 0) - new_paid)
            status = "paid" if new_balance <= 0 else "partial"
            
            await db.invoices.update_one(
                {"id": invoice_id},
                {"$set": {
                    "amount_paid": new_paid,
                    "balance_due": new_balance,
                    "payment_status": status,
                    "updated_at": datetime.now(timezone.utc).isoformat()
                }}
            )
    
    return {
        "id": receipt_id,
        "receipt_number": receipt_number,
        "customer_id": customer_id,
        "customer_name": customer.get("name"),
        "amount": amount,
        "payment_mode": payment_mode,
        "date": receipt_date,
        "message": "Receipt recorded successfully"
    }

