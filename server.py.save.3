@api_router.post("/stock-receiver/receive")
async def receive_stock_at_store(request: dict, user: dict = Depends(get_current_user)):
    """
    Receive stock transfer and update inventory at receiving store.
    This creates/updates inventory records at the destination store.
    """
    tenant_id = get_tenant_id(user)
    transfer_id = request.get("transfer_id")
    received_items = request.get("items", [])
    notes = request.get("notes", "")
    
    if not transfer_id:
        raise HTTPException(status_code=400, detail="Transfer ID is required")
    
    # Get the transfer
    transfer = await db.stock_transfers.find_one(
        {"id": transfer_id, "tenant_id": tenant_id},
        {"_id": 0}
    )
    
    if not transfer:
        raise HTTPException(status_code=404, detail="Transfer not found")
    
    if transfer.get("status") in ["received", "completed"]:
        raise HTTPException(status_code=400, detail="Transfer has already been received")
    
    to_store_id = transfer.get("to_store_id")
    from_store_id = transfer.get("from_store_id")
    
    # Process each received item
    inventory_updates = []
    items_created = []
    
    for item in received_items:
        item_id = item.get("item_id")
        item_name = item.get("item_name")
        variant_id = item.get("variant_id")
        received_qty = item.get("received_quantity", 0)
        damaged_qty = item.get("damaged_quantity", 0)
        
        if received_qty <= 0:
            continue
        
        # Check if item exists in items collection, if not create it
        existing_item = await db.items.find_one({"id": item_id, "tenant_id": tenant_id})
        if not existing_item and item_name:
            # Create the item
            new_item = {
                "id": item_id or str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "name": item_name,
                "sku": item_name.upper().replace(" ", "-")[:20],
                "description": "",
                "selling_price": 0,
                "cost_price": 0,
                "active": True,
                "created_at": datetime.now(timezone.utc).isoformat(),
                "created_by_transfer": transfer_id
            }
            await db.items.insert_one(new_item)
            items_created.append(item_name)
            item_id = new_item["id"]
        
        # Update or create inventory record at destination store
        existing_inventory = await db.inventory.find_one({
            "tenant_id": tenant_id,
            "store_id": to_store_id,
            "item_id": item_id
        })
        
        if existing_inventory:
            # Update existing inventory
            new_qty = existing_inventory.get("quantity", 0) + received_qty
            await db.inventory.update_one(
                {"id": existing_inventory["id"]},
                {"$set": {
                    "quantity": new_qty,
                    "current_stock": new_qty,
                    "last_updated": datetime.now(timezone.utc).isoformat(),
                    "last_transfer_id": transfer_id
                }}
            )
        else:
            # Create new inventory record
            new_inventory = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "store_id": to_store_id,
                "item_id": item_id,
                "item_name": item_name,
                "variant_id": variant_id,
                "quantity": received_qty,
                "current_stock": received_qty,
                "created_at": datetime.now(timezone.utc).isoformat(),
                "created_by_transfer": transfer_id
            }
            await db.inventory.insert_one(new_inventory)
        
        inventory_updates.append({
            "item_id": item_id,
            "item_name": item_name,
            "quantity_added": received_qty,
            "store_id": to_store_id
        })
        
        # Optionally: Reduce stock at source store
        source_inventory = await db.inventory.find_one({
            "tenant_id": tenant_id,
            "store_id": from_store_id,
            "item_id": item_id
        })
        if source_inventory:
            new_source_qty = max(0, source_inventory.get("quantity", 0) - received_qty)
            await db.inventory.update_one(
                {"id": source_inventory["id"]},
                {"$set": {
                    "quantity": new_source_qty,
                    "current_stock": new_source_qty,
                    "last_updated": datetime.now(timezone.utc).isoformat()
                }}
            )
    
    # Update transfer status
    await db.stock_transfers.update_one(
        {"id": transfer_id},
        {"$set": {
            "status": "received",
            "received_by": user.get("name"),
            "received_by_id": user.get("id"),
            "received_at": datetime.now(timezone.utc).isoformat(),
            "items": received_items,
            "receiver_notes": notes,
            "inventory_updated": True
        }}
    )
    
    # Create stock movement record for audit
    movement_record = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "transfer_id": transfer_id,
        "type": "transfer_received",
        "from_store_id": from_store_id,
        "to_store_id": to_store_id,
        "items": inventory_updates,
        "received_by": user.get("name"),
        "received_at": datetime.now(timezone.utc).isoformat(),
        "notes": notes
    }
    await db.stock_movements.insert_one(movement_record)
    
    return {
        "message": "Stock received successfully",
        "inventory_updated": len(inventory_updates),
        "items_created": len(items_created),
        "transfer_status": "received"
    }


