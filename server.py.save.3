async def get_gmb_credentials(tenant_id: str, store_id: str):
    """Get and refresh GMB credentials for a store"""
    connection = await db.gmb_connections.find_one(
        {"tenant_id": tenant_id, "store_id": store_id}
    )
    
    if not connection:
        return None
    
    # Create credentials object
    credentials = Credentials(
        token=connection.get("access_token"),
        refresh_token=connection.get("refresh_token"),
        token_uri="https://oauth2.googleapis.com/token",
        client_id=GOOGLE_CLIENT_ID,
        client_secret=GOOGLE_CLIENT_SECRET,
        scopes=GOOGLE_SCOPES
    )
    
    # Refresh if expired
    if credentials.expired and credentials.refresh_token:
        from google.auth.transport.requests import Request
        credentials.refresh(Request())
        
        # Update stored tokens
        await db.gmb_connections.update_one(
            {"tenant_id": tenant_id, "store_id": store_id},
            {"$set": {
                "access_token": credentials.token,
                "token_expiry": credentials.expiry.isoformat() if credentials.expiry else None
            }}
        )
    
    return credentials

@api_router.get("/gmb/reviews/{store_id}")
async def get_gmb_reviews(
    store_id: str,
    user: dict = Depends(get_current_user)
):
    """Fetch real Google reviews for a store"""
    tenant_id = get_tenant_id(user)
    
    credentials = await get_gmb_credentials(tenant_id, store_id)
    if not credentials:
        raise HTTPException(status_code=400, detail="Store not connected to Google My Business")
    
    connection = await db.gmb_connections.find_one(
        {"tenant_id": tenant_id, "store_id": store_id}
    )
    
    gmb_locations = connection.get("gmb_locations", [])
    if not gmb_locations:
        return {"reviews": [], "message": "No GMB locations found"}
    
    try:
        # Build reviews service
        http = credentials.authorize(httplib2.Http())
        reviews_service = build('mybusiness', 'v4', credentials=credentials, http=http,
                                discoveryServiceUrl='https://mybusiness.googleapis.com/$discovery/rest?version=v4')
        
        all_reviews = []
        for location in gmb_locations:
            try:
                reviews_response = reviews_service.accounts().locations().reviews().list(
                    parent=location.get('name')
                ).execute()
                
                reviews = reviews_response.get('reviews', [])
                for review in reviews:
                    all_reviews.append({
                        "id": review.get("reviewId"),
                        "location_name": location.get("title"),
                        "author": review.get("reviewer", {}).get("displayName", "Anonymous"),
                        "author_photo": review.get("reviewer", {}).get("profilePhotoUrl"),
                        "rating": review.get("starRating", "").replace("_", " ").title(),
                        "rating_num": {"ONE": 1, "TWO": 2, "THREE": 3, "FOUR": 4, "FIVE": 5}.get(review.get("starRating"), 0),
                        "text": review.get("comment", ""),
                        "date": review.get("createTime", ""),
                        "reply": review.get("reviewReply", {}).get("comment"),
                        "reply_date": review.get("reviewReply", {}).get("updateTime"),
                        "replied": bool(review.get("reviewReply"))
                    })
            except Exception as loc_err:
                print(f"Error fetching reviews for location {location.get('name')}: {loc_err}")
        
        # Cache reviews in database
        await db.gmb_reviews.update_one(
            {"tenant_id": tenant_id, "store_id": store_id},
            {"$set": {
                "reviews": all_reviews,
                "fetched_at": datetime.now(timezone.utc).isoformat()
            }},
            upsert=True
        )
        
        return {"reviews": all_reviews, "count": len(all_reviews)}
        
    except Exception as e:
        # Return cached reviews if available
        cached = await db.gmb_reviews.find_one(
            {"tenant_id": tenant_id, "store_id": store_id},
            {"_id": 0}
        )
        if cached:
            return {
                "reviews": cached.get("reviews", []),
                "count": len(cached.get("reviews", [])),
                "cached": True,
                "fetched_at": cached.get("fetched_at")
            }
        
        raise HTTPException(status_code=500, detail=f"Failed to fetch reviews: {str(e)}")

