@api_router.put("/stock-transfers/{transfer_id}/approve")
async def approve_stock_transfer(transfer_id: str, user: dict = Depends(get_current_user)):
    transfer = await db.stock_transfers.find_one({"id": transfer_id})
    if not transfer:
        raise HTTPException(status_code=404, detail="Transfer not found")
    
    low_stock_alerts = []
    tenant_id = transfer.get("tenant_id")
    
    # Get store names for audit trail
    from_store = await db.stores.find_one({"id": transfer.get("from_store_id")}, {"_id": 0})
    to_store = await db.stores.find_one({"id": transfer.get("to_store_id")}, {"_id": 0})
    from_store_name = from_store.get("name") if from_store else None
    to_store_name = to_store.get("name") if to_store else None
    
    # Process inventory changes
    for item in transfer.get("items", []):
        variant_id = item.get("variant_id")
        quantity = item.get("quantity", 0)
        item_id = item.get("item_id")
        item_name = item.get("name")
        
        # If variant_id is not provided, get default variant from item
        if not variant_id and item_id:
            variant = await db.variants.find_one({"item_id": item_id, "tenant_id": tenant_id})
            if variant:
                variant_id = variant.get("id")
                if not item_name:
                    item_doc = await db.items.find_one({"id": item_id}, {"name": 1})
                    item_name = item_doc.get("name") if item_doc else None
        
        if not variant_id:
            logger.warning(f"Skipping transfer item - no variant found for item {item_id}")
            continue
        
        # Get source inventory before update
        source_inv_before = await db.inventory.find_one({
            "variant_id": variant_id, 
            "store_id": transfer.get("from_store_id")
        })
        source_qty_before = source_inv_before.get("quantity", 0) if source_inv_before else 0
        
        # Decrease from source in BOTH inventory and central_stock
        source_inv_result = await db.inventory.find_one_and_update(
            {"variant_id": variant_id, "store_id": transfer.get("from_store_id")},
            {"$inc": {"quantity": -quantity}},
            return_document=True
        )
        
        # Also update central_stock (PRIMARY source)
        await db.central_stock.update_one(
            {"variant_id": variant_id, "warehouse_id": transfer.get("from_store_id"), "tenant_id": tenant_id},
            {"$inc": {"quantity": -quantity}, "$set": {"updated_at": datetime.now(timezone.utc).isoformat()}},
            upsert=False
        )
        
        # Log transfer_out from source store
        await log_stock_movement(
            tenant_id=tenant_id,
            item_id=item_id,
            variant_id=variant_id,
            store_id=transfer.get("from_store_id"),
            movement_type="transfer_out",
            quantity_change=-quantity,
            quantity_before=source_qty_before,
            quantity_after=source_qty_before - quantity,
            user_id=user.get("id"),
            user_name=user.get("name"),
            reference_type="stock_transfer",
            reference_id=transfer_id,
            notes=f"Transfer to {to_store_name}",
            item_name=item_name,
            store_name=from_store_name
        )
        
        # Check if source store stock is now below minimum
        if source_inv_result and item_id:
            # Get item to check min_stock_alert
            item_doc = await db.items.find_one({"id": item_id})
            if item_doc:
                min_stock = item_doc.get("min_stock_alert", 5)
                new_qty = source_inv_result.get("quantity", 0)
                
                if new_qty <= min_stock:
                    # Get store name for alert
                    source_store = await db.stores.find_one({"id": transfer.get("from_store_id")})
                    source_store_name = source_store.get("name", "Unknown Store") if source_store else "Unknown Store"
                    
                    # Get variant details
                    variant_doc = await db.variants.find_one({"id": variant_id})
                    variant_info = ""
                    if variant_doc:
                        size = variant_doc.get("size", "")
                        color = variant_doc.get("color", "")
                        variant_info = f" ({size}/{color})" if size or color else ""
                    
                    low_stock_alerts.append({
                        "item_name": item_doc.get("name", "Unknown Item") + variant_info,
                        "store_name": source_store_name,
                        "current_qty": new_qty,
                        "min_stock": min_stock
                    })
        
        # Increase at destination
        existing = await db.inventory.find_one({
            "variant_id": variant_id,
            "store_id": transfer.get("to_store_id")
        })
        
        dest_qty_before = existing.get("quantity", 0) if existing else 0
        
        # Get item_id from variant if not in transfer item
        actual_item_id = item_id
        if not actual_item_id and variant_id:
            variant_doc = await db.variants.find_one({"id": variant_id})
            if variant_doc:
                actual_item_id = variant_doc.get("item_id")
        
        if existing:
            # Also update item_id if it's missing
            update_data = {"$inc": {"quantity": quantity}}
            if not existing.get("item_id") and actual_item_id:
                update_data["$set"] = {"item_id": actual_item_id}
            await db.inventory.update_one(
                {"id": existing["id"]},
                update_data
            )
        else:
            variant = await db.variants.find_one({"id": variant_id})
            inv_doc = {
                "id": str(uuid.uuid4()),
                "tenant_id": transfer.get("tenant_id"),
                "variant_id": variant_id,
                "item_id": actual_item_id or (variant.get("item_id") if variant else None),
                "store_id": transfer.get("to_store_id"),
                "quantity": quantity,
                "purchase_rate": variant.get("purchase_rate", 0) if variant else 0,
                "created_at": datetime.now(timezone.utc).isoformat()
            }
            await db.inventory.insert_one(inv_doc)
        
        # Also update/create central_stock for destination (PRIMARY source)
        existing_cs = await db.central_stock.find_one({
            "variant_id": variant_id,
            "warehouse_id": transfer.get("to_store_id"),
            "tenant_id": tenant_id
        })
        
        if existing_cs:
            await db.central_stock.update_one(
                {"id": existing_cs["id"]},
                {"$inc": {"quantity": quantity}, "$set": {"updated_at": datetime.now(timezone.utc).isoformat()}}
            )
        else:
            # Create new central_stock record for destination
            cs_doc = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "item_id": actual_item_id,
                "variant_id": variant_id,
                "warehouse_id": transfer.get("to_store_id"),
                "quantity": quantity,
                "created_at": datetime.now(timezone.utc).isoformat(),
                "updated_at": datetime.now(timezone.utc).isoformat()
            }
            await db.central_stock.insert_one(cs_doc)
        
        # Log transfer_in to destination store
        await log_stock_movement(
            tenant_id=tenant_id,
            item_id=item_id,
            variant_id=variant_id,
            store_id=transfer.get("to_store_id"),
            movement_type="transfer_in",
            quantity_change=quantity,
            quantity_before=dest_qty_before,
            quantity_after=dest_qty_before + quantity,
            user_id=user.get("id"),
            user_name=user.get("name"),
            reference_type="stock_transfer",
            reference_id=transfer_id,
            notes=f"Transfer from {from_store_name}",
            item_name=item_name,
            store_name=to_store_name
        )
    
    # Create stock alerts if any items are below minimum
    if low_stock_alerts:
        for alert in low_stock_alerts:
            alert_doc = {
                "id": str(uuid.uuid4()),
                "tenant_id": transfer.get("tenant_id"),
                "type": "low_stock",
                "title": f"Low Stock Alert: {alert['item_name']}",
                "message": f"{alert['item_name']} at {alert['store_name']} is now at {alert['current_qty']} units (min: {alert['min_stock']})",
                "severity": "high" if alert['current_qty'] == 0 else "medium",
                "item_name": alert['item_name'],
                "store_name": alert['store_name'],
                "current_qty": alert['current_qty'],
                "min_stock": alert['min_stock'],
                "triggered_by": "stock_transfer",
                "transfer_id": transfer_id,
                "read": False,
                "created_at": datetime.now(timezone.utc).isoformat()
            }
            await db.stock_alerts.insert_one(alert_doc)
    
    await db.stock_transfers.update_one(
        {"id": transfer_id},
        {"$set": {
            "status": "approved",
            "approved_by": user.get("name"),
            "approved_at": datetime.now(timezone.utc).isoformat(),
            "low_stock_alerts_generated": len(low_stock_alerts)
        }}
    )
    
    result = {"message": "Transfer approved"}
    if low_stock_alerts:
        result["low_stock_alerts"] = low_stock_alerts
        result["alert_count"] = len(low_stock_alerts)
    
    return result

