# Indian States mapping for GST
INDIAN_STATES_MAP = {
    "01": "Jammu & Kashmir", "02": "Himachal Pradesh", "03": "Punjab",
    "04": "Chandigarh", "05": "Uttarakhand", "06": "Haryana", "07": "Delhi",
    "08": "Rajasthan", "09": "Uttar Pradesh", "10": "Bihar", "11": "Sikkim",
    "12": "Arunachal Pradesh", "13": "Nagaland", "14": "Manipur", "15": "Mizoram",
    "16": "Tripura", "17": "Meghalaya", "18": "Assam", "19": "West Bengal",
    "20": "Jharkhand", "21": "Odisha", "22": "Chhattisgarh", "23": "Madhya Pradesh",
    "24": "Gujarat", "26": "Dadra & Nagar Haveli and Daman & Diu", "27": "Maharashtra",
    "28": "Andhra Pradesh (Old)", "29": "Karnataka", "30": "Goa", "31": "Lakshadweep",
    "32": "Kerala", "33": "Tamil Nadu", "34": "Puducherry", "35": "Andaman & Nicobar Islands",
    "36": "Telangana", "37": "Andhra Pradesh", "38": "Ladakh"
}

@api_router.get("/gst/lookup/{gstin}")
async def lookup_gstin(gstin: str, user: dict = Depends(get_current_user)):
    """
    Look up GSTIN details with multiple API fallbacks.
    Fetches: Legal Name, Trade Name, Address, City, Pincode, Status, Registration Date.
    APIs tried in order: gstincheck.co.in (free), mastergst.com (free tier), local extraction.
    """
    import re
    import httpx
    
    gstin = gstin.upper().strip()
    
    # Validate GSTIN format (15 characters)
    gst_regex = r'^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$'
    if not re.match(gst_regex, gstin):
        raise HTTPException(status_code=400, detail="Invalid GSTIN format. Expected: 2 digits state code + 10 char PAN + 1 entity code + 1 'Z' + 1 checksum")
    
    # Extract state code (first 2 digits)
    state_code = gstin[:2]
    state_name = INDIAN_STATES_MAP.get(state_code)
    
    if not state_name:
        raise HTTPException(status_code=400, detail="Invalid state code in GSTIN")
    
    # Extract PAN from GSTIN (characters 3-12)
    pan = gstin[2:12]
    
    # Initialize result with local data
    result = {
        "gstin": gstin,
        "state_code": state_code,
        "state_name": state_name,
        "pan": pan,
        "valid": True,
        "legal_name": None,
        "trade_name": None,
        "address": None,
        "city": None,
        "pincode": None,
        "status": "Active",
        "registration_date": None,
        "business_type": None,
        "constitution_of_business": None,
        "nature_of_business": None,
        "last_updated": None,
        "source": "local",
        "api_tried": []
    }
    
    # Check if we have cached data
    cached = await db.gst_cache.find_one({"gstin": gstin}, {"_id": 0})
    if cached and cached.get("legal_name"):
        # Return cached data if less than 7 days old
        cache_time = cached.get("cached_at")
        if cache_time:
            from datetime import datetime, timezone, timedelta
            try:
                cache_dt = datetime.fromisoformat(cache_time.replace('Z', '+00:00'))
                if datetime.now(timezone.utc) - cache_dt < timedelta(days=7):
                    cached["source"] = "cache"
                    return cached
            except Exception:
                pass
    
    async with httpx.AsyncClient(timeout=15.0) as client:
        # API 1: gstincheck.co.in (free tier)
        try:
            result["api_tried"].append("gstincheck")
            response = await client.get(
                f"https://sheet.gstincheck.co.in/check/free/{gstin}",
                headers={"User-Agent": "BijnisBooks/1.0"}
            )
            if response.status_code == 200:
                data = response.json()
                if data.get("flag") and data.get("data"):
                    gst_data = data["data"]
                    result["legal_name"] = gst_data.get("lgnm")
                    result["trade_name"] = gst_data.get("tradeNam")
                    result["status"] = gst_data.get("sts", "Active")
                    result["registration_date"] = gst_data.get("rgdt")
                    result["constitution_of_business"] = gst_data.get("ctb")
                    result["business_type"] = gst_data.get("dty")
                    result["last_updated"] = gst_data.get("lstupdt")
                    result["source"] = "gstincheck"
                    
                    # Extract principal place of business address
                    pradr = gst_data.get("pradr", {})
                    if pradr:
                        result["address"] = pradr.get("adr")
                        addr_details = pradr.get("addr", {})
                        if addr_details:
                            result["city"] = addr_details.get("dst")
                            result["pincode"] = addr_details.get("pncd")
                    
                    # Extract nature of business
                    nba = gst_data.get("nba", [])
                    if nba:
                        result["nature_of_business"] = ", ".join(nba) if isinstance(nba, list) else nba
        except Exception as e:
            logger.warning(f"gstincheck API failed for {gstin}: {e}")
        
        # API 2: Try alternative API if primary failed
        if not result.get("legal_name"):
            try:
                result["api_tried"].append("gstsearch")
                # Try GST Search API (free tier)
                response = await client.get(
                    f"https://api.gstsearch.co.in/gst/{gstin}",
                    headers={"User-Agent": "BijnisBooks/1.0"},
                    timeout=10.0
                )
                if response.status_code == 200:
                    data = response.json()
                    if data.get("success") and data.get("data"):
                        gst_data = data["data"]
                        result["legal_name"] = gst_data.get("legal_name") or gst_data.get("lgnm")
                        result["trade_name"] = gst_data.get("trade_name") or gst_data.get("tradeNam")
                        result["status"] = gst_data.get("status") or "Active"
                        result["address"] = gst_data.get("address")
                        result["city"] = gst_data.get("city")
                        result["pincode"] = gst_data.get("pincode")
                        result["source"] = "gstsearch"
            except Exception as e:
                logger.warning(f"gstsearch API failed for {gstin}: {e}")
        
        # API 3: Try India InfoCorp API (free tier)
        if not result.get("legal_name"):
            try:
                result["api_tried"].append("indiainfocorp")
                response = await client.get(
                    f"https://api.indiainfocorp.com/gst/verify/{gstin}",
                    headers={"User-Agent": "BijnisBooks/1.0"},
                    timeout=10.0
                )
                if response.status_code == 200:
                    data = response.json()
                    if data.get("data"):
                        gst_data = data["data"]
                        result["legal_name"] = gst_data.get("legal_name")
                        result["trade_name"] = gst_data.get("trade_name")
                        result["status"] = gst_data.get("status") or "Active"
                        result["address"] = gst_data.get("address")
                        result["source"] = "indiainfocorp"
            except Exception as e:
                logger.warning(f"indiainfocorp API failed for {gstin}: {e}")
    
    # Cache the result if we got business details
    if result.get("legal_name"):
        cache_doc = {**result, "cached_at": datetime.now(timezone.utc).isoformat()}
        await db.gst_cache.update_one(
            {"gstin": gstin},
            {"$set": cache_doc},
            upsert=True
        )
    
    return result


@api_router.post("/gst/verify")
async def verify_gstin(request: dict, user: dict = Depends(get_current_user)):
    """Batch verify multiple GSTINs"""
    import re
    
    gstins = request.get("gstins", [])
    if not gstins or len(gstins) > 10:
        raise HTTPException(status_code=400, detail="Provide 1-10 GSTINs to verify")
    
    results = []
    gst_regex = r'^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$'
    
    for gstin in gstins:
        gstin = gstin.upper().strip()
        is_valid = bool(re.match(gst_regex, gstin))
        state_code = gstin[:2] if len(gstin) >= 2 else ""
        state_name = INDIAN_STATES_MAP.get(state_code)
        
        results.append({
            "gstin": gstin,
            "valid": is_valid and state_name is not None,
            "state_code": state_code,
            "state_name": state_name
        })
    
    return {"results": results}

