async def add_to_cart(item: dict, user: dict = Depends(get_current_user)):
    """Add item to cart"""
    tenant_id = get_tenant_id(user)
    user_id = user.get("id")
    
    # Get or create cart
    cart = await db.carts.find_one({"tenant_id": tenant_id, "user_id": user_id})
    
    if not cart:
        cart = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "user_id": user_id,
            "items": [],
            "total": 0,
            "count": 0,
            "created_at": datetime.now(timezone.utc).isoformat(),
            "updated_at": datetime.now(timezone.utc).isoformat()
        }
    
    # Check if item already in cart
    existing_idx = None
    for idx, cart_item in enumerate(cart.get("items", [])):
        if cart_item.get("item_id") == item.get("item_id"):
            existing_idx = idx
            break
    
    if existing_idx is not None:
        # Update quantity
        cart["items"][existing_idx]["quantity"] += item.get("quantity", 1)
    else:
        # Add new item
        cart_item = {
            "cart_item_id": str(uuid.uuid4()),
            "item_id": item.get("item_id"),
            "name": item.get("name"),
            "brand": item.get("brand"),
            "price": item.get("price", 0),
            "mrp": item.get("mrp", 0),
            "quantity": item.get("quantity", 1),
            "image": item.get("image"),
            "size": item.get("size"),
            "color": item.get("color"),
            "added_at": datetime.now(timezone.utc).isoformat()
        }
        cart["items"].append(cart_item)
    
    # Recalculate totals
    cart["total"] = sum(i.get("price", 0) * i.get("quantity", 1) for i in cart["items"])
    cart["count"] = sum(i.get("quantity", 1) for i in cart["items"])
    cart["updated_at"] = datetime.now(timezone.utc).isoformat()
    
    # Save cart
    await db.carts.update_one(
        {"tenant_id": tenant_id, "user_id": user_id},
        {"$set": cart},
        upsert=True
    )
    
    return {"message": "Item added to cart", "cart": {k: v for k, v in cart.items() if k != "_id"}}

