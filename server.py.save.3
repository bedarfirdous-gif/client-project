@api_router.post("/storefront/{tenant_slug}/cart/validate")
async def validate_cart(tenant_slug: str, cart_items: List[CartItem]):
    """Validate cart items and return pricing"""
    tenant = await db.tenants.find_one(
        {"$or": [{"slug": tenant_slug}, {"id": tenant_slug}]},
        {"_id": 0, "id": 1}
    )
    
    if not tenant:
        raise HTTPException(status_code=404, detail="Store not found")
    
    tenant_id = tenant.get("id")
    
    # Get e-commerce settings
    ecom_settings = await db.ecommerce_settings.find_one(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ) or {}
    
    validated_items = []
    subtotal = 0
    errors = []
    
    for cart_item in cart_items:
        item = await db.items.find_one(
            {"id": cart_item.item_id, "tenant_id": tenant_id},
            {"_id": 0}
        )
        
        if not item:
            errors.append(f"Product {cart_item.item_id} not found")
            continue
        
        # Check stock
        available_stock = item.get("stock_quantity", 0)
        if available_stock < cart_item.quantity:
            errors.append(f"{item.get('name')}: Only {available_stock} available")
            continue
        
        # Get variant price if applicable
        price = item.get("selling_price", 0)
        variant_name = None
        if cart_item.variant_id and item.get("variants"):
            variant = next((v for v in item["variants"] if v.get("id") == cart_item.variant_id), None)
            if variant:
                price = variant.get("price", price)
                variant_name = variant.get("name")
        
        item_total = price * cart_item.quantity
        subtotal += item_total
        
        validated_items.append({
            "item_id": cart_item.item_id,
            "variant_id": cart_item.variant_id,
            "name": item.get("name"),
            "variant_name": variant_name,
            "image": item.get("image") or (item.get("images", [None])[0] if item.get("images") else None),
            "price": price,
            "quantity": cart_item.quantity,
            "total": item_total,
            "max_quantity": available_stock
        })
    
    # Calculate delivery
    delivery_charge = ecom_settings.get("delivery_charge", 0)
    free_delivery_above = ecom_settings.get("free_delivery_above", 0)
    
    if free_delivery_above > 0 and subtotal >= free_delivery_above:
        delivery_charge = 0
    
    # Calculate tax (GST)
    tax_rate = 0.18  # 18% GST
    tax_amount = round(subtotal * tax_rate, 2)
    
    total = subtotal + delivery_charge + tax_amount
    
    return {
        "items": validated_items,
        "subtotal": round(subtotal, 2),
        "delivery_charge": delivery_charge,
        "tax_amount": tax_amount,
        "total": round(total, 2),
        "errors": errors,
        "min_order_amount": ecom_settings.get("min_order_amount", 0),
        "is_valid": len(errors) == 0 and subtotal >= ecom_settings.get("min_order_amount", 0)
    }


@api_router.post("/storefront/{tenant_slug}/checkout")
async def create_checkout(tenant_slug: str, request: CheckoutRequest):
    """Create checkout session and order"""
    tenant = await db.tenants.find_one(
        {"$or": [{"slug": tenant_slug}, {"id": tenant_slug}]},
        {"_id": 0}
    )
    
    if not tenant:
        raise HTTPException(status_code=404, detail="Store not found")
    
    tenant_id = tenant.get("id")
    
    # Validate cart first
    cart_validation = await validate_cart(tenant_slug, request.cart_items)
    
    if not cart_validation["is_valid"]:
        raise HTTPException(status_code=400, detail=f"Cart validation failed: {cart_validation['errors']}")
    
    # Get e-commerce settings
    ecom_settings = await db.ecommerce_settings.find_one(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ) or {}
    
    # Generate order ID
    order_id = f"ORD-{str(uuid.uuid4())[:8].upper()}"
    
    # Create order document
    order_doc = {
        "id": order_id,
        "tenant_id": tenant_id,
        "store_id": request.store_id,
        "order_type": "ecommerce",
        "status": EcommerceOrderStatus.PENDING,
        "payment_status": "pending",
        "payment_method": request.payment_method,
        
        # Customer info
        "customer_name": request.customer_name,
        "customer_email": request.customer_email,
        "customer_phone": request.customer_phone,
        "shipping_address": request.shipping_address,
        "billing_address": request.billing_address or request.shipping_address,
        
        # Order items
        "items": cart_validation["items"],
        "subtotal": cart_validation["subtotal"],
        "delivery_charge": cart_validation["delivery_charge"],
        "tax_amount": cart_validation["tax_amount"],
        "total_amount": cart_validation["total"],
        
        "notes": request.notes,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "updated_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Handle payment method
    if request.payment_method == "stripe":
        if not STRIPE_API_KEY:
            raise HTTPException(status_code=500, detail="Payment gateway not configured")
        
        try:
            # Create Stripe checkout session
            line_items = []
            for item in cart_validation["items"]:
                line_items.append({
                    "price_data": {
                        "currency": "inr",
                        "product_data": {
                            "name": item["name"] + (f" - {item['variant_name']}" if item.get("variant_name") else ""),
                        },
                        "unit_amount": int(item["price"] * 100),  # Stripe uses cents
                    },
                    "quantity": item["quantity"],
                })
            
            # Add delivery charge if any
            if cart_validation["delivery_charge"] > 0:
                line_items.append({
                    "price_data": {
                        "currency": "inr",
                        "product_data": {"name": "Delivery Charge"},
                        "unit_amount": int(cart_validation["delivery_charge"] * 100),
                    },
                    "quantity": 1,
                })
            
            # Add tax
            if cart_validation["tax_amount"] > 0:
                line_items.append({
                    "price_data": {
                        "currency": "inr",
                        "product_data": {"name": "GST (18%)"},
                        "unit_amount": int(cart_validation["tax_amount"] * 100),
                    },
                    "quantity": 1,
                })
            
            # Get the frontend URL for success/cancel
            frontend_url = os.environ.get("REACT_APP_BACKEND_URL", "").replace("/api", "")
            if not frontend_url:
                frontend_url = "https://erp-invoice-fix-1.preview.emergentagent.com"
            
            checkout_session = stripe.checkout.Session.create(
                payment_method_types=["card"],
                line_items=line_items,
                mode="payment",
                success_url=f"{frontend_url}/store/{tenant_slug}/order-success?order_id={order_id}&session_id={{CHECKOUT_SESSION_ID}}",
                cancel_url=f"{frontend_url}/store/{tenant_slug}/cart?cancelled=true",
                customer_email=request.customer_email,
                metadata={
                    "order_id": order_id,
                    "tenant_id": tenant_id
                }
            )
            
            order_doc["stripe_session_id"] = checkout_session.id
            order_doc["payment_url"] = checkout_session.url
            
        except stripe.error.StripeError as e:
            raise HTTPException(status_code=500, detail=f"Payment error: {str(e)}")
    
    elif request.payment_method == "cod":
        if not ecom_settings.get("accepts_cod", True):
            raise HTTPException(status_code=400, detail="Cash on delivery not available")
        
        order_doc["status"] = EcommerceOrderStatus.CONFIRMED
        order_doc["payment_status"] = "cod_pending"
    
    # Save order
    await db.ecommerce_orders.insert_one(order_doc)
    order_doc.pop("_id", None)
    
    # INVENTORY SYNC: Reduce stock when order is placed
    for item in request.cart_items:
        item_id = item.item_id
        variant_id = getattr(item, 'variant_id', None)
        quantity = item.quantity
        
        if variant_id:
            # Update variant stock
            await db.variants.update_one(
                {"id": variant_id, "tenant_id": tenant_id},
                {"$inc": {"current_stock": -quantity}}
            )
            # Also update the inventory collection for the variant
            await db.inventory.update_one(
                {"variant_id": variant_id, "tenant_id": tenant_id},
                {"$inc": {"quantity": -quantity}},
                upsert=False
            )
        else:
            # Update item stock
            await db.items.update_one(
                {"id": item_id, "tenant_id": tenant_id},
                {"$inc": {"current_stock": -quantity}}
            )
            # Also update the inventory collection
            await db.inventory.update_one(
                {"item_id": item_id, "variant_id": None, "tenant_id": tenant_id},
                {"$inc": {"quantity": -quantity}},
                upsert=False
            )
        
        # Track reserved stock for order cancellation handling
        await db.items.update_one(
            {"id": item_id, "tenant_id": tenant_id},
            {"$inc": {"reserved_stock": quantity, "ecommerce_sold": quantity}}
        )
    
    logger.info(f"E-commerce order {order_id} placed - inventory updated for {len(request.cart_items)} items")
    
    return {
        "order_id": order_id,
        "status": order_doc["status"],
        "payment_method": request.payment_method,
        "payment_url": order_doc.get("payment_url"),
        "total": cart_validation["total"],
        "message": "Order placed successfully" if request.payment_method == "cod" else "Redirecting to payment..."
    }


