    }

    await db.users.insert_one(new_user)

    return {"message": "User registered successfully"}


@api_router.post("/auth/login", response_model=Token)
async def login(request: LoginRequest, req: Request):
    user = await db.users.find_one({"email": request.email.lower()})

if not user:
    raise HTTPException(status_code=401, detail="Invalid credentials")

    
    # Check for backup code login if normal password fails
    password_valid = verify_password(request.password, user.get("password", ""))
    backup_code_used = False
    
    if not password_valid and user:
        # Check if the password is actually a backup code
        backup_codes = user.get("backup_codes", [])
    for i, code in enumerate(backup_codes):
        if code.get("code") == request.password and not code.get("used"):
            password_valid = True
            backup_code_used = True
            # Mark code as used
            backup_codes[i]["used"] = True
            backup_codes[i]["used_at"] = datetime.now(timezone.utc).isoformat()

            	await db.users.update_one(
                {"id": user["id"]}, 
                {"$set": {"backup_codes": backup_codes}}
            )
        
            	break
    
    if not user or not password_valid:
        # Record failed login attempt
        client_ip = req.headers.get("x-forwarded-for", req.client.host if req.client else "unknown")
        if client_ip and "," in client_ip:
            client_ip = client_ip.split(",")[0].strip()
        
        failed_login_doc = {
            "id": str(uuid.uuid4()),
            "tenant_id": user.get("tenant_id", "default") if user else "unknown",
            "user_id": user.get("id") if user else None,
            "user_email": request.email.lower(),
            "status": "failed",
            "failure_reason": "Invalid password" if user else "User not found",
            "ip_address": client_ip,
            "user_agent": req.headers.get("user-agent", "unknown"),
            "timestamp": datetime.now(timezone.utc).isoformat()
        }
        await db.login_history.insert_one(failed_login_doc)
        
        raise HTTPException(status_code=401, detail="Invalid credentials")
    if not user.get("is_active", True):
        raise HTTPException(status_code=401, detail="Account is deactivated")
    
    # Check if user/tenant is frozen (God-mode freeze)
    if user.get("is_frozen"):
        raise HTTPException(status_code=403, detail="Account is frozen. Contact Super Admin.")
    
    # Get client IP
    client_ip = req.headers.get("x-forwarded-for", req.client.host if req.client else "unknown")
    if client_ip and "," in client_ip:
        client_ip = client_ip.split(",")[0].strip()
    
    now = datetime.now(timezone.utc)
    now_iso = now.isoformat()
    
    # Check for suspicious activity
    alerts = []
    
    # Check late night access (between 11 PM and 5 AM)
    hour = now.hour
    if hour >= 23 or hour < 5:
        alerts.append({
            "id": str(uuid.uuid4()),
            "type": "late_night_access",
            "severity": "warning",
            "user_id": user["id"],
            "user_name": user.get("name", "Unknown"),
            "user_email": user["email"],
            "ip_address": client_ip,
            "message": f"Late night login detected at {now.strftime('%I:%M %p')}",
            "timestamp": now_iso,
            "acknowledged": False
        })
    
    # Check for new IP address
    known_ips = user.get("known_ips", [])
    if client_ip and client_ip not in known_ips and client_ip != "unknown":
        alerts.append({
            "id": str(uuid.uuid4()),
            "type": "new_ip_address",
            "severity": "high",
            "user_id": user["id"],
            "user_name": user.get("name", "Unknown"),
            "user_email": user["email"],
            "ip_address": client_ip,
            "message": f"Login from new IP address: {client_ip}",
            "timestamp": now_iso,
            "acknowledged": False
        })
        # Add to known IPs
        known_ips.append(client_ip)
    
    # Save alerts
    if alerts:
        await db.security_alerts.insert_many(alerts)
    
    # Create/update user session
    session_id = str(uuid.uuid4())
    session_doc = {
        "id": session_id,
        "user_id": user["id"],
        "user_name": user.get("name", "Unknown"),
        "user_email": user["email"],
        "user_role": user.get("role", "staff"),
        "ip_address": client_ip,
        "login_time": now_iso,
        "last_activity": now_iso,
        "is_active": True,
        "tenant_id": user.get("tenant_id", "default")
    }
    
    # Deactivate old sessions for this user
    await db.user_sessions.update_many(
        {"user_id": user["id"], "is_active": True},
        {"$set": {"is_active": False, "logout_time": now_iso}}
    )
    
    # Create new session
    await db.user_sessions.insert_one(session_doc)
    
    # Record login history for audit trail
    login_history_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": user.get("tenant_id", "default"),
        "user_id": user["id"],
        "user_email": user["email"],
        "user_name": user.get("name", "Unknown"),
        "status": "success",
        "ip_address": client_ip,
        "user_agent": req.headers.get("user-agent", "unknown"),
        "timestamp": now_iso,
        "backup_code_used": backup_code_used
    }
    await db.login_history.insert_one(login_history_doc)
    
    # Update user record - include reauth_expires to auto-authenticate the session
    # This prevents the "Security Verification Required" dialog from showing immediately after login
    reauth_expires = (now + timedelta(minutes=60)).isoformat()
    
    await db.users.update_one(
        {"id": user["id"]},
        {"$set": {
            "last_login": now_iso,
            "last_ip": client_ip,
            "known_ips": known_ips,
            "current_session_id": session_id,
            "reauth_expires": reauth_expires,
            "reauth_method": "password"
        }}
    )
    
    # Add backup code warning if used
    if backup_code_used:
        alerts.append({
            "id": str(uuid.uuid4()),
            "type": "backup_code_used",
            "severity": "high",
            "user_id": user["id"],
            "user_name": user.get("name", "Unknown"),
            "user_email": user["email"],
            "ip_address": client_ip,
            "message": "Backup recovery code used for login",
            "timestamp": now_iso,
            "acknowledged": False
        })
        await db.security_alerts.insert_one(alerts[-1])
    
    token = create_access_token({"sub": user["id"], "tenant_id": user.get("tenant_id"), "session_id": session_id})
    user_data = {k: v for k, v in user.items() if k not in ["_id", "password", "backup_codes"]}
    user_data["backup_code_login"] = backup_code_used
    return Token(access_token=token, user=user_data)

