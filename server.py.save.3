@api_router.post("/superadmin/god-mode/delete-tenant-data")
async def god_mode_delete_tenant_data(
    tenant_id: str = Body(...),
    confirm: bool = Body(False),
    user: dict = Depends(require_superadmin)
):
    """Emergency: Delete ALL data for a tenant (DANGER!)"""
    
    if not confirm:
        raise HTTPException(status_code=400, detail="Set confirm=true to proceed with data deletion")
    
    if tenant_id == "superadmin":
        raise HTTPException(status_code=403, detail="Cannot delete superadmin tenant")
    
    # Collect stats before deletion
    stats = {
        "users": await db.users.count_documents({"tenant_id": tenant_id}),
        "customers": await db.customers.count_documents({"tenant_id": tenant_id}),
        "items": await db.items.count_documents({"tenant_id": tenant_id}),
        "sales": await db.sales.count_documents({"tenant_id": tenant_id}),
        "inventory": await db.inventory.count_documents({"tenant_id": tenant_id}),
    }
    
    # Delete from all collections
    collections = [
        "users", "customers", "items", "variants", "inventory", "sales",
        "purchases", "orders", "quotations", "invoices", "payments",
        "stores", "suppliers", "employees", "attendance", "payroll",
        "backup_codes", "user_sessions", "audit_trail", "settings"
    ]
    
    deleted_counts = {}
    for coll_name in collections:
        collection = db[coll_name]
        result = await collection.delete_many({"tenant_id": tenant_id})
        deleted_counts[coll_name] = result.deleted_count
    
    # Log action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "god_mode_delete_tenant_data",
        "tenant_id": tenant_id,
        "stats_before": stats,
        "deleted_counts": deleted_counts,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": datetime.now(timezone.utc).isoformat()
    })
    
    return {
        "message": f"All data deleted for tenant {tenant_id}",
        "deleted_counts": deleted_counts,
        "warning": "This action cannot be undone!"
    }

@api_router.post("/superadmin/god-mode/generate-backup-codes")
