@api_router.get("/purchase-reports/monthly")
async def get_purchase_monthly(
    year: int = 0,
    user: dict = Depends(get_current_user)
):
    tenant_id = get_tenant_id(user)
    
    if year == 0:
        year = datetime.now().year
    
    invoices = await db.purchase_invoices.find({"tenant_id": tenant_id, "is_deleted": {"$ne": True}}, {"_id": 0}).to_list(10000)
    
    # Group by month
    monthly = {}
    for inv in invoices:
        inv_date = inv.get("invoice_date", "")
        if inv_date and inv_date.startswith(str(year)):
            month = inv_date[5:7]  # Extract MM from YYYY-MM-DD
            if month not in monthly:
                monthly[month] = {"month": month, "invoice_count": 0, "total_amount": 0}
            monthly[month]["invoice_count"] += 1
            monthly[month]["total_amount"] += inv.get("total_amount", 0)
    
    # Fill missing months
    result = []
    for m in range(1, 13):
        month_str = str(m).zfill(2)
        if month_str in monthly:
            result.append(monthly[month_str])
        else:
            result.append({"month": month_str, "invoice_count": 0, "total_amount": 0})
    
    return result

@api_router.get("/purchase-reports/export/excel")
async def export_purchase_report_excel(
    start_date: str = None,
    end_date: str = None,
    user: dict = Depends(get_current_user)
):
    """Export purchase report as Excel"""
    from io import BytesIO
    import openpyxl
    from openpyxl.styles import Font, Alignment, PatternFill, Border, Side
    
    tenant_id = get_tenant_id(user)
    
    query = {"tenant_id": tenant_id, "is_deleted": {"$ne": True}}
    if start_date and end_date:
        query["invoice_date"] = {"$gte": start_date, "$lte": end_date}
    
    invoices = await db.purchase_invoices.find(query, {"_id": 0}).sort("invoice_date", -1).to_list(10000)
    
    # Create workbook
    wb = openpyxl.Workbook()
    ws = wb.active
    ws.title = "Purchase Report"
    
    # Styles
    header_font = Font(bold=True, color="FFFFFF")
    header_fill = PatternFill(start_color="C81E1E", end_color="C81E1E", fill_type="solid")
    thin_border = Border(
        left=Side(style='thin'),
        right=Side(style='thin'),
        top=Side(style='thin'),
        bottom=Side(style='thin')
    )
    
    # Title
    ws.merge_cells('A1:G1')
    ws['A1'] = "Purchase Report"
    ws['A1'].font = Font(bold=True, size=16)
    ws['A1'].alignment = Alignment(horizontal='center')
    
    if start_date and end_date:
        ws.merge_cells('A2:G2')
        ws['A2'] = f"Period: {start_date} to {end_date}"
        ws['A2'].alignment = Alignment(horizontal='center')
    
    # Headers
    headers = ['#', 'Invoice No', 'Date', 'Supplier', 'Items', 'Total Amount', 'Status']
    start_row = 4
    for col, header in enumerate(headers, 1):
        cell = ws.cell(row=start_row, column=col, value=header)
        cell.font = header_font
        cell.fill = header_fill
        cell.alignment = Alignment(horizontal='center')
        cell.border = thin_border
    
    # Data
    for idx, inv in enumerate(invoices, 1):
        row = start_row + idx
        items_count = len(inv.get("items", []))
        ws.cell(row=row, column=1, value=idx).border = thin_border
        ws.cell(row=row, column=2, value=inv.get("invoice_number", "")).border = thin_border
        ws.cell(row=row, column=3, value=inv.get("invoice_date", "")).border = thin_border
        ws.cell(row=row, column=4, value=inv.get("supplier_name", "")).border = thin_border
        ws.cell(row=row, column=5, value=items_count).border = thin_border
        ws.cell(row=row, column=6, value=inv.get("total_amount", 0)).border = thin_border
        ws.cell(row=row, column=6).number_format = '₹#,##0.00'
        ws.cell(row=row, column=7, value=inv.get("payment_status", "pending").capitalize()).border = thin_border
    
    # Summary row
    summary_row = start_row + len(invoices) + 2
    ws.cell(row=summary_row, column=5, value="Total:").font = Font(bold=True)
    total_amount = sum(inv.get("total_amount", 0) for inv in invoices)
    ws.cell(row=summary_row, column=6, value=total_amount).font = Font(bold=True)
    ws.cell(row=summary_row, column=6).number_format = '₹#,##0.00'
    
    # Column widths
    ws.column_dimensions['A'].width = 5
    ws.column_dimensions['B'].width = 15
    ws.column_dimensions['C'].width = 12
    ws.column_dimensions['D'].width = 25
    ws.column_dimensions['E'].width = 8
    ws.column_dimensions['F'].width = 15
    ws.column_dimensions['G'].width = 12
    
    # Save to BytesIO
    output = BytesIO()
    wb.save(output)
    output.seek(0)
    
    return StreamingResponse(
        output,
        media_type="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        headers={"Content-Disposition": f"attachment; filename=purchase_report.xlsx"}
    )

