APPLICATION_UPLOAD_DIR = ROOT_DIR / 'uploads' / 'applications'
APPLICATION_UPLOAD_DIR.mkdir(parents=True, exist_ok=True)

@api_router.post("/employment-applications/{application_id}/upload")
async def upload_application_document(
    application_id: str,
    file: UploadFile = File(...),
    document_type: str = Form("document"),
    user: dict = Depends(get_current_user)
):
    """Upload document to an employment application"""
    tenant_id = get_tenant_id(user)
    
    # Verify application exists
    application = await db.employment_applications.find_one(
        {"tenant_id": tenant_id, "id": application_id}
    )
    if not application:
        raise HTTPException(status_code=404, detail="Application not found")
    
    # Validate file type
    allowed_types = ['application/pdf', 'image/jpeg', 'image/jpg', 'image/png']
    if file.content_type not in allowed_types:
        raise HTTPException(status_code=400, detail="Invalid file type. Allowed: PDF, JPG, PNG")
    
    # Create directory for this application
    app_dir = APPLICATION_UPLOAD_DIR / application_id
    app_dir.mkdir(parents=True, exist_ok=True)
    
    # Save file
    file_ext = file.filename.split('.')[-1] if '.' in file.filename else 'pdf'
    file_id = str(uuid.uuid4())
    filename = f"{document_type}_{file_id}.{file_ext}"
    file_path = app_dir / filename
    
    content = await file.read()
    with open(file_path, 'wb') as f:
        f.write(content)
    
    # Store document metadata in database
    doc_record = {
        "id": file_id,
        "application_id": application_id,
        "tenant_id": tenant_id,
        "document_type": document_type,
        "original_filename": file.filename,
        "stored_filename": filename,
        "file_path": str(file_path),
        "file_size": len(content),
        "content_type": file.content_type,
        "uploaded_at": datetime.now(timezone.utc).isoformat(),
        "uploaded_by": user.get("id")
    }
    
    await db.application_documents.insert_one(doc_record)
    
    # Update application with document reference
    await db.employment_applications.update_one(
        {"id": application_id},
        {"$push": {"documents": {"id": file_id, "type": document_type, "filename": file.filename}}}
    )
    
    doc_record.pop("_id", None)
    return doc_record


