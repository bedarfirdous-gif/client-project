@api_router.put("/fabrics/custom-stitch-requests/{request_id}/status")
async def update_stitch_request_status(
    request_id: str,
    status: str = Body(...),
    notes: str = Body(""),
    user: dict = Depends(require_permission("items"))
):
    """Update custom stitch request status"""
    tenant_id = get_tenant_id(user)
    
    valid_statuses = ["pending", "confirmed", "in_progress", "completed", "cancelled"]
    if status not in valid_statuses:
        raise HTTPException(status_code=400, detail=f"Invalid status. Must be one of: {valid_statuses}")
    
    update_data = {
        "status": status,
        "status_updated_at": datetime.now(timezone.utc).isoformat(),
        "status_updated_by": user.get("id")
    }
    
    if notes:
        update_data["admin_notes"] = notes
    
    if status == "completed":
        update_data["completed_at"] = datetime.now(timezone.utc).isoformat()
    
    result = await db.custom_stitch_requests.update_one(
        {"id": request_id, "tenant_id": tenant_id},
        {"$set": update_data}
    )
    
    if result.matched_count == 0:
        raise HTTPException(status_code=404, detail="Request not found")
    
    return {"message": f"Status updated to {status}"}


