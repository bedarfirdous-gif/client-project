@api_router.post("/auth/setup-pin")
async def setup_security_pin(request: PinSetup, user: dict = Depends(get_current_user)):
    """Set up or update security PIN for re-authentication"""
    user_id = user.get("id")
    
    # Validate PIN format (4-6 digits)
    if not request.pin.isdigit() or len(request.pin) < 4 or len(request.pin) > 6:
        raise HTTPException(status_code=400, detail="PIN must be 4-6 digits")
    
    if request.pin != request.confirm_pin:
        raise HTTPException(status_code=400, detail="PINs do not match")
    
    # Hash the PIN for security
    hashed_pin = hash_password(request.pin)
    
    await db.users.update_one(
        {"id": user_id},
        {"$set": {
            "security_pin": hashed_pin,
            "pin_updated_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": "Security PIN set successfully", "has_pin": True}

@api_router.post("/auth/verify-reauth")
async def verify_reauth(request: ReAuthRequest, user: dict = Depends(get_current_user)):
    """Verify re-authentication with PIN or password"""
    user_id = user.get("id")
    current_user = await db.users.find_one({"id": user_id})
    
    if not current_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    is_valid = False
    
    if request.method == "pin":
        # Verify PIN
        stored_pin = current_user.get("security_pin")
        if not stored_pin:
            raise HTTPException(status_code=400, detail="PIN not set. Please use password or set up a PIN.")
        is_valid = verify_password(request.credential, stored_pin)
    
    elif request.method == "password":
        # Verify password
        stored_password = current_user.get("password")
        if not stored_password:
            raise HTTPException(status_code=400, detail="Password not found")
        is_valid = verify_password(request.credential, stored_password)
    
    else:
        raise HTTPException(status_code=400, detail="Invalid authentication method. Use 'pin' or 'password'.")
    
    if not is_valid:
        # Log failed re-auth attempt
        await db.security_logs.insert_one({
            "id": str(uuid.uuid4()),
            "tenant_id": current_user.get("tenant_id"),
            "user_id": user_id,
            "action": "reauth_failed",
            "method": request.method,
            "timestamp": datetime.now(timezone.utc).isoformat()
        })
        raise HTTPException(status_code=401, detail="Invalid credentials")
    
    # Log successful re-auth
    await db.security_logs.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": current_user.get("tenant_id"),
        "user_id": user_id,
        "action": "reauth_success",
        "method": request.method,
        "timestamp": datetime.now(timezone.utc).isoformat()
    })
    
    # Generate a short-lived re-auth token (stored in session)
    reauth_token = str(uuid.uuid4())
    reauth_expires = datetime.now(timezone.utc) + timedelta(minutes=30)
    
    await db.users.update_one(
        {"id": user_id},
        {"$set": {
            "reauth_token": reauth_token,
            "reauth_expires": reauth_expires.isoformat(),
            "last_reauth": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {
        "message": "Re-authentication successful",
        "reauth_token": reauth_token,
        "expires_in_minutes": 30
    }


