# --- Login History ---
@api_router.get("/rbac/login-history")
async def get_login_history(
    user_id: str = None,
    from_date: str = None,
    to_date: str = None,
    status: str = None,
    limit: int = Query(100, le=1000),
    user: dict = Depends(get_current_user)
):
    """
    Get login history for audit purposes
    
    Query Parameters:
    - user_id: Filter by specific user
    - from_date: Start date (YYYY-MM-DD)
    - to_date: End date (YYYY-MM-DD)
    - status: success/failed
    - limit: Max records (default 100)
    """
    if user.get("role") not in ["admin", "superadmin"] and not is_superadmin(user):
        # Non-admins can only see their own history
        user_id = user.get("id")
    
    tenant_id = get_tenant_id(user)
    query = {"tenant_id": tenant_id}
    
    if user_id:
        query["user_id"] = user_id
    if status:
        query["status"] = status
    if from_date:
        query["timestamp"] = {"$gte": from_date}
    if to_date:
        if "timestamp" in query:
            query["timestamp"]["$lte"] = to_date + "T23:59:59"
        else:
            query["timestamp"] = {"$lte": to_date + "T23:59:59"}
    
    history = await db.login_history.find(query, {"_id": 0}).sort("timestamp", -1).to_list(limit)
    
    return {"history": history, "total": len(history)}


@api_router.get("/rbac/login-history/summary")
async def get_login_summary(
    days: int = 30,
    user: dict = Depends(get_current_user)
):
    """Get login statistics summary"""
    if user.get("role") not in ["admin", "superadmin"] and not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    cutoff = (datetime.now(timezone.utc) - timedelta(days=days)).isoformat()
    
    # Get counts
    total_logins = await db.login_history.count_documents({
        "tenant_id": tenant_id, "timestamp": {"$gte": cutoff}
    })
    successful = await db.login_history.count_documents({
        "tenant_id": tenant_id, "timestamp": {"$gte": cutoff}, "status": "success"
    })
    failed = await db.login_history.count_documents({
        "tenant_id": tenant_id, "timestamp": {"$gte": cutoff}, "status": "failed"
    })
    
    # Get unique users who logged in
    unique_users = await db.login_history.distinct("user_id", {
        "tenant_id": tenant_id, "timestamp": {"$gte": cutoff}, "status": "success"
    })
    
    return {
        "period_days": days,
        "total_attempts": total_logins,
        "successful": successful,
        "failed": failed,
        "success_rate": round((successful / total_logins * 100) if total_logins > 0 else 0, 2),
        "unique_users": len(unique_users)
    }


