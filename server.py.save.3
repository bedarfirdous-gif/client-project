    # Force logout all sessions
    await db.user_sessions.delete_many({"tenant_id": tenant_id})
    
    # Log action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "god_mode_freeze_tenant",
        "tenant_id": tenant_id,
        "users_affected": result.modified_count,
        "performed_by": user.get("id"),
        "timestamp": datetime.now(timezone.utc).isoformat()
    })
    
    return {"message": f"Tenant {tenant_id} frozen. {result.modified_count} users affected."}

@api_router.post("/superadmin/god-mode/unfreeze-tenant")
