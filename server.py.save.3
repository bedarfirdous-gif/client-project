@api_router.post("/stock-transfers/bulk-delete")
async def bulk_delete_stock_transfers(
    request: dict,
    user: dict = Depends(require_permission("stock_transfers"))
):
    """Bulk delete multiple stock transfers and reverse stock movements"""
    tenant_id = get_tenant_id(user)
    transfer_ids = request.get("transfer_ids", [])
    
    if not transfer_ids:
        raise HTTPException(status_code=400, detail="No transfer IDs provided")
    
    deleted_count = 0
    failed = []
    inv_service = InventoryService(db)
    
    for transfer_id in transfer_ids:
        # Find the transfer
        transfer = await db.stock_transfers.find_one(
            {"id": transfer_id, "tenant_id": tenant_id},
            {"_id": 0}
        )
        
        if not transfer:
            failed.append({"id": transfer_id, "reason": "Not found"})
            continue
        
        # Get transfer details
        source_store_id = transfer.get("from_store_id") or transfer.get("source_store_id")
        dest_store_id = transfer.get("to_store_id") or transfer.get("destination_store_id")
        transfer_status = transfer.get("status", "pending")
        items = transfer.get("items", [])
        
        # Reverse stock movements
        for item in items:
            variant_id = item.get("variant_id")
            quantity = item.get("quantity", 0)
            item_id = item.get("item_id", "")
            
            if not variant_id or quantity <= 0:
                continue
            
            # If item_id is missing, look it up from variant
            if not item_id:
                variant = await db.variants.find_one({"id": variant_id}, {"_id": 0})
                if variant:
                    item_id = variant.get("item_id", "")
            
            try:
                # ADD back to source store
                await inv_service.add_stock(
                    tenant_id=tenant_id,
                    item_id=item_id,
                    variant_id=variant_id,
                    quantity=quantity,
                    movement_type=MovementType.ADJUSTMENT,
                    reference_id=f"{transfer_id}_delete",
                    reference_type="transfer_reversal",
                    warehouse_id=source_store_id,
                    notes=f"Bulk delete - transfer {transfer_id} reversed",
                    performed_by=user.get("id")
                )
                
                # Update legacy inventory for source
                await db.inventory.update_one(
                    {"variant_id": variant_id, "store_id": source_store_id},
                    {"$inc": {"quantity": quantity}},
                    upsert=True
                )
                
                # If completed, DEDUCT from destination
                if transfer_status in ["completed", "received", "delivered"]:
                    await inv_service.deduct_stock(
                        tenant_id=tenant_id,
                        item_id=item_id,
                        variant_id=variant_id,
                        quantity=quantity,
                        movement_type=MovementType.ADJUSTMENT,
                        reference_id=f"{transfer_id}_delete",
                        reference_type="transfer_reversal",
                        warehouse_id=dest_store_id,
                        notes=f"Bulk delete - transfer {transfer_id} reversed",
                        performed_by=user.get("id"),
                        allow_negative=True
                    )
                    
                    await db.inventory.update_one(
                        {"variant_id": variant_id, "store_id": dest_store_id},
                        {"$inc": {"quantity": -quantity}}
                    )
            except Exception as e:
                logger.error(f"Failed to reverse stock for variant {variant_id}: {e}")
        
        # Delete the transfer
        await db.stock_transfers.delete_one({"id": transfer_id, "tenant_id": tenant_id})
        deleted_count += 1
    
    return {
        "message": f"Deleted {deleted_count} transfer(s) and reversed stock",
        "deleted_count": deleted_count,
        "failed": failed,
        "total_requested": len(transfer_ids)
    }

