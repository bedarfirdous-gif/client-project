@api_router.get("/size-prediction/{customer_id}")
async def get_ai_size_prediction(
    customer_id: str,
    category: str = Query(None),  # tops, bottoms, dresses, etc.
    user: dict = Depends(get_current_user)
):
    """AI-powered size prediction based on purchase history"""
    tenant_id = get_tenant_id(user)
    
    # Get customer's purchase history
    customer = await db.customers.find_one(
        {"$or": [{"id": customer_id}, {"phone": customer_id}, {"email": customer_id}], "tenant_id": tenant_id},
        {"_id": 0}
    )
    
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Get all sales for this customer with size info
    sales = await db.sales.find(
        {"tenant_id": tenant_id, "customer_id": customer.get("id")},
        {"_id": 0}
    ).sort("created_at", -1).to_list(100)
    
    # Also check e-commerce orders
    ecom_orders = await db.ecommerce_orders.find(
        {"tenant_id": tenant_id, "customer_email": customer.get("email")},
        {"_id": 0}
    ).sort("created_at", -1).to_list(100)
    
    # Analyze size patterns
    size_history = {"XS": 0, "S": 0, "M": 0, "L": 0, "XL": 0, "XXL": 0, "XXXL": 0}
    category_sizes = {}
    recent_sizes = []
    items_purchased = []
    
    # Process POS sales
    for sale in sales:
        for item in sale.get("items", []):
            size = item.get("size") or item.get("variant_name")
            if size and size.upper() in size_history:
                size_history[size.upper()] += 1
                recent_sizes.append({
                    "size": size.upper(),
                    "item": item.get("name"),
                    "date": sale.get("created_at"),
                    "returned": False
                })
                
                # Track by category
                item_category = item.get("category", "general")
                if item_category not in category_sizes:
                    category_sizes[item_category] = {}
                if size.upper() not in category_sizes[item_category]:
                    category_sizes[item_category][size.upper()] = 0
                category_sizes[item_category][size.upper()] += 1
                
                items_purchased.append(item.get("name"))
    
    # Process e-commerce orders (non-cancelled)
    for order in ecom_orders:
        if order.get("status") != "cancelled":
            for item in order.get("items", []):
                size = item.get("size") or item.get("variant_name")
                if size and size.upper() in size_history:
                    size_history[size.upper()] += 1
                    recent_sizes.append({
                        "size": size.upper(),
                        "item": item.get("name"),
                        "date": order.get("created_at"),
                        "returned": order.get("status") == "refunded"
                    })
    
    # Check returns to adjust prediction
    returns = await db.returns.find(
        {"tenant_id": tenant_id, "customer_id": customer.get("id")},
        {"_id": 0}
    ).to_list(50)
    
    returned_sizes = []
    for ret in returns:
        for item in ret.get("items", []):
            size = item.get("size")
            reason = item.get("return_reason", "").lower()
            if size:
                returned_sizes.append({
                    "size": size.upper(),
                    "reason": reason,
                    "too_small": "small" in reason or "tight" in reason,
                    "too_large": "large" in reason or "loose" in reason or "big" in reason
                })
    
    # Determine most common size (weighted by recency)
    total_purchases = sum(size_history.values())
    if total_purchases == 0:
        # No purchase history - check saved body measurements
        body_measurement = await db.body_measurements.find_one(
            {"$or": [{"user_id": customer.get("id")}, {"tenant_id": tenant_id}]},
            {"_id": 0}
        )
        
        if body_measurement:
            # Use body measurements to predict
            chest = body_measurement.get("chest", 0)
            waist = body_measurement.get("waist", 0)
            
            # Standard size chart logic
            if chest <= 86 or waist <= 71:
                predicted_size = "S"
            elif chest <= 96 or waist <= 81:
                predicted_size = "M"
            elif chest <= 106 or waist <= 91:
                predicted_size = "L"
            elif chest <= 116 or waist <= 101:
                predicted_size = "XL"
            else:
                predicted_size = "XXL"
            
            return {
                "customer_id": customer_id,
                "customer_name": customer.get("name"),
                "predicted_size": predicted_size,
                "confidence": 70,
                "prediction_source": "body_measurements",
                "body_measurements": {
                    "chest": chest,
                    "waist": waist,
                    "hip": body_measurement.get("hip", 0)
                },
                "recommendations": [
                    f"Based on body measurements, {predicted_size} should fit well",
                    "Consider going up a size for loose fit preference"
                ]
            }
        
        return {
            "customer_id": customer_id,
            "customer_name": customer.get("name"),
            "predicted_size": "M",  # Default
            "confidence": 20,
            "prediction_source": "default",
            "message": "No purchase history or measurements found. Using default size.",
            "recommendations": ["Recommend taking body measurements for accurate sizing"]
        }
    
    # Calculate weighted scores (recent purchases count more)
    weighted_scores = {}
    for i, item in enumerate(recent_sizes[:20]):  # Last 20 purchases
        size = item["size"]
        weight = 1.0 - (i * 0.04)  # Decay weight by 4% per older purchase
        if item.get("returned"):
            weight *= -0.5  # Negative weight for returned items
        
        if size not in weighted_scores:
            weighted_scores[size] = 0
        weighted_scores[size] += weight
    
    # Adjust for return patterns
    size_adjustments = {}
    for ret in returned_sizes:
        size = ret["size"]
        if ret["too_small"]:
            # Size was too small - recommend going up
            sizes = list(size_history.keys())
            idx = sizes.index(size) if size in sizes else -1
            if idx >= 0 and idx < len(sizes) - 1:
                next_size = sizes[idx + 1]
                size_adjustments[next_size] = size_adjustments.get(next_size, 0) + 1
        elif ret["too_large"]:
            # Size was too large - recommend going down
            sizes = list(size_history.keys())
            idx = sizes.index(size) if size in sizes else -1
            if idx > 0:
                prev_size = sizes[idx - 1]
                size_adjustments[prev_size] = size_adjustments.get(prev_size, 0) + 1
    
    # Apply adjustments
    for size, adjustment in size_adjustments.items():
        weighted_scores[size] = weighted_scores.get(size, 0) + (adjustment * 0.5)
    
    # Find best predicted size
    best_size = max(weighted_scores.items(), key=lambda x: x[1])[0] if weighted_scores else "M"
    
    # Calculate confidence
    if total_purchases >= 5:
        confidence = min(95, 60 + (total_purchases * 3))
    elif total_purchases >= 3:
        confidence = 70
    else:
        confidence = 50
    
    # Reduce confidence if many returns
    if len(returned_sizes) > 2:
        confidence = max(40, confidence - (len(returned_sizes) * 5))
    
    # Category-specific prediction
    category_prediction = None
    if category and category in category_sizes:
        cat_sizes = category_sizes[category]
        if cat_sizes:
            category_prediction = max(cat_sizes.items(), key=lambda x: x[1])[0]
    
    return {
        "customer_id": customer_id,
        "customer_name": customer.get("name"),
        "predicted_size": category_prediction or best_size,
        "confidence": confidence,
        "prediction_source": "purchase_history",
        "total_purchases_analyzed": total_purchases,
        "size_distribution": {k: v for k, v in size_history.items() if v > 0},
        "category_specific": category_prediction,
        "recent_purchases": recent_sizes[:5],
        "return_analysis": {
            "total_returns": len(returned_sizes),
            "size_fit_issues": sum(1 for r in returned_sizes if r.get("too_small") or r.get("too_large"))
        },
        "recommendations": [
            f"Customer typically wears size {best_size}",
            f"Confidence level: {confidence}% based on {total_purchases} purchases",
            "Size up recommended" if any(r.get("too_small") for r in returned_sizes[-3:]) else 
            "Size down recommended" if any(r.get("too_large") for r in returned_sizes[-3:]) else
            "Current size preference seems accurate"
        ]
    }


