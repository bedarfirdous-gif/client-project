# ============== TALLY-STYLE BOOKS (DAY BOOK, CASH BOOK, BANK BOOK) ==============

@api_router.get("/books/day-book")
async def get_day_book(
    date: str = None,
    start_date: str = None,
    end_date: str = None,
    voucher_type: str = None,
    user: dict = Depends(get_current_user)
):
    """
    Day Book - Shows all voucher entries for a day or date range
    Similar to Tally's Day Book report
    """
    tenant_id = get_tenant_id(user)
    
    # Default to today if no date provided
    if not date and not start_date:
        date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    query = {
        "tenant_id": tenant_id,
        "status": "approved",
        "is_deleted": {"$ne": True}
    }
    
    if date:
        query["date"] = date
    elif start_date:
        query["date"] = {"$gte": start_date}
        if end_date:
            query["date"]["$lte"] = end_date
    
    if voucher_type:
        query["voucher_type"] = voucher_type
    
    vouchers = await db.vouchers.find(query, {"_id": 0}).sort("date", 1).to_list(1000)
    
    # Calculate totals
    total_debit = sum(v.get("total_debit", 0) for v in vouchers)
    total_credit = sum(v.get("total_credit", 0) for v in vouchers)
    
    # Group by date for multi-day reports
    by_date = {}
    for v in vouchers:
        d = v.get("date", "Unknown")
        if d not in by_date:
            by_date[d] = {"vouchers": [], "total_debit": 0, "total_credit": 0}
        by_date[d]["vouchers"].append(v)
        by_date[d]["total_debit"] += v.get("total_debit", 0)
        by_date[d]["total_credit"] += v.get("total_credit", 0)
    
    return {
        "vouchers": vouchers,
        "by_date": by_date,
        "summary": {
            "total_vouchers": len(vouchers),
            "total_debit": total_debit,
            "total_credit": total_credit,
            "date": date,
            "start_date": start_date,
            "end_date": end_date
        }
    }


@api_router.get("/books/cash-book")
async def get_cash_book(
    start_date: str = None,
    end_date: str = None,
    user: dict = Depends(get_current_user)
):
    """
    Cash Book - Shows all cash transactions (receipts and payments)
    Groups transactions by Cash ledgers
    Similar to Tally's Cash Book
    """
    tenant_id = get_tenant_id(user)
    
    # Default to current month
    if not start_date:
        now = datetime.now(timezone.utc)
        start_date = now.replace(day=1).strftime("%Y-%m-%d")
        end_date = now.strftime("%Y-%m-%d")
    
    # Find cash ledgers (under cash_in_hand group or bank_accounts)
    cash_ledgers = await db.ledgers.find({
        "tenant_id": tenant_id,
        "group_id": {"$in": ["cash_in_hand", "bank_accounts"]},
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(100)
    
    cash_ledger_ids = [l["id"] for l in cash_ledgers]
    
    # Also include ledgers explicitly under cash-in-hand or with "cash" in name
    more_cash = await db.ledgers.find({
        "tenant_id": tenant_id,
        "$or": [
            {"name": {"$regex": "cash", "$options": "i"}},
            {"group_id": "cash_in_hand"}
        ],
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(100)
    
    for l in more_cash:
        if l["id"] not in cash_ledger_ids:
            cash_ledger_ids.append(l["id"])
            cash_ledgers.append(l)
    
    # Get transactions for cash ledgers
    transactions = await db.ledger_transactions.find({
        "tenant_id": tenant_id,
        "ledger_id": {"$in": cash_ledger_ids},
        "date": {"$gte": start_date, "$lte": end_date}
    }, {"_id": 0}).sort("date", 1).to_list(5000)
    
    # Calculate opening balance
    opening_transactions = await db.ledger_transactions.find({
        "tenant_id": tenant_id,
        "ledger_id": {"$in": cash_ledger_ids},
        "date": {"$lt": start_date}
    }, {"_id": 0}).to_list(10000)
    
    opening_debit = sum(t.get("debit", 0) for t in opening_transactions)
    opening_credit = sum(t.get("credit", 0) for t in opening_transactions)
    
    # Get opening balance from ledger settings
    ledger_opening = sum(
        l.get("opening_balance", 0) * (1 if l.get("opening_balance_type", "dr") == "dr" else -1)
        for l in cash_ledgers
    )
    
    opening_balance = ledger_opening + opening_debit - opening_credit
    
    # Group by date
    by_date = {}
    running_balance = opening_balance
    
    for t in transactions:
        d = t.get("date", "Unknown")
        if d not in by_date:
            by_date[d] = {
                "transactions": [],
                "receipts": 0,
                "payments": 0,
                "opening_balance": running_balance
            }
        
        by_date[d]["transactions"].append(t)
        by_date[d]["receipts"] += t.get("debit", 0)
        by_date[d]["payments"] += t.get("credit", 0)
        running_balance += t.get("debit", 0) - t.get("credit", 0)
        by_date[d]["closing_balance"] = running_balance
    
    # Calculate totals
    total_receipts = sum(t.get("debit", 0) for t in transactions)
    total_payments = sum(t.get("credit", 0) for t in transactions)
    closing_balance = opening_balance + total_receipts - total_payments
    
    return {
        "transactions": transactions,
        "by_date": by_date,
        "cash_ledgers": cash_ledgers,
        "summary": {
            "opening_balance": opening_balance,
            "total_receipts": total_receipts,
            "total_payments": total_payments,
            "closing_balance": closing_balance,
            "start_date": start_date,
            "end_date": end_date,
            "total_transactions": len(transactions)
        }
    }


@api_router.get("/books/bank-book")
async def get_bank_book(
    start_date: str = None,
    end_date: str = None,
    bank_ledger_id: str = None,
    user: dict = Depends(get_current_user)
):
    """
    Bank Book - Shows all bank transactions
    Can filter by specific bank account
    Similar to Tally's Bank Book
    """
    tenant_id = get_tenant_id(user)
    
    # Default to current month
    if not start_date:
        now = datetime.now(timezone.utc)
        start_date = now.replace(day=1).strftime("%Y-%m-%d")
        end_date = now.strftime("%Y-%m-%d")
    
    # Find bank ledgers
    bank_query = {
        "tenant_id": tenant_id,
        "$or": [
            {"group_id": "bank_accounts"},
            {"bank_name": {"$ne": ""}},
            {"account_number": {"$ne": ""}}
        ],
        "is_deleted": {"$ne": True}
    }
    
    bank_ledgers = await db.ledgers.find(bank_query, {"_id": 0}).to_list(100)
    
    bank_ledger_ids = [l["id"] for l in bank_ledgers]
    
    # Filter by specific bank if provided
    if bank_ledger_id:
        bank_ledger_ids = [bank_ledger_id]
    
    if not bank_ledger_ids:
        return {
            "transactions": [],
            "by_date": {},
            "bank_ledgers": [],
            "summary": {
                "opening_balance": 0,
                "total_deposits": 0,
                "total_withdrawals": 0,
                "closing_balance": 0,
                "start_date": start_date,
                "end_date": end_date
            }
        }
    
    # Get transactions
    transactions = await db.ledger_transactions.find({
        "tenant_id": tenant_id,
        "ledger_id": {"$in": bank_ledger_ids},
        "date": {"$gte": start_date, "$lte": end_date}
    }, {"_id": 0}).sort("date", 1).to_list(5000)
    
    # Calculate opening balance
    opening_transactions = await db.ledger_transactions.find({
        "tenant_id": tenant_id,
        "ledger_id": {"$in": bank_ledger_ids},
        "date": {"$lt": start_date}
    }, {"_id": 0}).to_list(10000)
    
    opening_debit = sum(t.get("debit", 0) for t in opening_transactions)
    opening_credit = sum(t.get("credit", 0) for t in opening_transactions)
    
    # Get opening balance from ledger settings
    selected_ledgers = [l for l in bank_ledgers if l["id"] in bank_ledger_ids]
    ledger_opening = sum(
        l.get("opening_balance", 0) * (1 if l.get("opening_balance_type", "dr") == "dr" else -1)
        for l in selected_ledgers
    )
    
    opening_balance = ledger_opening + opening_debit - opening_credit
    
    # Group by date and bank
    by_date = {}
    by_bank = {}
    running_balance = opening_balance
    
    for t in transactions:
        d = t.get("date", "Unknown")
        lid = t.get("ledger_id")
        
        if d not in by_date:
            by_date[d] = {
                "transactions": [],
                "deposits": 0,
                "withdrawals": 0,
                "opening_balance": running_balance
            }
        
        if lid not in by_bank:
            by_bank[lid] = {"transactions": [], "deposits": 0, "withdrawals": 0}
        
        by_date[d]["transactions"].append(t)
        by_date[d]["deposits"] += t.get("debit", 0)
        by_date[d]["withdrawals"] += t.get("credit", 0)
        running_balance += t.get("debit", 0) - t.get("credit", 0)
        by_date[d]["closing_balance"] = running_balance
        
        by_bank[lid]["transactions"].append(t)
        by_bank[lid]["deposits"] += t.get("debit", 0)
        by_bank[lid]["withdrawals"] += t.get("credit", 0)
    
    # Calculate totals
    total_deposits = sum(t.get("debit", 0) for t in transactions)
    total_withdrawals = sum(t.get("credit", 0) for t in transactions)
    closing_balance = opening_balance + total_deposits - total_withdrawals
    
    return {
        "transactions": transactions,
        "by_date": by_date,
        "by_bank": by_bank,
        "bank_ledgers": bank_ledgers,
        "summary": {
            "opening_balance": opening_balance,
            "total_deposits": total_deposits,
            "total_withdrawals": total_withdrawals,
            "closing_balance": closing_balance,
            "start_date": start_date,
            "end_date": end_date,
            "total_transactions": len(transactions)
        }
    }


@api_router.get("/books/ledger-wise")
async def get_ledger_wise_report(
    ledger_id: str,
    start_date: str = None,
    end_date: str = None,
    user: dict = Depends(get_current_user)
):
    """
    Ledger-wise Report - Shows all transactions for a specific ledger
    With opening balance, transactions, and closing balance
    """
    tenant_id = get_tenant_id(user)
    
    # Get ledger info
    ledger = await db.ledgers.find_one({
        "id": ledger_id,
        "tenant_id": tenant_id,
        "is_deleted": {"$ne": True}
    }, {"_id": 0})
    
    if not ledger:
        raise HTTPException(status_code=404, detail="Ledger not found")
    
    # Default to current financial year
    if not start_date:
        now = datetime.now(timezone.utc)
        if now.month >= 4:
            start_date = f"{now.year}-04-01"
        else:
            start_date = f"{now.year - 1}-04-01"
        end_date = now.strftime("%Y-%m-%d")
    
    # Get opening transactions
    opening_transactions = await db.ledger_transactions.find({
        "tenant_id": tenant_id,
        "ledger_id": ledger_id,
        "date": {"$lt": start_date}
    }, {"_id": 0}).to_list(10000)
    
    opening_debit = sum(t.get("debit", 0) for t in opening_transactions)
    opening_credit = sum(t.get("credit", 0) for t in opening_transactions)
    
    ledger_opening = ledger.get("opening_balance", 0)
    if ledger.get("opening_balance_type", "dr") == "cr":
        ledger_opening = -ledger_opening
    
    opening_balance = ledger_opening + opening_debit - opening_credit
    
    # Get transactions in date range
    transactions = await db.ledger_transactions.find({
        "tenant_id": tenant_id,
        "ledger_id": ledger_id,
        "date": {"$gte": start_date, "$lte": end_date}
    }, {"_id": 0}).sort("date", 1).to_list(5000)
    
    # Add running balance
    running = opening_balance
    for t in transactions:
        running += t.get("debit", 0) - t.get("credit", 0)
        t["running_balance"] = running
    
    total_debit = sum(t.get("debit", 0) for t in transactions)
    total_credit = sum(t.get("credit", 0) for t in transactions)
    closing_balance = opening_balance + total_debit - total_credit
    
    return {
        "ledger": ledger,
        "transactions": transactions,
        "summary": {
            "opening_balance": opening_balance,
            "opening_balance_type": "Dr" if opening_balance >= 0 else "Cr",
            "total_debit": total_debit,
            "total_credit": total_credit,
            "closing_balance": abs(closing_balance),
            "closing_balance_type": "Dr" if closing_balance >= 0 else "Cr",
            "start_date": start_date,
            "end_date": end_date
        }
    }


@api_router.get("/books/trial-balance")
async def get_trial_balance(
    as_on_date: str = None,
