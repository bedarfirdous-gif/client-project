@api_router.get("/salary-calculator/auto-calculate")
async def auto_calculate_salary(
    employee_id: str,
    month: int,
    year: int,
    working_hours_per_day: float = 8,
    user: dict = Depends(require_permission("salary_calculator"))
):
    """
    Automatically calculate salary based on:
    - Employee's salary structure (from employee profile)
    - Daily attendance records (present/absent/late)
    - Late hours calculation from attendance in/out times
    
    Returns complete salary breakdown with hourly deductions.
    """
    tenant_id = get_tenant_id(user)
    
    # Get employee details
    employee = await db.employees.find_one({"id": employee_id, "tenant_id": tenant_id})
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Get salary structure from employee profile or salary_structures collection
    salary_structure = await db.salary_structures.find_one({
        "employee_id": employee_id,
        "is_active": True
    })
    
    # If no salary structure, use employee's salary_info
    if not salary_structure:
        salary_info = employee.get("salary_info") or {}
        salary_structure = {
            "basic_salary": salary_info.get("basic_salary", employee.get("salary", 0)),
            "hra": salary_info.get("hra", 0),
            "da": salary_info.get("da", 0),
            "conveyance": salary_info.get("conveyance", 0),
            "medical_allowance": salary_info.get("medical_allowance", 0),
            "special_allowance": salary_info.get("special_allowance", 0),
            "other_allowances": salary_info.get("other_allowances", 0),
            "daily_allowance_rate": salary_info.get("daily_allowance_rate", 100),
            "professional_tax": salary_info.get("professional_tax", 0),
            "other_deductions": salary_info.get("other_deductions", 0),
            "working_hours_per_day": salary_info.get("working_hours_per_day", 8),
            "working_days_per_month": salary_info.get("working_days_per_month", 26)
        }
    
    # Get attendance records for the month
    date_prefix = f"{year}-{month:02d}"
    attendance_records = await db.attendance.find({
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "date": {"$regex": f"^{date_prefix}"}
    }).to_list(31)
    
    # Calculate attendance statistics
    present_days = 0
    absent_days = 0
    half_days = 0
    leave_days = 0
    total_late_minutes = 0
    late_entries = []
    
    # Define expected start time (9:00 AM default, can be customized)
    expected_start_hour = 9
    expected_start_minute = 0
    
    for record in attendance_records:
        status = record.get("status", "").lower()
        
        if status == "present":
            present_days += 1
            
            # Calculate late minutes from in_time
            in_time = record.get("in_time")
            if in_time:
                try:
                    # Parse time (format: "HH:MM" or "HH:MM:SS")
                    time_parts = in_time.split(":")
                    in_hour = int(time_parts[0])
                    in_minute = int(time_parts[1]) if len(time_parts) > 1 else 0
                    
                    # Calculate late minutes
                    expected_minutes = expected_start_hour * 60 + expected_start_minute
                    actual_minutes = in_hour * 60 + in_minute
                    
                    if actual_minutes > expected_minutes:
                        late_mins = actual_minutes - expected_minutes
                        total_late_minutes += late_mins
                        late_entries.append({
                            "date": record.get("date"),
                            "in_time": in_time,
                            "late_minutes": late_mins
                        })
                except:
                    pass
                    
        elif status == "absent":
            absent_days += 1
        elif status == "half_day":
            half_days += 1
            present_days += 0.5
        elif status in ["leave", "paid_leave"]:
            leave_days += 1
    
    # Convert late minutes to hours
    total_late_hours = round(total_late_minutes / 60, 2)
    
    # Get salary values
    basic_salary = salary_structure.get("basic_salary", 0)
    hra = salary_structure.get("hra", 0)
    da = salary_structure.get("da", 0)
    conveyance = salary_structure.get("conveyance", 0)
    medical_allowance = salary_structure.get("medical_allowance", 0)
    special_allowance = salary_structure.get("special_allowance", 0)
    other_allowances = salary_structure.get("other_allowances", 0)
    daily_allowance_rate = salary_structure.get("daily_allowance_rate", 100)
    working_days_per_month = salary_structure.get("working_days_per_month", 26)
    working_hours = salary_structure.get("working_hours_per_day", working_hours_per_day)
    
    # Calculate Monthly Salary
    monthly_salary = basic_salary + hra + da + conveyance + medical_allowance + special_allowance + other_allowances
    
    # Calculate Daily Allowance Deduction
    daily_allowance_deduction = daily_allowance_rate * working_days_per_month
    
    # Gross Salary
    gross_salary = monthly_salary - daily_allowance_deduction
    
    # Per Day Rate
    per_day_rate = gross_salary / 30 if gross_salary > 0 else 0
    
    # Absent Deduction
    absent_deduction = per_day_rate * absent_days
    
    # Salary After Absence
    salary_after_absence = gross_salary - absent_deduction
    
    # Hourly Calculations
    total_monthly_hours = working_days_per_month * working_hours
    hourly_rate = gross_salary / total_monthly_hours if total_monthly_hours > 0 else 0
    late_hours_deduction = total_late_hours * hourly_rate
    
    # Overtime Calculation
    overtime_hours = 0
    overtime_entries = []
    overtime_rate_multiplier = 1.5  # 1.5x hourly rate for overtime
    
    for record in attendance_records:
        out_time = record.get("out_time")
        if out_time and record.get("status", "").lower() == "present":
            try:
                time_parts = out_time.split(":")
                out_hour = int(time_parts[0])
                out_minute = int(time_parts[1]) if len(time_parts) > 1 else 0
                
                # Standard end time (6 PM = 18:00)
                expected_end_hour = 18
                expected_end_minute = 0
                
                expected_end_minutes = expected_end_hour * 60 + expected_end_minute
                actual_end_minutes = out_hour * 60 + out_minute
                
                if actual_end_minutes > expected_end_minutes:
                    extra_mins = actual_end_minutes - expected_end_minutes
                    extra_hours = extra_mins / 60
                    overtime_hours += extra_hours
                    overtime_entries.append({
                        "date": record.get("date"),
                        "out_time": out_time,
                        "overtime_hours": round(extra_hours, 2)
                    })
            except:
                pass
    
    overtime_hours = round(overtime_hours, 2)
    overtime_pay = round(overtime_hours * hourly_rate * overtime_rate_multiplier, 2)
    
    # Get active loan with auto-deduct for this employee
    active_loan = await db.employee_loans.find_one({
        "employee_id": employee_id,
        "tenant_id": tenant_id,
        "status": "active",
        "repayment_method": "auto_deduct"
    })
    
    loan_emi_deduction = 0
    loan_info = None
    if active_loan and active_loan.get("remaining_amount", 0) > 0:
        loan_emi_deduction = min(
            active_loan.get("emi_amount", 0),
            active_loan.get("remaining_amount", 0)
        )
        loan_info = {
            "loan_id": active_loan.get("id"),
            "total_loan": active_loan.get("amount"),
            "remaining": active_loan.get("remaining_amount"),
            "emi_amount": loan_emi_deduction
        }
    
    # Combined Final Salary (with overtime added)
    combined_final_salary = max(0, salary_after_absence - late_hours_deduction + overtime_pay)
    
    # Additional deductions
    professional_tax = salary_structure.get("professional_tax", 0)
    other_deductions = salary_structure.get("other_deductions", 0)
    total_statutory_deductions = professional_tax + other_deductions + loan_emi_deduction
    
    # Net Salary (after all deductions)
    net_salary = max(0, combined_final_salary - total_statutory_deductions)
    
    return {
        "employee": {
            "id": employee_id,
            "name": employee.get("name"),
            "email": employee.get("email"),
            "department": employee.get("department"),
            "designation": employee.get("designation"),
            "store_id": employee.get("store_id")
        },
        "period": {
            "month": month,
            "year": year,
            "working_days_per_month": working_days_per_month,
            "working_hours_per_day": working_hours
        },
        "attendance": {
            "total_records": len(attendance_records),
            "present_days": present_days,
            "absent_days": absent_days,
            "half_days": half_days,
            "leave_days": leave_days,
            "worked_days": present_days + (half_days * 0.5),
            "total_late_minutes": total_late_minutes,
            "total_late_hours": total_late_hours,
            "late_entries": late_entries[:10],
            "overtime_hours": overtime_hours,
            "overtime_entries": overtime_entries[:10]
        },
        "salary_structure": {
            "basic_salary": basic_salary,
            "hra": hra,
            "da": da,
            "conveyance": conveyance,
            "medical_allowance": medical_allowance,
            "special_allowance": special_allowance,
            "other_allowances": other_allowances,
            "monthly_salary": monthly_salary,
            "daily_allowance_rate": daily_allowance_rate
        },
        "calculations": {
            "daily_allowance_deduction": round(daily_allowance_deduction, 2),
            "gross_salary": round(gross_salary, 2),
            "per_day_rate": round(per_day_rate, 2),
            "absent_deduction": round(absent_deduction, 2),
            "salary_after_absence": round(salary_after_absence, 2),
            "total_monthly_hours": total_monthly_hours,
            "hourly_rate": round(hourly_rate, 2),
            "late_hours_deduction": round(late_hours_deduction, 2),
            "overtime_hours": overtime_hours,
            "overtime_rate": round(hourly_rate * overtime_rate_multiplier, 2),
            "overtime_pay": overtime_pay,
            "combined_final_salary": round(combined_final_salary, 2),
            "professional_tax": professional_tax,
            "other_deductions": other_deductions,
            "loan_emi_deduction": loan_emi_deduction,
            "total_deductions": round(daily_allowance_deduction + absent_deduction + late_hours_deduction + total_statutory_deductions, 2),
            "net_salary": round(net_salary, 2)
        },
        "loan_deduction": loan_info,
        "summary": {
            "monthly_salary": round(monthly_salary, 2),
            "overtime_pay": overtime_pay,
            "total_deductions": round(daily_allowance_deduction + absent_deduction + late_hours_deduction + total_statutory_deductions, 2),
            "final_salary_to_pay": round(net_salary, 2)
        }
    }


@api_router.post("/payroll/generate")
async def generate_payroll(
    employee_id: str,
    month: int,
    year: int,
    user: dict = Depends(require_permission("payroll"))
):
    tenant_id = get_tenant_id(user)
    
    # Get employee
    employee = await db.employees.find_one({"id": employee_id})
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Get salary structure
    structure = await db.salary_structures.find_one({
        "employee_id": employee_id,
        "is_active": True
    })
    
    if not structure:
        raise HTTPException(status_code=400, detail="No active salary structure")
    
    # Count attendance
    attendance = await db.attendance.find({
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "date": {"$regex": f"^{year}-{month:02d}"}
    }).to_list(31)
    
    present_days = sum(1 for a in attendance if a.get("status") == "present")
    absent_days = sum(1 for a in attendance if a.get("status") == "absent")
    half_days = sum(1 for a in attendance if a.get("status") == "half_day")
    leave_days = sum(1 for a in attendance if a.get("status") == "leave")
    
    # Calculate salary
    basic = structure.get("basic_salary", 0)
    gross = basic + structure.get("hra", 0) + structure.get("da", 0) + \
            structure.get("conveyance", 0) + structure.get("medical_allowance", 0) + \
            structure.get("special_allowance", 0) + structure.get("other_allowances", 0)
    
    deductions = structure.get("professional_tax", 0) + structure.get("other_deductions", 0)
    net_salary = gross - deductions
    
    payroll_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "store_id": employee.get("store_id"),
        "month": month,
        "year": year,
        "working_days": 26,
        "present_days": present_days,
        "absent_days": absent_days,
        "leave_days": leave_days,
        "half_days": half_days,
        "basic_salary": basic,
        "hra": structure.get("hra", 0),
        "da": structure.get("da", 0),
        "conveyance": structure.get("conveyance", 0),
        "medical_allowance": structure.get("medical_allowance", 0),
        "special_allowance": structure.get("special_allowance", 0),
        "other_allowances": structure.get("other_allowances", 0),
        "gross_salary": gross,
        "professional_tax": structure.get("professional_tax", 0),
        "other_deductions": structure.get("other_deductions", 0),
        "total_deductions": deductions,
        "net_salary": net_salary,
        "status": "draft",
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Check if payroll exists
    existing = await db.payroll.find_one({
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "month": month,
        "year": year
    })
    
    if existing:
        await db.payroll.update_one({"id": existing["id"]}, {"$set": payroll_doc})
        payroll_doc["id"] = existing["id"]
    else:
        await db.payroll.insert_one(payroll_doc)
    
    if "_id" in payroll_doc:
        del payroll_doc["_id"]
    return payroll_doc

