# ============== AUTO PURCHASE ORDER SYSTEM ==============

async def check_and_create_auto_purchase_order(
    tenant_id: str,
    item_id: str,
    variant_id: str,
    current_stock: int,
    triggered_by: str = "stock_deduction",
    user_id: str = None
):
    """
    Check if stock is below minimum and create auto purchase order if enabled.
    Returns the created purchase order ID if one was created, None otherwise.
    """
    try:
        # Get item details
        item = await db.items.find_one({"id": item_id, "tenant_id": tenant_id}, {"_id": 0})
        if not item:
            return None
        
        min_stock = item.get("min_stock_alert", 5)
        reorder_qty = item.get("reorder_quantity", 0) or (min_stock * 2)  # Default to 2x min stock
        preferred_supplier_id = item.get("preferred_supplier_id")
        
        # Check if stock is below minimum
        if current_stock > min_stock:
            return None
        
        # Check if auto-reorder is enabled for this tenant
        settings = await db.app_settings.find_one({"tenant_id": tenant_id, "key": "auto_reorder"})
        if not settings or not settings.get("value", {}).get("enabled", False):
            return None
        
        # Check if there's already a pending purchase order for this item
        existing_po = await db.purchase_orders.find_one({
            "tenant_id": tenant_id,
            "status": {"$in": ["draft", "pending", "approved"]},
            "items.item_id": item_id,
            "is_auto_generated": True
        })
        
        if existing_po:
            logger.info(f"Auto PO already exists for item {item_id}: {existing_po.get('id')}")
            return None
        
        # Get supplier - use preferred or first available
        supplier = None
        if preferred_supplier_id:
            supplier = await db.suppliers.find_one({"id": preferred_supplier_id, "tenant_id": tenant_id})
        
        if not supplier:
            # Get any active supplier
            supplier = await db.suppliers.find_one({"tenant_id": tenant_id, "is_active": {"$ne": False}})
        
        if not supplier:
            logger.warning(f"No supplier found for auto PO - item {item_id}")
            return None
        
        # Get variant details
        variant = await db.variants.find_one({"id": variant_id}, {"_id": 0}) if variant_id else None
        cost_price = variant.get("cost_price", 0) if variant else item.get("cost_price", 0)
        
        # Get default store
        store = await db.stores.find_one({"tenant_id": tenant_id, "is_main": True})
        if not store:
            store = await db.stores.find_one({"tenant_id": tenant_id})
        
        store_id = store.get("id") if store else "default"
        
        # Generate PO number
        count = await db.purchase_orders.count_documents({"tenant_id": tenant_id})
        po_number = f"AUTO-PO-{count + 1:06d}"
        
        # Create purchase order
        po_id = str(uuid.uuid4())
        po_item = {
            "item_id": item_id,
            "variant_id": variant_id,
            "name": item.get("name", ""),
            "sku": item.get("sku", ""),
            "quantity": reorder_qty,
            "rate": cost_price,
            "amount": cost_price * reorder_qty,
            "size": variant.get("size", "") if variant else "",
            "color": variant.get("color", "") if variant else ""
        }
        
        subtotal = cost_price * reorder_qty
        
        po_doc = {
            "id": po_id,
            "tenant_id": tenant_id,
            "po_number": po_number,
            "supplier_id": supplier.get("id"),
            "supplier_name": supplier.get("name", ""),
            "store_id": store_id,
            "items": [po_item],
            "subtotal": subtotal,
            "tax_amount": 0,
            "total_amount": subtotal,
            "status": "draft",  # Start as draft for review
            "is_auto_generated": True,
            "auto_trigger": triggered_by,
            "current_stock_at_creation": current_stock,
            "min_stock_alert": min_stock,
            "notes": f"Auto-generated: Stock ({current_stock}) fell below minimum ({min_stock})",
            "created_by": user_id or "system",
            "created_at": datetime.now(timezone.utc).isoformat()
        }
        
        await db.purchase_orders.insert_one(po_doc)
        
        # Create notification
        await db.notifications.insert_one({
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "type": "auto_purchase_order",
            "title": "Auto Purchase Order Created",
            "message": f"Low stock alert: {item.get('name')} ({current_stock} left). Auto PO #{po_number} created for {reorder_qty} units.",
            "data": {
                "po_id": po_id,
                "po_number": po_number,
                "item_id": item_id,
                "item_name": item.get("name"),
                "current_stock": current_stock,
                "min_stock": min_stock,
                "reorder_qty": reorder_qty
            },
            "is_read": False,
            "created_at": datetime.now(timezone.utc).isoformat()
        })
        
        logger.info(f"Auto PO created: {po_number} for item {item.get('name')} - qty: {reorder_qty}")
        return po_id
        
    except Exception as e:
        logger.error(f"Error creating auto purchase order: {e}")
        return None


