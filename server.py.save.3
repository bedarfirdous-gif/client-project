@api_router.post("/invoices/{invoice_id}/payment")
async def add_invoice_payment(invoice_id: str, method: str, amount: float, user: dict = Depends(get_current_user)):
    """Add a payment to an existing invoice"""
    invoice = await db.invoices.find_one({"id": invoice_id})
    if not invoice:
        raise HTTPException(status_code=404, detail="Invoice not found")
    
    payment = {
        "method": method,
        "amount": amount,
        "received_by": user.get("id"),
        "received_at": datetime.now(timezone.utc).isoformat()
    }
    
    new_paid = invoice.get("amount_paid", 0) + amount
    final_amount = invoice.get("final_amount", invoice.get("total_amount", 0))
    
    if new_paid >= final_amount:
        status = "paid"
    elif new_paid > 0:
        status = "partial"
    else:
        status = "unpaid"
    
    await db.invoices.update_one(
        {"id": invoice_id},
        {
            "$push": {"payment_methods": payment},
            "$set": {
                "amount_paid": new_paid,
                "balance_due": max(0, final_amount - new_paid),
                "status": status,
                "updated_at": datetime.now(timezone.utc).isoformat()
            }
        }
    )
    
    return {"message": "Payment added", "new_balance": max(0, final_amount - new_paid)}


