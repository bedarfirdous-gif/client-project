# Recovery login with backup code (no auth required)
@api_router.post("/auth/recover-with-backup-code")
async def recover_with_backup_code(
    email: str = Body(...),
    backup_code: str = Body(...)
):
    """Login using backup code when password is forgotten - available for all users"""
    
    # Find the user
    user = await db.users.find_one({"email": email.lower()})
    if not user:
        raise HTTPException(status_code=400, detail="Invalid email or backup code")
    
    # Find and verify backup code
    backup_codes = await db.backup_codes.find({"user_id": user.get("id"), "used": False}).to_list(100)
    
    valid_code = None
    for bc in backup_codes:
        if verify_password(backup_code.upper().replace("-", "").replace(" ", ""), bc.get("code_hash")):
            valid_code = bc
            break
    
    if not valid_code:
        raise HTTPException(status_code=400, detail="Invalid email or backup code")
    
    # Mark code as used
    await db.backup_codes.update_one(
        {"id": valid_code["id"]},
        {"$set": {"used": True, "used_at": datetime.now(timezone.utc).isoformat()}}
    )
    
    # Generate token
    token = create_access_token({"sub": user["id"], "tenant_id": user.get("tenant_id")})
    
    # Log recovery to appropriate audit table based on role
    audit_entry = {
        "id": str(uuid.uuid4()),
        "action": "backup_code_recovery",
        "user_id": user.get("id"),
        "user_email": user.get("email"),
        "user_role": user.get("role"),
        "tenant_id": user.get("tenant_id"),
        "timestamp": datetime.now(timezone.utc).isoformat()
    }
    
    if user.get("role") == "superadmin":
        await db.superadmin_audit.insert_one(audit_entry)
    else:
        await db.audit_trail.insert_one(audit_entry)
    
    user_data = {k: v for k, v in user.items() if k not in ["_id", "password", "backup_codes"]}
    user_data["recovered_with_backup_code"] = True
    
    return {
        "access_token": token,
        "token_type": "bearer",
        "user": user_data,
        "message": "Login successful. Please change your password immediately.",
        "remaining_codes": await db.backup_codes.count_documents({"user_id": user.get("id"), "used": False})
    }


