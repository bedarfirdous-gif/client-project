@api_router.put("/users/{user_id}")
async def update_user(user_id: str, request: UserUpdate, user: dict = Depends(get_current_user)):
    if user.get("role") != "admin" and user.get("id") != user_id:
        raise HTTPException(status_code=403, detail="Not authorized")
    
    tenant_id = get_tenant_id(user)
    existing_user = await db.users.find_one({"id": user_id})
    if not existing_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    update_data = {k: v for k, v in request.model_dump().items() if v is not None}
    
    # Hash password if provided
    if "password" in update_data and update_data["password"]:
        update_data["password"] = hash_password(update_data["password"])
    
    # Determine audit action type
    audit_action = "user_updated"
    audit_details = {}
    
    if "is_active" in update_data:
        if update_data["is_active"] is False and existing_user.get("is_active", True):
            audit_action = "user_deactivated"
        elif update_data["is_active"] is True and not existing_user.get("is_active", True):
            audit_action = "user_reactivated"
        audit_details["is_active"] = update_data["is_active"]
    
    if "role" in update_data and update_data["role"] != existing_user.get("role"):
        audit_action = "role_changed"
        audit_details["old_role"] = existing_user.get("role")
        audit_details["new_role"] = update_data["role"]
    
    if "permissions" in update_data:
        audit_action = "permissions_changed"
        audit_details["permissions"] = update_data["permissions"]
    
    update_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    update_data["updated_by"] = user.get("id")
    
    if update_data:
        await db.users.update_one({"id": user_id}, {"$set": update_data})
    
    # Create audit trail entry
    await db.audit_trail.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "action": audit_action,
        "entity_type": "user",
        "entity_id": user_id,
        "entity_name": existing_user.get("name"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "details": audit_details,
        "created_at": datetime.now(timezone.utc).isoformat()
    })
    
    updated = await db.users.find_one({"id": user_id}, {"_id": 0, "password": 0})
    return updated

@api_router.put("/users/{user_id}/permissions")
async def update_user_permissions(user_id: str, request: dict, user: dict = Depends(get_current_user)):
    """
    Update user permissions with hierarchical control:
    - SuperAdmin can grant any permission to anyone
    - Admin can only grant permissions they themselves have to their users
    - Users cannot grant permissions
    """
    tenant_id = get_tenant_id(user)
    current_role = user.get("role", "")
    current_permissions = user.get("permissions", {})
    
    # Only admin and superadmin can update permissions
    if current_role not in ["admin", "superadmin", "manager"]:
        raise HTTPException(status_code=403, detail="Only Admin or SuperAdmin can modify permissions")
    
    # Get target user
    if is_superadmin(user):
        existing_user = await db.users.find_one({"id": user_id})
    else:
        existing_user = await db.users.find_one({"id": user_id, "tenant_id": tenant_id})
    
    if not existing_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    target_role = existing_user.get("role", "")
    requested_permissions = request.get("permissions", {})
    assigned_role_id = request.get("assigned_role_id")
    
    # HIERARCHY ENFORCEMENT
    # 1. Cannot modify superadmin permissions
    if target_role == "superadmin":
        raise HTTPException(status_code=403, detail="SuperAdmin permissions cannot be modified. SuperAdmin has all permissions by default.")
    
    # 2. Only superadmin can modify admin permissions
    if target_role == "admin" and not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Only SuperAdmin can modify Admin permissions")
    
    # 3. Admin can only grant permissions they have (not superadmin)
    if not is_superadmin(user):
        for perm_key, perm_value in requested_permissions.items():
            if perm_value and not current_permissions.get(perm_key, False):
                raise HTTPException(
                    status_code=403, 
                    detail=f"You cannot grant '{perm_key}' permission as you don't have it yourself"
                )
    
    update_data = {
        "permissions": requested_permissions,
        "permissions_granted_by": user.get("id"),
        "permissions_granted_by_role": current_role,
        "updated_at": datetime.now(timezone.utc).isoformat(),
        "updated_by": user.get("id")
    }
    
    # Include assigned_role_id if provided (can be None to clear)
    if "assigned_role_id" in request:
        update_data["assigned_role_id"] = assigned_role_id
    
    await db.users.update_one(
        {"id": user_id},
        {"$set": update_data}
    )
    
    # Create audit trail entry
    audit_details = {
        "permissions": requested_permissions,
        "granted_by_role": current_role
    }
    if assigned_role_id:
        audit_details["assigned_role_id"] = assigned_role_id
    
    await db.audit_trail.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "action": "permissions_changed",
        "entity_type": "user",
        "entity_id": user_id,
        "entity_name": existing_user.get("name"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "details": audit_details,
        "created_at": datetime.now(timezone.utc).isoformat()
    })
    
    updated = await db.users.find_one({"id": user_id}, {"_id": 0, "password": 0})
    return updated


@api_router.get("/admin/my-grantable-permissions")
async def get_my_grantable_permissions(user: dict = Depends(get_current_user)):
    """
    Get the list of permissions the current user can grant to others.
    - SuperAdmin: All permissions
    - Admin: Only permissions they have
    - Others: None
    """
    if is_superadmin(user):
        return {
            "can_grant": True,
            "grantable_permissions": DEFAULT_ROLE_PERMISSIONS["superadmin"],
            "role": "superadmin",
            "message": "SuperAdmin can grant all permissions"
        }
    
    if user.get("role") == "admin":
        user_permissions = user.get("permissions", DEFAULT_ROLE_PERMISSIONS.get("admin", {}))
        grantable = {k: v for k, v in user_permissions.items() if v}
        return {
            "can_grant": True,
            "grantable_permissions": grantable,
            "role": "admin",
            "message": "You can only grant permissions you have"
        }
    
    if user.get("role") == "manager":
        user_permissions = user.get("permissions", DEFAULT_ROLE_PERMISSIONS.get("manager", {}))
        # Managers can grant limited permissions
        limited_perms = ["pos", "items", "inventory", "customers", "sales_history"]
        grantable = {k: v for k, v in user_permissions.items() if v and k in limited_perms}
        return {
            "can_grant": True,
            "grantable_permissions": grantable,
            "role": "manager", 
            "message": "Managers can grant limited permissions"
        }
    
    return {
        "can_grant": False,
        "grantable_permissions": {},
        "role": user.get("role"),
        "message": "You do not have permission to grant access to others"
    }


