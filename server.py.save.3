        columns = ['Customer', 'Opening', 'Sales', 'Receipts', 'Returns', 'Balance']
        data = [[
            d.get('customer_name', ''),
            f"₹{d.get('opening_balance', 0):,.2f}",
            f"₹{d.get('total_sales', 0):,.2f}",
            f"₹{d.get('total_receipts', 0):,.2f}",
            f"₹{d.get('total_returns', 0):,.2f}",
            f"₹{d.get('current_balance', 0):,.2f}"
        ] for d in entries]
        summary = {"total_customers": len(entries)}
        
    elif ledger_type == 'creditors':
        entries = await db.creditor_ledger.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(None)
        title = "Creditor Ledger (Suppliers)"
        columns = ['Supplier', 'Opening', 'Purchases', 'Payments', 'Returns', 'Balance']
        data = [[
            c.get('supplier_name', ''),
            f"₹{c.get('opening_balance', 0):,.2f}",
            f"₹{c.get('total_purchases', 0):,.2f}",
            f"₹{c.get('total_payments', 0):,.2f}",
            f"₹{c.get('total_returns', 0):,.2f}",
            f"₹{c.get('current_balance', 0):,.2f}"
        ] for c in entries]
        summary = {"total_suppliers": len(entries)}
        
    elif ledger_type == 'cash':
        settings = await db.accounting_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
        opening_cash = settings.get("opening_cash_balance", 0) if settings else 0
        
        query = {"tenant_id": tenant_id, "payment_mode": "cash"}
        if start_date:
            query["date"] = {"$gte": start_date}
        if end_date:
            query["date"] = {**query.get("date", {}), "$lte": end_date}
        entries = await db.central_ledger.find(query, {"_id": 0}).sort("date", 1).to_list(None)
        
        title = "Cash Ledger"
        columns = ['Date', 'Description', 'Reference', 'Type', 'Debit (In)', 'Credit (Out)', 'Balance']
        running_balance = opening_cash
        data = []
        for e in entries:
            if e.get("entry_type") in ["receipt", "sale"]:
                running_balance += e.get("amount", 0)
                data.append([e.get('date', ''), e.get('party_name', ''), e.get('reference_number', ''), 
                            e.get('entry_type', ''), f"₹{e.get('amount', 0):,.2f}", '-', f"₹{running_balance:,.2f}"])
            else:
                running_balance -= e.get("amount", 0)
                data.append([e.get('date', ''), e.get('party_name', ''), e.get('reference_number', ''),
                            e.get('entry_type', ''), '-', f"₹{e.get('amount', 0):,.2f}", f"₹{running_balance:,.2f}"])
        summary = {"opening_balance": opening_cash, "closing_balance": running_balance}
        
    elif ledger_type == 'bank':
        settings = await db.accounting_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
        opening_bank = settings.get("opening_bank_balance", 0) if settings else 0
        
        query = {"tenant_id": tenant_id, "payment_mode": {"$in": ["bank", "upi", "card", "bank_transfer", "cheque"]}}
        if start_date:
            query["date"] = {"$gte": start_date}
        if end_date:
            query["date"] = {**query.get("date", {}), "$lte": end_date}
        entries = await db.central_ledger.find(query, {"_id": 0}).sort("date", 1).to_list(None)
        
        title = "Bank Ledger"
        columns = ['Date', 'Description', 'Reference', 'Mode', 'Type', 'Debit (In)', 'Credit (Out)', 'Balance']
        running_balance = opening_bank
        data = []
        for e in entries:
            if e.get("entry_type") in ["receipt", "sale"]:
                running_balance += e.get("amount", 0)
                data.append([e.get('date', ''), e.get('party_name', ''), e.get('reference_number', ''),
                            e.get('payment_mode', '').upper(), e.get('entry_type', ''), 
                            f"₹{e.get('amount', 0):,.2f}", '-', f"₹{running_balance:,.2f}"])
            else:
                running_balance -= e.get("amount", 0)
                data.append([e.get('date', ''), e.get('party_name', ''), e.get('reference_number', ''),
                            e.get('payment_mode', '').upper(), e.get('entry_type', ''),
                            '-', f"₹{e.get('amount', 0):,.2f}", f"₹{running_balance:,.2f}"])
        summary = {"opening_balance": opening_bank, "closing_balance": running_balance}
        
    elif ledger_type == 'purchases':
        query = {"tenant_id": tenant_id}
        if start_date:
            query["invoice_date"] = {"$gte": start_date}
        if end_date:
            query["invoice_date"] = {**query.get("invoice_date", {}), "$lte": end_date}
        entries = await db.purchase_invoices.find(query, {"_id": 0}).sort("invoice_date", -1).to_list(None)
        
        title = "Purchase Ledger"
        columns = ['Date', 'Invoice No.', 'Supplier', 'Amount', 'GST', 'Total', 'Status']
        data = [[
            e.get('invoice_date', ''),
            e.get('invoice_number', ''),
            e.get('supplier_name', ''),
            f"₹{(e.get('subtotal', 0) or e.get('taxable_amount', 0) or 0):,.2f}",
            f"₹{(e.get('total_gst', 0) or e.get('gst_amount', 0) or 0):,.2f}",
            f"₹{(e.get('total_amount', 0) or 0):,.2f}",
            e.get('payment_status', '')
        ] for e in entries]
        total = sum(e.get('total_amount', 0) or 0 for e in entries)
        summary = {"total_invoices": len(entries), "total_amount": total}
        
    elif ledger_type == 'sales':
        query = {"tenant_id": tenant_id}
        if start_date:
            query["date"] = {"$gte": start_date}
        if end_date:
            query["date"] = {**query.get("date", {}), "$lte": end_date}
        entries = await db.invoices.find(query, {"_id": 0}).sort("date", -1).to_list(None)
        
        title = "Sales Ledger"
        columns = ['Date', 'Invoice No.', 'Customer', 'Amount', 'GST', 'Total', 'Payment', 'Status']
        data = [[
            e.get('date', ''),
            e.get('invoice_number', ''),
            e.get('customer_name', '') or e.get('customer', {}).get('name', 'Walk-in'),
            f"₹{(e.get('subtotal', 0) or e.get('taxable_amount', 0) or 0):,.2f}",
            f"₹{(e.get('total_gst', 0) or e.get('gst_amount', 0) or 0):,.2f}",
            f"₹{(e.get('total', 0) or e.get('total_amount', 0) or 0):,.2f}",
            (e.get('payment_method', '') or '').upper(),
            e.get('payment_status', 'paid')
        ] for e in entries]
        total = sum(e.get('total', 0) or e.get('total_amount', 0) or 0 for e in entries)
        summary = {"total_invoices": len(entries), "total_amount": total}
        
    else:
        raise HTTPException(status_code=400, detail="Invalid ledger type")
    
    # Generate file
    if format == 'pdf':
        buffer = create_ledger_pdf(title, columns, data, summary, company_info)
        media_type = "application/pdf"
        filename = f"{ledger_type}_ledger_{datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf"
    else:
        buffer = create_ledger_excel(title, columns, data, summary)
        media_type = "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
        filename = f"{ledger_type}_ledger_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"
    
    return StreamingResponse(
        buffer,
        media_type=media_type,
        headers={"Content-Disposition": f"attachment; filename={filename}"}
    )

