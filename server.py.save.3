    # Get unique sessions with latest message
    pipeline = [
        {"$sort": {"timestamp": -1}},
        {"$group": {
            "_id": "$session_id",
            "last_message": {"$first": "$content"},
            "last_timestamp": {"$first": "$timestamp"},
            "message_count": {"$sum": 1}
        }},
        {"$sort": {"last_timestamp": -1}},
        {"$limit": limit}
    ]
    
    sessions = await swarm_orchestrator.conversations.aggregate(pipeline).to_list(limit)
    return {"sessions": sessions}

