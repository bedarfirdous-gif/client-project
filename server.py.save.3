@api_router.put("/stock-transfers/{transfer_id}/receive")
async def receive_stock_transfer(transfer_id: str, body: dict = Body(...), user: dict = Depends(get_current_user)):
    """Receiver confirms receipt of stock transfer"""
    transfer = await db.stock_transfers.find_one({"id": transfer_id})
    if not transfer:
        raise HTTPException(status_code=404, detail="Transfer not found")
    
    if transfer.get("status") != "approved":
        raise HTTPException(status_code=400, detail="Transfer must be approved before receiving")
    
    # Get received items with any discrepancies
    received_items = body.get("received_items", [])
    notes = body.get("notes", "")
    
    # Check for discrepancies
    discrepancies = []
    for item in transfer.get("items", []):
        received = next((r for r in received_items if r.get("variant_id") == item.get("variant_id")), None)
        if received:
            expected_qty = item.get("quantity", 0)
            actual_qty = received.get("quantity", 0)
            if expected_qty != actual_qty:
                discrepancies.append({
                    "variant_id": item.get("variant_id"),
                    "item_name": item.get("item_name"),
                    "expected": expected_qty,
                    "received": actual_qty,
                    "difference": actual_qty - expected_qty
                })
    
    await db.stock_transfers.update_one(
        {"id": transfer_id},
        {"$set": {
            "status": "received",
            "received_by": user.get("name"),
            "received_at": datetime.now(timezone.utc).isoformat(),
            "received_items": received_items,
            "receiver_notes": notes,
            "discrepancies": discrepancies,
            "has_discrepancies": len(discrepancies) > 0
        }}
    )
    
    result = {"message": "Transfer received successfully", "status": "received"}
    if discrepancies:
        result["discrepancies"] = discrepancies
        result["warning"] = f"Found {len(discrepancies)} item(s) with quantity discrepancies"
    
    return result

