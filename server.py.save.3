@api_router.get("/posters/business-info")
async def get_business_info_for_posters(user: dict = Depends(get_current_user)):
    """Get business info for poster branding - fetches from multiple sources"""
    tenant_id = get_tenant_id(user)
    user_id = user.get("id")
    
    business_name = None
    brand_colors = ["#6366F1", "#EC4899", "#F59E0B"]
    logo_url = None
    
    # 1. Try businesses collection
    business = await db.businesses.find_one({"tenant_id": tenant_id}, {"_id": 0})
    if business:
        business_name = business.get("name")
        brand_colors = business.get("brand_colors", brand_colors)
        logo_url = business.get("logo_url")
    
    # 2. Try user invoice settings (company_name)
    if not business_name:
        invoice_settings = await db.user_invoice_settings.find_one({"user_id": user_id}, {"_id": 0})
        if invoice_settings and invoice_settings.get("company_name"):
            business_name = invoice_settings.get("company_name")
            logo_url = logo_url or invoice_settings.get("company_logo")
    
    # 3. Try admin's business_name from users collection
    if not business_name:
        admin_user = await db.users.find_one(
            {"tenant_id": tenant_id, "role": {"$in": ["admin", "superadmin"]}},
            {"_id": 0, "business_name": 1, "name": 1}
        )
        if admin_user:
            business_name = admin_user.get("business_name") or admin_user.get("name")
    
    # 4. Try current user's business_name
    if not business_name:
        business_name = user.get("business_name") or user.get("name", "Your Business")
    
    # 5. Try stores collection
    if not business_name or business_name == "Your Business":
        store = await db.stores.find_one({"tenant_id": tenant_id}, {"_id": 0, "name": 1})
        if store and store.get("name"):
            business_name = store.get("name")
    
    return {
        "business_name": business_name or "Your Business",
        "brand_colors": brand_colors,
        "logo_url": logo_url,
        "tenant_id": tenant_id
    }


