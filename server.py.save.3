@api_router.get("/customers")
async def list_customers(search: str = "", user: dict = Depends(require_permission("customers"))):
    """Get all customers with their linked ledger information"""
    tenant_id = get_tenant_id(user)
    query = {"tenant_id": tenant_id}
    
    if search:
        query["$or"] = [
            {"name": {"$regex": search, "$options": "i"}},
            {"phone": {"$regex": search, "$options": "i"}},
            {"email": {"$regex": search, "$options": "i"}}
        ]
    
    customers = await db.customers.find(query, {"_id": 0}).sort("created_at", -1).to_list(1000)
    
    # Enrich customers with their linked ledger info
    for customer in customers:
        if customer.get("ledger_id"):
            ledger = await db.ledgers.find_one(
                {"id": customer["ledger_id"], "tenant_id": tenant_id, "is_deleted": {"$ne": True}},
                {"_id": 0, "id": 1, "name": 1, "opening_balance": 1, "opening_balance_type": 1}
            )
            customer["ledger"] = ledger
    
    return customers

@api_router.get("/customers/with-ledgers")
async def list_customers_with_ledgers(user: dict = Depends(require_permission("customers"))):
    """
    Get customers OR Sundry Debtor ledgers for sales invoice dropdown.
    This allows selecting from both existing customers AND directly from ledger management.
    """
    tenant_id = get_tenant_id(user)
    
    # Get all active customers
    customers = await db.customers.find({
        "tenant_id": tenant_id,
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(1000)
    
    # Get all Sundry Debtor ledgers that might not be linked to customers
    debtor_ledgers = await db.ledgers.find({
        "tenant_id": tenant_id,
        "group_id": "sundry_debtors",
        "is_deleted": {"$ne": True},
        "is_active": True
    }, {"_id": 0}).to_list(1000)
    
    # Create a map of ledger IDs already linked to customers
    linked_ledger_ids = set(c.get("ledger_id") for c in customers if c.get("ledger_id"))
    
    # Build combined result
    result = []
    
    # Add customers with their ledger info
    for customer in customers:
        entry = {
            "id": customer["id"],
            "name": customer["name"],
            "type": "customer",
            "phone": customer.get("phone", ""),
            "email": customer.get("email", ""),
            "gst_number": customer.get("gst_number", ""),
            "state": customer.get("state", ""),
            "address": customer.get("address", ""),
            "ledger_id": customer.get("ledger_id"),
            "customer_id": customer["id"],
            "loyalty_points": customer.get("loyalty_points", 0)
        }
        if customer.get("ledger_id"):
            ledger = await db.ledgers.find_one(
                {"id": customer["ledger_id"], "tenant_id": tenant_id},
                {"_id": 0, "opening_balance": 1, "opening_balance_type": 1}
            )
            if ledger:
                entry["opening_balance"] = ledger.get("opening_balance", 0)
                entry["balance_type"] = ledger.get("opening_balance_type", "Dr")
        result.append(entry)
    
    # Add unlinked debtor ledgers as potential customers
    for ledger in debtor_ledgers:
        if ledger["id"] not in linked_ledger_ids:
            result.append({
                "id": ledger["id"],
                "name": ledger["name"],
                "type": "ledger",
                "phone": ledger.get("phone", ""),
                "email": ledger.get("email", ""),
                "gst_number": ledger.get("gstin", ""),
                "state": ledger.get("state", ""),
                "address": ledger.get("address", ""),
                "ledger_id": ledger["id"],
                "opening_balance": ledger.get("opening_balance", 0),
                "balance_type": ledger.get("opening_balance_type", "Dr")
            })
    
    return result

@api_router.get("/customers/{customer_id}")
async def get_customer(customer_id: str, user: dict = Depends(require_permission("customers"))):
    customer = await db.customers.find_one({"id": customer_id}, {"_id": 0})
