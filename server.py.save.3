@api_router.post("/virtual-tryon/simulate")
async def simulate_virtual_tryon(
    clothing_id: str = Body(...),
    measurements: dict = Body(...),
    size_recommendation: dict = Body(None),
    user: dict = Depends(get_current_user)
):
    """Simulate virtual try-on"""
    tenant_id = get_tenant_id(user)
    
    # Get clothing item
    clothing = await db.items.find_one(
        {"id": clothing_id, "tenant_id": tenant_id},
        {"_id": 0}
    )
    
    if not clothing:
        raise HTTPException(status_code=404, detail="Clothing item not found")
    
    # Generate fit analysis
    recommended_size = size_recommendation.get("recommendedSize", "M") if size_recommendation else "M"
    
    # Check if size is available
    available_sizes = clothing.get("sizes", ["S", "M", "L", "XL"])
    size_available = recommended_size in available_sizes
    
    # Calculate fit scores
    fit_score = 85  # Base score
    if size_recommendation:
        fit_analysis = size_recommendation.get("fitAnalysis", {})
        perfect_fits = sum(1 for v in fit_analysis.values() if v == "perfect")
        fit_score = 70 + (perfect_fits * 10)
    
    result = {
        "clothing_id": clothing_id,
        "clothing_name": clothing.get("name"),
        "clothing_image": clothing.get("image"),
        "recommended_size": recommended_size,
        "size_available": size_available,
        "available_sizes": available_sizes,
        "fit_score": fit_score,
        "fit_verdict": "Excellent fit" if fit_score >= 90 else "Good fit" if fit_score >= 75 else "Acceptable fit",
        "measurements_used": measurements,
        "price": clothing.get("selling_price", 0),
        "suggestions": [
            "This size should fit well based on your measurements",
            f"Chest measurement matches {recommended_size} size range",
            "Consider going one size up for a looser fit" if fit_score < 80 else "Perfect size match"
        ],
        "simulated_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Save to history (don't include _id, let MongoDB auto-generate)
    history_doc = {
        **result,
        "user_id": user.get("id"),
        "tenant_id": tenant_id
    }
    await db.virtual_tryon_history.insert_one(history_doc)
    
    return result


