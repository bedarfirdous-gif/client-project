@api_router.post("/employment-agreements/{agreement_id}/sign")
async def sign_agreement(
    agreement_id: str,
    data: dict,
    user: dict = Depends(get_current_user)
):
    """Sign an employment agreement"""
    tenant_id = get_tenant_id(user)
    
    agreement = await db.employment_agreements.find_one(
        {"tenant_id": tenant_id, "id": agreement_id}
    )
    
    if not agreement:
        raise HTTPException(status_code=404, detail="Agreement not found")
    
    signer_type = data.get("signer_type")  # "employee" or "employer"
    
    update_data = {"updated_at": datetime.now(timezone.utc).isoformat()}
    
    if signer_type == "employee":
        update_data["signed_by_employee"] = True
        update_data["employee_signature_date"] = datetime.now(timezone.utc).isoformat()
    elif signer_type == "employer":
        update_data["signed_by_employer"] = True
        update_data["employer_signature_date"] = datetime.now(timezone.utc).isoformat()
    
    # Check if both have signed
    check_agreement = {**agreement, **update_data}
    if check_agreement.get("signed_by_employee") and check_agreement.get("signed_by_employer"):
        update_data["status"] = "signed"
    elif check_agreement.get("signed_by_employee") or check_agreement.get("signed_by_employer"):
        update_data["status"] = "pending_signature"
    
    await db.employment_agreements.update_one(
        {"tenant_id": tenant_id, "id": agreement_id},
        {"$set": update_data}
    )
    
    return {"message": f"Agreement signed by {signer_type}"}

