@api_router.get("/gst-reports/gstr2")
async def get_gstr2_report(
    from_date: str,
    to_date: str,
    user: dict = Depends(require_permission("gst_master"))
):
    """Get GSTR-2 report data - Inward Supplies (Purchases)"""
    tenant_id = user.get("tenant_id")
    
    # Get all purchase vouchers in the date range
    purchase_vouchers = await db.accounting_vouchers.find({
        "tenant_id": tenant_id,
        "voucher_type": "purchase",
        "date": {"$gte": from_date, "$lte": to_date},
        "status": "approved",
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(1000)
    
    # Also get purchase invoices
    purchase_invoices = await db.invoices.find({
        "tenant_id": tenant_id,
        "invoice_type": {"$in": ["purchase", "purchase_invoice"]},
        "invoice_date": {"$gte": from_date, "$lte": to_date},
        "status": {"$ne": "cancelled"}
    }, {"_id": 0}).to_list(1000)
    
    # Categorize by supplier type
    b2b_purchases = []  # From registered suppliers
    b2bur_purchases = []  # From unregistered suppliers
    import_goods = []
    import_services = []
    
    total_taxable = 0
    total_igst = 0
    total_cgst = 0
    total_sgst = 0
    total_cess = 0
    
    for voucher in purchase_vouchers:
        gstin = voucher.get("party_gstin", "")
        supply_type = voucher.get("supply_type", "intrastate")
        
        for item in voucher.get("line_items", []):
            taxable = item.get("taxable_value", 0) or item.get("debit", 0)
            igst = item.get("igst", 0)
            cgst = item.get("cgst", 0)
            sgst = item.get("sgst", 0)
            cess = item.get("cess", 0)
            
            total_taxable += taxable
            total_igst += igst
            total_cgst += cgst
            total_sgst += sgst
            total_cess += cess
            
            purchase_data = {
                "voucher_number": voucher.get("voucher_number"),
                "date": voucher.get("date"),
                "supplier_gstin": gstin,
                "supplier_name": item.get("ledger_name", ""),
                "hsn_code": item.get("hsn_code", ""),
                "taxable_value": taxable,
                "igst": igst,
                "cgst": cgst,
                "sgst": sgst,
                "cess": cess,
                "total": taxable + igst + cgst + sgst + cess
            }
            
            if gstin and len(gstin) == 15:
                b2b_purchases.append(purchase_data)
            else:
                b2bur_purchases.append(purchase_data)
    
    # Process purchase invoices too
    for inv in purchase_invoices:
        gstin = inv.get("supplier_gstin", "") or inv.get("party_gstin", "")
        
        for item in inv.get("items", []):
            taxable = item.get("amount", 0)
            tax = item.get("tax_amount", 0)
            gst_rate = item.get("gst_rate", 18)
            
            if inv.get("supply_type") == "interstate":
                igst = tax
                cgst = sgst = 0
            else:
                cgst = sgst = tax / 2
                igst = 0
            
            total_taxable += taxable
            total_igst += igst
            total_cgst += cgst
            total_sgst += sgst
            
            purchase_data = {
                "invoice_number": inv.get("invoice_number"),
                "date": inv.get("invoice_date"),
                "supplier_gstin": gstin,
                "supplier_name": inv.get("supplier_name", inv.get("party_name", "")),
                "hsn_code": item.get("hsn_code", ""),
                "taxable_value": taxable,
                "igst": igst,
                "cgst": cgst,
                "sgst": sgst,
                "cess": 0,
                "total": taxable + tax
            }
            
            if gstin and len(gstin) == 15:
                b2b_purchases.append(purchase_data)
            else:
                b2bur_purchases.append(purchase_data)
    
    return {
        "period": {"from_date": from_date, "to_date": to_date},
        "summary": {
            "total_purchases": len(b2b_purchases) + len(b2bur_purchases),
            "b2b_count": len(b2b_purchases),
            "b2bur_count": len(b2bur_purchases),
            "total_taxable_value": round(total_taxable, 2),
            "total_igst": round(total_igst, 2),
            "total_cgst": round(total_cgst, 2),
            "total_sgst": round(total_sgst, 2),
            "total_cess": round(total_cess, 2),
            "total_itc_available": round(total_igst + total_cgst + total_sgst, 2)
        },
        "b2b": b2b_purchases,
        "b2bur": b2bur_purchases,
        "import_goods": import_goods,
        "import_services": import_services
    }


@api_router.get("/gst-reports/eway-bills")
async def get_eway_bills(
    from_date: str,
    to_date: str,
    user: dict = Depends(require_permission("gst_master"))
):
    """Get e-Way Bill data - Transport documents for goods movement"""
    tenant_id = user.get("tenant_id")
    
    # Get e-Way bills from dedicated collection (if exists)
    eway_bills = await db.eway_bills.find({
        "tenant_id": tenant_id,
        "date": {"$gte": from_date, "$lte": to_date},
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(1000)
    
    # Also get invoices that qualify for e-Way (value > 50000)
    qualifying_invoices = await db.invoices.find({
        "tenant_id": tenant_id,
        "invoice_date": {"$gte": from_date, "$lte": to_date},
        "total": {"$gte": 50000},
        "status": {"$ne": "cancelled"}
    }, {"_id": 0}).to_list(1000)
    
    # Get sales vouchers that qualify
    qualifying_vouchers = await db.accounting_vouchers.find({
        "tenant_id": tenant_id,
        "voucher_type": "sales",
        "date": {"$gte": from_date, "$lte": to_date},
        "total_debit": {"$gte": 50000},
        "status": "approved",
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(1000)
    
    # Process existing e-Way bills
    active_bills = []
    expired_bills = []
    cancelled_bills = []
    
    for bill in eway_bills:
        bill_data = {
            "eway_bill_no": bill.get("eway_bill_no"),
            "date": bill.get("date"),
            "document_type": bill.get("document_type", "Invoice"),
            "document_no": bill.get("document_no"),
            "from_gstin": bill.get("from_gstin"),
            "to_gstin": bill.get("to_gstin"),
            "from_place": bill.get("from_place"),
            "to_place": bill.get("to_place"),
            "transporter_id": bill.get("transporter_id"),
            "vehicle_no": bill.get("vehicle_no"),
            "distance_km": bill.get("distance_km"),
            "taxable_value": bill.get("taxable_value", 0),
            "cgst": bill.get("cgst", 0),
            "sgst": bill.get("sgst", 0),
            "igst": bill.get("igst", 0),
            "total_value": bill.get("total_value", 0),
            "status": bill.get("status", "active"),
            "valid_until": bill.get("valid_until")
        }
        
        if bill.get("status") == "cancelled":
            cancelled_bills.append(bill_data)
        elif bill.get("status") == "expired":
            expired_bills.append(bill_data)
        else:
            active_bills.append(bill_data)
    
    # Generate pending e-Way bills from qualifying invoices
    pending_bills = []
    for inv in qualifying_invoices:
        if not inv.get("eway_bill_generated"):
            pending_bills.append({
                "document_type": "Invoice",
                "document_no": inv.get("invoice_number"),
                "date": inv.get("invoice_date"),
                "party_name": inv.get("customer_name", inv.get("party_name", "")),
                "party_gstin": inv.get("customer_gstin", inv.get("party_gstin", "")),
                "total_value": inv.get("total", 0),
                "status": "pending_generation"
            })
    
    for voucher in qualifying_vouchers:
        if not voucher.get("eway_bill_generated"):
            pending_bills.append({
                "document_type": "Voucher",
                "document_no": voucher.get("voucher_number"),
                "date": voucher.get("date"),
                "party_name": voucher.get("party_name", ""),
                "party_gstin": voucher.get("party_gstin", ""),
                "total_value": voucher.get("total_debit", 0),
                "status": "pending_generation"
            })
    
    return {
        "period": {"from_date": from_date, "to_date": to_date},
        "summary": {
            "total_bills": len(active_bills) + len(expired_bills) + len(cancelled_bills),
            "active_count": len(active_bills),
            "expired_count": len(expired_bills),
            "cancelled_count": len(cancelled_bills),
            "pending_count": len(pending_bills),
            "total_value": sum(b.get("total_value", 0) for b in active_bills)
        },
        "active_bills": active_bills,
        "expired_bills": expired_bills,
        "cancelled_bills": cancelled_bills,
        "pending_bills": pending_bills
    }


@api_router.post("/gst-reports/eway-bills")
async def create_eway_bill(
    data: dict = Body(...),
    user: dict = Depends(require_permission("gst_master"))
):
    """Create a new e-Way Bill"""
    tenant_id = user.get("tenant_id")
    
    # Get settings for GSTIN
    settings = await db.invoice_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
    from_gstin = settings.get("gstin", "") if settings else ""
    
    # Generate e-Way bill number (format: EWB + timestamp)
    eway_bill_no = f"EWB{int(datetime.now().timestamp())}"
    
    # Calculate validity based on distance (1 day per 100 km, min 1 day)
    distance = data.get("distance_km", 100)
    validity_days = max(1, (distance // 100) + 1)
    valid_until = (datetime.now(timezone.utc) + timedelta(days=validity_days)).isoformat()
    
    new_bill = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "eway_bill_no": eway_bill_no,
        "date": datetime.now(timezone.utc).strftime("%Y-%m-%d"),
        "document_type": data.get("document_type", "Invoice"),
        "document_no": data.get("document_no"),
        "from_gstin": from_gstin,
        "to_gstin": data.get("to_gstin", ""),
        "from_place": data.get("from_place", ""),
        "to_place": data.get("to_place", ""),
        "from_state": data.get("from_state", ""),
        "to_state": data.get("to_state", ""),
        "transporter_id": data.get("transporter_id", ""),
        "transporter_name": data.get("transporter_name", ""),
        "vehicle_no": data.get("vehicle_no", ""),
        "vehicle_type": data.get("vehicle_type", "Regular"),
        "distance_km": distance,
        "taxable_value": data.get("taxable_value", 0),
        "cgst": data.get("cgst", 0),
        "sgst": data.get("sgst", 0),
        "igst": data.get("igst", 0),
        "cess": data.get("cess", 0),
        "total_value": data.get("total_value", 0),
        "hsn_code": data.get("hsn_code", ""),
        "product_name": data.get("product_name", ""),
        "product_desc": data.get("product_desc", ""),
        "quantity": data.get("quantity", 1),
        "unit": data.get("unit", "NOS"),
        "status": "active",
        "valid_until": valid_until,
        "created_by": user.get("name", user.get("email")),
        "created_at": datetime.now(timezone.utc).isoformat(),
        "is_deleted": False
    }
    
    await db.eway_bills.insert_one(new_bill)
    
    # Update the source document to mark e-Way bill as generated
    if data.get("document_type") == "Invoice":
        await db.invoices.update_one(
            {"tenant_id": tenant_id, "invoice_number": data.get("document_no")},
            {"$set": {"eway_bill_generated": True, "eway_bill_no": eway_bill_no}}
        )
    
    return {
        "message": "e-Way Bill created successfully",
        "eway_bill_no": eway_bill_no,
        "valid_until": valid_until
    }


