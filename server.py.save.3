@api_router.get("/autoheal/root-cause-categories")
async def get_root_cause_categories(user: dict = Depends(require_permission("settings"))):
    """Get root cause category breakdown from AutoHeal reports"""
    pipeline = [
        {"$group": {
            "_id": "$root_cause_category",
            "count": {"$sum": 1},
            "resolved": {"$sum": {"$cond": ["$resolved", 1, 0]}},
            "escalated": {"$sum": {"$cond": ["$escalated", 1, 0]}}
        }},
        {"$sort": {"count": -1}}
    ]
    
    cursor = db.autoheal_reports.aggregate(pipeline)
    categories = await cursor.to_list(length=20)
    
    return {
        "categories": categories,
        "total": sum(c["count"] for c in categories),
        "category_descriptions": {
            "frontend": "UI rendering, state management, component errors",
            "backend": "Server-side logic, API handlers, business logic",
            "database": "Connection, query, schema issues",
            "network": "DNS, SSL, connectivity, timeout",
            "memory": "Leaks, overflow, allocation failures",
            "thread": "Deadlocks, race conditions",
            "async": "Promise rejections, async timeouts",
            "dependency": "Missing packages, version conflicts",
            "unknown": "Unclassified errors"
        }
    }


