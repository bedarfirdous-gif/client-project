# ============== VOUCHER ENTRY SYSTEM (TALLY-STYLE) ==============
"""
Voucher Types:
1. Payment (PMT) - Payments made to parties
2. Receipt (RCT) - Payments received from parties  
3. Journal (JRN) - General adjustments
4. Contra (CNT) - Cash/Bank transfers
5. Sales (SLS) - Sales transactions
6. Purchase (PUR) - Purchase transactions

Approval Workflow: Pending -> Approved/Rejected
"""

VOUCHER_TYPES = {
    "payment": {"prefix": "PMT", "name": "Payment Voucher", "nature": "payment"},
    "receipt": {"prefix": "RCT", "name": "Receipt Voucher", "nature": "receipt"},
    "journal": {"prefix": "JRN", "name": "Journal Voucher", "nature": "journal"},
    "contra": {"prefix": "CNT", "name": "Contra Voucher", "nature": "contra"},
    "sales": {"prefix": "SLS", "name": "Sales Voucher", "nature": "sales"},
    "purchase": {"prefix": "PUR", "name": "Purchase Voucher", "nature": "purchase"}
}

VOUCHER_STATUS = ["pending", "approved", "rejected"]


class VoucherLineItem(BaseModel):
    """Single line item in a voucher"""
    ledger_id: str
    ledger_name: str = ""
    debit: float = 0.0
    credit: float = 0.0
    narration: str = ""
    # GST fields (for Sales/Purchase vouchers)
    hsn_code: str = ""
    gst_rate: float = 0.0  # Total GST rate (e.g., 18 for 18%)
    taxable_value: float = 0.0
    cgst: float = 0.0
    sgst: float = 0.0
    igst: float = 0.0
    cess: float = 0.0


class VoucherCreate(BaseModel):
    """Model for creating vouchers"""
    voucher_type: str  # payment, receipt, journal, contra, sales, purchase
    date: str  # YYYY-MM-DD
    line_items: List[VoucherLineItem]
    narration: str = ""
    reference_number: str = ""
    reference_date: str = ""
    # For linking to existing documents
    reference_doc_type: str = ""  # invoice, purchase_invoice, etc.
    reference_doc_id: str = ""
    # GST fields (for Sales/Purchase vouchers)
    party_gstin: str = ""
    place_of_supply: str = ""  # State code
    supply_type: str = "intrastate"  # intrastate, interstate


async def generate_voucher_number(tenant_id: str, voucher_type: str) -> str:
    """Generate unique voucher number like PMT/2024-25/0001"""
    prefix = VOUCHER_TYPES.get(voucher_type, {}).get("prefix", "VCH")
    
    # Get financial year
    now = datetime.now(timezone.utc)
    if now.month >= 4:
        fy = f"{now.year}-{str(now.year + 1)[-2:]}"
    else:
        fy = f"{now.year - 1}-{str(now.year)[-2:]}"
    
    # Get next sequence number
    last_voucher = await db.vouchers.find_one(
        {"tenant_id": tenant_id, "voucher_type": voucher_type},
        sort=[("sequence", -1)]
    )
    
    next_seq = (last_voucher.get("sequence", 0) if last_voucher else 0) + 1
    
    return f"{prefix}/{fy}/{str(next_seq).zfill(4)}", next_seq


