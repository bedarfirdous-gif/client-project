# ============== GLOBAL SEARCH ==============

@api_router.get("/global-search")
async def global_search(q: str = "", user: dict = Depends(get_current_user)):
    """Global search across items, customers, sales, and employees"""
    tenant_id = get_tenant_id(user)
    
    if not q or len(q) < 2:
        return {"items": [], "customers": [], "sales": [], "employees": []}
    
    # Create case-insensitive regex pattern
    search_pattern = {"$regex": q, "$options": "i"}
    
    # Search items
    items = await db.items.find({
        "tenant_id": tenant_id,
        "active": True,
        "$or": [
            {"name": search_pattern},
            {"sku": search_pattern},
            {"barcode": search_pattern},
            {"category": search_pattern},
            {"brand": search_pattern}
        ]
    }, {"_id": 0}).limit(10).to_list(10)
    
    # Search customers
    customers = await db.customers.find({
        "tenant_id": tenant_id,
        "$or": [
            {"name": search_pattern},
            {"phone": search_pattern},
            {"email": search_pattern},
            {"company": search_pattern}
        ]
    }, {"_id": 0}).limit(10).to_list(10)
    
    # Search sales by invoice number or customer name
    sales = await db.sales.find({
        "tenant_id": tenant_id,
        "$or": [
            {"invoice_number": search_pattern},
            {"customer_name": search_pattern}
        ]
    }, {"_id": 0}).sort("created_at", -1).limit(10).to_list(10)
    
    # Search employees
    employees = await db.employees.find({
        "tenant_id": tenant_id,
        "is_active": True,
        "$or": [
            {"name": search_pattern},
            {"email": search_pattern},
            {"phone": search_pattern},
            {"employee_id": search_pattern}
        ]
    }, {"_id": 0}).limit(10).to_list(10)
    
    return {
        "items": items,
        "customers": customers,
        "sales": sales,
        "employees": employees
    }

# ============== PUBLIC CATALOGUE (No Auth Required) ==============

@api_router.get("/public/catalogue")
async def get_public_catalogue(tenant: str = ""):
    """Public catalogue endpoint - no authentication required"""
    query = {"active": True}
    
    if tenant:
        query["tenant_id"] = tenant
    
    # Get items with limited fields for public view
    items = await db.items.find(
        query,
        {
            "_id": 0,
            "id": 1,
            "name": 1,
            "brand_id": 1,
            "category_id": 1,
            "selling_price": 1,
            "mrp": 1,
            "current_stock": 1,
            "images": 1,
            "variants": 1
        }
    ).to_list(500)
    
    # Get brands and categories for name lookup
    brand_ids = list(set(item.get("brand_id") for item in items if item.get("brand_id")))
    category_ids = list(set(item.get("category_id") for item in items if item.get("category_id")))
    
    brands = {}
    categories = {}
    
    if brand_ids:
        brand_docs = await db.brands.find({"id": {"$in": brand_ids}}, {"_id": 0, "id": 1, "name": 1}).to_list(100)
        brands = {b["id"]: b["name"] for b in brand_docs}
    
    if category_ids:
        cat_docs = await db.categories.find({"id": {"$in": category_ids}}, {"_id": 0, "id": 1, "name": 1}).to_list(100)
        categories = {c["id"]: c["name"] for c in cat_docs}
    
    # Enrich items with brand/category names and variant info
    enriched_items = []
    for item in items:
        sizes = []
        colors = []
        total_variant_stock = 0
        
        if item.get("variants"):
            sizes = list(set(v.get("size") for v in item["variants"] if v.get("size")))
            colors = list(set(v.get("color") for v in item["variants"] if v.get("color")))
            # Calculate total stock from variants
            total_variant_stock = sum(v.get("current_stock", 0) for v in item["variants"])
        
        # Use variant stock if item stock is 0
        item_stock = item.get("current_stock", 0)
        actual_stock = max(item_stock, total_variant_stock)
        
        enriched_items.append({
            "id": item.get("id"),
            "name": item.get("name"),
            "brand": brands.get(item.get("brand_id"), ""),
            "category": categories.get(item.get("category_id"), ""),
            "selling_price": item.get("selling_price", 0),
            "mrp": item.get("mrp", 0),
            "current_stock": actual_stock,
            "images": item.get("images", []),
            "sizes": sizes,
            "colors": colors
        })
    
    # Get store info for WhatsApp - check user_invoice_settings first (same logic as /public/store-info)
    store_info = {}
    if tenant:
        # First try: tenant could be a user_id directly (from catalogue share link)
        invoice_settings = await db.user_invoice_settings.find_one(
            {"user_id": tenant},
            {"_id": 0, "whatsapp_number": 1, "company_name": 1, "company_phone": 1}
        )
        
        # Second try: tenant could be a tenant_id - find admin user and get their settings
        if not invoice_settings:
            admin_user = await db.users.find_one(
                {"tenant_id": tenant, "role": {"$in": ["superadmin", "admin"]}},
                {"_id": 0, "id": 1}
            )
            if admin_user:
                invoice_settings = await db.user_invoice_settings.find_one(
                    {"user_id": admin_user["id"]},
                    {"_id": 0, "whatsapp_number": 1, "company_name": 1, "company_phone": 1}
                )
        
        # Third try: legacy invoice_settings collection
        if not invoice_settings:
            invoice_settings = await db.invoice_settings.find_one(
                {"tenant_id": tenant},
                {"_id": 0, "whatsapp_number": 1, "company_name": 1, "company_phone": 1}
            )
        
        if invoice_settings:
            store_info = {
                "business_name": invoice_settings.get("company_name"),
                "phone": invoice_settings.get("company_phone"),
                "whatsapp_number": invoice_settings.get("whatsapp_number") or invoice_settings.get("company_phone")
            }
    
    return {"items": enriched_items, "total": len(enriched_items), "store": store_info}

@api_router.get("/public/store-info")
async def get_public_store_info(tenant: str = ""):
    """Get public store info for catalogue page - includes WhatsApp number"""
    if not tenant:
        return {"error": "Tenant ID required"}
    
    invoice_settings = None
    
    # First try: tenant could be a user_id directly (from catalogue share link)
    invoice_settings = await db.user_invoice_settings.find_one(
        {"user_id": tenant},
        {"_id": 0, "whatsapp_number": 1, "company_name": 1, "company_phone": 1}
    )
    
    # Second try: tenant could be a tenant_id - find admin user and get their settings
    if not invoice_settings:
        admin_user = await db.users.find_one(
            {"tenant_id": tenant, "role": {"$in": ["superadmin", "admin"]}},
            {"_id": 0, "id": 1}
        )
        if admin_user:
            invoice_settings = await db.user_invoice_settings.find_one(
                {"user_id": admin_user["id"]},
                {"_id": 0, "whatsapp_number": 1, "company_name": 1, "company_phone": 1}
            )
    
    # Third try: legacy invoice_settings collection
    if not invoice_settings:
        invoice_settings = await db.invoice_settings.find_one(
            {"tenant_id": tenant},
            {"_id": 0, "whatsapp_number": 1, "company_name": 1, "company_phone": 1}
        )
    
    # Get tenant info for business details (try as tenant_id first, then as user_id)
    tenant_info = await db.tenants.find_one(
        {"id": tenant},
        {"_id": 0, "business_name": 1, "phone": 1, "email": 1, "address": 1, "city": 1}
    )
    
    # If tenant param is actually a user_id, get tenant from users collection
    if not tenant_info:
        user_info = await db.users.find_one(
            {"id": tenant},
            {"_id": 0, "tenant_id": 1}
        )
        if user_info and user_info.get("tenant_id"):
            tenant_info = await db.tenants.find_one(
                {"id": user_info["tenant_id"]},
                {"_id": 0, "business_name": 1, "phone": 1, "email": 1, "address": 1, "city": 1}
            )
    
    result = tenant_info if tenant_info else {}
    
    # Invoice settings take priority for whatsapp_number
    if invoice_settings:
        if invoice_settings.get("whatsapp_number"):
            result["whatsapp_number"] = invoice_settings["whatsapp_number"]
        if invoice_settings.get("company_name") and not result.get("business_name"):
            result["business_name"] = invoice_settings["company_name"]
        if invoice_settings.get("company_phone") and not result.get("phone"):
            result["phone"] = invoice_settings["company_phone"]
    
    # Use phone as whatsapp ONLY if whatsapp_number not set anywhere
    if not result.get("whatsapp_number") and result.get("phone"):
        result["whatsapp_number"] = result["phone"]
    
    return result


