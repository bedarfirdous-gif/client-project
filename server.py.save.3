# ============== MEMBERSHIP CARD PDF GENERATION ==============

from reportlab.lib import colors
from reportlab.lib.pagesizes import A4, letter, LETTER
from reportlab.lib.units import inch, mm, cm
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Image as RLImage, Table, TableStyle
from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
from reportlab.graphics.shapes import Drawing, Rect, String, Circle, Line
from reportlab.graphics.barcode.qr import QrCodeWidget
from reportlab.graphics import renderPDF
from reportlab.pdfgen import canvas
import qrcode

@api_router.get("/customers/{customer_id}/membership-card")
async def generate_membership_card_pdf(
    customer_id: str,
    card_size: str = "credit",  # credit (CR80) or a4
    user: dict = Depends(get_current_user)
):
    """Generate a professional membership card PDF for a customer"""
    tenant_id = get_tenant_id(user)
    
    # Get customer data
    customer = await db.customers.find_one({"id": customer_id, "tenant_id": tenant_id})
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Get organization/tenant info
    org_settings = await db.settings.find_one({"tenant_id": tenant_id, "type": "invoice"})
    org_name = org_settings.get("business_name", "BijnisBooks") if org_settings else "BijnisBooks"
    org_address = org_settings.get("address", "") if org_settings else ""
    org_phone = org_settings.get("phone", "") if org_settings else ""
    
    # Get loyalty settings for tier info
    loyalty_settings = await db.settings.find_one({"tenant_id": tenant_id, "type": "loyalty"})
    
    # Create PDF buffer
    buffer = BytesIO()
    
    # Card dimensions
    if card_size == "credit":
        # Credit card size (CR80): 3.375" x 2.125" = 85.6mm x 53.98mm
        width = 3.375 * inch
        height = 2.125 * inch
        page_size = (width + 0.5 * inch, height + 0.5 * inch)  # Add margins
    else:
        # A4 size
        page_size = A4
        width = A4[0] - 2 * inch
        height = 3 * inch
    
    # Create canvas
    c = canvas.Canvas(buffer, pagesize=page_size)
    
    # Get tier config
    tier = customer.get("loyalty_tier", "bronze").lower()
    tier_colors = {
        "bronze": {"primary": colors.Color(0.85, 0.55, 0.2), "secondary": colors.Color(0.95, 0.65, 0.3), "text": colors.black},
        "silver": {"primary": colors.Color(0.6, 0.6, 0.65), "secondary": colors.Color(0.75, 0.75, 0.8), "text": colors.black},
        "gold": {"primary": colors.Color(1, 0.84, 0), "secondary": colors.Color(1, 0.9, 0.3), "text": colors.black},
        "platinum": {"primary": colors.Color(0.55, 0.36, 0.85), "secondary": colors.Color(0.7, 0.5, 0.95), "text": colors.white},
    }
    tier_config = tier_colors.get(tier, tier_colors["bronze"])
    
    # Position card in center of page
    x_offset = (page_size[0] - width) / 2
    y_offset = (page_size[1] - height) / 2
    
    # Draw card background with gradient effect
    c.saveState()
    
    # Main card rectangle with rounded corners
    c.setFillColor(tier_config["primary"])
    c.roundRect(x_offset, y_offset, width, height, 10, stroke=0, fill=1)
    
    # Add gradient overlay
    c.setFillColor(tier_config["secondary"])
    c.setFillAlpha(0.3)
    c.roundRect(x_offset, y_offset + height * 0.6, width, height * 0.4, 10, stroke=0, fill=1)
    
    c.restoreState()
    
    # Draw decorative elements
    c.saveState()
    c.setStrokeColor(colors.white)
    c.setStrokeAlpha(0.2)
    c.setLineWidth(0.5)
    # Add diagonal lines for texture
    for i in range(0, int(width), 15):
        c.line(x_offset + i, y_offset, x_offset + i + 30, y_offset + height)
    c.restoreState()
    
    # Organization logo/name at top
    c.saveState()
    c.setFillColor(colors.white)
    c.setFont("Helvetica-Bold", 14)
    c.drawString(x_offset + 15, y_offset + height - 25, org_name[:20])
    c.setFont("Helvetica", 7)
    c.drawString(x_offset + 15, y_offset + height - 38, "MEMBERSHIP CARD")
    c.restoreState()
    
    # Tier badge
    tier_display = tier.upper()
    c.saveState()
    c.setFillColor(colors.white)
    c.setFillAlpha(0.9)
    badge_width = 60
    badge_height = 18
    c.roundRect(x_offset + width - badge_width - 15, y_offset + height - 35, badge_width, badge_height, 5, stroke=0, fill=1)
    c.setFillColor(tier_config["primary"])
    c.setFont("Helvetica-Bold", 8)
    c.drawCentredString(x_offset + width - badge_width/2 - 15, y_offset + height - 30, tier_display)
    c.restoreState()
    
    # Member name
    c.saveState()
    c.setFillColor(colors.white)
    c.setFont("Helvetica-Bold", 16)
    member_name = customer.get("name", "Member")[:25]
    c.drawString(x_offset + 15, y_offset + height - 70, member_name)
    c.restoreState()
    
    # Membership ID
    c.saveState()
    c.setFillColor(colors.white)
    c.setFillAlpha(0.9)
    c.setFont("Helvetica", 9)
    member_id = f"ID: {customer.get('id', '')[:12].upper()}"
    c.drawString(x_offset + 15, y_offset + height - 88, member_id)
    c.restoreState()
    
    # Points display
    points = customer.get("loyalty_points", 0)
    c.saveState()
    c.setFillColor(colors.white)
    c.setFont("Helvetica-Bold", 20)
    c.drawString(x_offset + 15, y_offset + 35, f"{points:,}")
    c.setFont("Helvetica", 8)
    c.drawString(x_offset + 15, y_offset + 20, "LOYALTY POINTS")
    c.restoreState()
    
    # Valid dates
    enrolled_date = customer.get("loyalty_enrolled_at", customer.get("created_at", ""))
    if enrolled_date:
        try:
            from datetime import datetime as dt
            if isinstance(enrolled_date, str):
                enrolled_dt = dt.fromisoformat(enrolled_date.replace('Z', '+00:00'))
            else:
                enrolled_dt = enrolled_date
            valid_from = enrolled_dt.strftime("%b %Y")
            valid_till = "Lifetime"
        except:
            valid_from = "N/A"
            valid_till = "Lifetime"
    else:
        valid_from = "N/A"
        valid_till = "Lifetime"
    
    c.saveState()
    c.setFillColor(colors.white)
    c.setFillAlpha(0.8)
    c.setFont("Helvetica", 7)
    c.drawString(x_offset + 100, y_offset + 35, "VALID FROM")
    c.drawString(x_offset + 100, y_offset + 20, "VALID TILL")
    c.setFont("Helvetica-Bold", 8)
    c.drawString(x_offset + 150, y_offset + 35, valid_from)
    c.drawString(x_offset + 150, y_offset + 20, valid_till)
    c.restoreState()
    
    # Generate QR code with member info
    qr_data = f"MEMBER:{customer.get('id')}|{customer.get('name')}|{customer.get('phone', '')}"
    qr = qrcode.QRCode(version=1, box_size=10, border=1)
    qr.add_data(qr_data)
    qr.make(fit=True)
    qr_img = qr.make_image(fill_color="black", back_color="white")
    
    # Save QR to buffer
    qr_buffer = BytesIO()
    qr_img.save(qr_buffer, format='PNG')
    qr_buffer.seek(0)
    
    # Draw QR code on card
    from reportlab.lib.utils import ImageReader
    qr_size = 45
    qr_x = x_offset + width - qr_size - 15
    qr_y = y_offset + 15
    
    c.saveState()
    # White background for QR
    c.setFillColor(colors.white)
    c.roundRect(qr_x - 3, qr_y - 3, qr_size + 6, qr_size + 6, 3, stroke=0, fill=1)
    c.drawImage(ImageReader(qr_buffer), qr_x, qr_y, width=qr_size, height=qr_size)
    c.restoreState()
    
    # Phone number at bottom
    phone = customer.get("phone", "")
    if phone:
        c.saveState()
        c.setFillColor(colors.white)
        c.setFillAlpha(0.7)
        c.setFont("Helvetica", 7)
        c.drawString(x_offset + width - qr_size - 60, y_offset + 8, f"Ph: {phone}")
        c.restoreState()
    
    c.save()
    
    # Return PDF
    buffer.seek(0)
    from fastapi.responses import StreamingResponse
    
    filename = f"membership_card_{customer.get('name', 'member').replace(' ', '_')}_{customer.get('id')[:8]}.pdf"
    
    return StreamingResponse(
        buffer,
        media_type="application/pdf",
        headers={
            "Content-Disposition": f"attachment; filename={filename}",
            "Access-Control-Expose-Headers": "Content-Disposition"
        }
    )


