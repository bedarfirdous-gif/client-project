@api_router.get("/loyalty/customer/{customer_id}")
async def get_customer_loyalty(customer_id: str, user: dict = Depends(get_current_user)):
    """Get customer loyalty details"""
    tenant_id = get_tenant_id(user)
    customer = await db.customers.find_one({"id": customer_id, "tenant_id": tenant_id}, {"_id": 0})
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Get loyalty transactions
    transactions = await db.loyalty_transactions.find(
        {"customer_id": customer_id, "tenant_id": tenant_id},
        {"_id": 0}
    ).sort("created_at", -1).to_list(50)
    
    # Get settings for tier calculation
    settings = await db.loyalty_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
    tiers = settings.get("tiers", {}) if settings else {}
    
    # Calculate current tier
    points = customer.get("loyalty_points", 0)
    current_tier = "bronze"
    for tier_name, tier_data in sorted(tiers.items(), key=lambda x: x[1].get("min_points", 0), reverse=True):
        if points >= tier_data.get("min_points", 0):
            current_tier = tier_name
            break
    
    return {
        "customer_id": customer_id,
        "points": points,
        "tier": current_tier,
        "tier_benefits": tiers.get(current_tier, {}).get("benefits", []),
        "tier_multiplier": tiers.get(current_tier, {}).get("multiplier", 1.0),
        "transactions": transactions
    }

@api_router.post("/loyalty/earn")
async def earn_loyalty_points(request: LoyaltyTransactionCreate, user: dict = Depends(get_current_user)):
    """Earn loyalty points from a sale"""
    tenant_id = get_tenant_id(user)
    
    # Get settings
    settings = await db.loyalty_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
    if not settings or not settings.get("is_active", True):
        raise HTTPException(status_code=400, detail="Loyalty program is not active")
    
    # Get customer
    customer = await db.customers.find_one({"id": request.customer_id, "tenant_id": tenant_id})
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Calculate multiplier based on tier
    tiers = settings.get("tiers", {})
    current_tier = customer.get("loyalty_tier", "bronze")
    multiplier = tiers.get(current_tier, {}).get("multiplier", 1.0)
    
    # Apply multiplier
    final_points = int(request.points * multiplier)
    
    # Create transaction
    transaction = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "customer_id": request.customer_id,
        "type": "earn",
        "points": final_points,
        "sale_id": request.sale_id,
        "description": request.description or f"Points earned from purchase (x{multiplier})",
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    await db.loyalty_transactions.insert_one(transaction)
    
    # Update customer points
    new_points = customer.get("loyalty_points", 0) + final_points
    
    # Calculate new tier
    new_tier = "bronze"
    for tier_name, tier_data in sorted(tiers.items(), key=lambda x: x[1].get("min_points", 0), reverse=True):
        if new_points >= tier_data.get("min_points", 0):
            new_tier = tier_name
            break
    
    await db.customers.update_one(
        {"id": request.customer_id},
        {"$set": {"loyalty_points": new_points, "loyalty_tier": new_tier}}
    )
    
    del transaction["_id"]
    return {"points_earned": final_points, "total_points": new_points, "tier": new_tier, "transaction": transaction}

@api_router.post("/loyalty/redeem")
async def redeem_loyalty_points(request: LoyaltyTransactionCreate, user: dict = Depends(get_current_user)):
    """Redeem loyalty points"""
    tenant_id = get_tenant_id(user)
    
    # Get settings
    settings = await db.loyalty_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
    if not settings or not settings.get("is_active", True):
        raise HTTPException(status_code=400, detail="Loyalty program is not active")
    
    # Get customer
    customer = await db.customers.find_one({"id": request.customer_id, "tenant_id": tenant_id})
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    current_points = customer.get("loyalty_points", 0)
    
    # Validate
    if request.points > current_points:
        raise HTTPException(status_code=400, detail="Insufficient points")
    
    if request.points < settings.get("min_redeem_points", 100):
        raise HTTPException(status_code=400, detail=f"Minimum {settings.get('min_redeem_points', 100)} points required")
    
    # Create transaction
    transaction = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "customer_id": request.customer_id,
        "type": "redeem",
        "points": -request.points,
        "sale_id": request.sale_id,
        "description": request.description or "Points redeemed",
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    await db.loyalty_transactions.insert_one(transaction)
    
    # Update customer points
    new_points = current_points - request.points
    await db.customers.update_one(
        {"id": request.customer_id},
        {"$set": {"loyalty_points": new_points}}
    )
    
    # Calculate discount value
    point_value = settings.get("point_value", 0.25)
    discount_amount = request.points * point_value
    
    del transaction["_id"]
    return {"points_redeemed": request.points, "discount_amount": discount_amount, "remaining_points": new_points, "transaction": transaction}

