            "reference": sale.get("invoice_number", ""),
            "description": f"Sale to {sale.get('customer_name', 'Customer')}",
            "account_code": "4000",
            "account_name": "Sales Revenue",
            "debit": 0,
            "credit": sale.get("total_amount", 0),
            "type": "sale"
        })
