@api_router.post("/purchase-invoices/reprocess-accounting")
async def reprocess_purchase_accounting(user: dict = Depends(get_current_user)):
    """
    Re-process accounting entries for existing purchase invoices.
    This is useful when purchases were created but ledger transactions were missing.
    """
    tenant_id = get_tenant_id(user)
    
    # Get all purchase invoices that are not deleted
    invoices = await db.purchase_invoices.find({
        "tenant_id": tenant_id,
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(10000)
    
    processed_count = 0
    failed_count = 0
    
    for invoice in invoices:
        try:
            supplier_id = invoice.get("supplier_id")
            if not supplier_id:
                continue
            
            total_amount = invoice.get("total_amount", 0)
            if total_amount <= 0:
                continue
            
            # Get supplier name
            supplier = await db.suppliers.find_one({"id": supplier_id}, {"_id": 0, "name": 1})
            supplier_name = supplier.get("name") if supplier else invoice.get("supplier_name", "Unknown Supplier")
            
            # If supplier not found, check if supplier_id is a ledger ID
            if not supplier:
                ledger = await db.ledgers.find_one({"id": supplier_id, "tenant_id": tenant_id}, {"_id": 0, "name": 1})
                if ledger:
                    supplier_name = ledger.get("name", "Unknown Supplier")
            
            # Check if ledger transaction already exists for this invoice
            existing_transaction = await db.ledger_transactions.find_one({
                "tenant_id": tenant_id,
                "reference_id": invoice.get("id")
            })
            
            if existing_transaction:
                # Skip if already processed
                continue
            
            # Process accounting
            await process_purchase_accounting(
                tenant_id=tenant_id,
                invoice_id=invoice.get("id"),
                invoice_number=invoice.get("invoice_number"),
                supplier_id=supplier_id,
                supplier_name=supplier_name,
                total_amount=total_amount,
                date=invoice.get("invoice_date") or invoice.get("created_at", "")[:10],
                store_id=invoice.get("store_id")
            )
            processed_count += 1
            logger.info(f"Reprocessed accounting for invoice: {invoice.get('invoice_number')}")
            
        except Exception as e:
            logger.error(f"Failed to reprocess invoice {invoice.get('invoice_number')}: {e}")
            failed_count += 1
    
    return {
        "message": f"Reprocessed {processed_count} invoices",
        "processed": processed_count,
        "failed": failed_count,
        "total_invoices": len(invoices)
    }



