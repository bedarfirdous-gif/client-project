@api_router.get("/suppliers/with-ledgers")
async def list_suppliers_with_ledgers(user: dict = Depends(require_permission("suppliers"))):
    """
    Get suppliers OR Sundry Creditor ledgers for purchase invoice dropdown.
    This allows selecting from both existing suppliers AND directly from ledger management.
    """
    tenant_id = get_tenant_id(user)
    
    # Get all suppliers
    suppliers = await db.suppliers.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(1000)
    
    # Get all Sundry Creditor ledgers that might not be linked to suppliers
    creditor_ledgers = await db.ledgers.find({
        "tenant_id": tenant_id,
        "group_id": "sundry_creditors",
        "is_deleted": {"$ne": True},
        "is_active": True
    }, {"_id": 0}).to_list(1000)
    
    # Create a map of ledger IDs already linked to suppliers
    linked_ledger_ids = set(s.get("ledger_id") for s in suppliers if s.get("ledger_id"))
    
    # Build combined result
    result = []
    
    # Add suppliers with their ledger info
    for supplier in suppliers:
        entry = {
            "id": supplier["id"],
            "name": supplier["name"],
            "type": "supplier",
            "phone": supplier.get("phone", ""),
            "gst_number": supplier.get("gst_number", ""),
            "state": supplier.get("state", ""),
            "address": supplier.get("address", ""),
            "ledger_id": supplier.get("ledger_id"),
            "supplier_id": supplier["id"]
        }
        if supplier.get("ledger_id"):
            ledger = await db.ledgers.find_one(
                {"id": supplier["ledger_id"], "tenant_id": tenant_id},
                {"_id": 0, "opening_balance": 1, "opening_balance_type": 1}
            )
            if ledger:
                entry["opening_balance"] = ledger.get("opening_balance", 0)
                entry["balance_type"] = ledger.get("opening_balance_type", "Dr")
        result.append(entry)
    
    # Add unlinked creditor ledgers as potential suppliers
    for ledger in creditor_ledgers:
        if ledger["id"] not in linked_ledger_ids:
            result.append({
                "id": ledger["id"],
                "name": ledger["name"],
                "type": "ledger",
                "phone": ledger.get("phone", ""),
                "gst_number": ledger.get("gstin", ""),
                "state": ledger.get("state", ""),
                "address": ledger.get("address", ""),
                "ledger_id": ledger["id"],
                "opening_balance": ledger.get("opening_balance", 0),
                "balance_type": ledger.get("opening_balance_type", "Dr")
            })
    
    return result

@api_router.post("/suppliers")
