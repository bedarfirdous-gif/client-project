@api_router.get("/customer-ledger/{customer_id}")
async def get_customer_ledger_detail(customer_id: str, user: dict = Depends(get_current_user)):
    """Get detailed ledger for a specific customer"""
    tenant_id = get_tenant_id(user)
    
    customer = await db.customers.find_one({"id": customer_id, "tenant_id": tenant_id}, {"_id": 0})
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Get all sales for this customer
    sales = await db.sales.find(
        {"tenant_id": tenant_id, "customer_id": customer_id}, {"_id": 0}
    ).to_list(10000)
    
    # Get all payments/receipts (if you have a payments collection)
    # For now, we'll derive from sales
    
    transactions = []
    running_balance = 0
    
    # Sort by date
    sales.sort(key=lambda x: x.get("created_at", x.get("sale_date", "")))
    
    for sale in sales:
        sale_amount = sale.get("total_amount", 0)
        paid_amount = sale.get("paid_amount", 0) if sale.get("payment_status") == "paid" else 0
        
        # Add sale transaction (debit - customer owes)
        running_balance += sale_amount
        transactions.append({
            "date": sale.get("sale_date", sale.get("created_at", "")[:10] if sale.get("created_at") else ""),
            "type": "sale",
            "reference": sale.get("invoice_number", sale.get("id", "")[:8]),
            "description": "Sale Invoice",
            "debit": sale_amount,
            "credit": 0,
            "balance": running_balance
        })
        
        # Add payment transaction if paid (credit - customer paid)
        if paid_amount > 0:
            running_balance -= paid_amount
            transactions.append({
                "date": sale.get("sale_date", sale.get("created_at", "")[:10] if sale.get("created_at") else ""),
                "type": "payment",
                "reference": f"PMT-{sale.get('invoice_number', sale.get('id', '')[:8])}",
                "description": "Payment Received",
                "debit": 0,
                "credit": paid_amount,
                "balance": running_balance
            })
    
    return {
        "customer": customer,
        "transactions": transactions,
        "summary": {
            "total_debit": sum(t["debit"] for t in transactions),
            "total_credit": sum(t["credit"] for t in transactions),
            "closing_balance": running_balance
        }
    }

