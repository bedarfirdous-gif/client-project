                "status": "success",
                "message": "No currencySymbol issues found",
                "issues_found": 0,
                "fixed": 0
            }
        
        # Then fix
        results = fix_currency_issues()
        
        return {
            "status": "success",
            "message": f"Fixed {len(results['fixed'])} out of {results['scanned_issues']} issues",
            "issues_found": results["scanned_issues"],
            "fixed": len(results["fixed"]),
            "failed": len(results["failed"]),
            "details": results
        }
    except Exception as e:
        logger.error(f"Currency scan-and-fix failed: {e}")
        raise HTTPException(status_code=500, detail=str(e))


