@api_router.get("/employees/next-code")
async def get_next_employee_code(user: dict = Depends(require_permission("employees"))):
    """Generate next available employee code"""
    tenant_id = get_tenant_id(user)
    
    # Find the highest employee code
    last_employee = await db.employees.find_one(
        {"tenant_id": tenant_id, "employee_code": {"$regex": "^EMP"}},
        sort=[("employee_code", -1)]
    )
    
    if last_employee and last_employee.get("employee_code"):
        try:
            last_num = int(last_employee["employee_code"].replace("EMP", ""))
            next_num = last_num + 1
        except (ValueError, KeyError):
            next_num = 1
    else:
        next_num = 1
    
    return {"next_code": f"EMP{str(next_num).zfill(4)}"}

