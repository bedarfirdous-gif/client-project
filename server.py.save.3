    }, {"_id": 0}).to_list(100)
    
    present_days = len([a for a in attendance_records if a.get("status") == "present"])
    absent_days = len([a for a in attendance_records if a.get("status") == "absent"])
    late_days = len([a for a in attendance_records if a.get("status") == "late"])
    
    # Get salary structure
    salary_structure = await db.salary_structures.find_one(
        {"tenant_id": tenant_id, "employee_id": employee_id, "is_active": True},
        {"_id": 0}
    )
    
    # Get latest payroll record
    latest_payroll = await db.payroll.find_one(
        {"tenant_id": tenant_id, "employee_id": employee_id},
        {"_id": 0},
        sort=[("year", -1), ("month", -1)]
    )
    
    # Get employee ratings
    ratings = await db.employee_ratings.find(
        {"tenant_id": tenant_id, "employee_id": employee_id},
        {"_id": 0}
    ).sort("created_at", -1).to_list(12)
    
    avg_rating = 0
    if ratings:
        total_rating = sum(r.get("overall_rating", 0) for r in ratings)
        avg_rating = round(total_rating / len(ratings), 1)
    
    # Get employment agreements
    agreements = await db.employment_agreements.find(
        {"tenant_id": tenant_id, "employee_id": employee_id},
        {"_id": 0}
    ).sort("created_at", -1).to_list(10)
    
    # Get store info
    store = None
    if employee.get("store_id"):
        store = await db.stores.find_one({"id": employee["store_id"]}, {"_id": 0, "name": 1, "address": 1})
    
    return {
        "employee": employee,
        "store": store,
        "attendance_summary": {
            "period": "Last 30 days",
            "present": present_days,
            "absent": absent_days,
            "late": late_days,
            "total_records": len(attendance_records)
        },
        "salary": {
            "structure": salary_structure,
            "latest_payroll": latest_payroll
        },
        "performance": {
            "average_rating": avg_rating,
            "total_reviews": len(ratings),
            "recent_ratings": ratings[:3]
