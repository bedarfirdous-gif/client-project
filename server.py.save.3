        raise HTTPException(status_code=400, detail="Prompt is required")
    
    # Collect streamed words
    response_words = []
    async for word in streaming_generator.stream_response(prompt, system_message, model):
        response_words.append(word)
    
    return {
        "success": True,
        "response": "".join(response_words).strip(),
        "model": model,
        "streamed": True
    }


# WebSocket for real-time streaming
@api_router.websocket("/ws/autonomous/stream")
async def websocket_stream(websocket: WebSocket):
    """
    WebSocket endpoint for real-time streaming AI responses.
    
    Send: {"type": "chat", "prompt": "...", "model": "gpt-5.2"}
    Receive: {"type": "word", "content": "..."} for each word
    """
    await websocket.accept()
    
    try:
        while True:
            data = await websocket.receive_json()
            
            if data.get("type") == "chat":
                prompt = data.get("prompt", "")
                model = data.get("model", "gpt-5.2")
                
                async for word in streaming_generator.stream_response(prompt, model=model):
                    await websocket.send_json({
                        "type": "word",
                        "content": word
                    })
                
                await websocket.send_json({
                    "type": "complete",
                    "model": model
                })
            
            elif data.get("type") == "ping":
                await websocket.send_json({"type": "pong"})
    
    except WebSocketDisconnect:
        pass


