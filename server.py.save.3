@api_router.post("/attendance")
async def create_attendance(request: AttendanceCreate, user: dict = Depends(require_permission("attendance"))):
    tenant_id = get_tenant_id(user)
    
    # Get employee to fetch shift timing
    employee = await db.employees.find_one(
        {"tenant_id": tenant_id, "id": request.employee_id},
        {"_id": 0, "shift_start_time": 1, "shift_end_time": 1, "name": 1}
    )
    
    # Calculate late hours and overtime based on shift timing
    late_hours = 0.0
    overtime_hours = 0.0
    shift_start = employee.get("shift_start_time", "09:00") if employee else "09:00"
    shift_end = employee.get("shift_end_time", "18:00") if employee else "18:00"
    
    if request.status == "present" and request.in_time:
        try:
            # Parse times
            in_time_parts = request.in_time.split(":")
            shift_start_parts = shift_start.split(":")
            
            in_minutes = int(in_time_parts[0]) * 60 + int(in_time_parts[1])
            shift_start_minutes = int(shift_start_parts[0]) * 60 + int(shift_start_parts[1])
            
            # Calculate late hours (if checked in after shift start)
            if in_minutes > shift_start_minutes:
                late_minutes = in_minutes - shift_start_minutes
                late_hours = round(late_minutes / 60, 2)
        except (ValueError, IndexError):
            pass
    
    if request.status == "present" and request.out_time:
        try:
            # Parse times
            out_time_parts = request.out_time.split(":")
            shift_end_parts = shift_end.split(":")
            
            out_minutes = int(out_time_parts[0]) * 60 + int(out_time_parts[1])
            shift_end_minutes = int(shift_end_parts[0]) * 60 + int(shift_end_parts[1])
            
            # Calculate overtime (if checked out after shift end)
            if out_minutes > shift_end_minutes:
                overtime_minutes = out_minutes - shift_end_minutes
                overtime_hours = round(overtime_minutes / 60, 2)
        except (ValueError, IndexError):
            pass
    
    # Check if attendance already exists
    existing = await db.attendance.find_one({
        "tenant_id": tenant_id,
        "employee_id": request.employee_id,
        "date": request.date
    })
    
    attendance_data = request.model_dump()
    attendance_data["late_hours"] = late_hours
    attendance_data["overtime_hours"] = overtime_hours
    attendance_data["shift_start_time"] = shift_start
    attendance_data["shift_end_time"] = shift_end
    
    if existing:
        # Update existing
        await db.attendance.update_one(
            {"id": existing["id"]},
            {"$set": {
                **attendance_data,
                "updated_at": datetime.now(timezone.utc).isoformat(),
                "marked_by": user.get("id")
            }}
        )
        updated = await db.attendance.find_one({"id": existing["id"]}, {"_id": 0})
        return updated
    
    attendance_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        **attendance_data,
        "marked_by": user.get("id"),
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    await db.attendance.insert_one(attendance_doc)
    del attendance_doc["_id"]
    return attendance_doc

