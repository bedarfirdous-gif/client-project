@api_router.post("/ai-developer/auto-fix-all")
async def auto_fix_all_errors(
    severity_threshold: str = "high",
    confidence_threshold: float = 0.8,
    user: dict = Depends(require_permission("settings"))
):
    """Automatically fix all errors above the confidence threshold"""
    global ai_developer_instance
    if ai_developer_instance is None:
        ai_developer_instance = await init_ai_developer(db)
    
    severity_order = {"critical": 0, "high": 1, "medium": 2, "low": 3, "info": 4}
    threshold_level = severity_order.get(severity_threshold, 1)
    
    results = {
        "attempted": 0,
        "successful": 0,
        "failed": 0,
        "skipped": 0,
        "fixes": []
    }
    
    for error in ai_developer_instance.errors_detected:
        if error.fixed:
            results["skipped"] += 1
            continue
        
        error_level = severity_order.get(error.severity, 5)
        if error_level > threshold_level:
            results["skipped"] += 1
            continue
        
        results["attempted"] += 1
        
        try:
            fix_result = await ai_developer_instance.autonomous_fix_error(error)
            
            if fix_result.get("success"):
                results["successful"] += 1
            else:
                results["failed"] += 1
            
            results["fixes"].append({
                "error_id": error.id,
                "success": fix_result.get("success"),
                "steps": fix_result.get("steps", [])
            })
        except Exception as e:
            results["failed"] += 1
            results["fixes"].append({
                "error_id": error.id,
                "success": False,
                "error": str(e)
            })
    
    return results


