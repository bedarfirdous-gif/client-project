# ============== FORGOT PASSWORD ==============

class ForgotPasswordRequest(BaseModel):
    email: str

class ResetPasswordRequest(BaseModel):
    token: str
    new_password: str

@api_router.post("/auth/forgot-password")
async def forgot_password(request: ForgotPasswordRequest, req: Request):
    """Send password reset email or return reset link directly"""
    email = request.email.lower().strip()
    user = await db.users.find_one({"email": email})
    
    # Always return success to prevent email enumeration
    if not user:
        return {"message": "If an account exists with this email, a reset link has been sent.", "email_sent": False}
    
    # Generate reset token
    reset_token = secrets.token_urlsafe(32)
    expires_at = datetime.now(timezone.utc) + timedelta(hours=1)
    
    # Store reset token
    await db.password_resets.delete_many({"email": email})  # Remove old tokens
    await db.password_resets.insert_one({
        "email": email,
        "token": reset_token,
        "expires_at": expires_at.isoformat(),
        "created_at": datetime.now(timezone.utc).isoformat()
    })
    
    # Get tenant settings for email configuration
    tenant_id = user.get("tenant_id", "default")
    settings = await db.settings.find_one({"tenant_id": tenant_id}) or {}
    
    # Build reset URL - use request origin or environment variable
    origin = req.headers.get("origin") or req.headers.get("referer", "").rstrip("/")
    if origin and "/api" in origin:
        origin = origin.split("/api")[0]
    
    # Fallback to environment variable
    if not origin or origin == "":
        frontend_url = os.environ.get("FRONTEND_URL") or os.environ.get("REACT_APP_BACKEND_URL", "")
        if frontend_url:
            origin = frontend_url.replace("/api", "").rstrip("/")
        else:
            origin = "https://bijnisbooks.com"  # Default production URL
    
    reset_url = f"{origin}/reset-password?token={reset_token}"
    
    # Try to send email using available email service
    email_sent = False
    try:
        # Check for SendGrid
        sendgrid_key = settings.get("sendgrid_api_key") or os.environ.get("SENDGRID_API_KEY")
        if sendgrid_key:
            import httpx
            async with httpx.AsyncClient() as client:
                response = await client.post(
                    "https://api.sendgrid.com/v3/mail/send",
                    headers={
                        "Authorization": f"Bearer {sendgrid_key}",
                        "Content-Type": "application/json"
                    },
                    json={
                        "personalizations": [{"to": [{"email": email}]}],
                        "from": {"email": settings.get("company_email", "noreply@bijnisbooks.com"), "name": settings.get("company_name", "BijnisBooks")},
                        "subject": "Password Reset Request",
                        "content": [{
                            "type": "text/html",
                            "value": f"""
                            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                                <h2 style="color: #6D28D9;">Password Reset Request</h2>
                                <p>Hello,</p>
                                <p>We received a request to reset your password. Click the button below to reset it:</p>
                                <div style="text-align: center; margin: 30px 0;">
                                    <a href="{reset_url}" style="background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%); color: white; padding: 12px 30px; text-decoration: none; border-radius: 8px; font-weight: bold;">Reset Password</a>
                                </div>
                                <p>Or copy and paste this link in your browser:</p>
                                <p style="word-break: break-all; color: #6D28D9;">{reset_url}</p>
                                <p style="color: #666; font-size: 14px;">This link will expire in 1 hour.</p>
                                <p style="color: #666; font-size: 14px;">If you didn't request this, please ignore this email.</p>
                                <hr style="border: none; border-top: 1px solid #eee; margin: 30px 0;" />
                                <p style="color: #999; font-size: 12px;">{settings.get("company_name", "BijnisBooks")}</p>
                            </div>
                            """
                        }]
                    }
                )
                if response.status_code in [200, 201, 202]:
                    email_sent = True
        
        # Check for Resend
        resend_key = settings.get("resend_api_key") or os.environ.get("RESEND_API_KEY")
        if resend_key and not email_sent:
            import httpx
            async with httpx.AsyncClient() as client:
                response = await client.post(
                    "https://api.resend.com/emails",
                    headers={
                        "Authorization": f"Bearer {resend_key}",
                        "Content-Type": "application/json"
                    },
                    json={
                        "from": settings.get("company_email", "onboarding@resend.dev"),
                        "to": [email],
                        "subject": "Password Reset Request",
                        "html": f"""
                            <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
                                <h2 style="color: #6D28D9;">Password Reset Request</h2>
                                <p>Hello,</p>
                                <p>We received a request to reset your password. Click the button below to reset it:</p>
                                <div style="text-align: center; margin: 30px 0;">
                                    <a href="{reset_url}" style="background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%); color: white; padding: 12px 30px; text-decoration: none; border-radius: 8px; font-weight: bold;">Reset Password</a>
                                </div>
                                <p>Or copy and paste this link in your browser:</p>
                                <p style="word-break: break-all; color: #6D28D9;">{reset_url}</p>
                                <p style="color: #666; font-size: 14px;">This link will expire in 1 hour.</p>
                            </div>
                            """
                    }
                )
                if response.status_code in [200, 201, 202]:
                    email_sent = True
        
        # If no email service configured, return reset link directly
        # This is useful for internal business software
        if not email_sent:
            print(f"[PASSWORD RESET] Email: {email}, Reset URL: {reset_url}")
            await db.password_resets.update_one(
                {"email": email, "token": reset_token},
                {"$set": {"email_sent": False, "reset_url": reset_url}}
            )
            # Return the reset link directly since no email service is configured
            return {
                "message": "No email service configured. Use the reset link below.",
                "email_sent": False,
                "reset_url": reset_url,
                "expires_in": "1 hour"
            }
    except Exception as e:
        print(f"[PASSWORD RESET ERROR] Failed to send email: {e}")
        # Return reset link on error as fallback
        return {
            "message": "Email service error. Use the reset link below.",
            "email_sent": False,
            "reset_url": reset_url,
            "expires_in": "1 hour"
        }
    
    return {"message": "Password reset link has been sent to your email.", "email_sent": True}

@api_router.post("/auth/reset-password")
async def reset_password(request: ResetPasswordRequest):
    """Reset password using token"""
    reset_record = await db.password_resets.find_one({"token": request.token})
    
    if not reset_record:
        raise HTTPException(status_code=400, detail="Invalid or expired reset token")
    
    # Check expiration
    expires_at = datetime.fromisoformat(reset_record["expires_at"].replace("Z", "+00:00"))
    if datetime.now(timezone.utc) > expires_at:
        await db.password_resets.delete_one({"token": request.token})
        raise HTTPException(status_code=400, detail="Reset token has expired. Please request a new one.")
    
    # Validate password
    if len(request.new_password) < 6:
        raise HTTPException(status_code=400, detail="Password must be at least 6 characters")
    
    # Update password
    email = reset_record["email"]
    hashed = hash_password(request.new_password)
    
    result = await db.users.update_one(
        {"email": email},
        {"$set": {
            "password": hashed,
            "password_reset_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    if result.modified_count == 0:
        raise HTTPException(status_code=400, detail="Failed to reset password")
    
    # Delete the used token
    await db.password_resets.delete_one({"token": request.token})
    
    return {"message": "Password has been reset successfully. You can now login with your new password."}

