    source_store_id = transfer.get("from_store_id") or transfer.get("source_store_id")
    dest_store_id = transfer.get("to_store_id") or transfer.get("destination_store_id")
    transfer_status = transfer.get("status", "pending")
    items = transfer.get("items", [])
    
    # Reverse stock movements based on transfer status
    inv_service = InventoryService(db)
    
    for item in items:
        variant_id = item.get("variant_id")
        quantity = item.get("quantity", 0)
        item_id = item.get("item_id", "")
        
        if not variant_id or quantity <= 0:
            continue
        
        # If item_id is missing, look it up from variant
        if not item_id:
            variant = await db.variants.find_one({"id": variant_id}, {"_id": 0})
            if variant:
                item_id = variant.get("item_id", "")
        
        try:
            # Always ADD back to source store (stock was deducted when transfer was created)
            await inv_service.add_stock(
                tenant_id=tenant_id,
                item_id=item_id,
                variant_id=variant_id,
                quantity=quantity,
                movement_type=MovementType.ADJUSTMENT,
                reference_id=f"{transfer_id}_delete",
                reference_type="transfer_reversal",
                warehouse_id=source_store_id,
                notes=f"Stock transfer {transfer_id} deleted - reversed from source",
                performed_by=user.get("id")
            )
            
            # Also update legacy inventory for source
            await db.inventory.update_one(
                {"variant_id": variant_id, "store_id": source_store_id},
                {"$inc": {"quantity": quantity}},
                upsert=True
            )
            
            # If transfer was completed/received, DEDUCT from destination store
            if transfer_status in ["completed", "received", "delivered"]:
                await inv_service.deduct_stock(
                    tenant_id=tenant_id,
                    item_id=item_id,
                    variant_id=variant_id,
                    quantity=quantity,
                    movement_type=MovementType.ADJUSTMENT,
                    reference_id=f"{transfer_id}_delete",
                    reference_type="transfer_reversal",
                    warehouse_id=dest_store_id,
                    notes=f"Stock transfer {transfer_id} deleted - reversed from destination",
                    performed_by=user.get("id"),
                    allow_negative=True  # Allow negative in case of data inconsistency
                )
                
                # Also update legacy inventory for destination
                await db.inventory.update_one(
                    {"variant_id": variant_id, "store_id": dest_store_id},
                    {"$inc": {"quantity": -quantity}}
                )
                
        except Exception as e:
            logger.error(f"Failed to reverse stock for variant {variant_id}: {e}")
            # Continue with other items even if one fails
    
    # Delete the transfer record
    await db.stock_transfers.delete_one({"id": transfer_id, "tenant_id": tenant_id})
    
    return {"message": "Stock transfer deleted and stock reversed successfully"}


