# ============== AI VOICE COMMANDS ENDPOINT ==============

@api_router.post("/ai-agents/voice/process")
async def process_voice_command(
    audio: UploadFile = File(...),
    agent_type: str = Form(default="business"),
    conversation_id: str = Form(default=None),
    preferred_model: str = Form(default=None),
    user: dict = Depends(require_permission("dashboard"))
):
    """
    Process voice commands using Whisper STT + Multi-LLM AI Agent.
    
    Features:
    - Speech-to-text transcription using OpenAI Whisper
    - Natural language processing by selected AI agent
    - Multi-LLM support: GPT-5.2, Gemini 3 Flash, Claude Sonnet 4.5
    - Intelligent model selection based on task type
    - Full task automation capabilities
    - Returns transcription, AI response, and model used
    
    Parameters:
    - audio: Audio file (mp3, wav, m4a, webm, mp4)
    - agent_type: Which AI agent to use (business, assistant, operations, analytics)
    - conversation_id: For multi-turn conversations
    - preferred_model: Specify LLM model (gpt-5.2, gemini-3-flash, claude-sonnet-4.5)
    """
    # from emergentintegrations.llm.openai import OpenAISpeechToText
    
    # Validate file type
    allowed_types = ["audio/mpeg", "audio/mp3", "audio/wav", "audio/m4a", "audio/webm", "audio/mp4"]
    if audio.content_type and audio.content_type not in allowed_types:
        # Also check file extension as fallback
        ext = audio.filename.split(".")[-1].lower() if audio.filename else ""
        if ext not in ["mp3", "wav", "m4a", "webm", "mp4", "mpeg", "mpga"]:
            raise HTTPException(
                status_code=400, 
                detail="Unsupported audio format. Supported: mp3, wav, m4a, webm, mp4"
            )
    
    try:
        # Initialize Whisper STT
        api_key = os.getenv("EMERGENT_LLM_KEY")
        stt = OpenAISpeechToText(api_key=api_key)
        
        # Read audio content
        audio_content = await audio.read()
        
        # Create a file-like object for the API
        import io
        audio_file = io.BytesIO(audio_content)
        audio_file.name = audio.filename or "audio.mp3"
        
        # Transcribe audio
        transcription = await stt.transcribe(
            file=audio_file,
            model="whisper-1",
            response_format="json",
            language="en"
        )
        
        transcribed_text = transcription.text
        
        # Now process through AI agent
        if agent_type not in emergent_agents:
            agent_type = "business"  # Default to business agent
        
        agent = emergent_agents[agent_type]
        
        # Generate conversation ID if not provided
        if not conversation_id:
            conversation_id = str(uuid.uuid4())
        
        # Build context with model preference
        context = {
            "input_type": "voice",
            "model": preferred_model  # Will trigger specific LLM if set
        }
        
        # Process with agent
        response = await agent.process(
            prompt=transcribed_text,
            user_id=user.get("id"),
            tenant_id=get_tenant_id(user),
            conversation_id=conversation_id,
            context=context
        )
        
        # Extract model used from response
        model_used = response.data.get("model_used", "auto-selected")
        
        return {
            "success": True,
            "input_type": "voice",
            "transcribed_text": transcribed_text,
            "agent_response": {
                "message": response.message,
                "data": response.data,
                "reasoning": response.reasoning,
                "actions_taken": response.actions_taken,
                "suggestions": response.suggestions,
                "confidence": response.confidence
            },
            "conversation_id": conversation_id,
            "agent_used": agent_type,
            "model_used": model_used
        }
        
    except Exception as e:
        logger.error(f"Voice processing failed: {e}")
        raise HTTPException(status_code=500, detail=f"Voice processing failed: {str(e)}")


