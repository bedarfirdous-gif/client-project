@api_router.put("/ecommerce/orders/{order_id}/status")
async def update_ecommerce_order_status(
    order_id: str,
    data: dict = Body(...),
    user: dict = Depends(get_current_user)
):
    """Update e-commerce order status"""
    tenant_id = get_tenant_id(user)
    
    new_status = data.get("status")
    if not new_status:
        raise HTTPException(status_code=400, detail="Status is required")
    
    valid_statuses = ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled"]
    if new_status not in valid_statuses:
        raise HTTPException(status_code=400, detail=f"Invalid status. Must be one of: {', '.join(valid_statuses)}")
    
    result = await db.ecommerce_orders.update_one(
        {"id": order_id, "tenant_id": tenant_id},
        {"$set": {
            "order_status": new_status,
            "updated_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    if result.matched_count == 0:
        raise HTTPException(status_code=404, detail="Order not found")
    
    return {"success": True, "message": f"Order status updated to {new_status}"}


# ============== ITEMS ROUTES ==============

@api_router.get("/items")
async def list_items(
    search: str = "",
    category_id: str = "",
    brand_id: str = "",
    active: Optional[bool] = None,
    user: dict = Depends(get_current_user)  # Changed from require_permission to allow more access
):
    tenant_id = get_tenant_id(user)
    query = {"tenant_id": tenant_id, "is_deleted": {"$ne": True}}
    
    if search:
        query["$or"] = [
            {"name": {"$regex": search, "$options": "i"}},
            {"sku": {"$regex": search, "$options": "i"}},
            {"style_code": {"$regex": search, "$options": "i"}}
        ]
    if category_id:
        query["category_id"] = category_id
    if brand_id:
        query["brand_id"] = brand_id
    if active is not None:
        if active:
            # Include items where active=true OR status="active" OR neither field exists (default to active)
            # Don't use $or if search is already using it
            if "$or" in query:
                # Build a combined query with $and
                search_conditions = query.pop("$or")
                query["$and"] = [
                    {"$or": search_conditions},
                    {"$or": [
                        {"active": True},
                        {"active": {"$exists": False}, "status": "active"},
                        {"active": {"$exists": False}, "status": {"$exists": False}}
                    ]}
                ]
            else:
                query["$or"] = [
                    {"active": True},
                    {"active": {"$exists": False}, "status": "active"},
                    {"active": {"$exists": False}, "status": {"$exists": False}}
                ]
        else:
            query["active"] = False
    
    items = await db.items.find(query, {"_id": 0}).sort("created_at", -1).to_list(1000)
    
    # Fetch variants for all items and attach them
    item_ids = [item["id"] for item in items]
    if item_ids:
        variants = await db.variants.find({"item_id": {"$in": item_ids}}, {"_id": 0}).to_list(5000)
        
        # Fetch inventory for all variants to get current stock
        variant_ids = [v["id"] for v in variants]
        
        # Check both inventory collection and central_stock
        inventory_records = await db.inventory.find(
            {"variant_id": {"$in": variant_ids}, "tenant_id": tenant_id},
            {"_id": 0, "variant_id": 1, "quantity": 1}
        ).to_list(10000)
        
        # Also check central_stock (primary source of truth)
        central_stock_records = await db.central_stock.find(
            {"variant_id": {"$in": variant_ids}, "tenant_id": tenant_id},
            {"_id": 0, "variant_id": 1, "quantity": 1}
        ).to_list(10000)
        
        # Group stock by variant_id (sum all warehouse quantities)
        # PRIORITY: central_stock is the single source of truth
        # Only fall back to inventory collection if central_stock has no records for a variant
        variant_stock = {}
        central_stock_variants = set()
        
        # First, get stock from central_stock (PRIMARY source of truth)
        for stock in central_stock_records:
            vid = stock.get("variant_id")
            central_stock_variants.add(vid)
            variant_stock[vid] = variant_stock.get(vid, 0) + (stock.get("quantity", 0) or 0)
        
        # Only use inventory collection for variants NOT in central_stock (legacy fallback)
        for inv in inventory_records:
            vid = inv.get("variant_id")
            if vid not in central_stock_variants:
                variant_stock[vid] = variant_stock.get(vid, 0) + (inv.get("quantity", 0) or 0)
        
        # Update variants with current_stock
        for v in variants:
            v["current_stock"] = variant_stock.get(v["id"], 0)
        
        # Group variants by item_id
        variants_by_item = {}
        for v in variants:
            item_id = v.get("item_id")
            if item_id not in variants_by_item:
                variants_by_item[item_id] = []
            variants_by_item[item_id].append(v)
        
        # Attach variants to each item and calculate total stock
        for item in items:
            item["variants"] = variants_by_item.get(item["id"], [])
            # Calculate total current stock across all variants
            item["current_stock"] = sum(v.get("current_stock", 0) for v in item["variants"])
            # Also set size/color from first variant if available (for barcode labels)
            if item["variants"]:
                first_variant = item["variants"][0]
                if not item.get("size") and first_variant.get("size"):
                    item["size"] = first_variant.get("size")
                if not item.get("color") and first_variant.get("color"):
                    item["color"] = first_variant.get("color")
    else:
        for item in items:
            item["current_stock"] = 0
    
    return items

@api_router.get("/items/{item_id}")
