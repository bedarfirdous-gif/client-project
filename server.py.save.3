# GST Ledger posting function
async def post_gst_to_ledgers(
    tenant_id: str,
    transaction_type: str,  # "sale" or "purchase"
    reference_id: str,
    reference_number: str,
    cgst_amount: float,
    sgst_amount: float,
    igst_amount: float,
    is_interstate: bool,
    date: str,
    party_name: str = "",
    party_gstin: str = "",
    store_id: str = ""
):
    """Post GST amounts to respective ledgers (CGST/SGST/IGST)"""
    timestamp = datetime.now(timezone.utc).isoformat()
    
    entries = []
    
    if transaction_type == "sale":
        # OUTPUT GST - Liability (we collect from customer, owe to govt)
        if is_interstate and igst_amount > 0:
            # IGST Output
            entries.append({
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "ledger_type": "igst_output",
                "ledger_name": "IGST Output",
                "account_code": "2410",  # Liability
                "entry_type": "credit",
                "amount": igst_amount,
                "reference_type": "sale",
                "reference_id": reference_id,
                "reference_number": reference_number,
                "party_name": party_name,
                "party_gstin": party_gstin,
                "description": f"IGST Output on {reference_number}",
                "date": date,
                "store_id": store_id,
                "created_at": timestamp
            })
        else:
            # CGST Output
            if cgst_amount > 0:
                entries.append({
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "ledger_type": "cgst_output",
                    "ledger_name": "CGST Output",
                    "account_code": "2411",
                    "entry_type": "credit",
                    "amount": cgst_amount,
                    "reference_type": "sale",
                    "reference_id": reference_id,
                    "reference_number": reference_number,
                    "party_name": party_name,
                    "party_gstin": party_gstin,
                    "description": f"CGST Output on {reference_number}",
                    "date": date,
                    "store_id": store_id,
                    "created_at": timestamp
                })
            # SGST Output
            if sgst_amount > 0:
                entries.append({
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "ledger_type": "sgst_output",
                    "ledger_name": "SGST Output",
                    "account_code": "2412",
                    "entry_type": "credit",
                    "amount": sgst_amount,
                    "reference_type": "sale",
                    "reference_id": reference_id,
                    "reference_number": reference_number,
                    "party_name": party_name,
                    "party_gstin": party_gstin,
                    "description": f"SGST Output on {reference_number}",
                    "date": date,
                    "store_id": store_id,
                    "created_at": timestamp
                })
    
    elif transaction_type == "purchase":
        # INPUT GST - Asset (we pay to supplier, can claim from govt)
        if is_interstate and igst_amount > 0:
            # IGST Input
            entries.append({
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "ledger_type": "igst_input",
                "ledger_name": "IGST Input",
                "account_code": "1410",  # Asset
                "entry_type": "debit",
                "amount": igst_amount,
                "reference_type": "purchase",
                "reference_id": reference_id,
                "reference_number": reference_number,
                "party_name": party_name,
                "party_gstin": party_gstin,
                "description": f"IGST Input on {reference_number}",
                "date": date,
                "store_id": store_id,
                "created_at": timestamp
            })
        else:
            # CGST Input
            if cgst_amount > 0:
                entries.append({
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "ledger_type": "cgst_input",
                    "ledger_name": "CGST Input",
                    "account_code": "1411",
                    "entry_type": "debit",
                    "amount": cgst_amount,
                    "reference_type": "purchase",
                    "reference_id": reference_id,
                    "reference_number": reference_number,
                    "party_name": party_name,
                    "party_gstin": party_gstin,
                    "description": f"CGST Input on {reference_number}",
                    "date": date,
                    "store_id": store_id,
                    "created_at": timestamp
                })
            # SGST Input
            if sgst_amount > 0:
                entries.append({
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "ledger_type": "sgst_input",
                    "ledger_name": "SGST Input",
                    "account_code": "1412",
                    "entry_type": "debit",
                    "amount": sgst_amount,
                    "reference_type": "purchase",
                    "reference_id": reference_id,
                    "reference_number": reference_number,
                    "party_name": party_name,
                    "party_gstin": party_gstin,
                    "description": f"SGST Input on {reference_number}",
                    "date": date,
                    "store_id": store_id,
                    "created_at": timestamp
                })
    
    # Insert all entries
    if entries:
        await db.gst_ledger.insert_many(entries)
        logger.info(f"Posted {len(entries)} GST ledger entries for {reference_number}")
    
    return entries

# Helper to get GST rate for an item (HSN-based or default)
async def get_item_gst_rate(tenant_id: str, item_id: str = None, hsn_code: str = None) -> dict:
    """Get GST rate for an item - prioritizes HSN-based rate, falls back to default"""
    # Default config
    config = await db.gst_config.find_one({"tenant_id": tenant_id}, {"_id": 0})
    default_rate = config.get("default_gst_rate", 5) if config else 5
    
    gst_info = {
        "total_rate": default_rate,
        "cgst_rate": default_rate / 2,
        "sgst_rate": default_rate / 2,
        "igst_rate": default_rate,
        "source": "default"
    }
    
    # Try to get HSN-based rate if item has HSN code
    if hsn_code:
        hsn = await db.hsn_codes.find_one({"tenant_id": tenant_id, "code": hsn_code, "is_active": True})
        if hsn and hsn.get("gst_slab_id"):
            slab = await db.gst_slabs.find_one({"id": hsn["gst_slab_id"], "tenant_id": tenant_id})
            if slab:
                gst_info = {
                    "total_rate": slab.get("total_rate", default_rate),
                    "cgst_rate": slab.get("cgst_rate", default_rate / 2),
                    "sgst_rate": slab.get("sgst_rate", default_rate / 2),
                    "igst_rate": slab.get("igst_rate", default_rate),
                    "slab_id": slab.get("id"),
                    "slab_name": slab.get("name"),
                    "source": "hsn"
                }
    
    # Try to get from item's own GST rate if specified
    if item_id:
        item = await db.items.find_one({"id": item_id, "tenant_id": tenant_id}, {"_id": 0, "gst_rate": 1, "hsn_code": 1})
        if item:
            if item.get("gst_rate") and item.get("gst_rate") > 0:
                rate = item["gst_rate"]
                gst_info = {
                    "total_rate": rate,
                    "cgst_rate": rate / 2,
                    "sgst_rate": rate / 2,
                    "igst_rate": rate,
                    "source": "item"
                }
            elif item.get("hsn_code") and not hsn_code:
                # Recursively get HSN-based rate
                return await get_item_gst_rate(tenant_id, hsn_code=item["hsn_code"])
    
    return gst_info

# GST Summary Report endpoint
@api_router.get("/gst-summary")
async def get_gst_summary(
    start_date: str = "",
    end_date: str = "",
    user: dict = Depends(get_current_user)
):
    """Get GST summary showing Input vs Output for CGST, SGST, IGST"""
    tenant_id = get_tenant_id(user)
    
    query = {"tenant_id": tenant_id}
    if start_date:
        query["date"] = {"$gte": start_date}
    if end_date:
        query.setdefault("date", {})["$lte": end_date]
    
    # Aggregate GST ledger entries
    pipeline = [
        {"$match": query},
        {"$group": {
            "_id": "$ledger_type",
            "total_amount": {"$sum": "$amount"},
            "count": {"$sum": 1}
        }}
    ]
    
    results = await db.gst_ledger.aggregate(pipeline).to_list(20)
    
    summary = {
        "cgst_input": 0,
        "cgst_output": 0,
        "sgst_input": 0,
        "sgst_output": 0,
        "igst_input": 0,
        "igst_output": 0
    }
    
    for r in results:
        if r["_id"] in summary:
            summary[r["_id"]] = r["total_amount"]
    
    # Calculate net payable/receivable
    summary["cgst_payable"] = summary["cgst_output"] - summary["cgst_input"]
    summary["sgst_payable"] = summary["sgst_output"] - summary["sgst_input"]
    summary["igst_payable"] = summary["igst_output"] - summary["igst_input"]
    summary["total_gst_payable"] = summary["cgst_payable"] + summary["sgst_payable"] + summary["igst_payable"]
    
    return {
        "period": {"start_date": start_date, "end_date": end_date},
        "summary": summary,
        "breakdown": results
    }

