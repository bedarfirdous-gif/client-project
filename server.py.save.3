@api_router.post("/rbac/api-keys")
async def create_api_key(request: dict = Body(...), user: dict = Depends(get_current_user)):
    """
    Create a new API key for external integrations
    
    Request Body:
    {
        "name": "ERP Integration",
        "permissions": ["read:items", "read:inventory", "write:sales"],
        "expires_at": "2025-12-31" or null,
        "rate_limit": 1000
    }
    
    Response includes the key (shown only once):
    {
        "id": "...",
        "name": "...",
        "key": "bk_live_xxxxxxxx",  // Only shown once!
        "permissions": [...]
    }
    """
    if user.get("role") not in ["admin", "superadmin"] and not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    
    # Generate API key
    import secrets
    api_key = f"bk_live_{secrets.token_hex(24)}"
    key_hash = hashlib.sha256(api_key.encode()).hexdigest()
    
    key_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "name": request.get("name"),
        "key_prefix": api_key[:12],  # Store prefix for identification
        "key_hash": key_hash,
        "permissions": request.get("permissions", ["read:all"]),
        "rate_limit": request.get("rate_limit", 1000),
        "expires_at": request.get("expires_at"),
        "is_active": True,
        "last_used": None,
        "usage_count": 0,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get("id")
    }
    
    await db.api_keys.insert_one(key_doc)
    
    # Return with the actual key (only time it's shown)
    return {
        "id": key_doc["id"],
        "name": key_doc["name"],
        "key": api_key,  # Only shown once!
        "permissions": key_doc["permissions"],
        "expires_at": key_doc["expires_at"],
        "message": "Save this API key securely. It won't be shown again."
    }


@api_router.delete("/rbac/api-keys/{key_id}")
async def revoke_api_key(key_id: str, user: dict = Depends(get_current_user)):
