        "group_id": "sundry_creditors",
        "ledger_type": "liability",
        "ledger_nature": "credit",
        "opening_balance": 0,
        "opening_balance_type": "Cr",
        "contact_person": request.contact_person if hasattr(request, 'contact_person') else "",
        "address": request.address if hasattr(request, 'address') else "",
        "city": request.city if hasattr(request, 'city') else "",
        "state": request.state if hasattr(request, 'state') else "",
