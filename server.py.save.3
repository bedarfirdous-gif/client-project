        "tenant_id": tenant_id,
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(5000)
    
    trial_balance = []
    total_debit = 0
    total_credit = 0
    
    for ledger in ledgers:
        # Get all transactions up to date
        transactions = await db.ledger_transactions.find({
            "tenant_id": tenant_id,
            "ledger_id": ledger["id"],
            "date": {"$lte": as_on_date}
        }, {"_id": 0}).to_list(10000)
        
        trans_debit = sum(t.get("debit", 0) for t in transactions)
        trans_credit = sum(t.get("credit", 0) for t in transactions)
        
        # Add opening balance
        opening = ledger.get("opening_balance", 0)
        if ledger.get("opening_balance_type", "dr") == "cr":
            opening = -opening
        
        balance = opening + trans_debit - trans_credit
        
        if abs(balance) > 0.01:  # Only include non-zero balances
            entry = {
                "ledger_id": ledger["id"],
                "ledger_name": ledger["name"],
                "group_id": ledger.get("group_id"),
                "ledger_type": ledger.get("ledger_type"),
                "debit": balance if balance > 0 else 0,
                "credit": -balance if balance < 0 else 0
            }
            trial_balance.append(entry)
            
            if balance > 0:
                total_debit += balance
            else:
                total_credit += -balance
    
    # Sort by ledger type and name
    trial_balance.sort(key=lambda x: (x.get("ledger_type", ""), x.get("ledger_name", "")))
    
    return {
        "trial_balance": trial_balance,
        "summary": {
            "total_debit": total_debit,
            "total_credit": total_credit,
            "difference": total_debit - total_credit,
            "is_balanced": abs(total_debit - total_credit) < 0.01,
            "as_on_date": as_on_date,
            "ledger_count": len(trial_balance)
        }
    }


