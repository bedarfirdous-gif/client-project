@api_router.get("/settings/sensitivity/check")
async def check_sensitivity_required(
    action_type: str,
    amount: float = 0,
    count: int = 1,
    user: dict = Depends(get_current_user)
):
    """Check if a specific action requires re-authentication based on settings"""
    tenant_id = get_tenant_id(user)
    
    setting = await db.sensitivity_settings.find_one({
        "tenant_id": tenant_id,
        "action_type": action_type
    })
    
    # Default to requiring re-auth if no setting exists
    if not setting:
        return {"requires_reauth": True, "reason": "Default security policy"}
    
    if not setting.get("enabled", True):
        return {"requires_reauth": False, "reason": "Re-auth disabled for this action"}
    
    threshold_type = setting.get("threshold_type", "none")
    threshold_value = setting.get("threshold_value", 0)
    
    if threshold_type == "none":
        return {"requires_reauth": True, "reason": "Always requires verification"}
    
    if threshold_type == "amount" and amount >= threshold_value:
        return {"requires_reauth": True, "reason": f"Amount ₹{amount} exceeds threshold ₹{threshold_value}"}
    
    if threshold_type == "count" and count >= threshold_value:
        return {"requires_reauth": True, "reason": f"Count {count} exceeds threshold {threshold_value}"}
    
    return {"requires_reauth": False, "reason": "Below threshold"}

