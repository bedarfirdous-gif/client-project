# REMINDER: DO NOT HARDCODE THE URL, OR ADD ANY FALLBACKS OR REDIRECT URLS, THIS BREAKS THE AUTH

from google.oauth2.credentials import Credentials
from google_auth_oauthlib.flow import Flow
from googleapiclient.discovery import build
import httplib2

# Google OAuth Configuration - Get from environment
GOOGLE_CLIENT_ID = os.environ.get("GOOGLE_CLIENT_ID", "")
GOOGLE_CLIENT_SECRET = os.environ.get("GOOGLE_CLIENT_SECRET", "")
GOOGLE_SCOPES = [
    'https://www.googleapis.com/auth/business.manage',
    'https://www.googleapis.com/auth/userinfo.email',
    'https://www.googleapis.com/auth/userinfo.profile'
]

def get_google_oauth_config():
    """Get Google OAuth configuration"""
    return {
        "web": {
            "client_id": GOOGLE_CLIENT_ID,
            "client_secret": GOOGLE_CLIENT_SECRET,
            "auth_uri": "https://accounts.google.com/o/oauth2/auth",
            "token_uri": "https://oauth2.googleapis.com/token",
            "redirect_uris": []  # Set dynamically based on request origin
        }
    }

@api_router.get("/gmb/auth-url/{store_id}")
async def get_gmb_auth_url(
    store_id: str,
    redirect_uri: str = Query(..., description="Frontend redirect URI"),
    user: dict = Depends(get_current_user)
):
    """Generate Google OAuth URL for connecting a store to GMB"""
    if not GOOGLE_CLIENT_ID or not GOOGLE_CLIENT_SECRET:
        raise HTTPException(
            status_code=400, 
            detail="Google OAuth not configured. Please set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET environment variables."
        )
    
    tenant_id = get_tenant_id(user)
    
    # Verify store exists and belongs to tenant
    store = await db.stores.find_one({"tenant_id": tenant_id, "id": store_id}, {"_id": 0})
    if not store:
        raise HTTPException(status_code=404, detail="Store not found")
    
    # Create OAuth flow
    config = get_google_oauth_config()
    config["web"]["redirect_uris"] = [redirect_uri]
    
    flow = Flow.from_client_config(
        config,
        scopes=GOOGLE_SCOPES,
        redirect_uri=redirect_uri
    )
    
    # Generate authorization URL with state containing store_id
    auth_url, state = flow.authorization_url(
        access_type='offline',
        include_granted_scopes='true',
        prompt='consent',
        state=f"{tenant_id}:{store_id}"
    )
    
    # Store state temporarily for verification
    await db.gmb_oauth_states.update_one(
        {"state": state},
        {"$set": {
            "state": state,
            "tenant_id": tenant_id,
            "store_id": store_id,
            "user_id": user.get("id"),
            "created_at": datetime.now(timezone.utc).isoformat(),
            "redirect_uri": redirect_uri
        }},
        upsert=True
    )
    
    return {"auth_url": auth_url, "state": state}

@api_router.post("/gmb/callback")
async def gmb_oauth_callback(
    code: str = Body(...),
    state: str = Body(...),
    redirect_uri: str = Body(...),
    user: dict = Depends(get_current_user)
):
    """Handle Google OAuth callback and store tokens"""
    if not GOOGLE_CLIENT_ID or not GOOGLE_CLIENT_SECRET:
        raise HTTPException(status_code=400, detail="Google OAuth not configured")
    
    # Verify state
    state_doc = await db.gmb_oauth_states.find_one({"state": state})
    if not state_doc:
        raise HTTPException(status_code=400, detail="Invalid OAuth state")
    
    tenant_id = state_doc["tenant_id"]
    store_id = state_doc["store_id"]
    
    # Clean up state
    await db.gmb_oauth_states.delete_one({"state": state})
    
    try:
        # Exchange code for tokens
        config = get_google_oauth_config()
        config["web"]["redirect_uris"] = [redirect_uri]
        
        flow = Flow.from_client_config(
            config,
            scopes=GOOGLE_SCOPES,
            redirect_uri=redirect_uri
        )
        
        flow.fetch_token(code=code)
        credentials = flow.credentials
        
        # Get user info (email of connected Google account)
        user_info_service = build('oauth2', 'v2', credentials=credentials)
        google_user = user_info_service.userinfo().get().execute()
        
        # Try to get GMB account info
        gmb_account = None
        gmb_locations = []
        try:
            # Build account management service
            account_service = build('mybusinessaccountmanagement', 'v1', credentials=credentials)
            accounts_response = account_service.accounts().list().execute()
            accounts = accounts_response.get('accounts', [])
            
            if accounts:
                gmb_account = accounts[0]  # Use first account
                
                # Get locations for this account
                try:
                    # Build business info service for locations
                    business_service = build('mybusinessbusinessinformation', 'v1', credentials=credentials)
                    locations_response = business_service.accounts().locations().list(
                        parent=gmb_account['name'],
                        readMask="name,title,storefrontAddress"
                    ).execute()
                    gmb_locations = locations_response.get('locations', [])
                except Exception as loc_err:
                    print(f"Error fetching locations: {loc_err}")
        except Exception as gmb_err:
            print(f"Error fetching GMB account: {gmb_err}")
        
        # Store tokens and connection info
        connection_doc = {
            "tenant_id": tenant_id,
            "store_id": store_id,
            "google_email": google_user.get("email"),
            "google_name": google_user.get("name"),
            "google_picture": google_user.get("picture"),
            "access_token": credentials.token,
            "refresh_token": credentials.refresh_token,
            "token_expiry": credentials.expiry.isoformat() if credentials.expiry else None,
            "gmb_account_id": gmb_account.get("name") if gmb_account else None,
            "gmb_account_name": gmb_account.get("accountName") if gmb_account else None,
            "gmb_locations": gmb_locations,
            "connected_at": datetime.now(timezone.utc).isoformat(),
            "connected_by": user.get("name"),
            "status": "connected"
        }
        
        await db.gmb_connections.update_one(
            {"tenant_id": tenant_id, "store_id": store_id},
            {"$set": connection_doc},
            upsert=True
        )
        
        # Update store with GMB connection status
        await db.stores.update_one(
            {"tenant_id": tenant_id, "id": store_id},
            {"$set": {
                "gmb_connected": True,
                "gmb_email": google_user.get("email"),
                "gmb_connected_at": datetime.now(timezone.utc).isoformat()
            }}
        )
        
        return {
            "success": True,
            "message": "Successfully connected to Google My Business",
            "google_email": google_user.get("email"),
            "gmb_account": gmb_account.get("accountName") if gmb_account else None,
            "locations_count": len(gmb_locations)
        }
        
    except Exception as e:
        raise HTTPException(status_code=400, detail=f"OAuth failed: {str(e)}")

