@api_router.get("/reports/ecommerce/sales")
async def get_ecommerce_sales_report(
    user: dict = Depends(get_current_user),
    start_date: str = Query(None),
    end_date: str = Query(None),
    group_by: str = Query("day")  # day, week, month
):
    """Get e-commerce sales report"""
    tenant_id = get_tenant_id(user)
    
    # Default to last 30 days
    if not end_date:
        end_date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    if not start_date:
        start_date = (datetime.now(timezone.utc) - timedelta(days=30)).strftime("%Y-%m-%d")
    
    query = {
        "tenant_id": tenant_id,
        "created_at": {"$gte": start_date, "$lte": end_date + "T23:59:59"},
        "payment_status": "paid"
    }
    
    orders = await db.ecommerce_orders.find(query, {"_id": 0}).to_list(None)
    
    # Group by date
    sales_by_date = {}
    for order in orders:
        date_key = order.get("created_at", "")[:10]  # YYYY-MM-DD
        
        if group_by == "month":
            date_key = date_key[:7]  # YYYY-MM
        elif group_by == "week":
            dt = datetime.fromisoformat(order.get("created_at", "").replace("Z", "+00:00"))
            week_start = dt - timedelta(days=dt.weekday())
            date_key = week_start.strftime("%Y-%m-%d")
        
        if date_key not in sales_by_date:
            sales_by_date[date_key] = {"orders": 0, "revenue": 0, "items_sold": 0}
        
        sales_by_date[date_key]["orders"] += 1
        sales_by_date[date_key]["revenue"] += order.get("total_amount", 0)
        sales_by_date[date_key]["items_sold"] += sum(item.get("quantity", 0) for item in order.get("items", []))
    
    # Sort by date
    sorted_sales = [{"date": k, **v} for k, v in sorted(sales_by_date.items())]
    
    # Calculate totals
    total_revenue = sum(o.get("total_amount", 0) for o in orders)
    total_orders = len(orders)
    total_items = sum(sum(item.get("quantity", 0) for item in o.get("items", [])) for o in orders)
    avg_order_value = total_revenue / total_orders if total_orders > 0 else 0
    
    return {
        "period": {"start": start_date, "end": end_date},
        "summary": {
            "total_revenue": round(total_revenue, 2),
            "total_orders": total_orders,
            "total_items_sold": total_items,
            "avg_order_value": round(avg_order_value, 2)
        },
        "sales_by_date": sorted_sales,
        "group_by": group_by
    }


@api_router.get("/reports/ecommerce/products")
async def get_product_performance_report(
    user: dict = Depends(get_current_user),
    start_date: str = Query(None),
    end_date: str = Query(None),
    limit: int = Query(20)
):
    """Get product performance report"""
    tenant_id = get_tenant_id(user)
    
    if not end_date:
        end_date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    if not start_date:
        start_date = (datetime.now(timezone.utc) - timedelta(days=30)).strftime("%Y-%m-%d")
    
    pipeline = [
        {"$match": {
            "tenant_id": tenant_id,
            "created_at": {"$gte": start_date, "$lte": end_date + "T23:59:59"},
            "payment_status": "paid"
        }},
        {"$unwind": "$items"},
        {"$group": {
            "_id": "$items.item_id",
            "name": {"$first": "$items.name"},
            "total_sold": {"$sum": "$items.quantity"},
            "total_revenue": {"$sum": {"$multiply": ["$items.price", "$items.quantity"]}},
            "order_count": {"$sum": 1}
        }},
        {"$sort": {"total_revenue": -1}},
        {"$limit": limit}
    ]
    
    products = await db.ecommerce_orders.aggregate(pipeline).to_list(limit)
    
    return {
        "period": {"start": start_date, "end": end_date},
        "top_products": products
    }


@api_router.get("/reports/ecommerce/customers")
async def get_customer_report(
    user: dict = Depends(get_current_user),
    start_date: str = Query(None),
    end_date: str = Query(None)
):
    """Get customer acquisition and retention report"""
    tenant_id = get_tenant_id(user)
    
    if not end_date:
        end_date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    if not start_date:
        start_date = (datetime.now(timezone.utc) - timedelta(days=30)).strftime("%Y-%m-%d")
    
    # Get unique customers
    pipeline = [
        {"$match": {
            "tenant_id": tenant_id,
            "created_at": {"$gte": start_date, "$lte": end_date + "T23:59:59"}
        }},
        {"$group": {
            "_id": "$customer_email",
            "name": {"$first": "$customer_name"},
            "total_orders": {"$sum": 1},
            "total_spent": {"$sum": "$total_amount"},
            "first_order": {"$min": "$created_at"},
            "last_order": {"$max": "$created_at"}
        }},
        {"$sort": {"total_spent": -1}}
    ]
    
    customers = await db.ecommerce_orders.aggregate(pipeline).to_list(100)
    
    # Calculate metrics
    total_customers = len(customers)
    new_customers = sum(1 for c in customers if c.get("total_orders", 0) == 1)
    repeat_customers = total_customers - new_customers
    avg_customer_value = sum(c.get("total_spent", 0) for c in customers) / total_customers if total_customers > 0 else 0
    
    return {
        "period": {"start": start_date, "end": end_date},
        "summary": {
            "total_customers": total_customers,
            "new_customers": new_customers,
            "repeat_customers": repeat_customers,
            "repeat_rate": round(repeat_customers / total_customers * 100, 1) if total_customers > 0 else 0,
            "avg_customer_value": round(avg_customer_value, 2)
        },
        "top_customers": customers[:20]
    }


@api_router.get("/reports/ecommerce/conversion")
async def get_conversion_report(
    user: dict = Depends(get_current_user),
    start_date: str = Query(None),
    end_date: str = Query(None)
):
    """Get conversion funnel report"""
    tenant_id = get_tenant_id(user)
    
    if not end_date:
        end_date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    if not start_date:
        start_date = (datetime.now(timezone.utc) - timedelta(days=30)).strftime("%Y-%m-%d")
    
    date_filter = {"$gte": start_date, "$lte": end_date + "T23:59:59"}
    
    # Get order statuses
    total_orders = await db.ecommerce_orders.count_documents({
        "tenant_id": tenant_id,
        "created_at": date_filter
    })
    
    paid_orders = await db.ecommerce_orders.count_documents({
        "tenant_id": tenant_id,
        "created_at": date_filter,
        "payment_status": "paid"
    })
    
    delivered_orders = await db.ecommerce_orders.count_documents({
        "tenant_id": tenant_id,
        "created_at": date_filter,
        "status": "delivered"
    })
    
    cancelled_orders = await db.ecommerce_orders.count_documents({
        "tenant_id": tenant_id,
        "created_at": date_filter,
        "status": "cancelled"
    })
    
    # Calculate rates
    payment_conversion = (paid_orders / total_orders * 100) if total_orders > 0 else 0
    fulfillment_rate = (delivered_orders / paid_orders * 100) if paid_orders > 0 else 0
    cancellation_rate = (cancelled_orders / total_orders * 100) if total_orders > 0 else 0
    
    return {
        "period": {"start": start_date, "end": end_date},
        "funnel": {
            "total_orders": total_orders,
            "paid_orders": paid_orders,
            "delivered_orders": delivered_orders,
            "cancelled_orders": cancelled_orders
        },
        "rates": {
            "payment_conversion": round(payment_conversion, 1),
            "fulfillment_rate": round(fulfillment_rate, 1),
            "cancellation_rate": round(cancellation_rate, 1)
        }
    }


