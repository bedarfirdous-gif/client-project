@api_router.get("/users/online")
async def get_online_users(user: dict = Depends(get_current_user)):
    """Get list of currently online users (active sessions within last 5 minutes)"""
    if not is_superadmin(user) and user.get("role") not in ["manager"]:
        raise HTTPException(status_code=403, detail="Admin access required")
    
    tenant_id = get_tenant_id(user)
    cutoff = (datetime.now(timezone.utc) - timedelta(minutes=5)).isoformat()
    
    # Get active sessions
    sessions = await db.user_sessions.find({
        "tenant_id": tenant_id,
        "is_active": True,
        "last_activity": {"$gte": cutoff}
    }, {"_id": 0}).to_list(100)
    
    # Get all users for offline comparison
    all_users = await db.users.find(
        {"tenant_id": tenant_id, "is_active": True},
        {"_id": 0, "password": 0}
    ).to_list(100)
    
    online_user_ids = [s["user_id"] for s in sessions]
    
    result = {
        "online": [],
        "offline": []
    }
    
    for u in all_users:
        user_info = {
            "id": u["id"],
            "name": u.get("name", "Unknown"),
            "email": u.get("email", ""),
            "role": u.get("role", "staff"),
            "last_login": u.get("last_login"),
            "last_ip": u.get("last_ip")
        }
        
        if u["id"] in online_user_ids:
            session = next((s for s in sessions if s["user_id"] == u["id"]), None)
            if session:
                user_info["session_start"] = session.get("login_time")
                user_info["last_activity"] = session.get("last_activity")
                user_info["ip_address"] = session.get("ip_address")
            result["online"].append(user_info)
        else:
            result["offline"].append(user_info)
    
    return result

