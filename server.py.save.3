    store_name = invoice_settings.get("company_name", "Our Store") if invoice_settings else "Our Store"
    
    prompt = f"""Analyze and optimize this blog post for SEO:

Title: {post.get('title', '')}
Content: {post.get('content', '')[:2000]}
Current Meta Title: {post.get('meta_title', '')}
Current Meta Description: {post.get('meta_description', '')}
