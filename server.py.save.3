        # Create message with image
        user_message = UserMessage(
            text="Extract all product/item details from this invoice image. Return only JSON array.",
            file_contents=[ImageContent(image_base64=image_base64)]
        )
        
        # Get response
        response = await chat.send_message(user_message)
        
        # Parse response
        items = []
        try:
            # Clean response - extract JSON from response
            response_text = response.strip()
            if response_text.startswith("```json"):
                response_text = response_text[7:]
            if response_text.startswith("```"):
                response_text = response_text[3:]
            if response_text.endswith("```"):
                response_text = response_text[:-3]
            response_text = response_text.strip()
            
            items = json.loads(response_text)
            
            # Normalize items
            normalized_items = []
            for item in items:
                normalized_items.append({
                    'name': str(item.get('name', '')).strip(),
                    'sku': str(item.get('sku', '')).strip(),
                    'category': str(item.get('category', '')).strip(),
                    'brand': str(item.get('brand', '')).strip(),
                    'size': str(item.get('size', '')).strip(),
                    'color': str(item.get('color', '')).strip(),
                    'mrp': float(item.get('mrp', 0) or 0),
                    'selling_price': float(item.get('selling_price', item.get('price', 0)) or 0),
                    'cost_price': float(item.get('cost_price', item.get('selling_price', 0)) or 0),
                    'quantity': int(item.get('quantity', item.get('qty', 1)) or 1),
                    'min_stock_alert': 5,
                    'gst_rate': float(item.get('gst_rate', 18) or 18),
                    'hsn_code': str(item.get('hsn_code', '')).strip(),
                })
            items = normalized_items
            
        except json.JSONDecodeError:
            logger.error(f"Failed to parse AI response: {response[:500]}")
            raise HTTPException(status_code=500, detail="AI could not extract items from this invoice. Try a clearer image.")
        
        return {
            "success": True,
            "items": items,
            "stats": {
                "total_extracted": len(items),
                "valid": len(items),
                "new": len(items),
                "update": 0,
                "errors": 0
            },
            "ai_powered": True
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Invoice scan error: {e}")
        error_msg = str(e)
        if "502" in error_msg or "timeout" in error_msg.lower() or "gateway" in error_msg.lower():
            raise HTTPException(status_code=503, detail="AI service temporarily unavailable. Please try again in a moment.")
        raise HTTPException(status_code=500, detail=f"Failed to scan invoice: {error_msg}")


@api_router.post("/smart-scanner/import")
async def import_scanned_items(
    body: dict = Body(...),
    user: dict = Depends(get_current_user)
):
    """Import scanned items into inventory"""
    tenant_id = get_tenant_id(user)
    
    items = body.get('items', [])
    store_id = body.get('store_id', '')
    
    if not items:
        raise HTTPException(status_code=400, detail="No items to import")
    
    imported = 0
    errors = 0
    
    # Get or create default category
    default_category = await db.categories.find_one({"tenant_id": tenant_id, "name": "Uncategorized"})
    if not default_category:
        default_category = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "name": "Uncategorized",
            "created_at": datetime.now(timezone.utc).isoformat()
        }
        await db.categories.insert_one(default_category)
    
    for item_data in items:
        try:
            # Find or create category
            category_id = ""
            if item_data.get('category'):
                cat = await db.categories.find_one({"tenant_id": tenant_id, "name": item_data['category']})
                if cat:
                    category_id = cat['id']
                else:
                    # Create new category
                    new_cat = {
                        "id": str(uuid.uuid4()),
                        "tenant_id": tenant_id,
                        "name": item_data['category'],
                        "created_at": datetime.now(timezone.utc).isoformat()
                    }
                    await db.categories.insert_one(new_cat)
                    category_id = new_cat['id']
            else:
                category_id = default_category['id']
            
            # Find or create brand
            brand_id = ""
            if item_data.get('brand'):
                brand = await db.brands.find_one({"tenant_id": tenant_id, "name": item_data['brand']})
                if brand:
                    brand_id = brand['id']
                else:
                    new_brand = {
                        "id": str(uuid.uuid4()),
                        "tenant_id": tenant_id,
                        "name": item_data['brand'],
                        "created_at": datetime.now(timezone.utc).isoformat()
                    }
                    await db.brands.insert_one(new_brand)
                    brand_id = new_brand['id']
            
            # Check if item exists by SKU
            existing = await db.items.find_one({"tenant_id": tenant_id, "sku": item_data.get('sku')}) if item_data.get('sku') else None
            
            if existing:
                # Update existing item stock
                await db.items.update_one(
                    {"id": existing['id']},
                    {"$inc": {"current_stock": item_data.get('quantity', 0)}}
                )
            else:
                # Create new item
                item_id = str(uuid.uuid4())
                sku = item_data.get('sku') or f"SKU-{item_id[:8].upper()}"
                
                new_item = {
                    "id": item_id,
                    "tenant_id": tenant_id,
                    "name": item_data['name'],
                    "sku": sku,
                    "category_id": category_id,
                    "brand_id": brand_id,
                    "hsn_code": item_data.get('hsn_code', ''),
                    "gst_rate": item_data.get('gst_rate', 18),
                    "mrp": item_data.get('mrp', 0),
                    "selling_price": item_data.get('selling_price', 0),
                    "cost_price": item_data.get('cost_price', 0),
                    "current_stock": item_data.get('quantity', 0),
                    "min_stock_alert": item_data.get('min_stock_alert', 5),
                    "unit": "pcs",
                    "active": True,
                    "status": "active",
                    "created_at": datetime.now(timezone.utc).isoformat(),
                    "updated_at": datetime.now(timezone.utc).isoformat()
                }
                await db.items.insert_one(new_item)
                
                # Create variant if size/color specified
                if item_data.get('size') or item_data.get('color'):
                    variant = {
                        "id": str(uuid.uuid4()),
                        "tenant_id": tenant_id,
                        "item_id": item_id,
                        "size": item_data.get('size', ''),
                        "color": item_data.get('color', ''),
                        "barcode": item_data.get('barcode', ''),
                        "mrp": item_data.get('mrp', 0),
                        "selling_price": item_data.get('selling_price', 0),
                        "current_stock": item_data.get('quantity', 0),
                        "created_at": datetime.now(timezone.utc).isoformat()
                    }
                    await db.variants.insert_one(variant)
                
                # Add initial stock to store inventory
                if store_id:
                    inventory_entry = {
                        "id": str(uuid.uuid4()),
                        "tenant_id": tenant_id,
                        "store_id": store_id,
                        "item_id": item_id,
                        "quantity": item_data.get('quantity', 0),
                        "created_at": datetime.now(timezone.utc).isoformat()
                    }
                    await db.inventory.insert_one(inventory_entry)
            
            imported += 1
            
        except Exception as e:
            logger.error(f"Error importing item {item_data.get('name')}: {e}")
            errors += 1
    
    # Save upload history
    upload_number = f"UPL-{datetime.now().strftime('%Y%m%d%H%M%S')}"
    upload_history = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "upload_number": upload_number,
        "source": body.get('source', 'excel'),
        "file_name": body.get('file_name', ''),
        "total_items": len(items),
        "imported": imported,
        "errors": errors,
        "status": "completed" if errors == 0 else ("partial" if imported > 0 else "failed"),
        "items": items,
        "error_log": [],
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get('id')
    }
    await db.upload_history.insert_one(upload_history)
    
    return {
        "success": True,
        "imported": imported,
        "errors": errors,
        "upload_number": upload_number,
        "message": f"Successfully imported {imported} items" + (f" with {errors} errors" if errors else "")
    }


