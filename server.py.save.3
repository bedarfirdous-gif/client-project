# User Profile - Update own profile (any authenticated user)
@api_router.put("/users/me/profile")
async def update_my_profile(request: dict, user: dict = Depends(get_current_user)):
    """Update current user's own profile (name, password)"""
    user_id = user.get("id")
    
    # Get current user from DB
    current_user = await db.users.find_one({"id": user_id})
    if not current_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    update_data = {}
    
    # Update name if provided
    if "name" in request and request["name"]:
        update_data["name"] = request["name"]
    
    # Update password if provided
    if "new_password" in request and request["new_password"]:
        # Verify current password
        if "current_password" not in request or not request["current_password"]:
            raise HTTPException(status_code=400, detail="Current password is required")
        
        if not verify_password(request["current_password"], current_user.get("password", "")):
            raise HTTPException(status_code=400, detail="Current password is incorrect")
        
        # Validate new password
        if len(request["new_password"]) < 6:
            raise HTTPException(status_code=400, detail="New password must be at least 6 characters")
        
        update_data["password"] = hash_password(request["new_password"])
    
    if not update_data:
        raise HTTPException(status_code=400, detail="No changes provided")
    
    update_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    
    await db.users.update_one({"id": user_id}, {"$set": update_data})
    
    # Create audit entry
    await db.audit_trail.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": get_tenant_id(user),
        "action": "profile_updated",
        "entity_type": "user",
        "entity_id": user_id,
        "entity_name": current_user.get("name"),
        "performed_by": user_id,
        "performed_by_name": current_user.get("name"),
        "details": {"password_changed": "new_password" in request and request["new_password"]},
        "created_at": datetime.now(timezone.utc).isoformat()
    })
    
    updated = await db.users.find_one({"id": user_id}, {"_id": 0, "password": 0})
    return updated

