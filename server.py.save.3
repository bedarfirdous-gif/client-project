@api_router.post("/sales-returns")
async def create_sales_return(request: SaleReturnCreate, user: dict = Depends(require_permission("returns"))):
    tenant_id = get_tenant_id(user)
    inv_service = get_inventory_service()
    
    # Get original sale
    sale = await db.sales.find_one({"id": request.invoice_id})
    if not sale:
        raise HTTPException(status_code=404, detail="Original sale not found")
    
    # Get return number
    count = await db.sales_returns.count_documents({"tenant_id": tenant_id})
    return_number = f"SR-{count + 1:06d}"
    return_id = str(uuid.uuid4())
    
    # Calculate amounts from return_items
    return_amount = request.return_amount or sum(i.get("amount", i.get("rate", 0) * i.get("quantity", 1)) for i in request.return_items)
    exchange_amount = request.exchange_amount or sum(i.get("amount", i.get("rate", 0) * i.get("quantity", 1)) for i in request.exchange_items)
    gst_amount = return_amount * 0.05  # Assuming 5% GST
    net_refund = return_amount - exchange_amount
    
    return_doc = {
        "id": return_id,
        "return_number": return_number,
        "tenant_id": tenant_id,
        "invoice_id": request.invoice_id,
        "original_invoice_number": request.invoice_number or sale.get("invoice_number"),
        "customer_id": request.customer_id or sale.get("customer_id"),
        "customer_name": request.customer_name or sale.get("customer_name"),
        "store_id": sale.get("store_id"),
        "type": request.type,
        "return_items": request.return_items,
        "exchange_items": request.exchange_items,
        "return_amount": return_amount,
        "exchange_amount": exchange_amount,
        "gst_amount": gst_amount,
        "net_refund": net_refund,
        "difference_amount": request.difference_amount,
        "refund_method": request.refund_method,
        "reason": request.reason,
        "notes": request.notes,
        "status": "completed",
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Process return items via centralized inventory service (add stock back)
    return_stock_items = []
    for item in request.return_items:
        variant_id = item.get("variant_id")
        if variant_id:
            return_stock_items.append({
                "item_id": item.get("item_id", ""),
                "variant_id": variant_id,
                "quantity": item.get("quantity", 1)
            })
            # Also update legacy inventory
            await db.inventory.update_one(
                {"variant_id": variant_id, "store_id": sale.get("store_id")},
                {"$inc": {"quantity": item.get("quantity", 1)}}
            )
    
    if return_stock_items:
        try:
            await inv_service.process_return(
                tenant_id=tenant_id,
                return_id=return_id,
                items=return_stock_items,
                return_type="sale_return",
                warehouse_id=sale.get("store_id"),
                performed_by=user.get("id")
            )
        except Exception as e:
            logger.error(f"Failed to process return stock: {e}")
    
    # Process exchange items via centralized inventory service (deduct stock)
    exchange_stock_items = []
    for item in request.exchange_items:
        variant_id = item.get("variant_id")
        if variant_id:
            exchange_stock_items.append({
                "item_id": item.get("item_id", ""),
                "variant_id": variant_id,
                "quantity": item.get("quantity", 1)
            })
            # Also update legacy inventory
            await db.inventory.update_one(
                {"variant_id": variant_id, "store_id": sale.get("store_id")},
                {"$inc": {"quantity": -item.get("quantity", 1)}}
            )
    
    if exchange_stock_items:
        try:
            # Check availability first
            availability = await inv_service.check_stock_availability(
                tenant_id, exchange_stock_items, warehouse_id=sale.get("store_id")
            )
            
            if not availability["available"]:
                raise HTTPException(
                    status_code=400,
                    detail="Insufficient stock for exchange items"
                )
            
            await inv_service.process_sale(
                tenant_id=tenant_id,
                sale_id=f"{return_id}_exchange",
                items=exchange_stock_items,
                warehouse_id=sale.get("store_id"),
                performed_by=user.get("id")
            )
        except HTTPException:
            raise
        except Exception as e:
            logger.error(f"Failed to process exchange stock: {e}")
    
    await db.sales_returns.insert_one(return_doc)
    del return_doc["_id"]
    return return_doc

