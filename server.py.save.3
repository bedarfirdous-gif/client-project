    user: dict = Depends(require_permission("training_center"))
):
    """Get upcoming training sessions for dashboard widget"""
    sessions = await training_system.get_sessions(
        user_id=user.get("id"),
        tenant_id=get_tenant_id(user),
        user_role=user.get("role"),
        status="scheduled",
        limit=limit
    )
    
    # Filter to only future sessions
    now = datetime.now(timezone.utc).isoformat()
    upcoming = [s for s in sessions if s.get("scheduled_start", "") > now]
    
    return {"sessions": upcoming[:limit]}


