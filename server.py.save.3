@api_router.get("/supplier-ledger")
async def get_supplier_ledger_list(user: dict = Depends(get_current_user)):
    """Get all suppliers with their ledger summary"""
    tenant_id = get_tenant_id(user)
    
    suppliers = await db.suppliers.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(10000)
    purchases = await db.purchase_invoices.find({"tenant_id": tenant_id, "is_deleted": {"$ne": True}}, {"_id": 0}).to_list(10000)
    returns = await db.purchase_returns.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(10000)
    
    # Also get Sundry Creditor ledgers to match purchases that use ledger_id as supplier_id
    creditor_ledgers = await db.ledgers.find({
        "tenant_id": tenant_id,
        "group_id": "sundry_creditors",
        "is_deleted": {"$ne": True}
    }, {"_id": 0}).to_list(10000)
    
    ledger_list = []
    processed_ledger_ids = set()
    
    # First, process suppliers that exist in the suppliers collection
    for supp in suppliers:
        supp_id = supp["id"]
        ledger_id = supp.get("ledger_id")
        
        # Match purchases by supplier_id OR ledger_id
        supp_purchases = [p for p in purchases if p.get("supplier_id") == supp_id or (ledger_id and p.get("supplier_id") == ledger_id)]
        supp_returns = [r for r in returns if r.get("supplier_id") == supp_id or (ledger_id and r.get("supplier_id") == ledger_id)]
        
        total_purchases = sum(p.get("total_amount", 0) for p in supp_purchases)
        total_paid = sum(p.get("total_amount", 0) for p in supp_purchases if p.get("payment_status") == "paid")
        total_returns = sum(r.get("refund_amount", 0) for r in supp_returns if r.get("status") == "completed")
        balance = total_purchases - total_paid - total_returns
        
        ledger_list.append({
            "supplier_id": supp_id,
            "supplier_name": supp.get("name", "Unknown"),
            "phone": supp.get("phone", ""),
            "gst_number": supp.get("gst_number", ""),
            "total_transactions": len(supp_purchases) + len(supp_returns),
            "total_purchases": total_purchases,
            "total_paid": total_paid,
            "total_returns": total_returns,
            "balance": balance
        })
        
        if ledger_id:
            processed_ledger_ids.add(ledger_id)
    
    # Now process creditor ledgers that don't have a corresponding supplier
    # (purchases made using ledger_id directly)
    for ledger in creditor_ledgers:
        ledger_id = ledger["id"]
        if ledger_id in processed_ledger_ids:
            continue
        
        # Check if any purchases use this ledger_id as supplier_id
        ledger_purchases = [p for p in purchases if p.get("supplier_id") == ledger_id]
        ledger_returns = [r for r in returns if r.get("supplier_id") == ledger_id]
        
        if not ledger_purchases and not ledger_returns:
            continue
        
        total_purchases = sum(p.get("total_amount", 0) for p in ledger_purchases)
        total_paid = sum(p.get("total_amount", 0) for p in ledger_purchases if p.get("payment_status") == "paid")
        total_returns = sum(r.get("refund_amount", 0) for r in ledger_returns if r.get("status") == "completed")
        balance = total_purchases - total_paid - total_returns
        
        ledger_list.append({
            "supplier_id": ledger_id,  # Use ledger_id as supplier_id for compatibility
            "supplier_name": ledger.get("name", "Unknown"),
            "phone": "",
            "gst_number": "",
            "total_transactions": len(ledger_purchases) + len(ledger_returns),
            "total_purchases": total_purchases,
            "total_paid": total_paid,
            "total_returns": total_returns,
            "balance": balance
        })
    
    return ledger_list

@api_router.get("/supplier-ledger/{supplier_id}")
async def get_supplier_ledger_detail(supplier_id: str, user: dict = Depends(get_current_user)):
    """Get detailed ledger for a specific supplier"""
    tenant_id = get_tenant_id(user)
    
    # First try to find supplier by ID
    supplier = await db.suppliers.find_one({"id": supplier_id, "tenant_id": tenant_id}, {"_id": 0})
    supplier_name = supplier.get("name", "Unknown") if supplier else None
    ledger_id = supplier.get("ledger_id") if supplier else None
    
    # If not found as supplier, check if supplier_id is actually a ledger ID
    if not supplier:
        ledger = await db.ledgers.find_one({
            "id": supplier_id, 
            "tenant_id": tenant_id,
            "group_id": "sundry_creditors"
        }, {"_id": 0})
        if ledger:
            supplier_name = ledger.get("name", "Unknown")
        else:
            raise HTTPException(status_code=404, detail="Supplier not found")
    
    # Get all purchases for this supplier - match by supplier_id OR ledger_id
    purchases = await db.purchase_invoices.find({
        "tenant_id": tenant_id,
        "is_deleted": {"$ne": True},
        "$or": [
            {"supplier_id": supplier_id},
            {"supplier_id": ledger_id} if ledger_id else {"supplier_id": supplier_id}
        ]
    }, {"_id": 0}).to_list(10000)
    
    # Get all returns for this supplier
    returns = await db.purchase_returns.find({
        "tenant_id": tenant_id,
        "$or": [
            {"supplier_id": supplier_id},
            {"supplier_id": ledger_id} if ledger_id else {"supplier_id": supplier_id}
        ]
    }, {"_id": 0}).to_list(10000)
    
    transactions = []
    running_balance = 0
    
    # Combine and sort by date
    all_txns = []
    for p in purchases:
        all_txns.append({
            "sort_date": p.get("invoice_date", p.get("created_at", "")),
            "type": "purchase",
            "data": p
        })
    for r in returns:
        all_txns.append({
            "sort_date": r.get("return_date", r.get("created_at", "")),
            "type": "return",
            "data": r
        })
    
    all_txns.sort(key=lambda x: x["sort_date"])
    
    for txn in all_txns:
        if txn["type"] == "purchase":
            p = txn["data"]
            purchase_amount = p.get("total_amount", 0)
            
            # Add purchase transaction (credit - we owe supplier)
            running_balance += purchase_amount
            transactions.append({
                "date": p.get("invoice_date", ""),
                "type": "purchase",
                "reference": p.get("invoice_number", p.get("id", "")[:8]),
                "description": "Purchase Invoice",
                "debit": 0,
                "credit": purchase_amount,
                "balance": running_balance
            })
            
            # Add payment if paid (debit - we paid supplier)
            if p.get("payment_status") == "paid":
                running_balance -= purchase_amount
                transactions.append({
                    "date": p.get("invoice_date", ""),
                    "type": "payment",
                    "reference": f"PMT-{p.get('invoice_number', p.get('id', '')[:8])}",
                    "description": "Payment Made",
                    "debit": purchase_amount,
                    "credit": 0,
                    "balance": running_balance
                })
        
        elif txn["type"] == "return":
            r = txn["data"]
            if r.get("status") == "completed":
                refund_amount = r.get("refund_amount", 0)
                running_balance -= refund_amount
                transactions.append({
                    "date": r.get("return_date", ""),
                    "type": "return",
                    "reference": r.get("return_number", r.get("id", "")[:8]),
                    "description": "Purchase Return",
                    "debit": refund_amount,
                    "credit": 0,
                    "balance": running_balance
                })
    
    return {
        "supplier": supplier if supplier else {"name": supplier_name, "id": supplier_id},
        "transactions": transactions,
        "summary": {
            "total_debit": sum(t["debit"] for t in transactions),
            "total_credit": sum(t["credit"] for t in transactions),
            "closing_balance": running_balance
        }
    }

