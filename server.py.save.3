        "shipping_policy": ecom_settings.get("shipping_policy", ""),
        "return_policy": ecom_settings.get("return_policy", ""),
        "accepts_cod": ecom_settings.get("accepts_cod", True),
        "min_order_amount": ecom_settings.get("min_order_amount", 0),
