@api_router.post("/self-healing/rollback/{fix_id}")
async def trigger_manual_rollback(
    fix_id: str,
    reason: str = "Manual rollback",
    user: dict = Depends(require_permission("settings"))
):
    """Manually trigger a rollback for a fix"""
    try:
        from self_healing_core.rollback_manager import RollbackReason
        action = await self_healing_orchestrator.rollback_manager.rollback(
            fix_id=fix_id,
            reason=RollbackReason.MANUAL_TRIGGER,
            description=f"{reason} by {user.get('email', 'unknown')}"
        )
        return {
            "action_id": action.action_id,
            "status": action.status.value,
            "success": action.success,
            "verification_result": action.verification_result
        }
    except Exception as e:
        logger.error(f"Error triggering rollback: {e}")
        raise HTTPException(status_code=500, detail=str(e))


