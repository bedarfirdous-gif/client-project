@api_router.get("/item-discounts/calculate")
async def calculate_item_discount(
    item_id: str = "",
    variant_id: str = "",
    category_id: str = "",
    brand_id: str = "",
    quantity: int = 1,
    original_price: float = 0,
    store_id: str = "",
    apply_on: str = "pos",  # pos, online, invoice
    user: dict = Depends(get_current_user)
):
    """Calculate applicable discount for an item with centralized discount support"""
    tenant_id = get_tenant_id(user)
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    # Find applicable discounts
    query = {
        "tenant_id": tenant_id,
        "active": True,
        "valid_from": {"$lte": today},
        "valid_until": {"$gte": today},
        "min_quantity": {"$lte": quantity},
        "$or": [
            {"item_id": item_id},
            {"variant_id": variant_id},
            {"category_id": category_id},
            {"brand_id": brand_id},
            {"item_id": None, "variant_id": None, "category_id": None, "brand_id": None}  # Global discounts
        ]
    }
    
    discounts = await db.item_discounts.find(query, {"_id": 0}).to_list(100)
    
    # Filter discounts based on centralized settings
    applicable_discounts = []
    for d in discounts:
        # Check if discount applies to this channel (pos/online/invoice)
        discount_apply_on = d.get("apply_on", ["pos", "online", "invoice"])
        if apply_on not in discount_apply_on:
            continue
        
        # Check if auto_apply is enabled (skip manual-only discounts)
        if not d.get("auto_apply", True):
            continue
        
        # Check store applicability
        is_global = d.get("is_global", True)
        applicable_stores = d.get("applicable_store_ids", [])
        excluded_stores = d.get("excluded_store_ids", [])
        
        # If store_id is provided, check if discount applies to this store
        if store_id:
            # Check if store is excluded
            if store_id in excluded_stores:
                continue
            # If not global, check if store is in applicable list
            if not is_global and applicable_stores and store_id not in applicable_stores:
                continue
        
        applicable_discounts.append(d)
    
    if not applicable_discounts:
        return {"original_price": original_price, "final_price": original_price, "discount_amount": 0, "discounts_applied": [], "auto_applied": True}
    
    # Apply best discount (highest value)
    best_discount = None
    best_discount_amount = 0
    
    for d in applicable_discounts:
        if d.get("discount_type") == "percentage":
            amount = original_price * d.get("discount_value", 0) / 100
        elif d.get("discount_type") == "fixed":
            amount = d.get("discount_value", 0)
        elif d.get("discount_type") == "price_override":
            amount = original_price - d.get("discount_value", 0)
        else:
            continue
        
        if amount > best_discount_amount:
            best_discount_amount = amount
            best_discount = d
    
    final_price = max(0, original_price - best_discount_amount)
    
    return {
        "original_price": original_price,
        "final_price": final_price,
        "discount_amount": best_discount_amount,
        "discounts_applied": [best_discount] if best_discount else [],
        "auto_applied": True
    }

