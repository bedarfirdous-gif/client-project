@api_router.post("/users")
async def create_user(request: UserCreate, user: dict = Depends(get_current_user)):
    if not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Admin only")
    
    existing = await db.users.find_one({"email": request.email.lower()})
    if existing:
        raise HTTPException(status_code=400, detail="Email already exists")
    
    tenant_id = get_tenant_id(user)
    
    # Get default permissions for role or use provided
    permissions = request.permissions if request.permissions else DEFAULT_ROLE_PERMISSIONS.get(request.role, DEFAULT_ROLE_PERMISSIONS["staff"])
    
    user_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "email": request.email.lower(),
        "password": hash_password(request.password),
        "name": request.name,
        "role": request.role,
        "store_ids": request.store_ids,
        "permissions": permissions,
        "is_active": True,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get("id")
    }
    await db.users.insert_one(user_doc)
    
    # Create audit trail entry
    await db.audit_trail.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "action": "user_created",
        "entity_type": "user",
        "entity_id": user_doc["id"],
        "entity_name": request.name,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "details": {"role": request.role, "email": request.email.lower()},
        "created_at": datetime.now(timezone.utc).isoformat()
    })
    
    # Return user with plain password (one-time display)
    user_doc["_id"] = None
    del user_doc["_id"]
    response_doc = {**user_doc}
    response_doc["plain_password"] = request.password  # Return password for one-time display
    del response_doc["password"]  # Remove hashed password
    return response_doc

@api_router.post("/users/{user_id}/reset-password")
async def admin_reset_user_password(user_id: str, user: dict = Depends(get_current_user)):
    """Admin can reset password for users in their tenant and see the new password"""
    if user.get("role") != "admin":
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    target_user = await db.users.find_one({"id": user_id, "tenant_id": tenant_id})
    
    if not target_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    # Generate new password
    import random
    import string
    new_password = ''.join(random.choices(string.ascii_letters + string.digits, k=12))
    hashed = hash_password(new_password)
    
    now = datetime.now(timezone.utc).isoformat()
    await db.users.update_one(
        {"id": user_id},
        {"$set": {
            "password": hashed,
            "password_reset_at": now,
            "password_reset_by": user.get("id"),
            "updated_at": now
        }}
    )
    
    # Audit trail
    await db.audit_trail.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "action": "password_reset",
        "entity_type": "user",
        "entity_id": user_id,
        "entity_name": target_user.get("name"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "details": {"reset_by_admin": True},
        "created_at": now
    })
    
    return {
        "success": True,
        "user_id": user_id,
        "user_email": target_user.get("email"),
        "user_name": target_user.get("name"),
        "new_password": new_password,
        "reset_at": now
    }

