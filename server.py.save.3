@api_router.get("/accounting/income-statement")
async def get_income_statement(
    start_date: str = "",
    end_date: str = "",
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Generate Income Statement (Profit & Loss)"""
    tenant_id = get_tenant_id(user)
    
    # Build date query
    date_query = {"tenant_id": tenant_id}
    if start_date:
        date_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in date_query:
            date_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            date_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    if store_id:
        date_query["store_id"] = store_id
    
    # Revenue from Sales
    sales = await db.sales.find(date_query, {"_id": 0}).to_list(10000)
    total_sales_revenue = sum(s.get("total_amount", 0) for s in sales)
    total_gst_collected = sum(s.get("gst_amount", 0) for s in sales)
    total_discounts_given = sum(s.get("discount_amount", 0) + s.get("voucher_discount", 0) for s in sales)
    
    # Revenue from Invoices (if not covered in sales)
    invoice_query = {"tenant_id": tenant_id}
    if start_date:
        invoice_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in invoice_query:
            invoice_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            invoice_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    invoices = await db.invoices.find(invoice_query, {"_id": 0}).to_list(10000)
    total_invoice_revenue = sum(i.get("total_amount", 0) or i.get("total", 0) for i in invoices)
    
    # Cost of Goods Sold (from purchases)
    purchase_query = {"tenant_id": tenant_id}
    if start_date:
        purchase_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in purchase_query:
            purchase_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            purchase_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    purchases = await db.purchase_invoices.find(purchase_query, {"_id": 0}).to_list(10000)
    total_cogs = sum(p.get("total_amount", 0) for p in purchases)
    
    # Operating Expenses (from payroll if available)
    payroll_query = {"tenant_id": tenant_id}
    if start_date and end_date:
        payroll_query["$or"] = [
            {"pay_period_start": {"$gte": start_date, "$lte": end_date}},
            {"pay_period_end": {"$gte": start_date, "$lte": end_date}}
        ]
    
    payroll = await db.payroll.find(payroll_query, {"_id": 0}).to_list(10000)
    total_salaries = sum(p.get("net_pay", 0) for p in payroll)
    
    # Sales Returns
    returns_query = {"tenant_id": tenant_id}
    if start_date:
        returns_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in returns_query:
            returns_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            returns_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    sales_returns = await db.sales_returns.find(returns_query, {"_id": 0}).to_list(10000)
    total_sales_returns = sum(r.get("refund_amount", 0) for r in sales_returns)
    
    # Calculate totals
    gross_revenue = total_sales_revenue + total_invoice_revenue
    net_revenue = gross_revenue - total_discounts_given - total_sales_returns
    gross_profit = net_revenue - total_cogs
    total_operating_expenses = total_salaries
    net_profit = gross_profit - total_operating_expenses
    
    return {
        "period": {"start_date": start_date, "end_date": end_date, "store_id": store_id},
        "revenue": {
            "sales_revenue": total_sales_revenue,
            "invoice_revenue": total_invoice_revenue,
            "gross_revenue": gross_revenue,
            "discounts": total_discounts_given,
            "sales_returns": total_sales_returns,
            "net_revenue": net_revenue,
            "gst_collected": total_gst_collected
        },
        "cost_of_goods_sold": {
            "purchases": total_cogs,
            "total_cogs": total_cogs
        },
        "gross_profit": gross_profit,
        "operating_expenses": {
            "salaries_wages": total_salaries,
            "total_operating_expenses": total_operating_expenses
        },
        "net_profit": net_profit,
        "profit_margin": round((net_profit / net_revenue * 100) if net_revenue > 0 else 0, 2),
        "transaction_counts": {
            "sales": len(sales),
            "invoices": len(invoices),
            "purchases": len(purchases),
            "returns": len(sales_returns)
        }
    }

@api_router.get("/accounting/balance-sheet")
async def get_balance_sheet(
    as_of_date: str = "",
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Generate Balance Sheet"""
    tenant_id = get_tenant_id(user)
    
    # Build date query (all transactions up to as_of_date)
    date_query = {"tenant_id": tenant_id}
    if as_of_date:
        date_query["created_at"] = {"$lte": datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))}
    if store_id:
        date_query["store_id"] = store_id
    
    # ASSETS
    # Cash = Total Sales Received - Total Purchases Paid - Payroll Paid
    sales = await db.sales.find(date_query, {"_id": 0}).to_list(10000)
    total_cash_from_sales = sum(s.get("total_amount", 0) for s in sales)
    
    # Invoices with payments
    invoice_query = {"tenant_id": tenant_id}
    if as_of_date:
        invoice_query["created_at"] = {"$lte": datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))}
    invoices = await db.invoices.find(invoice_query, {"_id": 0}).to_list(10000)
    total_invoice_payments = sum(i.get("amount_paid", 0) for i in invoices)
    
    # Accounts Receivable = Unpaid Invoice Amounts
    accounts_receivable = sum(i.get("balance_due", 0) for i in invoices)
    
    # Inventory Value
    inventory = await db.inventory.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(10000)
    total_inventory_value = sum(
        (i.get("quantity", 0) * i.get("purchase_rate", 0)) 
        for i in inventory
    )
    
    # Purchases (outflow)
    purchase_query = {"tenant_id": tenant_id}
    if as_of_date:
        purchase_query["created_at"] = {"$lte": datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))}
    purchases = await db.purchase_invoices.find(purchase_query, {"_id": 0}).to_list(10000)
    total_purchases_paid = sum(p.get("total_amount", 0) for p in purchases if p.get("payment_status") == "paid")
    
    # Accounts Payable = Unpaid Purchase Amounts
    accounts_payable = sum(
        p.get("total_amount", 0) - p.get("amount_paid", 0) 
        for p in purchases 
        if p.get("payment_status") != "paid"
    )
    
    # Payroll (outflow)
    payroll = await db.payroll.find({"tenant_id": tenant_id, "status": "paid"}, {"_id": 0}).to_list(10000)
    total_payroll_paid = sum(p.get("net_pay", 0) for p in payroll)
    
    # Calculate Cash
    cash = total_cash_from_sales + total_invoice_payments - total_purchases_paid - total_payroll_paid
    
    # LIABILITIES
    # Sales Tax Payable
    sales_tax_payable = sum(s.get("gst_amount", 0) for s in sales)
    
    # Calculate totals
    total_current_assets = cash + accounts_receivable + total_inventory_value
    total_assets = total_current_assets
    
    total_current_liabilities = accounts_payable + sales_tax_payable
    total_liabilities = total_current_liabilities
    
    # EQUITY
    owners_equity = total_assets - total_liabilities
    
    return {
        "as_of_date": as_of_date or datetime.now(timezone.utc).isoformat(),
        "store_id": store_id,
        "assets": {
            "current_assets": {
                "cash": round(cash, 2),
                "accounts_receivable": round(accounts_receivable, 2),
                "inventory": round(total_inventory_value, 2),
                "total_current_assets": round(total_current_assets, 2)
            },
            "fixed_assets": {
                "total_fixed_assets": 0
            },
            "total_assets": round(total_assets, 2)
        },
        "liabilities": {
            "current_liabilities": {
                "accounts_payable": round(accounts_payable, 2),
                "sales_tax_payable": round(sales_tax_payable, 2),
                "total_current_liabilities": round(total_current_liabilities, 2)
            },
            "long_term_liabilities": {
                "total_long_term_liabilities": 0
            },
            "total_liabilities": round(total_liabilities, 2)
        },
        "equity": {
            "owners_capital": round(owners_equity, 2),
            "retained_earnings": 0,
            "total_equity": round(owners_equity, 2)
        },
        "total_liabilities_and_equity": round(total_liabilities + owners_equity, 2)
    }

@api_router.get("/accounting/cash-flow")
async def get_cash_flow_statement(
    start_date: str = "",
    end_date: str = "",
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Generate Cash Flow Statement"""
    tenant_id = get_tenant_id(user)
    
    # Build date query
    date_query = {"tenant_id": tenant_id}
    if start_date:
        date_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in date_query:
            date_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            date_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    if store_id:
        date_query["store_id"] = store_id
    
    # OPERATING ACTIVITIES
    # Cash Inflows
    sales = await db.sales.find(date_query, {"_id": 0}).to_list(10000)
    cash_from_sales = sum(s.get("total_amount", 0) for s in sales)
    
    invoice_query = {"tenant_id": tenant_id}
    if start_date:
        invoice_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in invoice_query:
            invoice_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            invoice_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    invoices = await db.invoices.find(invoice_query, {"_id": 0}).to_list(10000)
    cash_from_invoices = sum(i.get("amount_paid", 0) for i in invoices)
    
    # Cash Outflows
    purchase_query = {"tenant_id": tenant_id}
    if start_date:
        purchase_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in purchase_query:
            purchase_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            purchase_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    purchases = await db.purchase_invoices.find(purchase_query, {"_id": 0}).to_list(10000)
    cash_for_purchases = sum(p.get("total_amount", 0) for p in purchases if p.get("payment_status") == "paid")
    
    # Payroll
    payroll_query = {"tenant_id": tenant_id, "status": "paid"}
    if start_date and end_date:
        payroll_query["$or"] = [
            {"pay_period_start": {"$gte": start_date, "$lte": end_date}},
            {"pay_period_end": {"$gte": start_date, "$lte": end_date}}
        ]
    payroll = await db.payroll.find(payroll_query, {"_id": 0}).to_list(10000)
    cash_for_payroll = sum(p.get("net_pay", 0) for p in payroll)
    
    # Sales Returns (refunds)
    returns_query = {"tenant_id": tenant_id}
    if start_date:
        returns_query["created_at"] = {"$gte": datetime.fromisoformat(start_date.replace('Z', '+00:00'))}
    if end_date:
        if "created_at" in returns_query:
            returns_query["created_at"]["$lte"] = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        else:
            returns_query["created_at"] = {"$lte": datetime.fromisoformat(end_date.replace('Z', '+00:00'))}
    
    sales_returns = await db.sales_returns.find(returns_query, {"_id": 0}).to_list(10000)
    cash_for_refunds = sum(r.get("refund_amount", 0) for r in sales_returns)
    
    # Net Operating Cash Flow
    operating_inflows = cash_from_sales + cash_from_invoices
    operating_outflows = cash_for_purchases + cash_for_payroll + cash_for_refunds
    net_operating_cash = operating_inflows - operating_outflows
    
    return {
        "period": {"start_date": start_date, "end_date": end_date, "store_id": store_id},
        "operating_activities": {
            "inflows": {
                "cash_from_sales": round(cash_from_sales, 2),
                "cash_from_invoices": round(cash_from_invoices, 2),
                "total_inflows": round(operating_inflows, 2)
            },
            "outflows": {
                "cash_for_purchases": round(cash_for_purchases, 2),
                "cash_for_payroll": round(cash_for_payroll, 2),
                "cash_for_refunds": round(cash_for_refunds, 2),
                "total_outflows": round(operating_outflows, 2)
            },
            "net_operating_cash": round(net_operating_cash, 2)
        },
        "investing_activities": {
            "inflows": {"total_inflows": 0},
            "outflows": {"total_outflows": 0},
            "net_investing_cash": 0
        },
        "financing_activities": {
            "inflows": {"total_inflows": 0},
            "outflows": {"total_outflows": 0},
            "net_financing_cash": 0
        },
        "net_change_in_cash": round(net_operating_cash, 2),
        "transaction_counts": {
            "sales": len(sales),
            "invoices": len(invoices),
            "purchases": len(purchases),
            "payroll": len(payroll),
            "refunds": len(sales_returns)
        }
    }

@api_router.get("/accounting/trial-balance")
async def get_trial_balance(
    as_of_date: str = "",
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Generate Trial Balance"""
    tenant_id = get_tenant_id(user)
    
    # Build date query
    date_query = {"tenant_id": tenant_id}
    if as_of_date:
        date_query["created_at"] = {"$lte": datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))}
    if store_id:
        date_query["store_id"] = store_id
    
    # Get all transaction data
    sales = await db.sales.find(date_query, {"_id": 0}).to_list(10000)
    
    invoice_query = {"tenant_id": tenant_id}
    if as_of_date:
        invoice_query["created_at"] = {"$lte": datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))}
    invoices = await db.invoices.find(invoice_query, {"_id": 0}).to_list(10000)
    
    purchase_query = {"tenant_id": tenant_id}
    if as_of_date:
        purchase_query["created_at"] = {"$lte": datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))}
    purchases = await db.purchase_invoices.find(purchase_query, {"_id": 0}).to_list(10000)
    
    inventory = await db.inventory.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(10000)
    
    payroll = await db.payroll.find({"tenant_id": tenant_id, "status": "paid"}, {"_id": 0}).to_list(10000)
    
    returns_query = {"tenant_id": tenant_id}
    if as_of_date:
        returns_query["created_at"] = {"$lte": datetime.fromisoformat(as_of_date.replace('Z', '+00:00'))}
    sales_returns = await db.sales_returns.find(returns_query, {"_id": 0}).to_list(10000)
    
    # Calculate account balances
    total_sales = sum(s.get("total_amount", 0) for s in sales)
    total_invoice_revenue = sum(i.get("amount_paid", 0) for i in invoices)
    total_purchases = sum(p.get("total_amount", 0) for p in purchases)
    total_inventory = sum((i.get("quantity", 0) * i.get("purchase_rate", 0)) for i in inventory)
    total_payroll = sum(p.get("net_pay", 0) for p in payroll)
    total_returns = sum(r.get("refund_amount", 0) for r in sales_returns)
    total_gst = sum(s.get("gst_amount", 0) for s in sales)
    total_receivables = sum(i.get("balance_due", 0) for i in invoices)
    total_payables = sum(p.get("total_amount", 0) - p.get("amount_paid", 0) for p in purchases if p.get("payment_status") != "paid")
    
    # Cash calculation
    cash = total_sales + total_invoice_revenue - total_purchases - total_payroll - total_returns
    
    accounts = [
        # Assets (Debit balances)
        {"account_code": "1000", "account_name": "Cash", "debit": round(max(cash, 0), 2), "credit": round(abs(min(cash, 0)), 2)},
        {"account_code": "1100", "account_name": "Accounts Receivable", "debit": round(total_receivables, 2), "credit": 0},
        {"account_code": "1200", "account_name": "Inventory", "debit": round(total_inventory, 2), "credit": 0},
        # Liabilities (Credit balances)
        {"account_code": "2000", "account_name": "Accounts Payable", "debit": 0, "credit": round(total_payables, 2)},
        {"account_code": "2200", "account_name": "Sales Tax Payable", "debit": 0, "credit": round(total_gst, 2)},
        # Revenue (Credit balances)
        {"account_code": "4000", "account_name": "Sales Revenue", "debit": 0, "credit": round(total_sales + total_invoice_revenue, 2)},
        # Expenses (Debit balances)
        {"account_code": "5000", "account_name": "Cost of Goods Sold", "debit": round(total_purchases, 2), "credit": 0},
        {"account_code": "5100", "account_name": "Salaries & Wages", "debit": round(total_payroll, 2), "credit": 0},
        {"account_code": "5800", "account_name": "Sales Returns & Allowances", "debit": round(total_returns, 2), "credit": 0},
    ]
    
    # Filter out zero balances
    accounts = [a for a in accounts if a["debit"] > 0 or a["credit"] > 0]
    
    total_debits = sum(a["debit"] for a in accounts)
    total_credits = sum(a["credit"] for a in accounts)
    
    # Add balancing entry if needed
    difference = total_debits - total_credits
    if abs(difference) > 0.01:
        if difference > 0:
            accounts.append({"account_code": "3000", "account_name": "Owner's Equity", "debit": 0, "credit": round(difference, 2)})
        else:
            accounts.append({"account_code": "3000", "account_name": "Owner's Equity", "debit": round(abs(difference), 2), "credit": 0})
    
    # Recalculate totals
    total_debits = sum(a["debit"] for a in accounts)
    total_credits = sum(a["credit"] for a in accounts)
    
    return {
        "as_of_date": as_of_date or datetime.now(timezone.utc).isoformat(),
        "store_id": store_id,
        "accounts": sorted(accounts, key=lambda x: x["account_code"]),
        "totals": {
            "total_debits": round(total_debits, 2),
            "total_credits": round(total_credits, 2),
            "is_balanced": abs(total_debits - total_credits) < 0.01
        }
    }

@api_router.get("/accounting/general-ledger")
