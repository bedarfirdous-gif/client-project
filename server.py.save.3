@api_router.post("/purchase-invoices")
async def create_purchase_invoice(request: PurchaseInvoiceCreate, user: dict = Depends(get_current_user)):
    tenant_id = get_tenant_id(user)
    inv_service = get_inventory_service()
    
    # Generate invoice number if not provided
    if not request.invoice_number:
        count = await db.purchase_invoices.count_documents({"tenant_id": tenant_id})
        invoice_number = f"PUR-{count + 1:06d}"
    else:
        invoice_number = request.invoice_number
    
    purchase_id = str(uuid.uuid4())
    
    # Calculate GST for each item from GST Master
    items_with_gst = []
    total_taxable = 0
    total_cgst = 0
    total_sgst = 0
    total_gst = 0
    stock_items = []
    
    for item in request.items:
        variant_id = item.get("variant_id")
        item_id = item.get("item_id", "")
        quantity = item.get("quantity", 1)
        rate = item.get("rate", 0)
        amount = rate * quantity
        
        if variant_id:
            stock_items.append({
                "item_id": item_id,
                "variant_id": variant_id,
                "quantity": quantity
            })
        
        # CENTRALIZED GST CALCULATION - Auto-calculate from item's GST slab
        if item_id:
            gst_calc = await calculate_gst_for_item(tenant_id, item_id, variant_id, amount, is_inclusive=False)
            items_with_gst.append({
                "item_id": item_id,
                "variant_id": variant_id,
                "item_name": item.get("name", ""),
                "hsn_code": item.get("hsn_code", ""),
                "quantity": quantity,
                "rate": rate,
                "amount": amount,
                **gst_calc
            })
            total_taxable += gst_calc["taxable_amount"]
            total_cgst += gst_calc["cgst"]
            total_sgst += gst_calc["sgst"]
            total_gst += gst_calc["total_gst"]
    
    invoice_doc = {
        "id": purchase_id,
        "tenant_id": tenant_id,
        **request.model_dump(),
        "invoice_number": invoice_number,
        "gst_amount": round(total_gst, 2),
        "cgst_amount": round(total_cgst, 2),
        "sgst_amount": round(total_sgst, 2),
        "taxable_amount": round(total_taxable, 2),
        "items_with_gst": items_with_gst,
        "is_finalized": True,  # Purchases are immutable once created
        "created_by": user.get("id"),
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Get store info for audit trail
    store = await db.stores.find_one({"id": request.store_id}, {"_id": 0}) if request.store_id else None
    store_name = store.get("name") if store else None
    
    # Get supplier GSTIN
    supplier = await db.suppliers.find_one({"id": request.supplier_id}, {"_id": 0, "gst_number": 1, "name": 1}) if request.supplier_id else None
    supplier_gstin = supplier.get("gst_number", "") if supplier else ""
    supplier_name = supplier.get("name", "Unknown Supplier") if supplier else "Unknown Supplier"
    
    # CENTRALIZED STOCK UPDATE - Process purchase through inventory service
    if stock_items:
        try:
            await inv_service.process_purchase(
                tenant_id=tenant_id,
                purchase_id=purchase_id,
                items=stock_items,
                warehouse_id=request.store_id,
                performed_by=user.get("id")
            )
        except Exception as e:
            logger.error(f"Failed to process purchase stock: {e}")
            # Continue with purchase creation even if central stock fails
    
    # Also update legacy inventory - add purchased items to stock
    # Track newly created items to update their stock after all inventory records are created
    created_items = []
    created_variants = []
    
    for item in request.items:
        variant_id = item.get("variant_id")
        item_id = item.get("item_id")
        item_name = item.get("name", "") or item.get("item_name", "")
        quantity = item.get("quantity", 0)
        purchase_rate = item.get("rate", 0)
        is_new_item = False
        
        # CENTRALIZED: Ensure item exists in items collection
        if item_name and not item_id:
            # Try to find existing item by name
            existing_item = await db.items.find_one({
                "tenant_id": tenant_id,
                "name": {"$regex": f"^{item_name}$", "$options": "i"}
            })
            if existing_item:
                item_id = existing_item["id"]
                # Also get existing variant
                existing_variant = await db.variants.find_one({
                    "item_id": item_id, "tenant_id": tenant_id
                })
                if existing_variant:
                    variant_id = existing_variant["id"]
            else:
                # Create new item with initial stock
                is_new_item = True
                item_id = str(uuid.uuid4())
                new_item = {
                    "id": item_id,
                    "tenant_id": tenant_id,
                    "name": item_name,
                    "sku": item_name.upper().replace(" ", "-")[:20] + "-" + str(uuid.uuid4())[:4],
                    "description": "",
                    "selling_price": purchase_rate * 1.3,  # Default 30% markup
                    "cost_price": purchase_rate,
                    "current_stock": quantity,  # SET INITIAL STOCK
                    "active": True,
                    "created_at": datetime.now(timezone.utc).isoformat(),
                    "created_by_purchase": purchase_id
                }
                await db.items.insert_one(new_item)
                created_items.append(item_id)
                logger.info(f"Created new item '{item_name}' (id={item_id}) with stock={quantity}")
                
                # Create default variant with initial stock
                variant_id = str(uuid.uuid4())
                new_variant = {
                    "id": variant_id,
                    "item_id": item_id,
                    "tenant_id": tenant_id,
                    "name": item_name,
                    "sku": new_item["sku"] + "-001",
                    "selling_price": purchase_rate * 1.3,
                    "cost_price": purchase_rate,
                    "current_stock": quantity,  # SET INITIAL STOCK
                    "created_at": datetime.now(timezone.utc).isoformat()
                }
                await db.variants.insert_one(new_variant)
                created_variants.append(variant_id)
                logger.info(f"Created new variant for '{item_name}' (id={variant_id}) with stock={quantity}")
        
        # If item_id is provided but variant_id is not, try to find the variant
        if item_id and not variant_id:
            existing_variant = await db.variants.find_one({
                "item_id": item_id, "tenant_id": tenant_id
            })
            if existing_variant:
                variant_id = existing_variant["id"]
                logger.info(f"Found variant {variant_id} for item {item_id}")
        
        # Update inventory - using item_id OR variant_id
        if item_id or variant_id:
            # Check if inventory exists
            inv_query = {"tenant_id": tenant_id, "store_id": request.store_id}
            if variant_id:
                inv_query["variant_id"] = variant_id
            elif item_id:
                inv_query["item_id"] = item_id
            
            existing = await db.inventory.find_one(inv_query)
            
            if existing:
                quantity_before = existing.get("quantity", 0)
                await db.inventory.update_one(
                    {"id": existing["id"]},
                    {"$inc": {"quantity": quantity}, "$set": {
                        "purchase_rate": purchase_rate,
                        "item_name": item_name,
                        "last_updated": datetime.now(timezone.utc).isoformat(),
                        "last_purchase_id": purchase_id
                    }}
                )
                logger.info(f"Updated inventory for '{item_name}': {quantity_before} -> {quantity_before + quantity}")
            else:
                quantity_before = 0
                inv_doc = {
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "variant_id": variant_id,
                    "item_id": item_id,
                    "item_name": item_name,
                    "store_id": request.store_id,
                    "quantity": quantity,
                    "current_stock": quantity,
                    "purchase_rate": purchase_rate,
                    "created_at": datetime.now(timezone.utc).isoformat(),
                    "created_by_purchase": purchase_id
                }
                await db.inventory.insert_one(inv_doc)
                logger.info(f"Created new inventory record for '{item_name}' with quantity={quantity}")
            
            # Log to audit trail
            await log_stock_movement(
                tenant_id=tenant_id,
                item_id=item_id,
                variant_id=variant_id,
                store_id=request.store_id,
                movement_type="purchase",
                quantity_change=quantity,
                quantity_before=quantity_before,
                quantity_after=quantity_before + quantity,
                user_id=user.get("id"),
                user_name=user.get("name"),
                reference_type="purchase_invoice",
                reference_id=purchase_id,
                notes=f"Purchase: {invoice_number}",
                item_name=item_name,
                store_name=store_name
            )
            
            # Update variant total stock if variant exists (ALWAYS update, not just for new)
            if variant_id:
                total = await db.inventory.aggregate([
                    {"$match": {"variant_id": variant_id, "tenant_id": tenant_id}},
                    {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
                ]).to_list(1)
                total_stock = total[0]["total"] if total else quantity
                await db.variants.update_one({"id": variant_id}, {"$set": {"current_stock": total_stock}})
                logger.info(f"Updated variant {variant_id} current_stock to {total_stock}")
            
            # Update item total stock (ALWAYS update, not just for new)
            if item_id:
                total = await db.inventory.aggregate([
                    {"$match": {"item_id": item_id, "tenant_id": tenant_id}},
                    {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
                ]).to_list(1)
                total_stock = total[0]["total"] if total else quantity
                await db.items.update_one({"id": item_id}, {"$set": {"current_stock": total_stock}})
                logger.info(f"Updated item {item_id} current_stock to {total_stock}")
    
    await db.purchase_invoices.insert_one(invoice_doc)
    
    # ============== CENTRALIZED ACCOUNTING ENTRY ==============
    # Process Purchase → Creditor Ledger → Central Ledger
    purchase_total = request.total_amount or (total_taxable + total_gst)
    purchase_date = request.invoice_date or datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    if request.supplier_id and purchase_total > 0:
        await process_purchase_accounting(
            tenant_id=tenant_id,
            invoice_id=purchase_id,
            invoice_number=invoice_number,
            supplier_id=request.supplier_id,
            supplier_name=supplier_name,
            total_amount=purchase_total,
            date=purchase_date,
            store_id=request.store_id
        )
        
        # ============== AUTOMATIC PAYMENT PROCESSING ==============
        # If payment mode is Cash/Bank, create payment entry automatically
        payment_method = getattr(request, 'payment_method', 'credit') or 'credit'
        payment_status = getattr(request, 'payment_status', 'pending') or 'pending'
        
        if payment_method.lower() != 'credit' and payment_status.lower() in ['paid', 'completed']:
            # Cash/Bank purchase - Create payment entry
            payment_id = f"{purchase_id}-pmt"
            payment_number = f"PAY-{invoice_number}"
            
            # Map payment modes
            if payment_method.lower() in ['cash']:
                accounting_mode = 'cash'
            elif payment_method.lower() in ['bank', 'upi', 'card', 'neft', 'rtgs', 'imps', 'cheque']:
                accounting_mode = 'bank'
            else:
                accounting_mode = 'cash'  # Default to cash
            
            await process_payment_accounting(
                tenant_id=tenant_id,
                payment_id=payment_id,
                payment_number=payment_number,
                supplier_id=request.supplier_id,
                supplier_name=supplier_name,
                amount=purchase_total,
                payment_mode=accounting_mode,
                date=purchase_date,
                store_id=request.store_id,
                invoice_id=purchase_id
            )
            
            # Create payment document for tracking
            payment_doc = {
                "id": payment_id,
                "payment_number": payment_number,
                "tenant_id": tenant_id,
                "supplier_id": request.supplier_id,
                "supplier_name": supplier_name,
                "invoice_id": purchase_id,
                "invoice_number": invoice_number,
                "amount": purchase_total,
                "payment_mode": payment_method,
                "accounting_mode": accounting_mode,
                "date": purchase_date,
                "store_id": request.store_id,
                "notes": f"Auto-generated payment for {invoice_number}",
                "created_by": user.get("id"),
                "created_at": datetime.now(timezone.utc).isoformat()
            }
            await db.payments.insert_one(payment_doc)
            
            logger.info(f"Payment {payment_number} auto-created for purchase {invoice_number} | Mode: {accounting_mode} | Amount: {purchase_total}")
        else:
            # Credit purchase - Update supplier payable (already done by process_purchase_accounting)
            logger.info(f"Credit purchase {invoice_number} - Accounts Payable updated for supplier {supplier_name}")
    # ============== END ACCOUNTING ENTRY ==============
    
    # RECORD GST LEDGER ENTRY (INPUT GST) - Centralized posting
    if total_gst > 0:
        # Check if interstate
        is_interstate = False
        gst_config = await db.gst_config.find_one({"tenant_id": tenant_id})
        seller_gstin = gst_config.get("seller_gstin", "") if gst_config else ""
        if supplier_gstin and seller_gstin and len(supplier_gstin) >= 2 and len(seller_gstin) >= 2:
            if supplier_gstin[:2] != seller_gstin[:2]:
                is_interstate = True
        
        cgst = total_gst / 2 if not is_interstate else 0
        sgst = total_gst / 2 if not is_interstate else 0
        igst = total_gst if is_interstate else 0
        
        await post_gst_to_ledgers(
            tenant_id=tenant_id,
            transaction_type="purchase",
            reference_id=purchase_id,
            reference_number=invoice_number,
            cgst_amount=cgst,
            sgst_amount=sgst,
            igst_amount=igst,
            is_interstate=is_interstate,
            date=purchase_date,
            party_name=supplier_name,
            party_gstin=supplier_gstin,
            store_id=request.store_id
        )
        logger.info(f"GST Input ledger posted for {invoice_number}: CGST={cgst}, SGST={sgst}, IGST={igst}")
        
        # Also record in legacy gst_ledger_entries for backward compatibility
        await record_gst_ledger_entry(
            tenant_id=tenant_id,
            entry_type="INPUT",
            reference_type="purchase",
            reference_id=purchase_id,
            reference_number=invoice_number,
            party_name=supplier_name,
            party_gstin=supplier_gstin,
            items_gst=items_with_gst,
            performed_by=user.get("id"),
            is_finalized=True
        )
    
    del invoice_doc["_id"]
    return invoice_doc

