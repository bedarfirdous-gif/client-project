@api_router.post("/real-autoheal/fix-error/{error_id}")
async def fix_specific_error(
    error_id: str,
    user: dict = Depends(require_permission("settings"))
):
    """Manually trigger fix for a specific error"""
    # Find the error
    errors = await real_autoheal_agent.get_errors(limit=100)
    target_error = None
    
    for err in errors:
        if err.get("error_id") == error_id:
            from real_autoheal_agent import DetectedError, ErrorCategory, Severity, FixStatus
            target_error = DetectedError(
                error_id=err["error_id"],
                category=ErrorCategory(err["category"]),
                severity=Severity(err["severity"]),
                message=err["message"],
                file_path=err.get("file_path", ""),
                source=err.get("source", ""),
                fix_status=FixStatus(err.get("fix_status", "pending"))
            )
            break
    
    if not target_error:
        raise HTTPException(status_code=404, detail="Error not found")
    
    fix = await real_autoheal_agent.analyze_and_fix(target_error)
    
    if fix:
        return {
            "fix_id": fix.fix_id,
            "description": fix.description,
            "status": fix.status.value,
            "verified": fix.verified,
            "verification_details": fix.verification_details
        }
    
    return {"message": "No fix could be generated", "status": "failed"}


