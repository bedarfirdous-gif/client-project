# ============== LIVE EXCHANGE RATES ==============

@api_router.get("/exchange-rates")
async def get_exchange_rates():
    """Get live exchange rates with daily caching"""
    import aiohttp
    
    # Check if we have cached rates from today
    cached = await db.exchange_rates.find_one({"_id": "latest"})
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    if cached and cached.get("date") == today:
        return {
            "rates": cached.get("rates", {}),
            "base": cached.get("base", "INR"),
            "date": cached.get("date"),
            "source": "cache",
            "last_updated": cached.get("last_updated")
        }
    
    # Fetch fresh rates from free API (ExchangeRate-API)
    try:
        async with aiohttp.ClientSession() as session:
            # Using free tier of exchangerate-api.com (no key needed for basic)
            url = "https://api.exchangerate-api.com/v4/latest/INR"
            async with session.get(url, timeout=10) as response:
                if response.status == 200:
                    data = await response.json()
                    
                    # Extract rates for supported currencies
                    all_rates = data.get("rates", {})
                    supported = ["INR", "USD", "EUR", "GBP", "AED", "SAR", "JPY", "CNY", "SGD", "AUD", "CAD", "MYR", "THB", "NPR", "BDT", "PKR", "LKR"]
                    rates = {currency: all_rates.get(currency, 1) for currency in supported if currency in all_rates}
                    rates["INR"] = 1  # Base currency
                    
                    # Cache the rates
                    now = datetime.now(timezone.utc).isoformat()
                    await db.exchange_rates.update_one(
                        {"_id": "latest"},
                        {"$set": {
                            "rates": rates,
                            "base": "INR",
                            "date": today,
                            "last_updated": now,
                            "source": "exchangerate-api.com"
                        }},
                        upsert=True
                    )
                    
                    return {
                        "rates": rates,
                        "base": "INR",
                        "date": today,
                        "source": "live",
                        "last_updated": now
                    }
    except Exception as e:
        logger.error(f"Failed to fetch exchange rates: {e}")
    
    # Fallback to cached rates or defaults
    if cached:
        return {
            "rates": cached.get("rates", {}),
            "base": cached.get("base", "INR"),
            "date": cached.get("date"),
            "source": "cache_fallback",
            "last_updated": cached.get("last_updated")
        }
    
    # Ultimate fallback - default rates
    default_rates = {
        "INR": 1, "USD": 0.012, "EUR": 0.011, "GBP": 0.0095,
        "AED": 0.044, "SAR": 0.045, "JPY": 1.79, "CNY": 0.087,
        "SGD": 0.016, "AUD": 0.018, "CAD": 0.016, "MYR": 0.056,
        "THB": 0.42, "NPR": 1.6, "BDT": 1.32, "PKR": 3.35, "LKR": 3.88
    }
    return {
        "rates": default_rates,
        "base": "INR",
        "date": today,
        "source": "default",
        "last_updated": datetime.now(timezone.utc).isoformat()
    }

@api_router.post("/exchange-rates/refresh")
async def refresh_exchange_rates():
    """Force refresh exchange rates from API"""
    # Delete cached rates to force fresh fetch
    await db.exchange_rates.delete_one({"_id": "latest"})
    return await get_exchange_rates()

