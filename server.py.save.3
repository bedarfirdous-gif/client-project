@api_router.get("/accounting/purchase-ledger")
async def get_purchase_ledger(
    start_date: str = None,
    end_date: str = None,
    supplier_id: str = None,
    user: dict = Depends(get_current_user)
):
    """Get purchase ledger - all purchase invoices with details"""
    tenant_id = get_tenant_id(user)
    
    # Build query
    query = {"tenant_id": tenant_id}
    if start_date:
        query["invoice_date"] = {"$gte": start_date}
    if end_date:
        query["invoice_date"] = {**query.get("invoice_date", {}), "$lte": end_date}
    if supplier_id:
        query["supplier_id"] = supplier_id
    
    # Get all purchase invoices
    invoices = await db.purchase_invoices.find(query, {"_id": 0}).sort("invoice_date", -1).to_list(None)
    
    # Format entries
    entries = []
    total_amount = 0
    total_gst = 0
    total_gross = 0
    
    for inv in invoices:
        amount = inv.get("subtotal", 0) or inv.get("taxable_amount", 0) or 0
        gst = inv.get("total_gst", 0) or inv.get("gst_amount", 0) or 0
        gross = inv.get("total_amount", 0) or (amount + gst)
        
        total_amount += amount
        total_gst += gst
        total_gross += gross
        
        entries.append({
            "id": inv.get("id"),
            "date": inv.get("invoice_date"),
            "invoice_number": inv.get("invoice_number"),
            "supplier_id": inv.get("supplier_id"),
            "supplier_name": inv.get("supplier_name"),
            "amount": amount,
            "gst": gst,
            "total": gross,
            "payment_status": inv.get("payment_status", "pending"),
            "items_count": len(inv.get("items", []))
        })
    
    return {
        "entries": entries,
        "summary": {
            "total_invoices": len(entries),
            "total_amount": total_amount,
            "total_gst": total_gst,
            "total_gross": total_gross
        }
    }

