    if result.modified_count == 0:
        raise HTTPException(status_code=404, detail="Purchase order not found")
    
    return {"message": f"Purchase order status updated to {status}"}


@api_router.post("/purchase-orders/{po_id}/convert-to-invoice")
async def convert_po_to_invoice(
    po_id: str,
    invoice_number: str = "",
    invoice_date: str = "",
    payment_status: str = "pending",
    user: dict = Depends(require_permission("purchase_orders"))
):
    """Convert an approved purchase order to a purchase invoice"""
    tenant_id = get_tenant_id(user)
    
    # Get the purchase order
    po = await db.purchase_orders.find_one({"id": po_id, "tenant_id": tenant_id}, {"_id": 0})
    if not po:
        raise HTTPException(status_code=404, detail="Purchase order not found")
    
    if po.get("status") not in ["approved", "pending"]:
        raise HTTPException(status_code=400, detail="Only approved or pending purchase orders can be converted to invoice")
    
    if po.get("converted_to_invoice"):
        raise HTTPException(status_code=400, detail="This purchase order has already been converted to an invoice")
    
    # Generate invoice number if not provided
    if not invoice_number:
        count = await db.purchase_invoices.count_documents({"tenant_id": tenant_id})
        invoice_number = f"PUR-{count + 1:06d}"
    
    if not invoice_date:
        invoice_date = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    # Create purchase invoice
    inv_service = get_inventory_service()
    purchase_id = str(uuid.uuid4())
    
    stock_items = []
    items_with_gst = []
    total_taxable = 0
    total_gst = 0
    
    for item in po.get("items", []):
        variant_id = item.get("variant_id")
        item_id = item.get("item_id", "")
        quantity = item.get("quantity", 1)
        rate = item.get("rate", 0)
        amount = rate * quantity
        
        if variant_id:
            stock_items.append({
                "item_id": item_id,
                "variant_id": variant_id,
                "quantity": quantity
            })
        
        # Calculate GST
        if item_id:
            gst_calc = await calculate_gst_for_item(tenant_id, item_id, variant_id, amount, is_inclusive=False)
            items_with_gst.append({
                "item_id": item_id,
                "variant_id": variant_id,
                "item_name": item.get("name", ""),
                "quantity": quantity,
                "rate": rate,
                "amount": amount,
                **gst_calc
            })
            total_taxable += gst_calc.get("taxable_amount", amount)
            total_gst += gst_calc.get("total_gst", 0)
    
    invoice_doc = {
        "id": purchase_id,
        "tenant_id": tenant_id,
        "supplier_id": po.get("supplier_id"),
        "store_id": po.get("store_id"),
        "invoice_number": invoice_number,
        "invoice_date": invoice_date,
        "items": po.get("items", []),
        "items_with_gst": items_with_gst,
        "subtotal": po.get("subtotal", 0),
        "tax_amount": total_gst,
        "gst_amount": total_gst,
        "taxable_amount": total_taxable,
        "discount_amount": 0,
        "freight_charges": 0,
        "other_charges": 0,
        "total_amount": po.get("subtotal", 0) + total_gst,
        "payment_status": payment_status,
        "payment_method": "",
        "notes": po.get("notes", "") + f" (Converted from PO: {po.get('po_number')})",
        "source_po_id": po_id,
        "source_po_number": po.get("po_number"),
        "is_finalized": True,
        "created_by": user.get("id"),
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    await db.purchase_invoices.insert_one(invoice_doc)
    
    # Add stock to inventory
    for stock_item in stock_items:
        try:
            await inv_service.add_stock(
                tenant_id=tenant_id,
                item_id=stock_item["item_id"],
                variant_id=stock_item["variant_id"],
                quantity=stock_item["quantity"],
                movement_type=MovementType.PURCHASE,
                warehouse_id=po.get("store_id"),
                notes=f"Purchase from invoice {invoice_number}",
                performed_by=user.get("id")
            )
        except Exception as e:
            logger.error(f"Failed to add stock for item {stock_item['item_id']}: {e}")
    
    # Mark PO as converted
    await db.purchase_orders.update_one(
        {"id": po_id},
        {"$set": {
            "status": "received",
            "converted_to_invoice": True,
            "invoice_id": purchase_id,
            "invoice_number": invoice_number,
            "updated_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    if "_id" in invoice_doc:
        del invoice_doc["_id"]
    return {
        "message": "Purchase order converted to invoice",
        "invoice": invoice_doc
    }


