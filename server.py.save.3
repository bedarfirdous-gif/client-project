@api_router.get("/gst-ledger")
async def get_gst_ledger(
    entry_type: str = None,  # INPUT or OUTPUT
    from_date: str = None,
    to_date: str = None,
    reference_type: str = None,
    party_gstin: str = None,
    limit: int = Query(500, le=5000),
    user: dict = Depends(get_current_user)
):
    """Get GST ledger entries"""
    tenant_id = get_tenant_id(user)
    query = {"tenant_id": tenant_id}
    
    if entry_type:
        query["entry_type"] = entry_type
    if reference_type:
        query["reference_type"] = reference_type
    if party_gstin:
        query["party_gstin"] = {"$regex": party_gstin, "$options": "i"}
    if from_date:
        query["created_at"] = {"$gte": from_date}
    if to_date:
        if "created_at" in query:
            query["created_at"]["$lte"] = to_date + "T23:59:59"
        else:
            query["created_at"] = {"$lte": to_date + "T23:59:59"}
    
    entries = await db.gst_ledger.find(query, {"_id": 0}).sort("created_at", -1).to_list(limit)
    return entries


@api_router.get("/gst-ledger/summary")
async def get_gst_summary(
    from_date: str = None,
    to_date: str = None,
    user: dict = Depends(get_current_user)
):
    """Get GST summary for reporting (GSTR-1, GSTR-3B style)"""
    tenant_id = get_tenant_id(user)
    query = {"tenant_id": tenant_id, "is_finalized": True}
    
    if from_date:
        query["created_at"] = {"$gte": from_date}
    if to_date:
        if "created_at" in query:
            query["created_at"]["$lte"] = to_date + "T23:59:59"
        else:
            query["created_at"] = {"$lte": to_date + "T23:59:59"}
    
    entries = await db.gst_ledger.find(query, {"_id": 0}).to_list(10000)
    
    # Calculate summaries
    output_gst = {"taxable": 0, "cgst": 0, "sgst": 0, "igst": 0, "cess": 0, "total": 0, "count": 0}
    input_gst = {"taxable": 0, "cgst": 0, "sgst": 0, "igst": 0, "cess": 0, "total": 0, "count": 0}
    
    for entry in entries:
        target = output_gst if entry.get("entry_type") == "OUTPUT" else input_gst
        target["taxable"] += entry.get("taxable_amount", 0)
        target["cgst"] += entry.get("cgst_amount", 0)
        target["sgst"] += entry.get("sgst_amount", 0)
        target["igst"] += entry.get("igst_amount", 0)
        target["cess"] += entry.get("cess_amount", 0)
        target["total"] += entry.get("total_gst", 0)
        target["count"] += 1
    
    net_liability = output_gst["total"] - input_gst["total"]
    
    return {
        "period": {"from": from_date, "to": to_date},
        "output_gst": output_gst,
        "input_gst": input_gst,
        "net_gst_liability": round(net_liability, 2),
        "itc_available": round(input_gst["total"], 2),
        "gst_payable": round(max(0, net_liability), 2),
        "itc_carryforward": round(max(0, -net_liability), 2)
    }


@api_router.get("/gst-ledger/by-slab")
async def get_gst_by_slab(
    from_date: str = None,
    to_date: str = None,
    user: dict = Depends(get_current_user)
):
    """Get GST breakup by slab for reporting"""
    tenant_id = get_tenant_id(user)
    
    # Get all GST slabs
    slabs = await db.gst_slabs.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(100)
    slab_map = {s["id"]: s for s in slabs}
    
    query = {"tenant_id": tenant_id, "is_finalized": True}
    if from_date:
        query["created_at"] = {"$gte": from_date}
    if to_date:
        if "created_at" in query:
            query["created_at"]["$lte"] = to_date + "T23:59:59"
        else:
            query["created_at"] = {"$lte": to_date + "T23:59:59"}
    
    entries = await db.gst_ledger.find(query, {"_id": 0}).to_list(10000)
    
    # Group by slab
    by_slab = {}
    for entry in entries:
        slab_id = entry.get("gst_slab_id", "unknown")
        slab = slab_map.get(slab_id, {"code": "Unknown", "total_rate": 0})
        
        if slab_id not in by_slab:
            by_slab[slab_id] = {
                "slab_code": slab.get("code", "Unknown"),
                "rate": slab.get("total_rate", 0),
                "output": {"taxable": 0, "gst": 0, "count": 0},
                "input": {"taxable": 0, "gst": 0, "count": 0}
            }
        
        target = "output" if entry.get("entry_type") == "OUTPUT" else "input"
        by_slab[slab_id][target]["taxable"] += entry.get("taxable_amount", 0)
        by_slab[slab_id][target]["gst"] += entry.get("total_gst", 0)
        by_slab[slab_id][target]["count"] += 1
    
    return {"by_slab": list(by_slab.values()), "period": {"from": from_date, "to": to_date}}


# GST Calculator Helper Function
async def calculate_gst_for_item(tenant_id: str, item_id: str, variant_id: str, amount: float, is_inclusive: bool = False):
    """
    Calculate GST for an item based on its linked GST slab.
    This is the ONLY place GST should be calculated.
    """
    # Get item's GST slab
    item = await db.items.find_one({"id": item_id, "tenant_id": tenant_id}, {"_id": 0, "gst_slab_id": 1, "gst_rate": 1, "gst_inclusive": 1})
    if not item:
        return {"taxable_amount": amount, "cgst": 0, "sgst": 0, "igst": 0, "total_gst": 0, "total_with_gst": amount}
    
    gst_slab_id = item.get("gst_slab_id")
    
    # If item has gst_slab_id, use it; otherwise fall back to legacy gst_rate
    if gst_slab_id:
        slab = await db.gst_slabs.find_one({"id": gst_slab_id}, {"_id": 0})
        if not slab:
            return {"taxable_amount": amount, "cgst": 0, "sgst": 0, "igst": 0, "total_gst": 0, "total_with_gst": amount}
        
        total_rate = slab.get("total_rate", 0)
        cgst_rate = slab.get("cgst_rate", 0)
        sgst_rate = slab.get("sgst_rate", 0)
        cess_rate = slab.get("cess_rate", 0)
    else:
        # Fallback to legacy gst_rate
        total_rate = item.get("gst_rate", 0)
        cgst_rate = total_rate / 2
        sgst_rate = total_rate / 2
        cess_rate = 0
    
    is_inclusive = is_inclusive or item.get("gst_inclusive", False)
    
    if is_inclusive:
        # GST inclusive - extract GST from amount
        taxable_amount = amount / (1 + total_rate / 100)
    else:
        taxable_amount = amount
    
    cgst = round(taxable_amount * cgst_rate / 100, 2)
    sgst = round(taxable_amount * sgst_rate / 100, 2)
    cess = round(taxable_amount * cess_rate / 100, 2)
    total_gst = cgst + sgst + cess
    
    return {
        "taxable_amount": round(taxable_amount, 2),
        "cgst": cgst,
        "sgst": sgst,
        "igst": 0,  # IGST for inter-state (determined by state code)
        "cess": cess,
        "total_gst": round(total_gst, 2),
        "total_with_gst": round(taxable_amount + total_gst, 2),
        "gst_slab_id": gst_slab_id or "",
        "gst_rate": total_rate
    }


async def record_gst_ledger_entry(
    tenant_id: str,
    entry_type: str,  # INPUT or OUTPUT
    reference_type: str,
    reference_id: str,
    reference_number: str,
    party_name: str,
    party_gstin: str,
    items_gst: List[Dict],  # List of GST calculations per item
    performed_by: str = None,
    is_finalized: bool = True
):
    """Record a GST ledger entry - the ONLY way to add to GST ledger"""
    
    # Aggregate GST from all items
    total_taxable = sum(i.get("taxable_amount", 0) for i in items_gst)
    total_cgst = sum(i.get("cgst", 0) for i in items_gst)
    total_sgst = sum(i.get("sgst", 0) for i in items_gst)
    total_igst = sum(i.get("igst", 0) for i in items_gst)
    total_cess = sum(i.get("cess", 0) for i in items_gst)
    total_gst = total_cgst + total_sgst + total_igst + total_cess
    
    ledger_entry = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "entry_type": entry_type,
        "reference_type": reference_type,
        "reference_id": reference_id,
        "reference_number": reference_number,
        "party_name": party_name,
        "party_gstin": party_gstin,
        "taxable_amount": round(total_taxable, 2),
        "cgst_amount": round(total_cgst, 2),
        "sgst_amount": round(total_sgst, 2),
        "igst_amount": round(total_igst, 2),
        "cess_amount": round(total_cess, 2),
        "total_gst": round(total_gst, 2),
        "items_detail": items_gst,
        "is_finalized": is_finalized,
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": performed_by
    }
    
    await db.gst_ledger.insert_one(ledger_entry)
    del ledger_entry["_id"]
    return ledger_entry


