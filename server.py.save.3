# ============== DOCUMENT VERIFICATION WORKFLOW ==============

class DocumentVerification(BaseModel):
    status: str  # verified, rejected
    expiry_date: Optional[str] = None
    remarks: Optional[str] = None
    verified_by: Optional[str] = None

@api_router.get("/document-verification")
async def get_all_documents_for_verification(user: dict = Depends(get_current_user)):
    """Get all employee documents for verification"""
    tenant_id = get_tenant_id(user)
    
    # Get documents from both employee files and application documents
    employee_docs = await db.employee_files.find(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ).to_list(1000)
    
    application_docs = await db.application_documents.find(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ).to_list(1000)
    
    # Combine and normalize documents
    all_docs = []
    
    for doc in employee_docs:
        doc["source"] = "employee"
        doc["verification_status"] = doc.get("verification_status", "pending")
        # Check expiry
        if doc.get("expiry_date"):
            expiry = datetime.fromisoformat(doc["expiry_date"].replace('Z', '+00:00'))
            days_until_expiry = (expiry - datetime.now(timezone.utc)).days
            if days_until_expiry <= 0:
                doc["verification_status"] = "expired"
            elif days_until_expiry <= 30:
                doc["verification_status"] = "expiring_soon"
        all_docs.append(doc)
    
    for doc in application_docs:
        doc["source"] = "application"
        doc["verification_status"] = doc.get("verification_status", "pending")
        all_docs.append(doc)
    
    # Sort by uploaded date descending
    all_docs.sort(key=lambda x: x.get("uploaded_at", ""), reverse=True)
    
    return all_docs


@api_router.get("/document-verification/stats")
async def get_document_verification_stats(user: dict = Depends(get_current_user)):
    """Get statistics for document verification"""
    tenant_id = get_tenant_id(user)
    now = datetime.now(timezone.utc)
    thirty_days_later = (now + timedelta(days=30)).isoformat()
    
    # Count from both collections
    pending_emp = await db.employee_files.count_documents({
        "tenant_id": tenant_id,
        "$or": [
            {"verification_status": {"$exists": False}},
            {"verification_status": "pending"}
        ]
    })
    
    pending_app = await db.application_documents.count_documents({
        "tenant_id": tenant_id,
        "$or": [
            {"verification_status": {"$exists": False}},
            {"verification_status": "pending"}
        ]
    })
    
    verified_emp = await db.employee_files.count_documents({
        "tenant_id": tenant_id,
        "verification_status": "verified"
    })
    
    verified_app = await db.application_documents.count_documents({
        "tenant_id": tenant_id,
        "verification_status": "verified"
    })
    
    rejected_emp = await db.employee_files.count_documents({
        "tenant_id": tenant_id,
        "verification_status": "rejected"
    })
    
    rejected_app = await db.application_documents.count_documents({
        "tenant_id": tenant_id,
        "verification_status": "rejected"
    })
    
    # Count expiring soon (within 30 days)
    expiring_soon = await db.employee_files.count_documents({
        "tenant_id": tenant_id,
        "verification_status": "verified",
        "expiry_date": {"$lte": thirty_days_later, "$gt": now.isoformat()}
    })
    
    # Count expired
    expired = await db.employee_files.count_documents({
        "tenant_id": tenant_id,
        "expiry_date": {"$lte": now.isoformat()}
    })
    
    return {
        "pending": pending_emp + pending_app,
        "verified": verified_emp + verified_app,
        "rejected": rejected_emp + rejected_app,
        "expiring_soon": expiring_soon,
        "expired": expired
    }


@api_router.post("/document-verification/{document_id}/verify")
async def verify_document(
    document_id: str,
    request: DocumentVerification,
    user: dict = Depends(get_current_user)
):
    """Verify or reject a document"""
    tenant_id = get_tenant_id(user)
    now = datetime.now(timezone.utc).isoformat()
    
    update_data = {
        "verification_status": request.status,
        "verified_at": now,
        "verified_by": user.get("id"),
        "verification_remarks": request.remarks
    }
    
    if request.expiry_date:
        update_data["expiry_date"] = request.expiry_date
    
    # Try to update in employee_files first
    result = await db.employee_files.update_one(
        {"tenant_id": tenant_id, "id": document_id},
        {"$set": update_data}
    )
    
    if result.modified_count == 0:
        # Try application_documents
        result = await db.application_documents.update_one(
            {"tenant_id": tenant_id, "id": document_id},
            {"$set": update_data}
        )
    
    if result.modified_count == 0:
        raise HTTPException(status_code=404, detail="Document not found")
    
    # Create notification for expiring documents
    if request.expiry_date:
        expiry_date = datetime.fromisoformat(request.expiry_date)
        days_until_expiry = (expiry_date - datetime.now(timezone.utc)).days
        
        if days_until_expiry <= 30:
            # Store notification for expiring document
            notification = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "type": "document_expiring",
                "document_id": document_id,
                "message": f"Document expires in {days_until_expiry} days",
                "expiry_date": request.expiry_date,
                "created_at": now,
                "read": False
            }
            await db.notifications.insert_one(notification)
    
    return {
        "message": f"Document {request.status} successfully",
        "document_id": document_id,
        "status": request.status
    }


