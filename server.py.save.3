@api_router.post("/ecommerce/business-customers/{customer_id}/apply-credit")
async def apply_credit_to_order(
    customer_id: str,
    order_id: str = Body(..., embed=True),
    amount: float = Body(..., embed=True),
    user: dict = Depends(get_current_user)
):
    """Apply credit to a business customer's order"""
    tenant_id = get_tenant_id(user)
    
    customer = await db.business_customers.find_one(
        {"id": customer_id, "tenant_id": tenant_id}
    )
    
    if not customer:
        raise HTTPException(status_code=404, detail="Business customer not found")
    
    available_credit = customer.get("credit_limit", 0) - customer.get("credit_utilized", 0)
    
    if amount > available_credit:
        raise HTTPException(status_code=400, detail=f"Insufficient credit. Available: {available_credit}")
    
    # Update credit utilized
    await db.business_customers.update_one(
        {"id": customer_id},
        {"$inc": {"credit_utilized": amount}}
    )
    
    # Update order
    await db.ecommerce_orders.update_one(
        {"id": order_id, "tenant_id": tenant_id},
        {"$set": {
            "credit_applied": amount,
            "business_customer_id": customer_id,
            "payment_status": "credit_applied",
            "updated_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": f"Credit of {amount} applied to order {order_id}"}


