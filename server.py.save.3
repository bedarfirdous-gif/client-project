):
    """Emergency: Generate backup codes for any user"""
    
    target_user = await db.users.find_one({"id": target_user_id})
    if not target_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    # Delete existing unused codes
    await db.backup_codes.delete_many({"user_id": target_user_id})
    
    # Generate 10 new codes
    codes = []
    for i in range(10):
        code = generate_backup_code()
        codes.append(code)
        
        # Store hashed code
        await db.backup_codes.insert_one({
            "id": str(uuid.uuid4()),
            "user_id": target_user_id,
            "code_hash": hash_password(code),
            "used": False,
            "created_at": datetime.now(timezone.utc).isoformat(),
            "generated_by": user.get("id")
        })
    
    # Log the generation
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "god_mode_generate_backup_codes",
        "target_user_id": target_user_id,
        "target_email": target_user.get("email"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": datetime.now(timezone.utc).isoformat()
    })
    
    return {
        "message": f"Backup codes generated for {target_user.get('email')}",
        "codes": codes,
        "warning": "Share these codes securely with the user. They won't be shown again!"
    }

@api_router.post("/superadmin/god-mode/change-role")
async def god_mode_change_role(
    target_user_id: str = Body(...),
    new_role: str = Body(...),
    user: dict = Depends(require_superadmin)
):
    """Emergency: Change any user's role"""
    
    valid_roles = ["admin", "manager", "staff", "cashier", "viewer"]
    if new_role not in valid_roles:
        raise HTTPException(status_code=400, detail=f"Invalid role. Valid roles: {valid_roles}")
    
    target_user = await db.users.find_one({"id": target_user_id})
    if not target_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    if target_user.get("role") == "superadmin":
        raise HTTPException(status_code=403, detail="Cannot change superadmin role")
    
    old_role = target_user.get("role")
    
    # Update role
    await db.users.update_one(
        {"id": target_user_id},
        {"$set": {
            "role": new_role,
            "permissions": DEFAULT_ROLE_PERMISSIONS.get(new_role, {}),
            "role_changed_at": datetime.now(timezone.utc).isoformat(),
            "role_changed_by": user.get("id")
        }}
    )
    
    # Log action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "god_mode_change_role",
        "target_user_id": target_user_id,
        "target_email": target_user.get("email"),
        "old_role": old_role,
        "new_role": new_role,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": datetime.now(timezone.utc).isoformat()
    })
    
    return {"message": f"Role changed: {target_user.get('email')} is now a {new_role} (was {old_role})"}

@api_router.get("/superadmin/god-mode/system-health")
