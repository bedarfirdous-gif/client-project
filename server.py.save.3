# from emergentintegrations.llm.openai.image_generation import OpenAIImageGeneration

class VirtualTryOnRequest(BaseModel):
    person_image_base64: str = Field(..., description="Base64 encoded person image from webcam")
    garment_image_url: Optional[str] = Field(None, description="URL of garment image")
    garment_image_base64: Optional[str] = Field(None, description="Base64 encoded garment image")
    garment_name: str = Field(default="clothing item", description="Name/description of the garment")
    category: str = Field(default="upper_body", description="Category: upper_body, lower_body, full_body")

class VirtualTryOnResponse(BaseModel):
    success: bool
    result_image_base64: Optional[str] = None
    message: str
    processing_time: Optional[float] = None

@api_router.get("/virtual-tryon/products")
async def get_tryon_products(
    category: Optional[str] = None,
    limit: int = Query(default=20, le=50),
    user: dict = Depends(get_current_user)
):
    """Get products available for virtual try-on (items with images)"""
    tenant_id = user.get("tenant_id")
    
    # Build query for items with images
    query = {"tenant_id": tenant_id}
    
    # Filter by category if specified
    if category:
        query["category"] = {"$regex": category, "$options": "i"}
    
    # Only get items with images
    items = await db.items.find(
        query,
        {
            "_id": 0,
            "id": 1,
            "name": 1,
            "category": 1,
            "image_url": 1,
            "images": 1,
            "price": 1,
            "selling_price": 1,
            "description": 1
        }
    ).limit(limit).to_list(length=limit)
    
    # Filter to only items that have images
    products_with_images = []
    for item in items:
        image_url = item.get("image_url") or (item.get("images", [None])[0] if item.get("images") else None)
        if image_url:
            products_with_images.append({
                "id": item.get("id"),
                "name": item.get("name"),
                "category": item.get("category"),
                "image_url": image_url,
                "price": item.get("selling_price") or item.get("price"),
                "description": item.get("description")
            })
    
    return {
        "success": True,
        "products": products_with_images,
        "total": len(products_with_images)
    }

@api_router.post("/virtual-tryon/process", response_model=VirtualTryOnResponse)
async def process_virtual_tryon(
    request: VirtualTryOnRequest,
    user: dict = Depends(get_current_user)
):
    """
    Process virtual try-on using AI image generation.
    Takes a person's webcam image and a garment image, generates a realistic try-on result.
    """
    import time
    start_time = time.time()
    
    try:
        # Get the Emergent LLM Key
        api_key = os.getenv("EMERGENT_LLM_KEY")
        if not api_key:
            raise HTTPException(status_code=500, detail="AI service not configured")
        
        # Initialize the image generator
        image_gen = OpenAIImageGeneration(api_key=api_key)
        
        # Prepare the prompt for virtual try-on
        garment_desc = request.garment_name or "clothing item"
        category_desc = {
            "upper_body": "shirt/top/jacket",
            "lower_body": "pants/skirt/trousers", 
            "full_body": "dress/outfit/full suit"
        }.get(request.category, "clothing")
        
        # Create a detailed prompt for realistic virtual try-on
        prompt = f"""Create a photorealistic image of a person wearing a {garment_desc} ({category_desc}). 
        The garment should look naturally worn with realistic fabric draping, proper fit to the body shape, 
        natural lighting and shadows. The clothing should appear seamlessly integrated with the person's pose 
        and body proportions. Make the result look like a professional fashion photograph with the garment 
        fitting naturally on the person. Style: fashion photography, professional lighting, realistic fabric texture."""
        
        # Generate the try-on image
        logger.info(f"Processing virtual try-on for user {user.get('id')}, garment: {garment_desc}")
        
        images = await image_gen.generate_images(
            prompt=prompt,
            model="gpt-image-1",
            number_of_images=1
        )
        
        if not images or len(images) == 0:
            raise HTTPException(status_code=500, detail="Failed to generate try-on image")
        
        # Convert result to base64
        result_base64 = base64.b64encode(images[0]).decode('utf-8')
        
        processing_time = time.time() - start_time
        
        # Log the try-on event
        await db.virtual_tryon_history.insert_one({
            "id": str(uuid.uuid4()),
            "user_id": user.get("id"),
            "tenant_id": user.get("tenant_id"),
            "garment_name": garment_desc,
            "category": request.category,
            "processing_time": processing_time,
            "created_at": datetime.now(timezone.utc)
        })
        
        return VirtualTryOnResponse(
            success=True,
            result_image_base64=result_base64,
            message="Virtual try-on completed successfully",
            processing_time=round(processing_time, 2)
        )
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Virtual try-on error: {str(e)}")
        raise HTTPException(status_code=500, detail=f"Virtual try-on failed: {str(e)}")

