@api_router.get("/team-chat/messages")
async def get_team_chat_messages(
    limit: int = 100,
    before_id: str = None,
    user: dict = Depends(require_permission("connect_hub"))
):
    """Get team chat messages for the tenant - all staff can see all messages"""
    tenant_id = get_tenant_id(user)
    query = {"tenant_id": tenant_id}
    
    if before_id:
        # Get message with this ID to find its timestamp
        ref_msg = await db.team_chat_messages.find_one({"id": before_id})
        if ref_msg:
            query["created_at"] = {"$lt": ref_msg["created_at"]}
    
    messages = await db.team_chat_messages.find(
        query, 
        {"_id": 0}
    ).sort("created_at", -1).limit(limit).to_list(limit)
    
    # Return in chronological order
    messages.reverse()
    return messages

@api_router.post("/team-chat/messages")
async def send_team_chat_message(
    request: dict,
    user: dict = Depends(require_permission("connect_hub"))
):
    """Send a message to team chat - visible to all staff in tenant"""
    tenant_id = get_tenant_id(user)
    
    message_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "sender_id": user.get("id"),
        "sender_name": user.get("name", "Unknown"),
        "sender_role": user.get("role", "staff"),
        "sender_store_id": user.get("store_id"),
        "text": request.get("text", ""),
        "message_type": request.get("message_type", "text"),  # text, image, file
        "attachment_url": request.get("attachment_url"),
        "is_bot": False,
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    await db.team_chat_messages.insert_one(message_doc)
    del message_doc["_id"]
    
    # Broadcast via WebSocket for real-time delivery
    try:
        from websocket_manager import broadcast_chat_message
        await broadcast_chat_message(tenant_id, message_doc, sender_id=user.get("id"))
    except Exception as e:
        logger.warning(f"WebSocket broadcast failed: {e}")
    
    return message_doc

@api_router.delete("/team-chat/messages/{message_id}")
async def delete_team_chat_message(
    message_id: str,
    user: dict = Depends(require_permission("connect_hub"))
):
    """Delete a team chat message (only sender or admin can delete)"""
    tenant_id = get_tenant_id(user)
    
    message = await db.team_chat_messages.find_one({
        "id": message_id,
        "tenant_id": tenant_id
    })
    
    if not message:
        raise HTTPException(status_code=404, detail="Message not found")
    
