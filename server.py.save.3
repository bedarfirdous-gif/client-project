@api_router.post("/customers/import/scrape-url")
async def scrape_url_for_customers(
    url: str = Body(..., embed=True),
    direct_import: bool = Body(False, embed=True),
    auth_type: str = Body("none", embed=True),
    username: Optional[str] = Body(None, embed=True),
    password: Optional[str] = Body(None, embed=True),
    cookies: Optional[Dict[str, str]] = Body(None, embed=True),
    user: dict = Depends(get_current_user)
):
    """Scrape customer data from a web page URL"""
    from customer_import_system import WebScraperConfig
    
    tenant_id = get_tenant_id(user)
    
    # Create scraper config
    config = WebScraperConfig(
        url=url,
        auth_type=auth_type,
        username=username,
        password=password,
        cookies=cookies
    )
    
    # Process web page
    result = await customer_import_system.process_web_page(url, config)
    
    if not result.get("success"):
        raise HTTPException(status_code=400, detail=result.get("error", "Scraping failed"))
    
    # Create batch and save to staging
    batch_id = str(uuid.uuid4())
    
    batch = {
        "id": batch_id,
        "tenant_id": tenant_id,
        "user_id": user.get("id", user.get("user_id")),
        "source": "web_scraper",
        "file_type": "web_page",
        "filename": url,
        "status": "review" if not direct_import else "imported",
        "direct_import": direct_import,
        "total_extracted": result.get("data", {}).get("total_extracted", 0),
        "total_imported": 0,
        "total_failed": 0,
        "created_at": datetime.now(timezone.utc),
        "updated_at": datetime.now(timezone.utc)
    }
    
    await db.customer_import_batches.insert_one(batch)
    
    # Save extracted customers to staging
    customers = result.get("data", {}).get("customers", [])
    staging_records = []
    
    for idx, customer in enumerate(customers):
        staging_record = {
            "id": str(uuid.uuid4()),
            "batch_id": batch_id,
            "tenant_id": tenant_id,
            "index": idx,
            "name": customer.get("name"),
            "phone": customer.get("phone"),
            "email": customer.get("email"),
            "address": customer.get("address"),
            "company": customer.get("company"),
            "gst_number": customer.get("gst_number"),
            "id_number": customer.get("id_number"),
            "confidence_scores": customer.get("confidence_scores", {}),
            "needs_review": customer.get("needs_review", False),
            "review_notes": customer.get("review_notes", []),
            "status": "review" if not direct_import else "pending",
            "created_at": datetime.now(timezone.utc)
        }
        staging_records.append(staging_record)
    
    if staging_records:
        await db.customer_import_staging.insert_many(staging_records)
        
        if direct_import:
            # Auto-import
            imported = 0
            for record in staging_records:
                try:
                    customer_doc = {
                        "id": str(uuid.uuid4()),
                        "tenant_id": tenant_id,
                        "name": record.get("name") or "Unknown",
                        "phone": record.get("phone"),
                        "email": record.get("email"),
                        "address": record.get("address"),
                        "company": record.get("company"),
                        "gst_number": record.get("gst_number"),
                        "customer_type": "retail",
                        "loyalty_enrolled": False,
                        "loyalty_points": 0,
                        "import_source": "web_scraper",
                        "import_batch_id": batch_id,
                        "created_at": datetime.now(timezone.utc)
                    }
                    await db.customers.insert_one(customer_doc)
                    await db.customer_import_staging.update_one(
                        {"id": record["id"]},
                        {"$set": {"status": "imported"}}
                    )
                    imported += 1
                except Exception as e:
                    logger.error(f"Import error: {str(e)}")
            
            await db.customer_import_batches.update_one(
                {"id": batch_id},
                {"$set": {"total_imported": imported, "status": "imported"}}
            )
    
    return {
        "success": True,
        "batch_id": batch_id,
        "total_extracted": len(customers),
        "needs_review": sum(1 for c in customers if c.get("needs_review")),
        "source_url": url
    }


