@api_router.get("/employees/{employee_id}/id-card")
async def get_employee_id_card(employee_id: str, user: dict = Depends(require_permission("employees"))):
    """Get employee ID card data with QR code for attendance"""
    tenant_id = get_tenant_id(user)
    
    # Allow viewing ID card for both active and inactive employees
    employee = await db.employees.find_one(
        {"id": employee_id, "tenant_id": tenant_id},
        {"_id": 0}
    )
    
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Generate employee_code if not exists
    employee_code = employee.get("employee_code")
    if not employee_code:
        # Generate a new employee code and update the employee record
        last_employee = await db.employees.find_one(
            {"tenant_id": tenant_id, "employee_code": {"$regex": "^EMP"}},
            sort=[("employee_code", -1)]
        )
        next_num = 1
        if last_employee and last_employee.get("employee_code"):
            try:
                last_num = int(last_employee["employee_code"].replace("EMP", ""))
                next_num = last_num + 1
            except:
                pass
        employee_code = f"EMP{next_num:04d}"
        # Update the employee record with the new code
        await db.employees.update_one(
            {"id": employee_id, "tenant_id": tenant_id},
            {"$set": {"employee_code": employee_code}}
        )
    
    # Get tenant info for card branding
    tenant = await db.tenants.find_one({"id": tenant_id}, {"_id": 0, "name": 1, "business_name": 1, "logo": 1})
    
    # Get store info
    store = None
    if employee.get("store_id"):
        store = await db.stores.find_one({"id": employee.get("store_id")}, {"_id": 0, "name": 1})
    
    # Generate QR code data for attendance - use employee_id for scanning
    qr_data = f"EMPLOYEE:{tenant_id}:{employee_id}:{employee_code}"
    
    # Generate barcode image from employee code
    barcode_image = generate_barcode_image(employee_code, "code128")
    
    return {
        "card_data": {
            "employee_id": employee_id,
            "employee_code": employee_code,
            "name": employee.get("name", ""),
            "designation": employee.get("designation", ""),
            "department": employee.get("department", ""),
            "photo": employee.get("photo", ""),
            "phone": employee.get("phone", ""),
            "email": employee.get("email", ""),
            "store_name": store.get("name") if store else "",
            "date_of_joining": employee.get("date_of_joining", ""),
            "qr_code_data": qr_data,
            "barcode_image": barcode_image
        },
        "business": {
            "name": (tenant.get("business_name") or tenant.get("name", "Company")) if tenant else "Company",
            "logo": tenant.get("logo", "") if tenant else ""
        }
    }


@api_router.post("/attendance/scan-id")
async def scan_employee_id_for_attendance(
    qr_data: str = Body(..., embed=True),
    user: dict = Depends(get_current_user)
):
    """Scan employee ID card QR code for check-in/check-out"""
    tenant_id = get_tenant_id(user)
    
    # Parse QR data: EMPLOYEE:tenant_id:employee_id
    parts = qr_data.split(":")
    if len(parts) != 3 or parts[0] != "EMPLOYEE":
        raise HTTPException(status_code=400, detail="Invalid employee ID card QR code")
    
    qr_tenant_id, employee_id = parts[1], parts[2]
    
    # Verify tenant matches
    if qr_tenant_id != tenant_id:
        raise HTTPException(status_code=403, detail="This ID card belongs to a different organization")
    
    # Get employee
    employee = await db.employees.find_one(
        {"id": employee_id, "tenant_id": tenant_id, "is_active": {"$ne": False}},
        {"_id": 0}
    )
    
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Check today's attendance
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    existing_attendance = await db.attendance.find_one({
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "date": today
    })
    
    now = datetime.now(timezone.utc)
    
    if existing_attendance:
        # Check out
        if existing_attendance.get("check_out"):
            return {
                "action": "already_checked_out",
                "message": f"{employee.get('name')} has already checked out today",
                "employee": employee,
                "attendance": existing_attendance
            }
        
        # Perform check out
        await db.attendance.update_one(
            {"id": existing_attendance["id"]},
            {"$set": {
                "check_out": now.isoformat(),
                "check_out_method": "qr_scan"
            }}
        )
        
        return {
            "action": "check_out",
            "message": f"Check-out successful for {employee.get('name')}",
            "employee": employee,
            "check_out_time": now.isoformat()
        }
    else:
        # Check in
        attendance_doc = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "employee_id": employee_id,
            "store_id": employee.get("store_id"),
            "date": today,
            "check_in": now.isoformat(),
            "check_in_method": "qr_scan",
            "status": "present",
            "created_at": now.isoformat()
        }
        
        await db.attendance.insert_one(attendance_doc)
        attendance_doc.pop("_id", None)
        
        return {
            "action": "check_in",
            "message": f"Check-in successful for {employee.get('name')}",
            "employee": employee,
            "check_in_time": now.isoformat()
        }


@api_router.post("/attendance/scan-barcode")
async def scan_barcode_for_attendance(
    employee_code: str = Body(..., embed=True),
    user: dict = Depends(get_current_user)
):
    """
    Scan employee barcode for attendance check-in/check-out.
    
    Flow:
    1. Scanner reads Employee Code from barcode
    2. System checks database for employee
    3. Marks IN/OUT time based on current status
    4. Stores in attendance table
    """
    tenant_id = get_tenant_id(user)
    
    # Clean the employee code (remove any whitespace)
    employee_code = employee_code.strip().upper()
    
    if not employee_code:
        raise HTTPException(status_code=400, detail="Employee code is required")
    
    # Find employee by employee_code
    employee = await db.employees.find_one(
        {"tenant_id": tenant_id, "employee_code": employee_code, "is_active": {"$ne": False}},
        {"_id": 0}
    )
    
    if not employee:
        raise HTTPException(
            status_code=404, 
            detail=f"Employee with code '{employee_code}' not found"
        )
    
    employee_id = employee.get("id")
    employee_name = employee.get("name", "Employee")
    
    # Get today's date
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    now = datetime.now(timezone.utc)
    
    # Check existing attendance for today
    existing_attendance = await db.attendance.find_one({
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "date": today
    }, {"_id": 0})
    
    if existing_attendance:
        # Employee has already checked in today
        if existing_attendance.get("check_out"):
            # Already checked out - return info
            return {
                "success": True,
                "action": "already_completed",
                "message": f"{employee_name} has already completed attendance for today",
                "employee": {
                    "id": employee_id,
                    "name": employee_name,
                    "employee_code": employee_code,
                    "designation": employee.get("designation", ""),
                    "department": employee.get("department", ""),
                    "photo": employee.get("photo", "")
                },
                "attendance": {
                    "date": today,
                    "check_in": existing_attendance.get("check_in"),
                    "check_out": existing_attendance.get("check_out"),
                    "status": "completed"
                }
            }
        
        # Check out the employee
        check_out_time = now.isoformat()
        
        # Calculate total hours
        check_in_str = existing_attendance.get("check_in")
        if check_in_str:
            try:
                check_in_time = datetime.fromisoformat(check_in_str.replace('Z', '+00:00'))
                total_hours = (now - check_in_time).total_seconds() / 3600
            except (ValueError, AttributeError):
                total_hours = 0
        else:
            total_hours = 0
        
        await db.attendance.update_one(
            {"id": existing_attendance["id"]},
            {"$set": {
                "check_out": check_out_time,
                "check_out_method": "barcode_scan",
                "total_hours": round(total_hours, 2),
                "updated_at": check_out_time
            }}
        )
        
        return {
            "success": True,
            "action": "check_out",
            "message": f"Check-out successful for {employee_name}",
            "employee": {
                "id": employee_id,
                "name": employee_name,
                "employee_code": employee_code,
                "designation": employee.get("designation", ""),
                "department": employee.get("department", ""),
                "photo": employee.get("photo", "")
            },
            "attendance": {
                "date": today,
                "check_in": existing_attendance.get("check_in"),
                "check_out": check_out_time,
                "total_hours": round(total_hours, 2),
                "status": "checked_out"
            }
        }
    else:
        # Check in the employee
        check_in_time = now.isoformat()
        
        # Calculate late hours if employee has shift time
        late_hours = 0
        shift_start = employee.get("shift_start_time", "09:00")
        if shift_start:
            try:
                shift_hour, shift_min = map(int, shift_start.split(":"))
                shift_datetime = now.replace(hour=shift_hour, minute=shift_min, second=0, microsecond=0)
                if now > shift_datetime:
                    late_hours = (now - shift_datetime).total_seconds() / 3600
            except:
                pass
        
        attendance_doc = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "employee_id": employee_id,
            "employee_code": employee_code,
            "store_id": employee.get("store_id"),
            "date": today,
            "check_in": check_in_time,
            "check_in_method": "barcode_scan",
            "status": "present",
            "late_hours": round(late_hours, 2) if late_hours > 0 else 0,
            "created_at": check_in_time
        }
        
        await db.attendance.insert_one(attendance_doc)
        attendance_doc.pop("_id", None)
        
        return {
            "success": True,
            "action": "check_in",
            "message": f"Check-in successful for {employee_name}",
            "employee": {
                "id": employee_id,
                "name": employee_name,
                "employee_code": employee_code,
                "designation": employee.get("designation", ""),
                "department": employee.get("department", ""),
                "photo": employee.get("photo", "")
            },
            "attendance": {
                "date": today,
                "check_in": check_in_time,
                "late_hours": round(late_hours, 2) if late_hours > 0 else 0,
                "status": "checked_in"
            }
        }


