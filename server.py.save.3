@api_router.get("/ledger/reports/day-wise")
async def get_day_wise_summary(start_date: str, end_date: str, current_user: dict = Depends(get_current_user)):
    """Get day-wise transaction summary"""
    pipeline = [
        {"$match": {"tenant_id": current_user.get("tenant_id"), "date": {"$gte": start_date, "$lte": end_date}, "status": "approved"}},
        {"$group": {
            "_id": "$date",
            "receipts": {"$sum": "$receipt_amount"},
            "payments": {"$sum": "$payment_amount"},
            "transaction_count": {"$sum": 1}
        }},
        {"$sort": {"_id": 1}}
    ]
    results = await db.ledger_entries.aggregate(pipeline).to_list(None)
    
    days = [{"date": r["_id"], "receipts": r["receipts"], "payments": r["payments"], "net": r["receipts"] - r["payments"], "transaction_count": r["transaction_count"]} for r in results]
    
    return {
        "report_type": "day_wise_summary", "start_date": start_date, "end_date": end_date,
        "days": days,
        "grand_total": {"receipts": sum(d["receipts"] for d in days), "payments": sum(d["payments"] for d in days), "net": sum(d["net"] for d in days)}
    }

