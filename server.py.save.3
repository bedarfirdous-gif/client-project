@api_router.get("/autoheal/stats")
async def get_autoheal_stats(user: dict = Depends(require_permission("settings"))):
    """Get AutoHeal statistics"""
    now = datetime.now(timezone.utc)
    today = now.replace(hour=0, minute=0, second=0, microsecond=0)
    week_ago = now - timedelta(days=7)
    
    # Today's stats
    today_total = await db.autoheal_reports.count_documents({"created_at": {"$gte": today.isoformat()}})
    today_resolved = await db.autoheal_reports.count_documents({
        "created_at": {"$gte": today.isoformat()},
        "resolved": True
    })
    
    # Weekly stats
    week_total = await db.autoheal_reports.count_documents({"created_at": {"$gte": week_ago.isoformat()}})
    week_resolved = await db.autoheal_reports.count_documents({
        "created_at": {"$gte": week_ago.isoformat()},
        "resolved": True
    })
    
    # Error type breakdown (last 7 days)
    pipeline = [
        {"$match": {"created_at": {"$gte": week_ago.isoformat()}}},
        {"$group": {"_id": "$error_type", "count": {"$sum": 1}}},
        {"$sort": {"count": -1}}
    ]
    error_breakdown = await db.autoheal_reports.aggregate(pipeline).to_list(20)
    
    # Pending alerts
    pending_alerts = await db.admin_alerts.count_documents({"acknowledged": False})
    
    return {
        "today": {
            "total_errors": today_total,
            "auto_resolved": today_resolved,
            "resolution_rate": round((today_resolved / today_total * 100) if today_total > 0 else 0, 1)
        },
        "week": {
            "total_errors": week_total,
            "auto_resolved": week_resolved,
            "resolution_rate": round((week_resolved / week_total * 100) if week_total > 0 else 0, 1)
        },
        "error_breakdown": [{"error_type": e["_id"], "count": e["count"]} for e in error_breakdown],
        "pending_alerts": pending_alerts
    }

