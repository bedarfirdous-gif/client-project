@api_router.post("/security/mfa/verify")
async def verify_mfa(
    code: str = Body(..., embed=True),
    user: dict = Depends(get_current_user)
):
    """Verify MFA code and enable MFA for user"""
    tenant_id = get_tenant_id(user)
    
    user_security = await db.user_security.find_one(
        {"tenant_id": tenant_id, "user_id": user.get("id")}
    )
    
    if not user_security or not user_security.get("mfa_secret"):
        raise HTTPException(status_code=400, detail="MFA not set up. Please run setup first.")
    
    # Verify code
    if not backup_security.verify_mfa_code(user_security["mfa_secret"], code):
        # Log failed attempt
        await db.security_audit.insert_one(
            backup_security.create_security_audit_log(
                action="mfa_verify_failed",
                user=user,
                success=False,
                details={"reason": "Invalid code"}
            )
        )
        raise HTTPException(status_code=400, detail="Invalid verification code")
    
    # Enable MFA
    await db.user_security.update_one(
        {"tenant_id": tenant_id, "user_id": user.get("id")},
        {"$set": {
            "mfa_enabled": True,
            "mfa_verified": True,
            "verified_at": datetime.now(timezone.utc).isoformat(),
            "last_mfa_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    # Log success
    await db.security_audit.insert_one(
        backup_security.create_security_audit_log(
            action="mfa_enabled",
            user=user,
            success=True
        )
    )
    
    return {"message": "MFA enabled successfully", "mfa_enabled": True}

@api_router.post("/security/mfa/validate")
async def validate_mfa_for_operation(
    code: str = Body(..., embed=True),
    operation: str = Body(..., embed=True),
    user: dict = Depends(get_current_user)
):
    """Validate MFA code for sensitive operations (backup/restore)"""
    tenant_id = get_tenant_id(user)
    
    user_security = await db.user_security.find_one(
        {"tenant_id": tenant_id, "user_id": user.get("id")}
    )
    
    # If MFA not enabled, check if operation requires admin
    if not user_security or not user_security.get("mfa_enabled"):
        # For backup operations, MFA is recommended but not required if not set up
        if operation in ["backup_upload", "backup_restore"]:
            # Still require admin role
            allowed, reason = backup_security.check_backup_permission(user, operation.replace("backup_", ""))
            if not allowed:
                raise HTTPException(status_code=403, detail=reason)
            return {"validated": True, "mfa_used": False, "message": "Operation allowed (MFA not enabled)"}
        return {"validated": True, "mfa_used": False}
    
    # Verify MFA code
    if not backup_security.verify_mfa_code(user_security["mfa_secret"], code):
        await db.security_audit.insert_one(
            backup_security.create_security_audit_log(
                action=f"mfa_validation_failed_{operation}",
                user=user,
                success=False
            )
        )
        raise HTTPException(status_code=400, detail="Invalid MFA code")
    
    # Update last MFA timestamp
    await db.user_security.update_one(
        {"tenant_id": tenant_id, "user_id": user.get("id")},
        {"$set": {"last_mfa_at": datetime.now(timezone.utc).isoformat()}}
    )
    
    # Log success
    await db.security_audit.insert_one(
        backup_security.create_security_audit_log(
            action=f"mfa_validated_{operation}",
            user=user,
            success=True
        )
    )
    
    return {"validated": True, "mfa_used": True, "operation": operation}

