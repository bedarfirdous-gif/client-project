@api_router.delete("/items/{item_id}")
async def delete_item(item_id: str, user: dict = Depends(get_current_user)):
    """Soft delete item - moves to recycle bin. Admins have full delete access."""
    tenant_id = get_tenant_id(user)
    
    # Admins can delete any item, others need specific permission
    if not is_admin_or_higher(user):
        # Check if user has items permission for non-admins
        permissions = user.get("permissions", {})
        if not permissions.get("items", {}).get("delete", False):
            raise HTTPException(status_code=403, detail="Permission denied. Admin access required for delete.")
    
    # Find the item first (include already deleted items to check)
    item = await db.items.find_one(
        {"tenant_id": tenant_id, "id": item_id},
        {"_id": 0}
    )
    
    if not item:
        raise HTTPException(status_code=404, detail="Item not found")
    
    # Check if already deleted
    if item.get("is_deleted"):
        raise HTTPException(status_code=400, detail="Item is already deleted")
    
    # Get associated variants
    variants = await db.variants.find({"item_id": item_id}, {"_id": 0}).to_list(100)
    
    # Move to recycle bin
    deleted_item = {
        "id": str(uuid.uuid4()),
        "original_id": item_id,
        "item_type": "item",
        "item_data": {**item, "variants": variants},
        "deleted_by": user.get("id"),
        "deleted_by_name": user.get("name"),
        "deleted_at": datetime.now(timezone.utc).isoformat(),
        "tenant_id": tenant_id,
        "auto_delete_at": (datetime.now(timezone.utc) + timedelta(days=30)).isoformat(),
        "is_permanently_deleted": False
    }
    
    await db.recycle_bin.insert_one(deleted_item)
    
    # Mark item as deleted (soft delete)
    await db.items.update_one(
        {"tenant_id": tenant_id, "id": item_id}, 
        {"$set": {
            "is_active": False, 
            "is_deleted": True,
            "deleted_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    # Also mark variants as deleted
    await db.variants.update_many(
        {"item_id": item_id},
        {"$set": {"is_deleted": True}}
    )
    
    return {"message": "Item moved to Recycle Bin", "recycle_bin_id": deleted_item["id"]}

