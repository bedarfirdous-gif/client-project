@api_router.get("/expenses/summary")
async def get_expense_summary(
    user: dict = Depends(get_current_user),
    store_id: Optional[str] = Query(None),
    period: str = Query("month"),  # day, week, month, quarter, year
    start_date: Optional[str] = Query(None),
    end_date: Optional[str] = Query(None)
):
    """Get expense summary for dashboard"""
    tenant_id = get_tenant_id(user)
    
    # Determine date range based on period
    today = datetime.now(timezone.utc)
    
    if start_date and end_date:
        date_start = start_date
        date_end = end_date
    elif period == "day":
        date_start = today.strftime("%Y-%m-%d")
        date_end = date_start
    elif period == "week":
        start = today - timedelta(days=today.weekday())
        date_start = start.strftime("%Y-%m-%d")
        date_end = today.strftime("%Y-%m-%d")
    elif period == "month":
        date_start = today.replace(day=1).strftime("%Y-%m-%d")
        date_end = today.strftime("%Y-%m-%d")
    elif period == "quarter":
        quarter_start_month = ((today.month - 1) // 3) * 3 + 1
        date_start = today.replace(month=quarter_start_month, day=1).strftime("%Y-%m-%d")
        date_end = today.strftime("%Y-%m-%d")
    else:  # year
        date_start = today.replace(month=1, day=1).strftime("%Y-%m-%d")
        date_end = today.strftime("%Y-%m-%d")
    
    query = {
        "tenant_id": tenant_id,
        "date": {"$gte": date_start, "$lte": date_end}
    }
    
    if store_id:
        query["$or"] = [{"store_id": store_id}, {"store_id": None}]
    
    expenses = await db.expenses.find(query, {"_id": 0}).to_list(None)
    
    # Calculate totals
    total_expenses = sum(e.get("amount", 0) for e in expenses)
    
    # Group by category
    by_category = {}
    for exp in expenses:
        cat = exp.get("category", "other")
        if cat not in by_category:
            by_category[cat] = {"total": 0, "count": 0, "expenses": []}
        by_category[cat]["total"] += exp.get("amount", 0)
        by_category[cat]["count"] += 1
    
    # Group by store
    by_store = {"global": {"total": 0, "count": 0}}
    for exp in expenses:
        sid = exp.get("store_id") or "global"
        if sid not in by_store:
            by_store[sid] = {"total": 0, "count": 0}
        by_store[sid]["total"] += exp.get("amount", 0)
        by_store[sid]["count"] += 1
    
    # Group by expense type
    by_type = {}
    for exp in expenses:
        etype = exp.get("expense_type", "daily")
        if etype not in by_type:
            by_type[etype] = {"total": 0, "count": 0}
        by_type[etype]["total"] += exp.get("amount", 0)
        by_type[etype]["count"] += 1
    
    # Get sales data for profit calculation
    sales_query = {
        "tenant_id": tenant_id,
        "created_at": {"$gte": date_start, "$lte": date_end + "T23:59:59"}
    }
    if store_id:
        sales_query["store_id"] = store_id
    
    sales = await db.sales.find(sales_query, {"_id": 0, "total_amount": 1, "subtotal": 1}).to_list(None)
    total_revenue = sum(s.get("total_amount", 0) for s in sales)
    
    # Calculate profit
    gross_profit = total_revenue
    net_profit = gross_profit - total_expenses
    
    return {
        "period": period,
        "date_range": {"start": date_start, "end": date_end},
        "total_expenses": round(total_expenses, 2),
        "total_revenue": round(total_revenue, 2),
        "gross_profit": round(gross_profit, 2),
        "net_profit": round(net_profit, 2),
        "expense_count": len(expenses),
        "by_category": by_category,
        "by_store": by_store,
        "by_type": by_type,
        "profit_margin": round((net_profit / total_revenue * 100) if total_revenue > 0 else 0, 2)
    }


@api_router.get("/expenses/trends")
async def get_expense_trends(
    user: dict = Depends(get_current_user),
    store_id: Optional[str] = Query(None),
    months: int = Query(6, ge=1, le=24)
):
    """Get expense trends over time"""
    tenant_id = get_tenant_id(user)
    
    today = datetime.now(timezone.utc)
    start_date = (today - timedelta(days=months * 30)).strftime("%Y-%m-%d")
    
    query = {
        "tenant_id": tenant_id,
        "date": {"$gte": start_date}
    }
    
    if store_id:
        query["$or"] = [{"store_id": store_id}, {"store_id": None}]
    
    expenses = await db.expenses.find(query, {"_id": 0}).to_list(None)
    
    # Group by month
    monthly_data = {}
    for exp in expenses:
        month_key = exp.get("date", "")[:7]  # YYYY-MM
        if month_key not in monthly_data:
            monthly_data[month_key] = {"total": 0, "count": 0, "categories": {}}
        monthly_data[month_key]["total"] += exp.get("amount", 0)
        monthly_data[month_key]["count"] += 1
        
        cat = exp.get("category", "other")
        if cat not in monthly_data[month_key]["categories"]:
            monthly_data[month_key]["categories"][cat] = 0
        monthly_data[month_key]["categories"][cat] += exp.get("amount", 0)
    
    # Sort by month
    trends = []
    for month_key in sorted(monthly_data.keys()):
        trends.append({
            "month": month_key,
            **monthly_data[month_key]
        })
    
    return {
        "trends": trends,
        "months_analyzed": months,
        "total_expense": round(sum(t["total"] for t in trends), 2),
        "avg_monthly": round(sum(t["total"] for t in trends) / max(len(trends), 1), 2)
    }


@api_router.post("/expenses")
async def create_expense(request: ExpenseCreate, user: dict = Depends(get_current_user)):
    """Create a new expense entry"""
    tenant_id = get_tenant_id(user)
    
