# ============== SELF CHECK-IN/CHECK-OUT ==============

class SelfCheckRequest(BaseModel):
    action: str  # 'check_in' or 'check_out'
    ip_address: Optional[str] = None
    device_info: Optional[str] = None

def get_current_season():
    """Determine current season based on month"""
    month = datetime.now().month
    # Winter: November (11) to February (2)
    if month >= 11 or month <= 2:
        return 'winter'
    return 'summer'

def get_shift_timing(work_timing: dict):
    """Get current shift timing based on season"""
    if not work_timing.get("enable_seasonal_timing", True):
        return work_timing.get("winter_start_time", "09:30"), work_timing.get("winter_end_time", "18:00")
    
    season = get_current_season()
    if season == 'winter':
        return work_timing.get("winter_start_time", "09:30"), work_timing.get("winter_end_time", "18:00")
    else:
        return work_timing.get("summer_start_time", "09:00"), work_timing.get("summer_end_time", "19:30")

@api_router.post("/attendance/self-check")
async def self_check_attendance(request: SelfCheckRequest, user: dict = Depends(get_current_user)):
    """Employee self check-in/check-out with IP tracking"""
    tenant_id = get_tenant_id(user)
    now = datetime.now(timezone.utc)
    today = now.strftime("%Y-%m-%d")
    
    # Find employee record for current user
    employee = await db.employees.find_one(
        {"tenant_id": tenant_id, "$or": [{"user_id": user.get("id")}, {"email": user.get("email")}]},
        {"_id": 0}
    )
    
    if not employee:
        raise HTTPException(status_code=404, detail="Employee record not found for current user")
    
    # Get work timing configuration
    work_timing = await db.work_timing.find_one({"tenant_id": tenant_id}, {"_id": 0}) or {}
    shift_start, shift_end = get_shift_timing(work_timing)
    grace_minutes = work_timing.get("grace_period_minutes", 15)
    
    # Check existing attendance for today
    existing = await db.attendance.find_one({
        "tenant_id": tenant_id,
        "employee_id": employee["id"],
        "date": today
    })
    
    if request.action == "check_in":
        if existing and existing.get("check_in"):
            raise HTTPException(status_code=400, detail="Already checked in today")
        
        # Calculate late hours
        late_hours = 0.0
        is_late = False
        try:
            shift_hour, shift_min = map(int, shift_start.split(":"))
            # Add grace period
            shift_datetime = now.replace(hour=shift_hour, minute=shift_min, second=0, microsecond=0, tzinfo=timezone.utc)
            grace_datetime = shift_datetime + timedelta(minutes=grace_minutes)
            
            if now > grace_datetime:
                late_minutes = (now - shift_datetime).total_seconds() / 60
                late_hours = round(late_minutes / 60, 2)
                is_late = True
        except (ValueError, IndexError):
            pass
        
        attendance_data = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "employee_id": employee["id"],
            "store_id": employee.get("store_id") or (employee.get("store_ids", [])[0] if employee.get("store_ids") else ""),
            "date": today,
            "status": "present",
            "check_in": now.isoformat(),
            "check_in_method": "self_check",
            "ip_address": request.ip_address,
            "device_info": request.device_info,
            "late_hours": late_hours,
            "shift_start_time": shift_start,
            "shift_end_time": shift_end,
            "created_at": now.isoformat()
        }
        
        if existing:
            await db.attendance.update_one({"id": existing["id"]}, {"$set": attendance_data})
            attendance_data["id"] = existing["id"]
        else:
            await db.attendance.insert_one(attendance_data)
        
        attendance_data.pop("_id", None)
        return {
            "action": "check_in",
            "attendance": attendance_data,
            "is_late": is_late,
            "late_hours": late_hours,
            "shift_start": shift_start,
            "message": f"Check-in successful at {now.strftime('%H:%M')}" + (f" (Late by {late_hours:.1f}h)" if is_late else " (On time)")
        }
    
    elif request.action == "check_out":
        if not existing or not existing.get("check_in"):
            raise HTTPException(status_code=400, detail="You haven't checked in today")
        
        if existing.get("check_out"):
            raise HTTPException(status_code=400, detail="Already checked out today")
        
        # Calculate total hours
        check_in_str = existing.get("check_in")
        if check_in_str:
            try:
                check_in_time = datetime.fromisoformat(check_in_str.replace('Z', '+00:00'))
                total_hours = (now - check_in_time).total_seconds() / 3600
            except (ValueError, AttributeError):
                total_hours = 0
        else:
            total_hours = 0
        
        # Calculate overtime
        overtime_hours = 0.0
        try:
            shift_hour, shift_min = map(int, shift_end.split(":"))
            shift_end_datetime = now.replace(hour=shift_hour, minute=shift_min, second=0, microsecond=0, tzinfo=timezone.utc)
            if now > shift_end_datetime:
                overtime_hours = (now - shift_end_datetime).total_seconds() / 3600
        except (ValueError, IndexError):
            pass
        
        update_data = {
            "check_out": now.isoformat(),
            "check_out_method": "self_check",
            "check_out_ip": request.ip_address,
            "check_out_device": request.device_info,
            "total_hours": round(total_hours, 2),
            "overtime_hours": round(overtime_hours, 2),
            "updated_at": now.isoformat()
        }
        
        await db.attendance.update_one({"id": existing["id"]}, {"$set": update_data})
        
        updated = await db.attendance.find_one({"id": existing["id"]}, {"_id": 0})
        return {
            "action": "check_out",
            "attendance": updated,
            "total_hours": round(total_hours, 2),
            "overtime_hours": round(overtime_hours, 2),
            "message": f"Check-out successful. Total hours: {total_hours:.2f}"
        }
    
    else:
        raise HTTPException(status_code=400, detail="Invalid action. Use 'check_in' or 'check_out'")


