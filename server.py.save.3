# ============== FILE UPLOAD ==============

@api_router.post("/uploads/images")
async def upload_image(file: UploadFile = File(...), user: dict = Depends(get_current_user)):
    # Check if file is an image by content type or extension
    allowed_extensions = {'jpg', 'jpeg', 'png', 'gif', 'webp', 'heic', 'heif', 'bmp', 'tiff'}
    # Handle filenames with spaces before extension
    ext = file.filename.split(".")[-1].lower().strip() if "." in file.filename else ""
    
    is_image = (
        (file.content_type and file.content_type.startswith("image/")) or
        ext in allowed_extensions
    )
    
    if not is_image:
        raise HTTPException(status_code=400, detail=f"File must be an image. Received: {file.content_type}, extension: {ext}")
    
    file_id = str(uuid.uuid4())
    if ext not in allowed_extensions:
        ext = "jpg"  # Default extension
    filename = f"{file_id}.{ext}"
    filepath = UPLOAD_DIR / filename
    
    content = await file.read()
    
    # Validate file size (max 10MB)
    if len(content) > 10 * 1024 * 1024:
        raise HTTPException(status_code=400, detail="File size must be less than 10MB")
    
    # Validate it's actually an image by checking magic bytes
    image_signatures = {
        b'\xff\xd8\xff': 'jpg',
        b'\x89PNG': 'png',
        b'GIF8': 'gif',
        b'RIFF': 'webp',  # WebP starts with RIFF
    }
    
    is_valid_image = False
    for sig in image_signatures:
        if content[:len(sig)] == sig:
            is_valid_image = True
            break
    
    # Also allow if extension is valid (some formats have different signatures)
    if not is_valid_image and ext in allowed_extensions:
        is_valid_image = True
    
    if not is_valid_image:
        raise HTTPException(status_code=400, detail="Invalid image file")
    
    async with aiofiles.open(filepath, 'wb') as f:
        await f.write(content)
    
    return {"url": f"/api/uploads/images/{filename}", "filename": filename}


