class TenantUserCreate(BaseModel):
    email: str
    password: str
    name: str
    role: str = "staff"
    store_ids: List[str] = []

class TenantUserUpdate(BaseModel):
    name: Optional[str] = None
    role: Optional[str] = None
    store_ids: Optional[List[str]] = None
    is_active: Optional[bool] = None

# Create user for a specific admin/tenant
@api_router.post("/superadmin/admins/{admin_id}/users")
async def create_tenant_user(
    admin_id: str,
    user_data: TenantUserCreate,
    user: dict = Depends(require_superadmin)
):
    """Create a new user for a specific admin's tenant"""
    
    # Get the admin to find their tenant
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    tenant_id = admin.get("tenant_id")
    
    # Check if email already exists
    existing = await db.users.find_one({"email": user_data.email.lower()})
    if existing:
        raise HTTPException(status_code=400, detail="Email already registered")
    
    # Validate role
    valid_roles = ["manager", "staff", "cashier", "viewer"]
    if user_data.role not in valid_roles:
        raise HTTPException(status_code=400, detail=f"Invalid role. Must be one of: {', '.join(valid_roles)}")
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Create the user
    new_user = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "email": user_data.email.lower(),
        "password": hash_password(user_data.password),
        "name": user_data.name,
        "role": user_data.role,
        "store_ids": user_data.store_ids,
        "permissions": DEFAULT_ROLE_PERMISSIONS.get(user_data.role, DEFAULT_ROLE_PERMISSIONS["staff"]),
        "is_active": True,
        "created_at": now,
        "created_by": user.get("id"),
        "created_by_superadmin": True
    }
    
    await db.users.insert_one(new_user)
    
    # Log the action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "tenant_user_created",
        "admin_id": admin_id,
        "admin_email": admin.get("email"),
        "user_id": new_user["id"],
        "user_email": user_data.email,
        "user_role": user_data.role,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    del new_user["_id"]
    del new_user["password"]
    
    return {
        "message": f"User '{user_data.name}' created successfully",
        "user": new_user
    }

# Update user in a specific tenant
@api_router.put("/superadmin/admins/{admin_id}/users/{user_id}")
async def update_tenant_user(
    admin_id: str,
    user_id: str,
    user_data: TenantUserUpdate,
    user: dict = Depends(require_superadmin)
):
    """Update a user in a specific admin's tenant"""
    
    # Get the admin to find their tenant
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    tenant_id = admin.get("tenant_id")
    
    # Get the target user
    target_user = await db.users.find_one({"id": user_id, "tenant_id": tenant_id})
    if not target_user:
        raise HTTPException(status_code=404, detail="User not found in this tenant")
    
    # Cannot modify admin user through this endpoint
    if target_user.get("role") == "admin":
        raise HTTPException(status_code=400, detail="Cannot modify admin user through this endpoint")
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Build update data
    update_data = {"updated_at": now, "updated_by_superadmin": user.get("id")}
    
    if user_data.name is not None:
        update_data["name"] = user_data.name
    if user_data.role is not None:
        valid_roles = ["manager", "staff", "cashier", "viewer"]
        if user_data.role not in valid_roles:
            raise HTTPException(status_code=400, detail=f"Invalid role. Must be one of: {', '.join(valid_roles)}")
        update_data["role"] = user_data.role
        update_data["permissions"] = DEFAULT_ROLE_PERMISSIONS.get(user_data.role, DEFAULT_ROLE_PERMISSIONS["staff"])
    if user_data.store_ids is not None:
        update_data["store_ids"] = user_data.store_ids
    if user_data.is_active is not None:
        update_data["is_active"] = user_data.is_active
    
    await db.users.update_one({"id": user_id}, {"$set": update_data})
    
    # Log the action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "tenant_user_updated",
        "admin_id": admin_id,
        "admin_email": admin.get("email"),
        "user_id": user_id,
        "user_email": target_user.get("email"),
        "changes": {k: v for k, v in update_data.items() if k not in ["updated_at", "updated_by_superadmin"]},
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    updated_user = await db.users.find_one({"id": user_id}, {"_id": 0, "password": 0})
    
    return {
        "message": "User updated successfully",
        "user": updated_user
    }

# Delete user from a specific tenant
