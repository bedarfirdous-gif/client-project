@api_router.get("/invoice-settings/next-number")
async def get_next_invoice_number(doc_type: str = "invoice", user: dict = Depends(get_current_user)):
    """Get next invoice/quotation/order number - User-specific"""
    user_id = user.get("id")
    tenant_id = get_tenant_id(user)
    
    # Get user-specific settings
    settings = await db.user_invoice_settings.find_one({"user_id": user_id}, {"_id": 0})
    
    prefix_map = {
        "invoice": ("invoice_prefix", "invoice_starting_number"),
        "quotation": ("quotation_prefix", "invoice_starting_number"),
        "order": ("order_prefix", "invoice_starting_number")
    }
    
    prefix_key, number_key = prefix_map.get(doc_type, ("invoice_prefix", "invoice_starting_number"))
    prefix = settings.get(prefix_key, "INV-") if settings else "INV-"
    starting_number = settings.get(number_key, 1) if settings else 1
    
    # Count existing documents
    collection_map = {"invoice": "sales", "quotation": "quotations", "order": "orders"}
    collection = collection_map.get(doc_type, "sales")
    count = await db[collection].count_documents({"tenant_id": tenant_id})
    
    next_number = starting_number + count
    return {"prefix": prefix, "number": next_number, "formatted": f"{prefix}{next_number:06d}"}


