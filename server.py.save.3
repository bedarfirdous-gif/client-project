@api_router.get("/auth/check-reauth")
async def check_reauth_status(user: dict = Depends(get_current_user)):
    """Check if current re-auth session is still valid"""
    user_id = user.get("id")
    current_user = await db.users.find_one({"id": user_id})
    
    if not current_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    reauth_expires_str = current_user.get("reauth_expires")
    if not reauth_expires_str:
        return {"is_valid": False, "reason": "No re-auth session"}
    
    try:
        reauth_expires = datetime.fromisoformat(reauth_expires_str.replace('Z', '+00:00'))
        if reauth_expires.tzinfo is None:
            reauth_expires = reauth_expires.replace(tzinfo=timezone.utc)
        
        now = datetime.now(timezone.utc)
        is_valid = now < reauth_expires
        
        return {
            "is_valid": is_valid,
            "expires_at": reauth_expires_str,
            "remaining_minutes": max(0, int((reauth_expires - now).total_seconds() / 60)) if is_valid else 0
        }
    except Exception:
        return {"is_valid": False, "reason": "Invalid session"}

