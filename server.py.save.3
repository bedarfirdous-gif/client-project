        },
        {"_id": 0, "id": 1, "name": 1, "current_stock": 1, "min_stock_alert": 1}
    ).limit(20).to_list(20)
    
    # Get recent e-commerce orders that affected inventory
    recent_orders = await db.ecommerce_orders.find(
        {"tenant_id": tenant_id, "status": {"$in": ["confirmed", "shipped", "delivered"]}},
        {"_id": 0, "id": 1, "items": 1, "created_at": 1, "status": 1}
