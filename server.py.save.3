EMERGENT_LLM_KEY = os.environ.get("EMERGENT_LLM_KEY", "")

@api_router.post("/smart-scanner/excel")
async def process_excel_upload(
    file: UploadFile = File(...),
    store_id: str = "",
    user: dict = Depends(get_current_user)
):
    """Process Excel/CSV file and extract item data"""
    tenant_id = get_tenant_id(user)
    
    # Read file content
    content = await file.read()
    filename = file.filename.lower()
    
    try:
        # Parse based on file type
        if filename.endswith('.csv'):
            df = pd.read_csv(io.BytesIO(content))
        elif filename.endswith(('.xlsx', '.xls')):
            df = pd.read_excel(io.BytesIO(content))
        else:
            raise HTTPException(status_code=400, detail="Unsupported file format. Use .xlsx, .xls, or .csv")
        
        # Normalize column names
        df.columns = df.columns.str.strip().str.lower().str.replace(' ', '_')
        
        # Map common column names
        column_mapping = {
            'item_name': 'name', 'product_name': 'name', 'product': 'name', 'item': 'name',
            'sku_code': 'sku', 'item_code': 'sku', 'product_code': 'sku', 'code': 'sku',
            'category_name': 'category', 'cat': 'category',
            'brand_name': 'brand',
            'selling': 'selling_price', 'sale_price': 'selling_price', 'price': 'selling_price',
            'cost': 'cost_price', 'purchase_price': 'cost_price',
            'qty': 'quantity', 'stock': 'quantity', 'opening_stock': 'quantity',
            'reorder': 'min_stock_alert', 'reorder_level': 'min_stock_alert',
            'gst': 'gst_rate', 'tax': 'gst_rate', 'tax_rate': 'gst_rate',
            'hsn': 'hsn_code',
        }
        
        df.rename(columns=column_mapping, inplace=True)
        
        # Convert to list of items
        items = []
        errors = 0
        
        for idx, row in df.iterrows():
            try:
                item = {
                    'name': str(row.get('name', '')).strip(),
                    'sku': str(row.get('sku', f"SKU-{idx+1}")).strip(),
                    'category': str(row.get('category', '')).strip(),
                    'brand': str(row.get('brand', '')).strip(),
                    'size': str(row.get('size', '')).strip(),
                    'color': str(row.get('color', '')).strip(),
                    'mrp': float(row.get('mrp', 0) or 0),
                    'selling_price': float(row.get('selling_price', 0) or 0),
                    'cost_price': float(row.get('cost_price', 0) or 0),
                    'quantity': int(row.get('quantity', 0) or 0),
                    'min_stock_alert': int(row.get('min_stock_alert', 5) or 5),
                    'gst_rate': float(row.get('gst_rate', 18) or 18),
                    'hsn_code': str(row.get('hsn_code', '')).strip(),
                }
                
                # Skip empty rows
                if not item['name']:
                    continue
                    
                # Set selling price from MRP if not provided
                if item['selling_price'] == 0 and item['mrp'] > 0:
                    item['selling_price'] = item['mrp']
                
                items.append(item)
            except Exception as e:
                errors += 1
                logger.error(f"Error parsing row {idx}: {e}")
        
        return {
            "success": True,
            "items": items,
            "stats": {
                "total_rows": len(df),
                "valid": len(items),
                "new": len(items),
                "update": 0,
                "errors": errors
            }
        }
        
    except Exception as e:
        logger.error(f"Excel processing error: {e}")
        raise HTTPException(status_code=400, detail=f"Failed to process file: {str(e)}")


