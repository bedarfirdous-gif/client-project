@api_router.get("/inventory/alerts")
async def get_inventory_alerts(
    user: dict = Depends(get_current_user),
    status: str = Query(None),  # pending, acknowledged, resolved
    skip: int = Query(0),
    limit: int = Query(50)
):
    """Get inventory alerts"""
    tenant_id = get_tenant_id(user)
    
    # Get settings
    settings = await db.inventory_alert_settings.find_one({"tenant_id": tenant_id})
    threshold = settings.get("low_stock_threshold", 10) if settings else 10
    
    # Find low stock items
    low_stock_items = await db.items.find(
        {
            "tenant_id": tenant_id,
            "stock_quantity": {"$lte": threshold},
            "is_active": {"$ne": False}
        },
        {"_id": 0}
    ).sort("stock_quantity", 1).to_list(limit)
    
    # Get recent alerts
    query = {"tenant_id": tenant_id}
    if status:
        query["status"] = status
    
    alerts = await db.inventory_alerts.find(query, {"_id": 0}).sort("created_at", -1).skip(skip).limit(limit).to_list(limit)
    
    return {
        "low_stock_items": low_stock_items,
        "alerts": alerts,
        "threshold": threshold,
        "total_low_stock": len(low_stock_items)
    }


@api_router.post("/inventory/alerts/check")
async def check_and_create_alerts(user: dict = Depends(get_current_user)):
    """Manually trigger inventory alert check"""
    tenant_id = get_tenant_id(user)
    
    # Get settings
    settings = await db.inventory_alert_settings.find_one({"tenant_id": tenant_id})
    if not settings or not settings.get("enabled", True):
        return {"message": "Alerts disabled", "alerts_created": 0}
    
    threshold = settings.get("low_stock_threshold", 10)
    
    # Find items needing alerts
    low_stock_items = await db.items.find(
        {
            "tenant_id": tenant_id,
            "stock_quantity": {"$lte": threshold},
            "is_active": {"$ne": False}
        },
        {"_id": 0}
    ).to_list(None)
    
    alerts_created = 0
    for item in low_stock_items:
        # Check if alert already exists for this item
        existing = await db.inventory_alerts.find_one({
            "tenant_id": tenant_id,
            "item_id": item["id"],
            "status": {"$in": ["pending", "acknowledged"]}
        })
        
        if not existing:
            alert_type = "out_of_stock" if item["stock_quantity"] <= 0 else "low_stock"
            
            alert_doc = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "item_id": item["id"],
                "item_name": item.get("name"),
                "item_sku": item.get("sku"),
                "current_stock": item["stock_quantity"],
                "threshold": threshold,
                "alert_type": alert_type,
                "status": "pending",
                "channels_notified": [],
                "created_at": datetime.now(timezone.utc).isoformat()
            }
            
            await db.inventory_alerts.insert_one(alert_doc)
            alerts_created += 1
            
            # Send notifications based on channels
            channels = settings.get("channels", ["in_app"])
            
            if "in_app" in channels:
                # Create in-app notification
                await db.notifications.insert_one({
                    "id": str(uuid.uuid4()),
                    "tenant_id": tenant_id,
                    "type": "inventory_alert",
                    "title": f"{'Out of Stock' if alert_type == 'out_of_stock' else 'Low Stock'}: {item.get('name')}",
                    "message": f"Stock level is {item['stock_quantity']} (threshold: {threshold})",
                    "read": False,
                    "created_at": datetime.now(timezone.utc).isoformat()
                })
    
    return {"message": "Alert check complete", "alerts_created": alerts_created}


