@api_router.get("/purchase-reports/summary")
async def get_purchase_summary(
    start_date: str = "",
    end_date: str = "",
    user: dict = Depends(get_current_user)
):
    tenant_id = get_tenant_id(user)
    query = {"tenant_id": tenant_id, "is_deleted": {"$ne": True}}
    
    if start_date and end_date:
        query["invoice_date"] = {"$gte": start_date, "$lte": end_date}
    elif start_date:
        query["invoice_date"] = {"$gte": start_date}
    elif end_date:
        query["invoice_date"] = {"$lte": end_date}
    
    # Get purchase invoices (excluding deleted)
    invoices = await db.purchase_invoices.find(query, {"_id": 0}).to_list(10000)
    
    # Get purchase returns
    return_query = {"tenant_id": tenant_id}
    if start_date and end_date:
        return_query["return_date"] = {"$gte": start_date, "$lte": end_date}
    elif start_date:
        return_query["return_date"] = {"$gte": start_date}
    elif end_date:
        return_query["return_date"] = {"$lte": end_date}
    
    returns = await db.purchase_returns.find(return_query, {"_id": 0}).to_list(10000)
    
    # Calculate summary
    total_purchases = sum(inv.get("total_amount", 0) for inv in invoices)
    total_tax = sum(inv.get("tax_amount", 0) for inv in invoices)
    total_discount = sum(inv.get("discount_amount", 0) for inv in invoices)
    total_freight = sum(inv.get("freight_charges", 0) for inv in invoices)
    pending_amount = sum(inv.get("total_amount", 0) for inv in invoices if inv.get("payment_status") == "pending")
    paid_amount = sum(inv.get("total_amount", 0) for inv in invoices if inv.get("payment_status") == "paid")
    
    total_returns = sum(ret.get("refund_amount", 0) for ret in returns)
    
    return {
        "total_invoices": len(invoices),
        "total_purchases": total_purchases,
        "total_tax": total_tax,
        "total_discount": total_discount,
        "total_freight": total_freight,
        "pending_amount": pending_amount,
        "paid_amount": paid_amount,
        "total_returns": len(returns),
        "total_return_amount": total_returns,
        "net_purchases": total_purchases - total_returns
    }

