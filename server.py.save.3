@api_router.post("/ai-agents/{agent_type}/collaborate")
async def agent_collaborate(
    agent_type: str,
    request: dict,
    user: dict = Depends(require_permission("dashboard"))
):
    """
    Initiate collaboration between AI agents.
    
    The specified agent will act as the lead and can delegate
    tasks to or consult with other agents.
    
    Request body:
    - prompt: The task or question for the agents
    - collaboration_type: 'delegate' or 'collaborate' (default: collaborate)
    - target_agent: (for delegate) which agent to delegate to
    - involved_agents: (for collaborate) list of agents to involve (auto-selected if not provided)
    """
    from emergent_agents import get_collaboration_hub
    
    if agent_type not in emergent_agents:
        raise HTTPException(
            status_code=404,
            detail=f"Agent '{agent_type}' not found. Available: {list(emergent_agents.keys())}"
        )
    
    prompt = request.get("prompt", "")
    collaboration_type = request.get("collaboration_type", "collaborate")
    target_agent = request.get("target_agent")
    involved_agents = request.get("involved_agents")
    
    if not prompt:
        raise HTTPException(status_code=400, detail="Prompt is required")
    
    # Get or create collaboration hub
    hub = get_collaboration_hub(agents=emergent_agents, db=db)
    
    try:
        if collaboration_type == "delegate" and target_agent:
            # Delegate task to a specific agent
            if target_agent not in emergent_agents:
                raise HTTPException(
                    status_code=404,
                    detail=f"Target agent '{target_agent}' not found"
                )
            
            response = await hub.delegate_task(
                from_agent_id=agent_type,
                to_agent_id=target_agent,
                task_description=prompt,
                parameters=request.get("parameters", {}),
                user_id=user.get("id"),
                tenant_id=get_tenant_id(user)
            )
        else:
            # Multi-agent collaboration
            response = await hub.collaborate(
                lead_agent_id=agent_type,
                prompt=prompt,
                involved_agents=involved_agents,
                user_id=user.get("id"),
                tenant_id=get_tenant_id(user)
            )
        
        return {
            "success": response.success,
            "message": response.message,
            "data": response.data,
            "reasoning": response.reasoning,
            "plan": response.plan,
            "actions_taken": response.actions_taken,
            "suggestions": response.suggestions,
            "follow_up_questions": response.follow_up_questions,
            "confidence": response.confidence,
            "execution_time_ms": response.execution_time_ms,
            "conversation_id": response.conversation_id,
            "memory_updated": response.memory_updated,
            "collaborated_with": response.collaborated_with,
            "delegation_results": response.delegation_results
        }
    except HTTPException:
        # Re-raise HTTP exceptions as-is to preserve status codes
        raise
    except Exception as e:
        logger.error(f"Agent collaboration failed: {e}")
        raise HTTPException(status_code=500, detail=f"Collaboration failed: {str(e)}")


