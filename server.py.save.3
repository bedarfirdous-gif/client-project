@api_router.get("/backups")
async def get_backups(user: dict = Depends(get_current_user)):
    """Get all backups for tenant"""
    tenant_id = get_tenant_id(user)
    backups = await db.backups.find(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ).sort("created_at", -1).to_list(100)
    return backups

@api_router.post("/backups")
async def create_backup(request: BackupCreate, user: dict = Depends(get_current_user)):
    """Create a new backup"""
    tenant_id = get_tenant_id(user)
    
    # Gather all data for backup
    collections_to_backup = [
        "items", "inventory", "sales", "customers", "suppliers", 
        "employees", "stores", "vouchers", "discounts", "invoices",
        "quotations", "orders", "transfers", "users"
    ]
    
    backup_data = {}
    total_size = 0
    
    for collection in collections_to_backup:
        docs = await db[collection].find(
            {"tenant_id": tenant_id},
            {"_id": 0}
        ).to_list(10000)
        backup_data[collection] = docs
        total_size += len(str(docs))
    
    backup_id = str(uuid.uuid4())
    backup_name = request.name or f"Backup {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M')}"
    
    backup_record = {
        "id": backup_id,
        "tenant_id": tenant_id,
        "name": backup_name,
        "type": request.type,
        "size": total_size,
        "collections": list(backup_data.keys()),
        "item_counts": {k: len(v) for k, v in backup_data.items()},
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get("id"),
    }
    
    # Store backup data separately (in production, store to file/cloud)
    await db.backup_data.insert_one({
        "backup_id": backup_id,
        "tenant_id": tenant_id,
        "data": backup_data,
        "created_at": datetime.now(timezone.utc).isoformat(),
    })
    
    await db.backups.insert_one(backup_record)
    
    # Update last backup time in settings
    await db.backup_settings.update_one(
        {"tenant_id": tenant_id},
        {"$set": {"last_backup": datetime.now(timezone.utc).isoformat()}},
        upsert=True
    )
    
    return {k: v for k, v in backup_record.items() if k != "_id"}

@api_router.get("/backups/{backup_id}/download")
async def download_backup(backup_id: str, user: dict = Depends(get_current_user)):
    """Download backup data"""
    tenant_id = get_tenant_id(user)
    
    backup_data = await db.backup_data.find_one(
        {"backup_id": backup_id, "tenant_id": tenant_id},
        {"_id": 0}
    )
    
    if not backup_data:
        raise HTTPException(status_code=404, detail="Backup not found")
    
    return backup_data

@api_router.post("/backups/{backup_id}/restore")
async def restore_backup(backup_id: str, user: dict = Depends(get_current_user)):
    """Restore data from backup"""
    if not is_superadmin(user) and user.get("role") not in ["admin", "owner"]:
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    
    backup_data = await db.backup_data.find_one(
        {"backup_id": backup_id, "tenant_id": tenant_id}
    )
    
    if not backup_data:
        raise HTTPException(status_code=404, detail="Backup not found")
    
    data = backup_data.get("data", {})
    
    # Restore each collection
    for collection_name, documents in data.items():
        if documents:
            # Clear existing data
            await db[collection_name].delete_many({"tenant_id": tenant_id})
            # Insert backup data
            for doc in documents:
                doc["tenant_id"] = tenant_id
                await db[collection_name].insert_one(doc)
    
    return {"message": "Backup restored successfully", "collections_restored": list(data.keys())}

@api_router.delete("/backups/{backup_id}")
async def delete_backup(backup_id: str, user: dict = Depends(get_current_user)):
    """Delete a backup"""
    tenant_id = get_tenant_id(user)
    
    result = await db.backups.delete_one({"id": backup_id, "tenant_id": tenant_id})
    await db.backup_data.delete_one({"backup_id": backup_id, "tenant_id": tenant_id})
    
    if result.deleted_count == 0:
        raise HTTPException(status_code=404, detail="Backup not found")
    
    return {"message": "Backup deleted"}

@api_router.post("/backups/upload")
async def upload_backup(
    file: UploadFile = File(...),
    mfa_code: Optional[str] = None,
    user: dict = Depends(get_current_user)
):
    """Upload a backup file with security validation"""
    tenant_id = get_tenant_id(user)
    
    # RBAC Check
    allowed, reason = backup_security.check_backup_permission(user, "upload")
    if not allowed:
        await db.security_audit.insert_one(
            backup_security.create_security_audit_log(
                action="backup_upload_denied",
                user=user,
                success=False,
                details={"reason": reason, "filename": file.filename}
            )
        )
        raise HTTPException(status_code=403, detail=reason)
    
    # Check if user has MFA enabled and validate if so
    user_security = await db.user_security.find_one(
        {"tenant_id": tenant_id, "user_id": user.get("id")}
    )
    
    if user_security and user_security.get("mfa_enabled"):
        if not mfa_code:
            raise HTTPException(
                status_code=428, 
                detail="MFA verification required for backup upload",
                headers={"X-MFA-Required": "true"}
            )
        if not backup_security.verify_mfa_code(user_security.get("mfa_secret"), mfa_code):
            await db.security_audit.insert_one(
                backup_security.create_security_audit_log(
                    action="backup_upload_mfa_failed",
                    user=user,
                    success=False
                )
            )
            raise HTTPException(status_code=400, detail="Invalid MFA code")
    
    try:
        # Read the uploaded file
        content = await file.read()
        
        # Size limit check (50MB max)
        if len(content) > 50 * 1024 * 1024:
            raise HTTPException(status_code=400, detail="Backup file too large (max 50MB)")
        
        # Try to parse as JSON
        try:
            backup_data = json.loads(content.decode('utf-8'))
        except json.JSONDecodeError:
            raise HTTPException(status_code=400, detail="Invalid backup file format. Expected JSON.")
        
        # Check if backup is encrypted
        is_encrypted = backup_data.get("encrypted", False)
        
        if is_encrypted:
            # Decrypt backup
            try:
                backup_data = backup_security.decrypt_backup(backup_data)
            except ValueError as e:
                raise HTTPException(status_code=400, detail=f"Failed to decrypt backup: {str(e)}")
        
        # Validate backup structure and scan for malware
        is_valid, issues = backup_security.validate_backup_structure(backup_data)
        
        security_scan_result = {
            "passed": is_valid,
            "issues": issues,
            "threats_found": len([i for i in issues if "security threats" in i.lower()])
        }
        
        if security_scan_result["threats_found"] > 0:
            # Log security threat
            await db.security_audit.insert_one(
                backup_security.create_security_audit_log(
                    action="backup_upload_threats_detected",
                    user=user,
                    success=False,
                    details={"threats": issues, "filename": file.filename}
                )
            )
            raise HTTPException(
                status_code=400, 
                detail=f"Security scan failed: {'; '.join(issues[:3])}"
            )
        
        # Sanitize backup data
        sanitized_data = backup_security.sanitize_backup_data(backup_data)
        
        # Encrypt backup data before storing
        encrypted_backup = backup_security.encrypt_backup(sanitized_data)
        
        # Create backup record
        backup_id = str(uuid.uuid4())
        backup_record = {
            "id": backup_id,
            "tenant_id": tenant_id,
            "name": file.filename or f"Uploaded Backup {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M')}",
            "type": "uploaded",
            "size": len(content),
            "created_at": datetime.now(timezone.utc).isoformat(),
            "created_by": user.get("name"),
            "created_by_id": user.get("id"),
            "status": "ready",
            "collections": list(sanitized_data.keys()),
            "encrypted": True,
            "security_scan": security_scan_result,
            "mfa_verified": bool(mfa_code)
        }
        
        await db.backups.insert_one(backup_record)
        
        # Store encrypted backup data
        await db.backup_data.insert_one({
            "backup_id": backup_id,
            "tenant_id": tenant_id,
            "data": encrypted_backup,
            "encrypted": True,
            "created_at": datetime.now(timezone.utc).isoformat()
        })
        
        # Log successful upload
        await db.security_audit.insert_one(
            backup_security.create_security_audit_log(
                action="backup_upload_success",
                user=user,
                success=True,
                details={
                    "backup_id": backup_id,
                    "filename": file.filename,
                    "size": len(content),
                    "collections": list(sanitized_data.keys()),
                    "encrypted": True,
                    "mfa_used": bool(mfa_code)
                }
            )
        )
        
        del backup_record["_id"]
        
        return {
            "message": "Backup uploaded and encrypted successfully",
            "backup": backup_record,
            "security": {
                "encrypted": True,
                "scan_passed": security_scan_result["passed"],
                "mfa_verified": bool(mfa_code)
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        await db.security_audit.insert_one(
            backup_security.create_security_audit_log(
                action="backup_upload_error",
                user=user,
                success=False,
                details={"error": str(e)}
            )
        )
        raise HTTPException(status_code=500, detail=f"Failed to process backup file: {str(e)}")

