@api_router.delete("/suppliers/{supplier_id}")
async def delete_supplier(supplier_id: str, user: dict = Depends(get_current_user)):
    """Delete a supplier. Admins have full delete access."""
    tenant_id = get_tenant_id(user)
    
    # Admins can delete any supplier
    if not is_admin_or_higher(user):
        permissions = user.get("permissions", {})
        if not permissions.get("suppliers", {}).get("delete", False):
            raise HTTPException(status_code=403, detail="Permission denied. Admin access required for delete.")
    
    # Find the supplier first
    supplier = await db.suppliers.find_one({"id": supplier_id, "tenant_id": tenant_id})
    if not supplier:
        raise HTTPException(status_code=404, detail="Supplier not found")
    
    # Delete the supplier
    await db.suppliers.delete_one({"id": supplier_id, "tenant_id": tenant_id})
    return {"message": "Supplier deleted successfully"}

@api_router.post("/suppliers/sync-ledgers")
async def sync_supplier_ledgers(user: dict = Depends(require_permission("suppliers"))):
    """
    Sync existing suppliers with Sundry Creditor ledgers.
    Creates ledgers for suppliers that don't have linked ledgers.
    """
    tenant_id = get_tenant_id(user)
    now = datetime.now(timezone.utc).isoformat()
    
    # Get all suppliers without ledger_id
    suppliers = await db.suppliers.find({
        "tenant_id": tenant_id,
        "$or": [
            {"ledger_id": {"$exists": False}},
            {"ledger_id": None},
            {"ledger_id": ""}
        ]
    }, {"_id": 0}).to_list(1000)
    
    created_count = 0
    linked_count = 0
    
    for supplier in suppliers:
        # Check if ledger already exists with same name
        existing_ledger = await db.ledgers.find_one({
            "tenant_id": tenant_id,
            "name": {"$regex": f"^{supplier['name']}$", "$options": "i"},
            "group_id": "sundry_creditors",
            "is_deleted": {"$ne": True}
        })
        
        if existing_ledger:
            # Link existing ledger to supplier
            await db.suppliers.update_one(
                {"id": supplier["id"]},
                {"$set": {"ledger_id": existing_ledger["id"]}}
            )
            await db.ledgers.update_one(
                {"id": existing_ledger["id"]},
                {"$set": {"linked_supplier_id": supplier["id"]}}
            )
            linked_count += 1
        else:
            # Create new ledger
            ledger_id = str(uuid.uuid4())
            new_ledger = {
                "id": ledger_id,
                "tenant_id": tenant_id,
                "name": supplier["name"],
                "group_id": "sundry_creditors",
                "ledger_type": "liability",
                "ledger_nature": "credit",
                "opening_balance": 0,
                "opening_balance_type": "Cr",
                "phone": supplier.get("phone", ""),
                "email": supplier.get("email", ""),
                "gstin": supplier.get("gst_number", ""),
                "state": supplier.get("state", ""),
                "address": supplier.get("address", ""),
                "is_active": True,
                "linked_supplier_id": supplier["id"],
                "created_at": now,
                "updated_at": now,
                "is_deleted": False
            }
            await db.ledgers.insert_one(new_ledger)
            
            await db.suppliers.update_one(
                {"id": supplier["id"]},
                {"$set": {"ledger_id": ledger_id}}
            )
            created_count += 1
    
    return {
        "message": f"Synced {created_count + linked_count} suppliers",
        "created_ledgers": created_count,
        "linked_existing": linked_count
    }

