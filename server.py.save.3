# Database indexes for scalability (100K users, 100M records)
@app.on_event("startup")
async def create_database_indexes():
    """Create indexes for optimal performance at scale"""
    try:
        # Users collection indexes
        await db.users.create_index("id", unique=True)
        await db.users.create_index("email", unique=True)
        await db.users.create_index("tenant_id")
        await db.users.create_index("role")
        await db.users.create_index([("tenant_id", 1), ("role", 1)])
        await db.users.create_index([("tenant_id", 1), ("is_active", 1)])
        
        # Customers collection indexes (100M+ records)
        await db.customers.create_index("id", unique=True)
        await db.customers.create_index("tenant_id")
        await db.customers.create_index("phone")
        await db.customers.create_index("email")
        await db.customers.create_index([("tenant_id", 1), ("phone", 1)])
        await db.customers.create_index([("tenant_id", 1), ("name", 1)])
        await db.customers.create_index([("tenant_id", 1), ("created_at", -1)])
        await db.customers.create_index([("tenant_id", 1), ("total_spent", -1)])
        
        # Products/Items collection indexes
        await db.products.create_index("id", unique=True)
        await db.products.create_index("tenant_id")
        await db.products.create_index("barcode")
        await db.products.create_index("sku")
        await db.products.create_index([("tenant_id", 1), ("name", 1)])
        await db.products.create_index([("tenant_id", 1), ("category", 1)])
        await db.products.create_index([("tenant_id", 1), ("store_id", 1)])
        await db.products.create_index([("tenant_id", 1), ("is_active", 1)])
        
        # Sales/Orders collection indexes
        await db.sales.create_index("id", unique=True)
        await db.sales.create_index("tenant_id")
        await db.sales.create_index("invoice_number")
        await db.sales.create_index([("tenant_id", 1), ("created_at", -1)])
        await db.sales.create_index([("tenant_id", 1), ("store_id", 1)])
        await db.sales.create_index([("tenant_id", 1), ("customer_id", 1)])
        await db.sales.create_index([("tenant_id", 1), ("status", 1)])
        
        # Inventory collection indexes
        await db.inventory.create_index("id", unique=True)
        await db.inventory.create_index([("tenant_id", 1), ("product_id", 1), ("store_id", 1)])
        await db.inventory.create_index([("tenant_id", 1), ("quantity", 1)])
        
        # Stores collection indexes
        await db.stores.create_index("id", unique=True)
        await db.stores.create_index("tenant_id")
        await db.stores.create_index([("tenant_id", 1), ("is_active", 1)])
        
        # Audit logs collection indexes (append-only, time-series)
        await db.superadmin_audit.create_index([("timestamp", -1)])
        await db.superadmin_audit.create_index([("action", 1), ("timestamp", -1)])
        await db.superadmin_audit.create_index([("admin_id", 1), ("timestamp", -1)])
        
        # Subscription plans indexes
        await db.subscription_plans.create_index("id", unique=True)
        await db.subscription_plans.create_index("is_active")
        
        # Plan change history indexes
        await db.plan_changes.create_index([("admin_id", 1), ("created_at", -1)])
        await db.plan_changes.create_index([("created_at", -1)])
        
        # Centralized subscription system indexes
        await db.plans_master.create_index("id", unique=True)
        await db.plans_master.create_index("plan_code", unique=True)
        await db.plans_master.create_index("is_active")
        await db.plans_master.create_index("display_order")
        
        await db.plan_versions.create_index("id", unique=True)
        await db.plan_versions.create_index([("plan_id", 1), ("version_number", -1)])
        
        await db.subscriptions.create_index("id", unique=True)
        await db.subscriptions.create_index("tenant_id")
        await db.subscriptions.create_index([("tenant_id", 1), ("is_active", 1)])
        await db.subscriptions.create_index([("plan_id", 1), ("status", 1)])
        await db.subscriptions.create_index([("status", 1), ("next_renewal_at", 1)])
        await db.subscriptions.create_index("current_period_end")
        
        await db.subscription_history.create_index([("subscription_id", 1), ("timestamp", -1)])
        await db.subscription_history.create_index([("tenant_id", 1), ("timestamp", -1)])
        await db.subscription_history.create_index("event_type")
        
        await db.subscription_payments.create_index([("subscription_id", 1), ("created_at", -1)])
        await db.subscription_payments.create_index([("tenant_id", 1), ("created_at", -1)])
        
        await db.revenue_daily.create_index("date", unique=True)
        await db.revenue_monthly.create_index("month", unique=True)
        await db.churn_analytics.create_index("month", unique=True)
        
        logger.info("Database indexes created successfully for scalability")
    except Exception as e:
        logger.warning(f"Index creation warning (may already exist): {e}")


