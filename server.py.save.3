@api_router.post("/bogo-offers/calculate")
async def calculate_bogo(
    cart_items: List[Dict[str, Any]],
    user: dict = Depends(get_current_user),
    store_id: str = "",
    apply_on: str = "pos"
):
    """Calculate BOGO discounts for cart items with centralized discount support
    cart_items: [{item_id, variant_id, category_id, quantity, price}, ...]
    """
    tenant_id = get_tenant_id(user)
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    
    # Get active BOGO offers
    offers = await db.bogo_offers.find({
        "tenant_id": tenant_id,
        "active": True,
        "valid_from": {"$lte": today},
        "valid_until": {"$gte": today}
    }, {"_id": 0}).to_list(100)
    
    # Filter offers based on centralized settings
    applicable_offers = []
    for offer in offers:
        # Check channel
        offer_apply_on = offer.get("apply_on", ["pos", "online", "invoice"])
        if apply_on not in offer_apply_on:
            continue
        
        # Check auto_apply
        if not offer.get("auto_apply", True):
            continue
        
        # Check store applicability
        is_global = offer.get("is_global", True)
        applicable_stores = offer.get("applicable_store_ids", [])
        excluded_stores = offer.get("excluded_store_ids", [])
        
        if store_id:
            if store_id in excluded_stores:
                continue
            if not is_global and applicable_stores and store_id not in applicable_stores:
                continue
        
        applicable_offers.append(offer)
    
    if not applicable_offers:
        return {"free_items": [], "discount_amount": 0, "auto_applied": True}
    
    free_items = []
    total_discount = 0
    
    for offer in applicable_offers:
        buy_qty = offer.get("buy_quantity", 1)
        get_qty = offer.get("get_quantity", 1)
        get_discount = offer.get("get_discount_percent", 100) / 100
        
        # Check if cart has qualifying items
        qualifying_qty = 0
        qualifying_item = None
        
        # Determine if this is a GLOBAL BOGO (applies to all items)
        # BOGO is global ONLY if buy_item_ids AND buy_category_ids are both None (not set)
        # Empty arrays [] mean "specific items were supposed to be selected but none were" = doesn't apply
        buy_item_ids = offer.get("buy_item_ids")
        buy_category_ids = offer.get("buy_category_ids")
        
        is_global_bogo = (buy_item_ids is None and buy_category_ids is None)
        
        for item in cart_items:
            is_qualifying = False
            
            if is_global_bogo:
                # Global BOGO applies to all items
                is_qualifying = True
            elif buy_item_ids and len(buy_item_ids) > 0 and item.get("item_id") in buy_item_ids:
                # Item-specific BOGO - cart item is in the buy list
                is_qualifying = True
            elif buy_category_ids and len(buy_category_ids) > 0 and item.get("category_id") in buy_category_ids:
                # Category-specific BOGO - cart item's category is in the buy list
                is_qualifying = True
            # If buy_item_ids or buy_category_ids are empty arrays [], item doesn't qualify
            
            if is_qualifying:
                qualifying_qty += item.get("quantity", 0)
                qualifying_item = item
        
        # Calculate free items
        if qualifying_qty >= buy_qty and qualifying_item:
            sets_qualified = qualifying_qty // buy_qty
            free_count = sets_qualified * get_qty
            
            # Determine what item is free
            get_item_ids = offer.get("get_item_ids")
            if get_item_ids and len(get_item_ids) > 0:
                free_item_id = get_item_ids[0]
            else:
                free_item_id = qualifying_item.get("item_id")
            
            free_item_price = qualifying_item.get("price", 0)
            discount = free_item_price * free_count * get_discount
            
            free_items.append({
                "offer_id": offer.get("id"),
                "offer_name": offer.get("name"),
                "item_id": free_item_id,
                "free_quantity": free_count,
                "discount_percent": offer.get("get_discount_percent"),
                "discount_amount": discount,
                "is_global": is_global_bogo,
                "auto_applied": offer.get("auto_apply", True)
            })
            total_discount += discount
    
    return {"free_items": free_items, "discount_amount": total_discount, "auto_applied": True}

