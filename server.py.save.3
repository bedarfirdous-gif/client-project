@api_router.post("/users/bulk-assign-role")
async def bulk_assign_role(request: dict, user: dict = Depends(get_current_user)):
    """Bulk assign role to multiple users (admin only)"""
    # Allow both superadmin and regular admin
    if user.get("role") != "admin" and not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Admin only")
    
    tenant_id = get_tenant_id(user)
    user_ids = request.get("user_ids", [])
    assigned_role_id = request.get("assigned_role_id")
    permissions = request.get("permissions", {})
    
    if not user_ids:
        raise HTTPException(status_code=400, detail="No users selected")
    
    # Update all selected users
    update_data = {
        "permissions": permissions,
        "assigned_role_id": assigned_role_id,
        "updated_at": datetime.now(timezone.utc).isoformat(),
        "updated_by": user.get("id")
    }
    
    result = await db.users.update_many(
        {"id": {"$in": user_ids}, "role": {"$ne": "admin"}},  # Don't update admins
        {"$set": update_data}
    )
    
    # Create audit trail entry for bulk action
    await db.audit_trail.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "action": "bulk_role_assignment",
        "entity_type": "users",
        "entity_id": None,
        "entity_name": f"{len(user_ids)} users",
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "details": {
            "user_ids": user_ids,
            "assigned_role_id": assigned_role_id,
            "users_updated": result.modified_count
        },
        "created_at": datetime.now(timezone.utc).isoformat()
    })
    
    return {
        "message": f"Role assigned to {result.modified_count} users",
        "updated_count": result.modified_count
    }

