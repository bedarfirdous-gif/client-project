# Stock movement types for audit trail
STOCK_MOVEMENT_TYPES = [
    "sale",              # Stock decreased due to sale
    "purchase",          # Stock increased due to purchase
    "transfer_out",      # Stock decreased due to transfer to another store
    "transfer_in",       # Stock increased due to transfer from another store
    "return_in",         # Stock increased due to customer return
    "return_out",        # Stock decreased due to return to supplier
    "adjustment_add",    # Manual stock adjustment (increase)
    "adjustment_remove", # Manual stock adjustment (decrease)
    "initial_stock",     # Initial stock entry
    "damaged",           # Stock removed due to damage
    "expired"            # Stock removed due to expiry
]

# Helper function to log stock movements
async def log_stock_movement(
    tenant_id: str,
    item_id: str,
    variant_id: str,
    store_id: str,
    movement_type: str,
    quantity_change: int,  # positive for increase, negative for decrease
    quantity_before: int,
    quantity_after: int,
    user_id: str,
    user_name: str,
    reference_type: str = None,  # "sale", "purchase", "transfer", etc.
    reference_id: str = None,    # ID of the related document
    notes: str = None,
    item_name: str = None,
    store_name: str = None
):
    """Log a stock movement to the audit trail"""
    movement_log = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "item_id": item_id,
