@api_router.get("/accounting/summary")
async def get_accounting_summary(
    start_date: str = None,
    end_date: str = None,
    user: dict = Depends(get_current_user)
):
    """Get overall accounting summary"""
    tenant_id = get_tenant_id(user)
    
    # Get debtors total
    debtors_total = await db.debtor_ledger.aggregate([
        {"$match": {"tenant_id": tenant_id}},
        {"$group": {"_id": None, "total": {"$sum": "$current_balance"}}}
    ]).to_list(1)
    
    # Get creditors total
    creditors_total = await db.creditor_ledger.aggregate([
        {"$match": {"tenant_id": tenant_id}},
        {"$group": {"_id": None, "total": {"$sum": "$current_balance"}}}
    ]).to_list(1)
    
    # Build date query
    date_query = {"tenant_id": tenant_id}
    if start_date and end_date:
        date_query["date"] = {"$gte": start_date, "$lte": end_date}
    
    # Get sales total
    sales_total = await db.central_ledger.aggregate([
        {"$match": {**date_query, "entry_type": "sale"}},
        {"$group": {"_id": None, "total": {"$sum": "$amount"}}}
    ]).to_list(1)
    
    # Get purchases total
    purchases_total = await db.central_ledger.aggregate([
        {"$match": {**date_query, "entry_type": "purchase"}},
        {"$group": {"_id": None, "total": {"$sum": "$amount"}}}
    ]).to_list(1)
    
    # Get receipts total
    receipts_total = await db.central_ledger.aggregate([
        {"$match": {**date_query, "entry_type": "receipt"}},
        {"$group": {"_id": None, "total": {"$sum": "$amount"}}}
    ]).to_list(1)
    
    # Get payments total
    payments_total = await db.central_ledger.aggregate([
        {"$match": {**date_query, "entry_type": "payment"}},
        {"$group": {"_id": None, "total": {"$sum": "$amount"}}}
    ]).to_list(1)
    
    return {
        "total_receivable": debtors_total[0]["total"] if debtors_total else 0,
        "total_payable": creditors_total[0]["total"] if creditors_total else 0,
        "total_sales": sales_total[0]["total"] if sales_total else 0,
        "total_purchases": purchases_total[0]["total"] if purchases_total else 0,
        "total_receipts": receipts_total[0]["total"] if receipts_total else 0,
        "total_payments": payments_total[0]["total"] if payments_total else 0,
        "net_receivable": (debtors_total[0]["total"] if debtors_total else 0) - (creditors_total[0]["total"] if creditors_total else 0),
        "cash_flow": (receipts_total[0]["total"] if receipts_total else 0) - (payments_total[0]["total"] if payments_total else 0)
    }

# ============== CASH LEDGER ==============
@api_router.get("/accounting/cash-ledger")
async def get_cash_ledger(
    start_date: str = None,
    end_date: str = None,
    user: dict = Depends(get_current_user)
):
    """Get cash ledger - all cash transactions with running balance"""
    tenant_id = get_tenant_id(user)
    
    # Get opening balance from settings
    settings = await db.accounting_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
    opening_cash = settings.get("opening_cash_balance", 0) if settings else 0
    
    # Build date query for cash transactions
    query = {"tenant_id": tenant_id, "payment_mode": "cash"}
    if start_date:
        query["date"] = {"$gte": start_date}
    if end_date:
        query["date"] = {**query.get("date", {}), "$lte": end_date}
    
    # Get all cash transactions from central ledger
    entries = await db.central_ledger.find(query, {"_id": 0}).sort("date", 1).to_list(None)
    
    # Calculate running balance
    running_balance = opening_cash
    entries_with_balance = []
    total_receipts = 0
    total_payments = 0
    
    for entry in entries:
        if entry.get("entry_type") in ["receipt", "sale"]:
            running_balance += entry.get("amount", 0)
            total_receipts += entry.get("amount", 0)
            entries_with_balance.append({
                **entry,
                "debit": entry.get("amount", 0),
                "credit": 0,
                "balance": running_balance
            })
        elif entry.get("entry_type") in ["payment", "purchase"]:
            running_balance -= entry.get("amount", 0)
            total_payments += entry.get("amount", 0)
            entries_with_balance.append({
                **entry,
                "debit": 0,
                "credit": entry.get("amount", 0),
                "balance": running_balance
            })
    
    return {
        "entries": entries_with_balance,
        "summary": {
            "opening_balance": opening_cash,
            "total_receipts": total_receipts,
            "total_payments": total_payments,
            "closing_balance": running_balance,
            "total_entries": len(entries_with_balance)
        }
    }

