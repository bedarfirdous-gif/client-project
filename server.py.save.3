from starlette.responses import JSONResponse
import barcode
from barcode.writer import ImageWriter
from io import BytesIO
import base64

# ============== BARCODE GENERATION ==============

def generate_barcode_image(code: str, barcode_type: str = "code128") -> str:
    """
    Generate a barcode image and return as base64 encoded string.
    
    Args:
        code: The code to encode in the barcode
        barcode_type: Type of barcode (code128, code39, ean13, etc.)
    
    Returns:
        Base64 encoded PNG image string
    """
    try:
        # Get the barcode class
        barcode_class = barcode.get_barcode_class(barcode_type)
        
        # Create barcode with custom options
        writer = ImageWriter()
        writer.set_options({
            'module_width': 0.3,
            'module_height': 10,
            'font_size': 8,
            'text_distance': 2,
            'quiet_zone': 2
        })
        
        # Generate barcode
        bc = barcode_class(code, writer=writer)
        
        # Write to bytes buffer
        buffer = BytesIO()
        bc.write(buffer)
        buffer.seek(0)
        
        # Encode as base64
        img_base64 = base64.b64encode(buffer.getvalue()).decode('utf-8')
        return f"data:image/png;base64,{img_base64}"
    except Exception as e:
        logger.error(f"Failed to generate barcode: {e}")
        return ""

# ============== CENTRALIZED ACCOUNTING ENGINE ==============
"""
Double-Entry Accounting System:
- Sales → Debtor Ledger → Central Ledger (Debit: Debtors, Credit: Sales)
- Purchase → Creditor Ledger → Central Ledger (Debit: Purchases, Credit: Creditors)
- Receipt → Adjust Debtor → Central Ledger (Debit: Cash/Bank, Credit: Debtors)
- Payment → Adjust Creditor → Central Ledger (Debit: Creditors, Credit: Cash/Bank)
"""

class LedgerEntryType:
    SALE = "sale"
    PURCHASE = "purchase"
    RECEIPT = "receipt"
    PAYMENT = "payment"
    SALE_RETURN = "sale_return"
    PURCHASE_RETURN = "purchase_return"
    OPENING_BALANCE = "opening_balance"
    ADJUSTMENT = "adjustment"

class AccountType:
    DEBTOR = "debtor"      # Customers owe us (Asset)
    CREDITOR = "creditor"  # We owe suppliers (Liability)
    CASH = "cash"          # Cash account (Asset)
    BANK = "bank"          # Bank account (Asset)
    SALES = "sales"        # Sales revenue (Income)
    PURCHASES = "purchases" # Purchase expense (Expense)

async def create_central_ledger_entry(
    tenant_id: str,
    entry_type: str,
    reference_id: str,
    reference_number: str,
    party_id: str,
    party_name: str,
    party_type: str,  # 'customer' or 'supplier'
    debit_account: str,
    credit_account: str,
    amount: float,
    description: str,
    date: str,
    store_id: str = None,
    metadata: dict = None
):
    """
    Create a double-entry ledger record in the central ledger.
    Every transaction has a debit and credit entry.
    Also posts transactions to Tally-style ledger management system.
    """
    entry_id = str(uuid.uuid4())
    now = datetime.now(timezone.utc).isoformat()
    
    ledger_entry = {
        "id": entry_id,
        "tenant_id": tenant_id,
        "entry_type": entry_type,
        "reference_id": reference_id,
        "reference_number": reference_number,
        "party_id": party_id,
        "party_name": party_name,
        "party_type": party_type,
        "debit_account": debit_account,
        "credit_account": credit_account,
        "amount": amount,
        "description": description,
        "date": date,
        "store_id": store_id,
        "metadata": metadata or {},
        "created_at": now,
        "is_reversed": False
    }
    
    await db.central_ledger.insert_one(ledger_entry)
    ledger_entry.pop("_id", None)
    
    # ============== TALLY-STYLE LEDGER INTEGRATION ==============
    # Post transactions to the Tally-style ledger management system
    await post_to_tally_ledger(
        tenant_id=tenant_id,
        party_id=party_id,
        party_name=party_name,
        party_type=party_type,
        entry_type=entry_type,
        debit_account=debit_account,
        credit_account=credit_account,
        amount=amount,
        reference_id=reference_id,
        reference_number=reference_number,
        description=description,
        date=date
    )
    # ============== END TALLY INTEGRATION ==============
    
    logger.info(f"Central Ledger Entry: {entry_type} | {debit_account} -> {credit_account} | Amount: {amount}")
    
    return ledger_entry

async def post_to_tally_ledger(
    tenant_id: str,
    party_id: str,
    party_name: str,
    party_type: str,
    entry_type: str,
    debit_account: str,
    credit_account: str,
    amount: float,
    reference_id: str,
    reference_number: str,
    description: str,
    date: str
):
    """
    Post transactions to Tally-style ledger management system.
    Creates transactions in the appropriate ledgers (party ledger + contra account).
    """
    now = datetime.now(timezone.utc).isoformat()
    
    # Find the party's linked ledger
    party_ledger = None
    group_id = "sundry_creditors" if party_type == "supplier" else "sundry_debtors"
    
    if party_type == "supplier":
        supplier = await db.suppliers.find_one({"id": party_id, "tenant_id": tenant_id}, {"_id": 0, "ledger_id": 1})
        if supplier and supplier.get("ledger_id"):
            party_ledger = await db.ledgers.find_one({"id": supplier["ledger_id"], "tenant_id": tenant_id}, {"_id": 0})
    elif party_type == "customer":
        customer = await db.customers.find_one({"id": party_id, "tenant_id": tenant_id}, {"_id": 0, "ledger_id": 1})
        if customer and customer.get("ledger_id"):
            party_ledger = await db.ledgers.find_one({"id": customer["ledger_id"], "tenant_id": tenant_id}, {"_id": 0})
    
    # FALLBACK 1: Check if party_id is actually a ledger ID directly
    if not party_ledger:
        party_ledger = await db.ledgers.find_one({
            "id": party_id,
            "tenant_id": tenant_id,
            "group_id": group_id,
            "is_deleted": {"$ne": True}
        }, {"_id": 0})
        if party_ledger:
            logger.info(f"Found ledger directly by party_id: {party_ledger['name']}")
    
    # FALLBACK 2: Try to find by name
    if not party_ledger:
        party_ledger = await db.ledgers.find_one({
            "tenant_id": tenant_id,
            "name": {"$regex": f"^{party_name}$", "$options": "i"},
            "group_id": group_id,
            "is_deleted": {"$ne": True}
        }, {"_id": 0})
    
    if not party_ledger:
        logger.warning(f"No linked ledger found for {party_type}: {party_name}")
        return
    
    # Find the contra account ledger (Purchase A/c, Sales A/c, Cash, Bank)
    contra_ledger = await find_or_create_contra_ledger(tenant_id, debit_account if party_type == "supplier" else credit_account)
    
    # Determine debit/credit based on entry type
    if entry_type == LedgerEntryType.PURCHASE:
        # Purchase: Debit Purchase A/c, Credit Supplier
        party_transaction = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "ledger_id": party_ledger["id"],
            "date": date,
            "particulars": f"Purchase Invoice: {reference_number}",
            "voucher_type": "Purchase",
            "voucher_number": reference_number,
            "reference_id": reference_id,
            "debit": 0,
            "credit": amount,
            "created_at": now
        }
        if contra_ledger:
            contra_transaction = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "ledger_id": contra_ledger["id"],
                "date": date,
                "particulars": f"To {party_name} ({reference_number})",
                "voucher_type": "Purchase",
                "voucher_number": reference_number,
                "reference_id": reference_id,
                "debit": amount,
                "credit": 0,
                "created_at": now
            }
            await db.ledger_transactions.insert_one(contra_transaction)
    
    elif entry_type == LedgerEntryType.PAYMENT:
        # Payment to supplier: Debit Supplier, Credit Cash/Bank
        party_transaction = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "ledger_id": party_ledger["id"],
            "date": date,
            "particulars": f"Payment: {reference_number}",
            "voucher_type": "Payment",
            "voucher_number": reference_number,
            "reference_id": reference_id,
            "debit": amount,
            "credit": 0,
            "created_at": now
        }
        if contra_ledger:
            contra_transaction = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "ledger_id": contra_ledger["id"],
                "date": date,
                "particulars": f"By {party_name} ({reference_number})",
                "voucher_type": "Payment",
                "voucher_number": reference_number,
                "reference_id": reference_id,
                "debit": 0,
                "credit": amount,
                "created_at": now
            }
            await db.ledger_transactions.insert_one(contra_transaction)
    
    elif entry_type == LedgerEntryType.SALE:
        # Sale: Debit Customer, Credit Sales A/c
        party_transaction = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "ledger_id": party_ledger["id"],
            "date": date,
            "particulars": f"Sales Invoice: {reference_number}",
            "voucher_type": "Sales",
            "voucher_number": reference_number,
            "reference_id": reference_id,
            "debit": amount,
            "credit": 0,
            "created_at": now
        }
        if contra_ledger:
            contra_transaction = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "ledger_id": contra_ledger["id"],
                "date": date,
                "particulars": f"By {party_name} ({reference_number})",
                "voucher_type": "Sales",
                "voucher_number": reference_number,
                "reference_id": reference_id,
                "debit": 0,
                "credit": amount,
                "created_at": now
            }
            await db.ledger_transactions.insert_one(contra_transaction)
    
    elif entry_type == LedgerEntryType.RECEIPT:
        # Receipt from customer: Debit Cash/Bank, Credit Customer
        party_transaction = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "ledger_id": party_ledger["id"],
            "date": date,
            "particulars": f"Receipt: {reference_number}",
            "voucher_type": "Receipt",
            "voucher_number": reference_number,
            "reference_id": reference_id,
            "debit": 0,
            "credit": amount,
            "created_at": now
        }
        if contra_ledger:
            contra_transaction = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "ledger_id": contra_ledger["id"],
                "date": date,
                "particulars": f"To {party_name} ({reference_number})",
                "voucher_type": "Receipt",
                "voucher_number": reference_number,
                "reference_id": reference_id,
                "debit": amount,
                "credit": 0,
                "created_at": now
            }
            await db.ledger_transactions.insert_one(contra_transaction)
    else:
        return
    
    await db.ledger_transactions.insert_one(party_transaction)
    logger.info(f"Posted to Tally ledger: {party_ledger['name']} | {entry_type} | Amount: {amount}")

async def find_or_create_contra_ledger(tenant_id: str, account_type: str):
    """
    Find or create the contra account ledger (Purchase A/c, Sales A/c, Cash, Bank).
    """
    now = datetime.now(timezone.utc).isoformat()
    
    # Map account types to ledger names and groups
    ledger_map = {
        AccountType.PURCHASES: {"name": "Purchase Account", "group_id": "direct_expenses", "type": "expense", "nature": "debit"},
        AccountType.SALES: {"name": "Sales Account", "group_id": "direct_income", "type": "income", "nature": "credit"},
        AccountType.CASH: {"name": "Cash Account", "group_id": "cash_in_hand", "type": "asset", "nature": "debit"},
        AccountType.BANK: {"name": "Bank Account", "group_id": "bank_accounts", "type": "asset", "nature": "debit"},
    }
    
    ledger_info = ledger_map.get(account_type)
    if not ledger_info:
        return None
    
    # Try to find existing ledger
    ledger = await db.ledgers.find_one({
        "tenant_id": tenant_id,
        "name": ledger_info["name"],
        "is_deleted": {"$ne": True}
    }, {"_id": 0})
    
    if ledger:
        return ledger
    
    # Create the ledger if it doesn't exist
    ledger_id = str(uuid.uuid4())
    new_ledger = {
        "id": ledger_id,
        "tenant_id": tenant_id,
        "name": ledger_info["name"],
        "group_id": ledger_info["group_id"],
        "ledger_type": ledger_info["type"],
        "ledger_nature": ledger_info["nature"],
        "opening_balance": 0,
        "opening_balance_type": "Dr" if ledger_info["nature"] == "debit" else "Cr",
        "is_active": True,
        "is_system_ledger": True,
        "created_at": now,
        "updated_at": now,
        "is_deleted": False
    }
    
    await db.ledgers.insert_one(new_ledger)
    logger.info(f"Created system ledger: {ledger_info['name']}")
    
    return new_ledger

async def update_debtor_balance(tenant_id: str, customer_id: str, customer_name: str, amount: float, entry_type: str, reference_id: str, reference_number: str, date: str, store_id: str = None):
    """
    Update customer's debtor balance.
    - Sale: Increases balance (customer owes more)
    - Receipt: Decreases balance (customer paid)
    - Sale Return: Decreases balance (we owe customer)
    """
    now = datetime.now(timezone.utc).isoformat()
    
    # Get or create debtor record
    debtor = await db.debtor_ledger.find_one({
        "tenant_id": tenant_id,
        "customer_id": customer_id
    })
    
    if not debtor:
        debtor = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "customer_id": customer_id,
            "customer_name": customer_name,
            "opening_balance": 0,
            "current_balance": 0,
            "total_sales": 0,
            "total_receipts": 0,
            "total_returns": 0,
            "last_transaction_date": date,
            "created_at": now
        }
        await db.debtor_ledger.insert_one(debtor)
    
    # Calculate new balance based on entry type
    current_balance = debtor.get("current_balance", 0)
    
    if entry_type == LedgerEntryType.SALE:
        new_balance = current_balance + amount
        update_fields = {
            "current_balance": new_balance,
            "total_sales": debtor.get("total_sales", 0) + amount,
            "last_transaction_date": date,
            "updated_at": now
        }
    elif entry_type == LedgerEntryType.RECEIPT:
        new_balance = current_balance - amount
        update_fields = {
            "current_balance": new_balance,
            "total_receipts": debtor.get("total_receipts", 0) + amount,
            "last_transaction_date": date,
            "updated_at": now
        }
    elif entry_type == LedgerEntryType.SALE_RETURN:
        new_balance = current_balance - amount
        update_fields = {
            "current_balance": new_balance,
            "total_returns": debtor.get("total_returns", 0) + amount,
            "last_transaction_date": date,
            "updated_at": now
        }
    else:
        new_balance = current_balance
        update_fields = {"updated_at": now}
    
    await db.debtor_ledger.update_one(
        {"tenant_id": tenant_id, "customer_id": customer_id},
        {"$set": update_fields}
    )
    
    # Create debtor transaction record
    transaction = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "customer_id": customer_id,
        "customer_name": customer_name,
        "entry_type": entry_type,
        "reference_id": reference_id,
        "reference_number": reference_number,
        "debit": amount if entry_type == LedgerEntryType.SALE else 0,
        "credit": amount if entry_type in [LedgerEntryType.RECEIPT, LedgerEntryType.SALE_RETURN] else 0,
        "balance": new_balance,
        "date": date,
        "store_id": store_id,
        "created_at": now
    }
    await db.debtor_transactions.insert_one(transaction)
    
    logger.info(f"Debtor Balance Updated: {customer_name} | Type: {entry_type} | Amount: {amount} | Balance: {new_balance}")
    
    return new_balance

async def update_creditor_balance(tenant_id: str, supplier_id: str, supplier_name: str, amount: float, entry_type: str, reference_id: str, reference_number: str, date: str, store_id: str = None):
    """
    Update supplier's creditor balance.
    - Purchase: Increases balance (we owe more)
    - Payment: Decreases balance (we paid)
    - Purchase Return: Decreases balance (supplier owes us)
    """
    now = datetime.now(timezone.utc).isoformat()
    
    # Get or create creditor record
    creditor = await db.creditor_ledger.find_one({
        "tenant_id": tenant_id,
        "supplier_id": supplier_id
    })
    
    if not creditor:
        creditor = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "supplier_id": supplier_id,
            "supplier_name": supplier_name,
            "opening_balance": 0,
            "current_balance": 0,
            "total_purchases": 0,
            "total_payments": 0,
            "total_returns": 0,
            "last_transaction_date": date,
            "created_at": now
        }
        await db.creditor_ledger.insert_one(creditor)
    
    # Calculate new balance based on entry type
    current_balance = creditor.get("current_balance", 0)
    
    if entry_type == LedgerEntryType.PURCHASE:
        new_balance = current_balance + amount
        update_fields = {
            "current_balance": new_balance,
            "total_purchases": creditor.get("total_purchases", 0) + amount,
            "last_transaction_date": date,
            "updated_at": now
        }
    elif entry_type == LedgerEntryType.PAYMENT:
        new_balance = current_balance - amount
        update_fields = {
            "current_balance": new_balance,
            "total_payments": creditor.get("total_payments", 0) + amount,
            "last_transaction_date": date,
            "updated_at": now
        }
    elif entry_type == LedgerEntryType.PURCHASE_RETURN:
        new_balance = current_balance - amount
        update_fields = {
            "current_balance": new_balance,
            "total_returns": creditor.get("total_returns", 0) + amount,
            "last_transaction_date": date,
            "updated_at": now
        }
    else:
        new_balance = current_balance
        update_fields = {"updated_at": now}
    
    await db.creditor_ledger.update_one(
        {"tenant_id": tenant_id, "supplier_id": supplier_id},
        {"$set": update_fields}
    )
    
    # Create creditor transaction record
    transaction = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "supplier_id": supplier_id,
        "supplier_name": supplier_name,
        "entry_type": entry_type,
        "reference_id": reference_id,
        "reference_number": reference_number,
        "debit": amount if entry_type in [LedgerEntryType.PAYMENT, LedgerEntryType.PURCHASE_RETURN] else 0,
        "credit": amount if entry_type == LedgerEntryType.PURCHASE else 0,
        "balance": new_balance,
        "date": date,
        "store_id": store_id,
        "created_at": now
    }
    await db.creditor_transactions.insert_one(transaction)
    
    logger.info(f"Creditor Balance Updated: {supplier_name} | Type: {entry_type} | Amount: {amount} | Balance: {new_balance}")
    
    return new_balance

async def process_sale_accounting(tenant_id: str, invoice_id: str, invoice_number: str, customer_id: str, customer_name: str, total_amount: float, date: str, store_id: str = None):
    """
    Process accounting entries for a sale:
    1. Debit: Debtors (customer owes us)
    2. Credit: Sales (revenue earned)
    3. Update Debtor Balance
    """
    # Create Central Ledger Entry
    await create_central_ledger_entry(
        tenant_id=tenant_id,
        entry_type=LedgerEntryType.SALE,
        reference_id=invoice_id,
        reference_number=invoice_number,
        party_id=customer_id,
        party_name=customer_name,
        party_type="customer",
        debit_account=AccountType.DEBTOR,
        credit_account=AccountType.SALES,
        amount=total_amount,
        description=f"Sale Invoice {invoice_number} to {customer_name}",
        date=date,
        store_id=store_id
    )
    
    # Update Debtor Balance
    await update_debtor_balance(
        tenant_id=tenant_id,
        customer_id=customer_id,
        customer_name=customer_name,
        amount=total_amount,
        entry_type=LedgerEntryType.SALE,
        reference_id=invoice_id,
        reference_number=invoice_number,
        date=date,
        store_id=store_id
    )
    
    logger.info(f"Sale Accounting Processed: {invoice_number} | Customer: {customer_name} | Amount: {total_amount}")

async def process_purchase_accounting(tenant_id: str, invoice_id: str, invoice_number: str, supplier_id: str, supplier_name: str, total_amount: float, date: str, store_id: str = None):
    """
    Process accounting entries for a purchase:
    1. Debit: Purchases (expense incurred)
    2. Credit: Creditors (we owe supplier)
    3. Update Creditor Balance
    """
    # Create Central Ledger Entry
    await create_central_ledger_entry(
        tenant_id=tenant_id,
        entry_type=LedgerEntryType.PURCHASE,
        reference_id=invoice_id,
        reference_number=invoice_number,
        party_id=supplier_id,
        party_name=supplier_name,
        party_type="supplier",
        debit_account=AccountType.PURCHASES,
        credit_account=AccountType.CREDITOR,
        amount=total_amount,
        description=f"Purchase Invoice {invoice_number} from {supplier_name}",
        date=date,
        store_id=store_id
    )
    
    # Update Creditor Balance
    await update_creditor_balance(
        tenant_id=tenant_id,
        supplier_id=supplier_id,
        supplier_name=supplier_name,
        amount=total_amount,
        entry_type=LedgerEntryType.PURCHASE,
        reference_id=invoice_id,
        reference_number=invoice_number,
        date=date,
        store_id=store_id
    )
    
    logger.info(f"Purchase Accounting Processed: {invoice_number} | Supplier: {supplier_name} | Amount: {total_amount}")

async def process_receipt_accounting(tenant_id: str, receipt_id: str, receipt_number: str, customer_id: str, customer_name: str, amount: float, payment_mode: str, date: str, store_id: str = None, invoice_id: str = None):
    """
    Process accounting entries for a receipt (money received from customer):
    1. Debit: Cash/Bank (asset increases)
    2. Credit: Debtors (customer owes less)
    3. Update Debtor Balance
    """
    credit_account = AccountType.BANK if payment_mode in ['bank', 'upi', 'card', 'cheque'] else AccountType.CASH
    
    # Create Central Ledger Entry
    await create_central_ledger_entry(
        tenant_id=tenant_id,
        entry_type=LedgerEntryType.RECEIPT,
        reference_id=receipt_id,
        reference_number=receipt_number,
        party_id=customer_id,
        party_name=customer_name,
        party_type="customer",
        debit_account=credit_account,
        credit_account=AccountType.DEBTOR,
        amount=amount,
        description=f"Receipt {receipt_number} from {customer_name}",
        date=date,
        store_id=store_id,
        metadata={"payment_mode": payment_mode, "invoice_id": invoice_id}
    )
    
    # Update Debtor Balance
    await update_debtor_balance(
        tenant_id=tenant_id,
        customer_id=customer_id,
        customer_name=customer_name,
        amount=amount,
        entry_type=LedgerEntryType.RECEIPT,
        reference_id=receipt_id,
        reference_number=receipt_number,
        date=date,
        store_id=store_id
    )
    
    logger.info(f"Receipt Accounting Processed: {receipt_number} | Customer: {customer_name} | Amount: {amount}")

async def process_payment_accounting(tenant_id: str, payment_id: str, payment_number: str, supplier_id: str, supplier_name: str, amount: float, payment_mode: str, date: str, store_id: str = None, invoice_id: str = None):
    """
    Process accounting entries for a payment (money paid to supplier):
    1. Debit: Creditors (we owe less)
    2. Credit: Cash/Bank (asset decreases)
    3. Update Creditor Balance
    """
    credit_account = AccountType.BANK if payment_mode in ['bank', 'upi', 'card', 'cheque'] else AccountType.CASH
    
    # Create Central Ledger Entry
    await create_central_ledger_entry(
        tenant_id=tenant_id,
        entry_type=LedgerEntryType.PAYMENT,
        reference_id=payment_id,
        reference_number=payment_number,
        party_id=supplier_id,
        party_name=supplier_name,
        party_type="supplier",
        debit_account=AccountType.CREDITOR,
        credit_account=credit_account,
        amount=amount,
        description=f"Payment {payment_number} to {supplier_name}",
        date=date,
        store_id=store_id,
        metadata={"payment_mode": payment_mode, "invoice_id": invoice_id}
    )
    
    # Update Creditor Balance
    await update_creditor_balance(
        tenant_id=tenant_id,
        supplier_id=supplier_id,
        supplier_name=supplier_name,
        amount=amount,
        entry_type=LedgerEntryType.PAYMENT,
        reference_id=payment_id,
        reference_number=payment_number,
        date=date,
        store_id=store_id
    )
    
    logger.info(f"Payment Accounting Processed: {payment_number} | Supplier: {supplier_name} | Amount: {amount}")


