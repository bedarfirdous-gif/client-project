from reportlab.lib.pagesizes import landscape

async def get_tenant_info(tenant_id: str):
    """Get tenant/company info for PDF headers"""
    tenant = await db.tenants.find_one({"id": tenant_id}, {"_id": 0})
    if tenant:
        return {
            "name": tenant.get("business_name", tenant.get("name", "Company")),
            "address": tenant.get("address", ""),
            "phone": tenant.get("phone", ""),
            "email": tenant.get("email", ""),
            "gstin": tenant.get("gstin", "")
        }
    return {"name": "Company", "address": "", "phone": "", "email": "", "gstin": ""}

def create_ledger_pdf(title: str, columns: list, data: list, summary: dict, company_info: dict):
    """Generate PDF for ledger export"""
    buffer = BytesIO()
    doc = SimpleDocTemplate(buffer, pagesize=landscape(A4), topMargin=30, bottomMargin=30)
    elements = []
    styles = getSampleStyleSheet()
    
    # Company Header
    title_style = ParagraphStyle('Title', parent=styles['Heading1'], fontSize=16, alignment=1)
    subtitle_style = ParagraphStyle('Subtitle', parent=styles['Normal'], fontSize=10, alignment=1, textColor=colors.grey)
    
    elements.append(Paragraph(company_info.get("name", "Company"), title_style))
    if company_info.get("address"):
        elements.append(Paragraph(company_info["address"], subtitle_style))
    if company_info.get("gstin"):
        elements.append(Paragraph(f"GSTIN: {company_info['gstin']}", subtitle_style))
    elements.append(Spacer(1, 10))
    
    # Report Title
    report_title = ParagraphStyle('ReportTitle', parent=styles['Heading2'], fontSize=14, alignment=1)
    elements.append(Paragraph(title, report_title))
    elements.append(Paragraph(f"Generated on: {datetime.now().strftime('%Y-%m-%d %H:%M')}", subtitle_style))
    elements.append(Spacer(1, 15))
    
    # Summary section
    if summary:
        summary_data = [[k.replace('_', ' ').title(), f"₹{v:,.2f}" if isinstance(v, (int, float)) else str(v)] for k, v in summary.items()]
        summary_table = Table(summary_data, colWidths=[150, 150])
        summary_table.setStyle(TableStyle([
            ('BACKGROUND', (0, 0), (-1, -1), colors.lightgrey),
            ('TEXTCOLOR', (0, 0), (-1, -1), colors.black),
            ('ALIGN', (0, 0), (-1, -1), 'LEFT'),
            ('FONTNAME', (0, 0), (-1, -1), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, -1), 9),
            ('BOTTOMPADDING', (0, 0), (-1, -1), 6),
            ('GRID', (0, 0), (-1, -1), 0.5, colors.grey),
        ]))
        elements.append(summary_table)
        elements.append(Spacer(1, 15))
    
    # Data Table
    if data:
        table_data = [columns] + data
        col_count = len(columns)
        col_widths = [700 / col_count] * col_count
        
        table = Table(table_data, colWidths=col_widths, repeatRows=1)
        table.setStyle(TableStyle([
            ('BACKGROUND', (0, 0), (-1, 0), colors.HexColor('#2563eb')),
            ('TEXTCOLOR', (0, 0), (-1, 0), colors.whitesmoke),
            ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
            ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, 0), 9),
            ('FONTSIZE', (0, 1), (-1, -1), 8),
            ('BOTTOMPADDING', (0, 0), (-1, 0), 8),
            ('BACKGROUND', (0, 1), (-1, -1), colors.white),
            ('GRID', (0, 0), (-1, -1), 0.5, colors.grey),
            ('ROWBACKGROUNDS', (0, 1), (-1, -1), [colors.white, colors.HexColor('#f3f4f6')]),
        ]))
        elements.append(table)
    else:
        elements.append(Paragraph("No data available", styles['Normal']))
    
    doc.build(elements)
    buffer.seek(0)
    return buffer

def create_ledger_excel(title: str, columns: list, data: list, summary: dict):
    """Generate Excel for ledger export"""
    buffer = BytesIO()
    
    # Create DataFrame
    df = pd.DataFrame(data, columns=columns) if data else pd.DataFrame(columns=columns)
    
    with pd.ExcelWriter(buffer, engine='xlsxwriter') as writer:
        # Write summary
        if summary:
            summary_df = pd.DataFrame(list(summary.items()), columns=['Metric', 'Value'])
            summary_df.to_excel(writer, sheet_name='Summary', index=False)
        
        # Write data
        df.to_excel(writer, sheet_name='Data', index=False)
        
        # Format
        workbook = writer.book
        header_format = workbook.add_format({'bold': True, 'bg_color': '#2563eb', 'font_color': 'white'})
        
        for sheet_name in writer.sheets:
            worksheet = writer.sheets[sheet_name]
            for col_num, col_name in enumerate(df.columns if sheet_name == 'Data' else ['Metric', 'Value']):
                worksheet.write(0, col_num, col_name, header_format)
                worksheet.set_column(col_num, col_num, 15)
    
    buffer.seek(0)
    return buffer

@api_router.get("/accounting/export/{ledger_type}/{format}")
