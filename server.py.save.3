@api_router.delete("/purchase-invoices/{invoice_id}")
async def delete_purchase_invoice(invoice_id: str, user: dict = Depends(get_current_user)):
    """Soft delete purchase invoice - moves to recycle bin. Admins have full delete access."""
    tenant_id = get_tenant_id(user)
    
    # Admins can delete any purchase invoice
    if not is_admin_or_higher(user):
        permissions = user.get("permissions", {})
        if not permissions.get("purchases", {}).get("delete", False):
            raise HTTPException(status_code=403, detail="Permission denied. Admin access required for delete.")
    
    # Find the purchase invoice first
    purchase = await db.purchase_invoices.find_one(
        {"id": invoice_id, "tenant_id": tenant_id},
        {"_id": 0}
    )
    
    if not purchase:
        raise HTTPException(status_code=404, detail="Purchase invoice not found")
    
    # Move to recycle bin
    deleted_item = {
        "id": str(uuid.uuid4()),
        "original_id": invoice_id,
        "item_type": "purchase",
        "item_data": purchase,
        "deleted_by": user.get("id"),
        "deleted_by_name": user.get("name"),
        "deleted_at": datetime.now(timezone.utc).isoformat(),
        "tenant_id": tenant_id,
        "auto_delete_at": (datetime.now(timezone.utc) + timedelta(days=30)).isoformat(),
        "is_permanently_deleted": False
    }
    
    await db.recycle_bin.insert_one(deleted_item)
    
    # Mark purchase as deleted (soft delete)
    await db.purchase_invoices.update_one(
        {"id": invoice_id, "tenant_id": tenant_id}, 
        {"$set": {
            "is_deleted": True,
            "deleted_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": "Purchase moved to Recycle Bin", "recycle_bin_id": deleted_item["id"]}

@api_router.post("/purchase-invoices/{invoice_id}/restore")
async def restore_purchase_invoice(invoice_id: str, user: dict = Depends(get_current_user)):
    """Restore a deleted purchase invoice"""
    tenant_id = get_tenant_id(user)
    
    # Find the deleted purchase invoice
    purchase = await db.purchase_invoices.find_one(
        {"id": invoice_id, "tenant_id": tenant_id, "is_deleted": True},
        {"_id": 0}
    )
    
    if not purchase:
        raise HTTPException(status_code=404, detail="Deleted purchase invoice not found")
    
    # Restore the invoice (remove is_deleted flag)
    await db.purchase_invoices.update_one(
        {"id": invoice_id, "tenant_id": tenant_id},
        {"$unset": {"is_deleted": "", "deleted_at": ""}}
    )
    
    # Remove from recycle bin
    await db.recycle_bin.delete_one({"original_id": invoice_id, "item_type": "purchase"})
    
    # Log the restoration
    logger.info(f"Purchase invoice {invoice_id} restored by user {user.get('name')}")
    
    return {"message": "Purchase invoice restored successfully", "invoice_id": invoice_id}

@api_router.delete("/purchase-invoices/{invoice_id}/permanent")
async def permanently_delete_purchase_invoice(invoice_id: str, user: dict = Depends(get_current_user)):
    """Permanently delete a purchase invoice (cannot be restored)"""
    tenant_id = get_tenant_id(user)
    
    # Find the deleted purchase invoice
    purchase = await db.purchase_invoices.find_one(
        {"id": invoice_id, "tenant_id": tenant_id, "is_deleted": True},
        {"_id": 0}
    )
    
    if not purchase:
        raise HTTPException(status_code=404, detail="Deleted purchase invoice not found")
    
    # Permanently delete from purchase_invoices
    await db.purchase_invoices.delete_one({"id": invoice_id, "tenant_id": tenant_id})
    
    # Update recycle bin to mark as permanently deleted
    await db.recycle_bin.update_one(
        {"original_id": invoice_id, "item_type": "purchase"},
        {"$set": {"is_permanently_deleted": True, "permanently_deleted_at": datetime.now(timezone.utc).isoformat()}}
    )
    
    return {"message": "Purchase invoice permanently deleted", "invoice_id": invoice_id}

