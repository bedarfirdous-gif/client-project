# Helper function to get plans (from database or defaults)
async def get_subscription_plans_data():
    """Get all subscription plans from database or use defaults"""
    plans = await db.subscription_plans.find({}, {"_id": 0}).to_list(None)
    if not plans:
        # Initialize with defaults
        for plan_id, plan_data in DEFAULT_SUBSCRIPTION_PLANS.items():
            await db.subscription_plans.update_one(
                {"id": plan_id},
                {"$set": {"id": plan_id, **plan_data}},
                upsert=True
            )
        plans = await db.subscription_plans.find({}, {"_id": 0}).to_list(None)
    return {p["id"]: p for p in plans}

