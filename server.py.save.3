@api_router.post("/superadmin/god-mode/impersonate")
async def god_mode_impersonate(
    target_user_id: str = Body(...),
    user: dict = Depends(require_superadmin)
):
    """Emergency: Impersonate any user (get their session token)"""
    
    target_user = await db.users.find_one({"id": target_user_id})
