@api_router.post("/real-autoheal/scan")
async def real_autoheal_scan(user: dict = Depends(require_permission("settings"))):
    """Trigger a manual scan for errors"""
    errors = await real_autoheal_agent.scan_logs()
    
    # Attempt to fix detected errors
    fixes_attempted = 0
    fixes_successful = 0
    
    for error in errors:
        fix = await real_autoheal_agent.analyze_and_fix(error)
        if fix:
            fixes_attempted += 1
            if fix.verified:
                fixes_successful += 1
    
    return {
        "errors_detected": len(errors),
        "fixes_attempted": fixes_attempted,
        "fixes_successful": fixes_successful,
        "errors": [
            {
                "error_id": e.error_id,
                "category": e.category.value,
                "severity": e.severity.value,
                "message": e.message[:200],
                "source": e.source
            }
            for e in errors[:10]
        ]
    }

