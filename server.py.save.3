@api_router.get("/gst-reports/gstr1")
async def get_gstr1_report(
    from_date: str = None,
    to_date: str = None,
    user: dict = Depends(get_current_user)
):
    """
    Generate GSTR-1 Report (Outward Supplies)
    Returns data in format suitable for GST portal filing
    """
    tenant_id = get_tenant_id(user)
    
    # Default to current month
    if not from_date:
        from_date = datetime.now().replace(day=1).strftime('%Y-%m-%d')
    if not to_date:
        to_date = datetime.now().strftime('%Y-%m-%d')
    
    # Query sales/invoices
    query = {
        "tenant_id": tenant_id,
        "created_at": {"$gte": from_date, "$lte": to_date + "T23:59:59"},
        "is_deleted": {"$ne": True}
    }
    
    # Get all sales
    sales = await db.sales.find(query, {"_id": 0}).to_list(10000)
    
    # Categorize invoices
    b2b_invoices = []  # Business to Business (GSTIN provided)
    b2c_large = []     # B2C > 2.5L (inter-state)
    b2c_small = []     # B2C < 2.5L
    cdnr = []          # Credit/Debit notes - Registered
    cdnur = []         # Credit/Debit notes - Unregistered
    exports = []       # Export invoices
    nil_rated = []     # Nil/Exempt rated
    hsn_summary = {}   # HSN-wise summary
    
    totals = {
        "total_invoices": 0,
        "total_taxable": 0,
        "total_cgst": 0,
        "total_sgst": 0,
        "total_igst": 0,
        "total_cess": 0,
        "total_invoice_value": 0
    }
    
    for sale in sales:
        totals["total_invoices"] += 1
        
        # Extract GST details
        items = sale.get("items", [])
        invoice_taxable = 0
        invoice_cgst = 0
        invoice_sgst = 0
        invoice_igst = 0
        invoice_cess = 0
        
        for item in items:
            taxable = float(item.get("price", 0)) * int(item.get("quantity", 1))
            gst_rate = float(item.get("gst_rate", 18))
            hsn = item.get("hsn_code", "")
            
            # Determine if IGST or CGST+SGST based on customer state
            customer_gstin = sale.get("customer_gstin", "")
            is_inter_state = len(customer_gstin) >= 2 and customer_gstin[:2] != "29"  # Assuming state code 29
            
            if is_inter_state:
                igst = taxable * gst_rate / 100
                invoice_igst += igst
            else:
                cgst = taxable * (gst_rate / 2) / 100
                sgst = taxable * (gst_rate / 2) / 100
                invoice_cgst += cgst
                invoice_sgst += sgst
            
            invoice_taxable += taxable
            
            # HSN Summary
            if hsn:
                if hsn not in hsn_summary:
                    hsn_summary[hsn] = {
                        "hsn_code": hsn,
                        "description": item.get("name", ""),
                        "uqc": "NOS",
                        "total_quantity": 0,
                        "total_value": 0,
                        "taxable_value": 0,
                        "igst": 0,
                        "cgst": 0,
                        "sgst": 0,
                        "cess": 0
                    }
                hsn_summary[hsn]["total_quantity"] += int(item.get("quantity", 1))
                hsn_summary[hsn]["total_value"] += taxable + (invoice_igst if is_inter_state else invoice_cgst + invoice_sgst)
                hsn_summary[hsn]["taxable_value"] += taxable
                if is_inter_state:
                    hsn_summary[hsn]["igst"] += taxable * gst_rate / 100
                else:
                    hsn_summary[hsn]["cgst"] += taxable * (gst_rate / 2) / 100
                    hsn_summary[hsn]["sgst"] += taxable * (gst_rate / 2) / 100
        
        invoice_value = invoice_taxable + invoice_cgst + invoice_sgst + invoice_igst + invoice_cess
        
        totals["total_taxable"] += invoice_taxable
        totals["total_cgst"] += invoice_cgst
        totals["total_sgst"] += invoice_sgst
        totals["total_igst"] += invoice_igst
        totals["total_cess"] += invoice_cess
        totals["total_invoice_value"] += invoice_value
        
        invoice_data = {
            "invoice_no": sale.get("sale_id", sale.get("id", "")),
            "invoice_date": sale.get("created_at", "")[:10],
            "invoice_value": round(invoice_value, 2),
            "place_of_supply": sale.get("customer_state", ""),
            "reverse_charge": "N",
            "invoice_type": "Regular",
            "taxable_value": round(invoice_taxable, 2),
            "cgst": round(invoice_cgst, 2),
            "sgst": round(invoice_sgst, 2),
            "igst": round(invoice_igst, 2),
            "cess": round(invoice_cess, 2),
            "rate": 18  # Default rate
        }
        
        customer_gstin = sale.get("customer_gstin", "")
        
        if customer_gstin and len(customer_gstin) == 15:
            # B2B Invoice
            invoice_data["gstin"] = customer_gstin
            invoice_data["customer_name"] = sale.get("customer_name", "")
            b2b_invoices.append(invoice_data)
        elif invoice_value > 250000 and is_inter_state:
            # B2C Large (> 2.5L inter-state)
            b2c_large.append(invoice_data)
        else:
            # B2C Small
            b2c_small.append(invoice_data)
    
    return {
        "period": {"from": from_date, "to": to_date},
        "summary": {
            "total_invoices": totals["total_invoices"],
            "b2b_count": len(b2b_invoices),
            "b2c_large_count": len(b2c_large),
            "b2c_small_count": len(b2c_small),
            "cdnr_count": len(cdnr),
            "exports_count": len(exports),
            "nil_rated_count": len(nil_rated)
        },
        "totals": {k: round(v, 2) for k, v in totals.items()},
        "b2b": b2b_invoices[:100],  # Limit for display
        "b2c_large": b2c_large[:100],
        "b2c_small": b2c_small[:100],
        "cdnr": cdnr,
        "cdnur": cdnur,
        "exports": exports,
        "nil_rated": nil_rated,
        "hsn_summary": list(hsn_summary.values())
    }


@api_router.get("/gst-reports/gstr3b")
async def get_gstr3b_report(
    from_date: str = None,
    to_date: str = None,
    user: dict = Depends(get_current_user)
):
    """
    Generate GSTR-3B Summary Report
    Monthly summary return with tax liability and ITC
    """
    tenant_id = get_tenant_id(user)
    
    # Default to current month
    if not from_date:
        from_date = datetime.now().replace(day=1).strftime('%Y-%m-%d')
    if not to_date:
        to_date = datetime.now().strftime('%Y-%m-%d')
    
    # Get GSTR-1 data for outward supplies
    gstr1_query = {
        "tenant_id": tenant_id,
        "created_at": {"$gte": from_date, "$lte": to_date + "T23:59:59"},
        "is_deleted": {"$ne": True}
    }
    
    sales = await db.sales.find(gstr1_query, {"_id": 0}).to_list(10000)
    purchases = await db.purchases.find(gstr1_query, {"_id": 0}).to_list(10000)
    
    # Section 3.1 - Outward supplies (sales)
    outward_taxable_b2b = {"taxable": 0, "igst": 0, "cgst": 0, "sgst": 0, "cess": 0, "count": 0}
    outward_taxable_b2c = {"taxable": 0, "igst": 0, "cgst": 0, "sgst": 0, "cess": 0, "count": 0}
    outward_zero_rated = {"taxable": 0, "igst": 0, "cgst": 0, "sgst": 0, "cess": 0, "count": 0}
    outward_nil_rated = {"taxable": 0, "igst": 0, "cgst": 0, "sgst": 0, "cess": 0, "count": 0}
    outward_exempt = {"taxable": 0, "igst": 0, "cgst": 0, "sgst": 0, "cess": 0, "count": 0}
    
    for sale in sales:
        items = sale.get("items", [])
        taxable = 0
        cgst = 0
        sgst = 0
        igst = 0
        
        for item in items:
            item_taxable = float(item.get("price", 0)) * int(item.get("quantity", 1))
            gst_rate = float(item.get("gst_rate", 18))
            taxable += item_taxable
            
            customer_gstin = sale.get("customer_gstin", "")
            is_inter_state = len(customer_gstin) >= 2 and customer_gstin[:2] != "29"
            
            if is_inter_state:
                igst += item_taxable * gst_rate / 100
            else:
                cgst += item_taxable * (gst_rate / 2) / 100
                sgst += item_taxable * (gst_rate / 2) / 100
        
        target = outward_taxable_b2b if sale.get("customer_gstin") else outward_taxable_b2c
        target["taxable"] += taxable
        target["igst"] += igst
        target["cgst"] += cgst
        target["sgst"] += sgst
        target["count"] += 1
    
    # Section 4 - Input Tax Credit (purchases)
    itc_igst = 0
    itc_cgst = 0
    itc_sgst = 0
    itc_cess = 0
    purchase_count = 0
    
    for purchase in purchases:
        items = purchase.get("items", [])
        for item in items:
            item_taxable = float(item.get("price", 0)) * int(item.get("quantity", 1))
            gst_rate = float(item.get("gst_rate", 18))
            
            supplier_gstin = purchase.get("supplier_gstin", "")
            is_inter_state = len(supplier_gstin) >= 2 and supplier_gstin[:2] != "29"
            
            if is_inter_state:
                itc_igst += item_taxable * gst_rate / 100
            else:
                itc_cgst += item_taxable * (gst_rate / 2) / 100
                itc_sgst += item_taxable * (gst_rate / 2) / 100
        purchase_count += 1
    
    # Calculate tax liability
    total_output_igst = outward_taxable_b2b["igst"] + outward_taxable_b2c["igst"]
    total_output_cgst = outward_taxable_b2b["cgst"] + outward_taxable_b2c["cgst"]
    total_output_sgst = outward_taxable_b2b["sgst"] + outward_taxable_b2c["sgst"]
    
    net_igst = max(0, total_output_igst - itc_igst)
    net_cgst = max(0, total_output_cgst - itc_cgst)
    net_sgst = max(0, total_output_sgst - itc_sgst)
    
    return {
        "period": {"from": from_date, "to": to_date},
        "return_period": datetime.strptime(from_date, '%Y-%m-%d').strftime('%m%Y'),
        
        # Section 3.1 - Outward supplies
        "section_3_1": {
            "a_outward_taxable_b2b": {
                "description": "(a) Outward taxable supplies (other than zero rated, nil rated and exempted)",
                "taxable_value": round(outward_taxable_b2b["taxable"], 2),
                "integrated_tax": round(outward_taxable_b2b["igst"], 2),
                "central_tax": round(outward_taxable_b2b["cgst"], 2),
                "state_tax": round(outward_taxable_b2b["sgst"], 2),
                "cess": round(outward_taxable_b2b["cess"], 2),
                "voucher_count": outward_taxable_b2b["count"]
            },
            "b_outward_taxable_b2c": {
                "description": "(b) Outward taxable supplies (B2C - unregistered)",
                "taxable_value": round(outward_taxable_b2c["taxable"], 2),
                "integrated_tax": round(outward_taxable_b2c["igst"], 2),
                "central_tax": round(outward_taxable_b2c["cgst"], 2),
                "state_tax": round(outward_taxable_b2c["sgst"], 2),
                "cess": round(outward_taxable_b2c["cess"], 2),
                "voucher_count": outward_taxable_b2c["count"]
            },
            "c_zero_rated": {
                "description": "(c) Zero rated supply (Export on payment of tax)",
                "taxable_value": round(outward_zero_rated["taxable"], 2),
                "integrated_tax": round(outward_zero_rated["igst"], 2),
                "voucher_count": outward_zero_rated["count"]
            },
            "d_nil_rated": {
                "description": "(d) Nil rated",
                "taxable_value": round(outward_nil_rated["taxable"], 2),
                "voucher_count": outward_nil_rated["count"]
            },
            "e_exempt": {
                "description": "(e) Exempted",
                "taxable_value": round(outward_exempt["taxable"], 2),
                "voucher_count": outward_exempt["count"]
            }
        },
        
        # Section 4 - ITC
        "section_4": {
            "a_itc_available": {
                "description": "(A) ITC Available",
                "integrated_tax": round(itc_igst, 2),
                "central_tax": round(itc_cgst, 2),
                "state_tax": round(itc_sgst, 2),
                "cess": round(itc_cess, 2),
                "voucher_count": purchase_count
            },
            "b_itc_reversed": {
                "description": "(B) ITC Reversed",
                "integrated_tax": 0,
                "central_tax": 0,
                "state_tax": 0,
                "cess": 0
            },
            "c_net_itc": {
                "description": "(C) Net ITC Available (A - B)",
                "integrated_tax": round(itc_igst, 2),
                "central_tax": round(itc_cgst, 2),
                "state_tax": round(itc_sgst, 2),
                "cess": round(itc_cess, 2)
            }
        },
        
        # Section 5 - Tax Liability
        "section_5": {
            "a_tax_on_outward": {
                "description": "Tax on outward and reverse charge supplies",
                "integrated_tax": round(total_output_igst, 2),
                "central_tax": round(total_output_cgst, 2),
                "state_tax": round(total_output_sgst, 2),
                "cess": 0
            },
            "b_itc_claimed": {
                "description": "ITC claimed",
                "integrated_tax": round(itc_igst, 2),
                "central_tax": round(itc_cgst, 2),
                "state_tax": round(itc_sgst, 2),
                "cess": round(itc_cess, 2)
            }
        },
        
        # Section 6 - Tax Payable
        "section_6": {
            "tax_payable": {
                "description": "Tax payable",
                "integrated_tax": round(net_igst, 2),
                "central_tax": round(net_cgst, 2),
                "state_tax": round(net_sgst, 2),
                "cess": 0,
                "total": round(net_igst + net_cgst + net_sgst, 2)
            },
            "tax_paid": {
                "integrated_tax": 0,
                "central_tax": 0,
                "state_tax": 0,
                "cess": 0
            }
        },
        
        # Summary
        "summary": {
            "total_vouchers": len(sales) + len(purchases),
            "included_in_return": len(sales),
            "purchases_for_itc": purchase_count,
            "total_output_tax": round(total_output_igst + total_output_cgst + total_output_sgst, 2),
            "total_itc": round(itc_igst + itc_cgst + itc_sgst, 2),
            "net_tax_payable": round(net_igst + net_cgst + net_sgst, 2)
        }
    }


@api_router.get("/gst-reports/hsn-summary")
async def get_hsn_summary_report(
    from_date: str = None,
    to_date: str = None,
    user: dict = Depends(get_current_user)
):
    """Get HSN/SAC wise summary for GSTR-1 & GSTR-9"""
    tenant_id = get_tenant_id(user)
    
    if not from_date:
        from_date = datetime.now().replace(day=1).strftime('%Y-%m-%d')
    if not to_date:
        to_date = datetime.now().strftime('%Y-%m-%d')
    
    query = {
        "tenant_id": tenant_id,
        "created_at": {"$gte": from_date, "$lte": to_date + "T23:59:59"},
        "is_deleted": {"$ne": True}
    }
    
    sales = await db.sales.find(query, {"_id": 0}).to_list(10000)
    
    hsn_data = {}
    
    for sale in sales:
        for item in sale.get("items", []):
            hsn = item.get("hsn_code", "") or "OTHER"
            gst_rate = float(item.get("gst_rate", 18))
            qty = int(item.get("quantity", 1))
            taxable = float(item.get("price", 0)) * qty
            
            customer_gstin = sale.get("customer_gstin", "")
            is_inter_state = len(customer_gstin) >= 2 and customer_gstin[:2] != "29"
            
            if is_inter_state:
                igst = taxable * gst_rate / 100
                cgst = sgst = 0
            else:
                cgst = sgst = taxable * (gst_rate / 2) / 100
                igst = 0
            
            key = f"{hsn}_{int(gst_rate)}"
            if key not in hsn_data:
                hsn_data[key] = {
                    "hsn_code": hsn,
                    "description": item.get("name", "")[:50],
                    "uqc": "NOS",
                    "rate": gst_rate,
                    "total_quantity": 0,
                    "total_value": 0,
                    "taxable_value": 0,
                    "igst": 0,
                    "cgst": 0,
                    "sgst": 0,
                    "cess": 0
                }
            
            hsn_data[key]["total_quantity"] += qty
            hsn_data[key]["taxable_value"] += taxable
            hsn_data[key]["igst"] += igst
            hsn_data[key]["cgst"] += cgst
            hsn_data[key]["sgst"] += sgst
            hsn_data[key]["total_value"] += taxable + igst + cgst + sgst
    
    hsn_list = list(hsn_data.values())
    hsn_list.sort(key=lambda x: x["hsn_code"])
    
    # Round all values
    for h in hsn_list:
        for k in ["total_value", "taxable_value", "igst", "cgst", "sgst", "cess"]:
            h[k] = round(h[k], 2)
    
    totals = {
        "total_quantity": sum(h["total_quantity"] for h in hsn_list),
        "total_value": round(sum(h["total_value"] for h in hsn_list), 2),
        "taxable_value": round(sum(h["taxable_value"] for h in hsn_list), 2),
        "igst": round(sum(h["igst"] for h in hsn_list), 2),
        "cgst": round(sum(h["cgst"] for h in hsn_list), 2),
        "sgst": round(sum(h["sgst"] for h in hsn_list), 2),
        "cess": round(sum(h["cess"] for h in hsn_list), 2)
    }
    
    return {
        "period": {"from": from_date, "to": to_date},
        "hsn_summary": hsn_list,
        "totals": totals,
        "record_count": len(hsn_list)
    }


