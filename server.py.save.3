# Reset user password
@api_router.post("/superadmin/admins/{admin_id}/users/{user_id}/reset-password")
async def reset_tenant_user_password(
    admin_id: str,
    user_id: str,
    new_password: str = Body(..., embed=True),
    user: dict = Depends(require_superadmin)
):
    """Reset password for a user in a specific admin's tenant"""
    
    # Get the admin to find their tenant
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    tenant_id = admin.get("tenant_id")
    
    # Get the target user
    target_user = await db.users.find_one({"id": user_id, "tenant_id": tenant_id})
    if not target_user:
        raise HTTPException(status_code=404, detail="User not found in this tenant")
    
    # Validate password
    if len(new_password) < 6:
        raise HTTPException(status_code=400, detail="Password must be at least 6 characters")
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Update password
    await db.users.update_one(
        {"id": user_id},
        {"$set": {
            "password": hash_password(new_password),
            "password_reset_at": now,
            "password_reset_by_superadmin": user.get("id")
        }}
    )
    
    # Log the action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "tenant_user_password_reset",
        "admin_id": admin_id,
        "admin_email": admin.get("email"),
        "user_id": user_id,
        "user_email": target_user.get("email"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    return {"message": f"Password reset successfully for '{target_user.get('name')}'"}

# ============== MODULE MANAGEMENT ENDPOINTS ==============

class ModuleUpdate(BaseModel):
    enabled_modules: Dict[str, bool]

@api_router.get("/superadmin/modules")
async def get_all_modules(user: dict = Depends(require_superadmin)):
    """Get all available modules with their categories"""
    return {
        "modules": MODULE_CATEGORIES,
        "plan_limits": PLAN_MODULE_LIMITS
    }

@api_router.get("/superadmin/admins/{admin_id}/modules")
async def get_admin_modules(
    admin_id: str,
    user: dict = Depends(require_superadmin)
):
    """Get modules configuration for a specific admin"""
    
    # Get the admin
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    # Get admin's plan
    plan = admin.get("plan", "free")
    
    # Get available modules for their plan
    available_modules = get_modules_for_plan(plan)
    
    # Get admin's custom module settings (if any)
    admin_modules = await db.admin_modules.find_one({"admin_id": admin_id})
    custom_modules = admin_modules.get("enabled_modules", {}) if admin_modules else {}
    
    # Merge custom settings with plan defaults
    for category_key, category in available_modules.items():
        for module_key, module in category["modules"].items():
            if module_key in custom_modules:
                module["enabled"] = custom_modules[module_key] and module["available"]
    
    return {
        "admin_id": admin_id,
        "admin_name": admin.get("name"),
        "business_name": admin.get("business_name"),
        "plan": plan,
        "plan_limits": PLAN_MODULE_LIMITS.get(plan, {}),
        "modules": available_modules,
        "custom_modules": custom_modules
    }

@api_router.put("/superadmin/admins/{admin_id}/modules")
async def update_admin_modules(
    admin_id: str,
    module_update: ModuleUpdate,
    user: dict = Depends(require_superadmin)
):
    """Update module access for a specific admin"""
    
    # Get the admin
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    plan = admin.get("plan", "free")
    now = datetime.now(timezone.utc).isoformat()
    
    # Validate modules against plan
    available_modules = get_modules_for_plan(plan)
    valid_modules = {}
    invalid_modules = []
    
    for module_key, enabled in module_update.enabled_modules.items():
        # Find if module exists and is available for the plan
        module_found = False
        for category in available_modules.values():
            if module_key in category["modules"]:
                module_found = True
                if category["modules"][module_key]["available"]:
                    valid_modules[module_key] = enabled
                else:
                    invalid_modules.append(module_key)
                break
        
        if not module_found:
            invalid_modules.append(module_key)
    
    # Save module settings
    await db.admin_modules.update_one(
        {"admin_id": admin_id},
        {"$set": {
            "admin_id": admin_id,
            "enabled_modules": valid_modules,
            "updated_at": now,
            "updated_by": user.get("id")
        }},
        upsert=True
    )
    
    # Also update the admin's permissions based on modules
    permissions = admin.get("permissions", DEFAULT_ROLE_PERMISSIONS["admin"].copy())
    for module_key, enabled in valid_modules.items():
        if module_key in permissions:
            permissions[module_key] = enabled
    
    await db.users.update_one(
        {"id": admin_id},
        {"$set": {"permissions": permissions, "updated_at": now}}
    )
    
    # Log the action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "admin_modules_updated",
        "admin_id": admin_id,
        "admin_email": admin.get("email"),
        "modules_changed": valid_modules,
        "invalid_modules": invalid_modules,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    return {
        "message": f"Module access updated for '{admin.get('name')}'",
        "valid_modules": valid_modules,
        "invalid_modules": invalid_modules if invalid_modules else None
    }

@api_router.post("/superadmin/admins/{admin_id}/modules/reset")
async def reset_admin_modules(
    admin_id: str,
    user: dict = Depends(require_superadmin)
):
    """Reset admin's modules to plan defaults"""
    
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Delete custom module settings
    await db.admin_modules.delete_one({"admin_id": admin_id})
    
    # Reset permissions to default for their role
    await db.users.update_one(
        {"id": admin_id},
        {"$set": {
            "permissions": DEFAULT_ROLE_PERMISSIONS["admin"].copy(),
            "updated_at": now
        }}
    )
    
    # Log the action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "admin_modules_reset",
        "admin_id": admin_id,
        "admin_email": admin.get("email"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    return {"message": f"Modules reset to plan defaults for '{admin.get('name')}'"}

@api_router.get("/superadmin/modules/stats")
async def get_module_usage_stats(user: dict = Depends(require_superadmin)):
    """Get module usage statistics across all admins"""
    
    # Get all admin module settings
    pipeline = [
        {"$match": {"role": "admin"}},
        {"$lookup": {
            "from": "admin_modules",
            "localField": "id",
            "foreignField": "admin_id",
            "as": "module_config"
        }},
        {"$project": {
            "_id": 0,
            "plan": 1,
            "permissions": 1,
            "module_config": {"$arrayElemAt": ["$module_config", 0]}
        }}
    ]
    
    admins = await db.users.aggregate(pipeline).to_list(None)
    
    # Calculate stats
    module_usage = {}
    plan_distribution = {"free": 0, "basic": 0, "pro": 0, "enterprise": 0}
    
    for admin in admins:
        plan = admin.get("plan", "free")
        plan_distribution[plan] = plan_distribution.get(plan, 0) + 1
        
        # Count enabled modules
        permissions = admin.get("permissions", {})
        for module_key, enabled in permissions.items():
            if enabled:
                if module_key not in module_usage:
                    module_usage[module_key] = 0
                module_usage[module_key] += 1
    
    # Sort by usage
    sorted_modules = sorted(module_usage.items(), key=lambda x: x[1], reverse=True)
    
    return {
        "total_admins": len(admins),
        "plan_distribution": plan_distribution,
        "top_modules": dict(sorted_modules[:20]),
        "all_module_usage": module_usage
    }

# ============== SUPER ADMIN SUBSCRIPTION PLAN MANAGEMENT ==============

class PlanCreate(BaseModel):
    id: str
    name: str
    price: float
    currency: str = "inr"
    interval: str = "month"
    features: List[str] = []
    limits: Dict[str, int] = {}
    is_active: bool = True
    is_popular: bool = False
    description: Optional[str] = None
    trial_days: int = 0

class PlanUpdate(BaseModel):
    name: Optional[str] = None
    price: Optional[float] = None
    currency: Optional[str] = None
    interval: Optional[str] = None
    features: Optional[List[str]] = None
    limits: Optional[Dict[str, int]] = None
    is_active: Optional[bool] = None
    is_popular: Optional[bool] = None
    description: Optional[str] = None
    trial_days: Optional[int] = None

@api_router.get("/superadmin/plans")
async def get_all_plans_admin(user: dict = Depends(require_superadmin)):
    """Get all subscription plans with full details for Super Admin"""
    plans = await get_subscription_plans_data()
    
    # Get subscriber counts for each plan
    plan_stats = {}
    for plan_id in plans.keys():
        count = await db.users.count_documents({"role": "admin", "plan": plan_id})
        plan_stats[plan_id] = count
    
    return {
        "plans": [
            {
                "id": plan_id,
                **plan_data,
                "subscriber_count": plan_stats.get(plan_id, 0),
                "price_display": f"₹{int(plan_data.get('price', 0))}/{plan_data.get('interval', 'month')}" if plan_data.get('price', 0) > 0 else "Free"
            }
            for plan_id, plan_data in plans.items()
        ],
        "total_plans": len(plans)
    }

@api_router.get("/superadmin/plans/{plan_id}")
async def get_plan_details_admin(
    plan_id: str,
    user: dict = Depends(require_superadmin)
):
    """Get detailed info about a specific plan"""
    plan = await db.subscription_plans.find_one({"id": plan_id}, {"_id": 0})
    if not plan:
        raise HTTPException(status_code=404, detail="Plan not found")
    
    # Get subscribers
    subscribers = await db.users.find(
        {"role": "admin", "plan": plan_id},
        {"_id": 0, "password": 0}
    ).to_list(100)
    
    # Get revenue stats
    revenue_this_month = len(subscribers) * plan.get("price", 0)
    
    return {
        "plan": plan,
        "subscribers": subscribers,
        "subscriber_count": len(subscribers),
        "revenue_this_month": revenue_this_month
    }

@api_router.post("/superadmin/plans")
async def create_plan(
    plan_data: PlanCreate,
    user: dict = Depends(require_superadmin)
):
    """Create a new subscription plan"""
    
    # Check if plan ID already exists
    existing = await db.subscription_plans.find_one({"id": plan_data.id})
    if existing:
        raise HTTPException(status_code=400, detail="Plan ID already exists")
    
    now = datetime.now(timezone.utc).isoformat()
    
    plan_doc = {
        "id": plan_data.id.lower().replace(" ", "_"),
        "name": plan_data.name,
        "price": plan_data.price,
        "currency": plan_data.currency,
        "interval": plan_data.interval,
        "features": plan_data.features,
        "limits": plan_data.limits or {
            "stores": 1,
            "products": 100,
            "users": 2,
            "sales_per_month": 500,
            "customers": 100
        },
        "is_active": plan_data.is_active,
        "is_popular": plan_data.is_popular,
        "description": plan_data.description,
        "trial_days": plan_data.trial_days,
        "created_at": now,
        "created_by": user.get("id")
    }
    
    await db.subscription_plans.insert_one(plan_doc)
    
    # Log action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "plan_created",
        "plan_id": plan_doc["id"],
        "plan_name": plan_doc["name"],
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    del plan_doc["_id"]
    return {"message": f"Plan '{plan_data.name}' created successfully", "plan": plan_doc}

