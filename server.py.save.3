@api_router.post("/customers")
async def create_customer(request: CustomerCreate, user: dict = Depends(require_permission("customers"))):
    """Create a new customer and automatically create a linked Sundry Debtor ledger"""
    tenant_id = get_tenant_id(user)
    now = datetime.now(timezone.utc).isoformat()
    
    customer_id = str(uuid.uuid4())
    ledger_id = str(uuid.uuid4())
    
    # Create the corresponding ledger under Sundry Debtors
    new_ledger = {
        "id": ledger_id,
        "tenant_id": tenant_id,
        "name": request.name,
        "group_id": "sundry_debtors",
        "ledger_type": "asset",
        "ledger_nature": "debit",
        "opening_balance": 0,
        "opening_balance_type": "Dr",
        "contact_person": "",
        "address": request.address if hasattr(request, 'address') else "",
        "city": request.city if hasattr(request, 'city') else "",
        "state": request.state if hasattr(request, 'state') else "",
        "pincode": request.pincode if hasattr(request, 'pincode') else "",
        "phone": request.phone if hasattr(request, 'phone') else "",
        "email": request.email if hasattr(request, 'email') else "",
        "gstin": request.gst_number if hasattr(request, 'gst_number') else "",
        "is_active": True,
        "linked_customer_id": customer_id,
        "created_at": now,
        "updated_at": now,
        "is_deleted": False
    }
    
    await db.ledgers.insert_one(new_ledger)
    
    # Create the customer with ledger link
    customer_doc = {
        "id": customer_id,
        "tenant_id": tenant_id,
        "ledger_id": ledger_id,  # Link to the ledger
        **request.model_dump(),
        "loyalty_points": 0,
        "loyalty_tier": "standard",
        "created_at": now
    }
    
    if request.loyalty_enrolled:
        customer_doc["loyalty_enrolled_at"] = now
    
    await db.customers.insert_one(customer_doc)
    customer_doc.pop("_id", None)
    
    logger.info(f"Customer created: {request.name} with linked ledger {ledger_id}")
    
    return customer_doc

@api_router.put("/customers/{customer_id}")
async def update_customer(customer_id: str, request: CustomerCreate, user: dict = Depends(require_permission("customers"))):
    await db.customers.update_one({"id": customer_id}, {"$set": request.model_dump()})
    customer = await db.customers.find_one({"id": customer_id}, {"_id": 0})
    return customer

@api_router.delete("/customers/{customer_id}")
async def delete_customer(customer_id: str, user: dict = Depends(get_current_user)):
    """Soft delete customer - moves to recycle bin. Admins have full delete access."""
    tenant_id = get_tenant_id(user)
    
    # Admins can delete any customer
    if not is_admin_or_higher(user):
        permissions = user.get("permissions", {})
        if not permissions.get("customers", {}).get("delete", False):
            raise HTTPException(status_code=403, detail="Permission denied. Admin access required for delete.")
    
    # Find the customer first
    customer = await db.customers.find_one(
        {"tenant_id": tenant_id, "id": customer_id},
        {"_id": 0}
    )
    
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Move to recycle bin
    deleted_item = {
        "id": str(uuid.uuid4()),
        "original_id": customer_id,
        "item_type": "customer",
        "item_data": customer,
        "deleted_by": user.get("id"),
        "deleted_by_name": user.get("name"),
        "deleted_at": datetime.now(timezone.utc).isoformat(),
        "tenant_id": tenant_id,
        "auto_delete_at": (datetime.now(timezone.utc) + timedelta(days=30)).isoformat(),
        "is_permanently_deleted": False
    }
    
    await db.recycle_bin.insert_one(deleted_item)
    
    # Mark customer as deleted (soft delete)
    await db.customers.update_one(
        {"tenant_id": tenant_id, "id": customer_id}, 
        {"$set": {
            "is_active": False, 
            "is_deleted": True,
            "deleted_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": "Customer moved to Recycle Bin", "recycle_bin_id": deleted_item["id"]}


