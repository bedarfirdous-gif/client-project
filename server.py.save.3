@api_router.delete("/users/{user_id}")
async def delete_user(user_id: str, user: dict = Depends(get_current_user)):
    """Delete a user (admin only)"""
    tenant_id = get_tenant_id(user)
    
    # Check if current user has permission to delete users
    if user.get("role") not in ["admin", "superadmin"] and not is_superadmin(user):
        raise HTTPException(status_code=403, detail="Only admins can delete users")
    
    # Check if user exists
    target_user = await db.users.find_one({"id": user_id, "tenant_id": tenant_id})
    if not target_user:
        raise HTTPException(status_code=404, detail="User not found")
    
    # Prevent self-deletion
    if user_id == user.get("id"):
        raise HTTPException(status_code=400, detail="Cannot delete your own account")
    
    # Prevent deletion of superadmin
    if target_user.get("role") == "superadmin" or target_user.get("is_superadmin"):
        raise HTTPException(status_code=400, detail="Cannot delete superadmin account")
    
    # Delete the user
    await db.users.delete_one({"id": user_id, "tenant_id": tenant_id})
    
    # Log the action
    await db.audit_trail.insert_one({
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "entity_id": user_id,
        "entity_type": "user",
        "action": "user_deleted",
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "details": {"deleted_user_name": target_user.get("name"), "deleted_user_email": target_user.get("email")},
        "created_at": datetime.now(timezone.utc).isoformat()
    })
    
    return {"message": "User deleted successfully"}


