@api_router.post("/whatsapp/send-bulk")
async def send_bulk_whatsapp_messages(
    bulk_data: BulkMessageCreate,
    user: dict = Depends(get_current_user)
):
    """Send WhatsApp messages to multiple customers"""
    if user.get("role") not in ["superadmin", "admin", "manager"]:
        raise HTTPException(status_code=403, detail="Insufficient permissions for bulk messaging")
    
    tenant_id = get_tenant_id(user)
    
    # Fetch customers from database
    from bson import ObjectId
    customer_ids = [ObjectId(cid) for cid in bulk_data.customer_ids]
    customers = await db.customers.find({
        "_id": {"$in": customer_ids},
        "tenant_id": tenant_id
    }).to_list(length=len(customer_ids))
    
    if not customers:
        raise HTTPException(status_code=404, detail="No customers found")
    
    # Convert ObjectIds to strings for customers
    for c in customers:
        c["id"] = str(c["_id"])
    
    result = await whatsapp_system.send_bulk_messages(tenant_id, bulk_data, customers)
    return result

