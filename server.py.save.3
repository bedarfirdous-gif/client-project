        "rates": EXCHANGE_RATES,
        "base_currency": "INR",
        "last_updated": datetime.now(timezone.utc).isoformat()
    }


@api_router.post("/currency/convert")
async def convert_currency(
    amount: float = Body(...),
    from_currency: str = Body("INR"),
    to_currency: str = Body(...)
):
    """Convert amount between currencies"""
    if from_currency not in EXCHANGE_RATES or to_currency not in EXCHANGE_RATES:
        raise HTTPException(status_code=400, detail="Unsupported currency")
    
    # Convert to INR first, then to target currency
    inr_amount = amount / EXCHANGE_RATES[from_currency]
    converted_amount = inr_amount * EXCHANGE_RATES[to_currency]
    
    decimal_places = SUPPORTED_CURRENCIES[to_currency]["decimal_places"]
    
    return {
        "original": {"amount": amount, "currency": from_currency},
        "converted": {
            "amount": round(converted_amount, decimal_places),
            "currency": to_currency,
            "symbol": SUPPORTED_CURRENCIES[to_currency]["symbol"]
        },
        "rate": EXCHANGE_RATES[to_currency] / EXCHANGE_RATES[from_currency]
    }


