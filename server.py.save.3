# ============== ADMIN PLAN UPGRADE/DOWNGRADE WORKFLOW ==============

class PlanChangeRequest(BaseModel):
    new_plan: str
    billing_cycle: str = "month"  # month or year

@api_router.get("/billing/compare-plans")
async def compare_plans(user: dict = Depends(require_permission("billing"))):
    """Get plan comparison for upgrade/downgrade decision"""
    tenant_id = get_tenant_id(user)
    
    # Get admin's current plan
    admin = await db.users.find_one({"tenant_id": tenant_id, "role": "admin"}, {"_id": 0})
    current_plan = admin.get("plan", "free") if admin else "free"
    
    # Get all active plans from database
    plans = await get_subscription_plans_data()
    
    # Get current usage
    usage = {
        "stores": await db.stores.count_documents({"tenant_id": tenant_id}),
        "products": await db.products.count_documents({"tenant_id": tenant_id}),
        "users": await db.users.count_documents({"tenant_id": tenant_id}),
        "customers": await db.customers.count_documents({"tenant_id": tenant_id}),
        "sales_this_month": await db.sales.count_documents({
            "tenant_id": tenant_id,
            "created_at": {"$gte": (datetime.now(timezone.utc) - timedelta(days=30)).isoformat()}
        })
    }
    
    # Build comparison
    plan_list = []
    for plan_id, plan_data in plans.items():
        if not plan_data.get("is_active", True):
            continue
            
        limits = plan_data.get("limits", {})
        
        # Check if this plan can accommodate current usage
        can_accommodate = True
        warnings = []
        
        if limits.get("stores", -1) != -1 and usage["stores"] > limits.get("stores", 0):
            can_accommodate = False
            warnings.append(f"You have {usage['stores']} stores but this plan allows {limits.get('stores')}")
        if limits.get("products", -1) != -1 and usage["products"] > limits.get("products", 0):
            can_accommodate = False
            warnings.append(f"You have {usage['products']} products but this plan allows {limits.get('products')}")
        if limits.get("users", -1) != -1 and usage["users"] > limits.get("users", 0):
            can_accommodate = False
            warnings.append(f"You have {usage['users']} users but this plan allows {limits.get('users')}")
        
        is_upgrade = plan_data.get("price", 0) > plans.get(current_plan, {}).get("price", 0)
        is_downgrade = plan_data.get("price", 0) < plans.get(current_plan, {}).get("price", 0)
        
        plan_list.append({
            "id": plan_id,
            "name": plan_data.get("name"),
            "price": plan_data.get("price", 0),
            "price_display": f"₹{int(plan_data.get('price', 0))}" if plan_data.get("price", 0) > 0 else "Free",
            "interval": plan_data.get("interval", "month"),
            "features": plan_data.get("features", []),
            "limits": limits,
            "is_current": plan_id == current_plan,
            "is_upgrade": is_upgrade,
            "is_downgrade": is_downgrade,
            "can_accommodate": can_accommodate,
            "warnings": warnings if not can_accommodate else [],
            "is_popular": plan_data.get("is_popular", False),
            "trial_days": plan_data.get("trial_days", 0)
        })
    
    # Sort by price
    plan_list.sort(key=lambda x: x["price"])
    
    return {
        "current_plan": current_plan,
        "current_usage": usage,
        "plans": plan_list
    }

@api_router.post("/billing/change-plan")
async def change_plan(
    request: PlanChangeRequest,
    user: dict = Depends(require_permission("billing"))
):
    """Request a plan change - requires SuperAdmin approval for paid upgrades"""
    tenant_id = get_tenant_id(user)
    
    # Get admin or superadmin
    admin = await db.users.find_one({
        "tenant_id": tenant_id, 
        "role": {"$in": ["admin", "superadmin", "manager"]}
    })
    if not admin:
        # Fallback: use the current user if they have billing permission
        admin = await db.users.find_one({"id": user.get("id")})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin account not found")
    
    current_plan = admin.get("plan", "free")
    new_plan = request.new_plan.lower()
    
    # Validate new plan exists
    plans = await get_subscription_plans_data()
    if new_plan not in plans:
        raise HTTPException(status_code=400, detail="Invalid plan selected")
    
    if new_plan == current_plan:
        raise HTTPException(status_code=400, detail="Already on this plan")
    
    # Check if there's already a pending request
    pending_request = await db.plan_upgrade_requests.find_one({
        "tenant_id": tenant_id,
        "status": "pending"
    })
    if pending_request:
        raise HTTPException(status_code=400, detail="You already have a pending upgrade request. Please wait for SuperAdmin approval or cancel the existing request.")
    
    new_plan_data = plans[new_plan]
    current_plan_data = plans.get(current_plan, {})
    
    # Check if downgrading - validate current usage fits
    new_limits = new_plan_data.get("limits", {})
    current_usage = {
        "stores": await db.stores.count_documents({"tenant_id": tenant_id}),
        "products": await db.products.count_documents({"tenant_id": tenant_id}),
        "users": await db.users.count_documents({"tenant_id": tenant_id})
    }
    
    is_downgrade = new_plan_data.get("price", 0) < current_plan_data.get("price", 0)
    
    if is_downgrade:
        # Validate usage fits new plan limits
        if new_limits.get("stores", -1) != -1 and current_usage["stores"] > new_limits.get("stores", 0):
            raise HTTPException(
                status_code=400, 
                detail=f"Cannot downgrade: You have {current_usage['stores']} stores but {new_plan_data['name']} allows only {new_limits['stores']}. Please reduce stores first."
            )
        if new_limits.get("products", -1) != -1 and current_usage["products"] > new_limits.get("products", 0):
            raise HTTPException(
                status_code=400, 
                detail=f"Cannot downgrade: You have {current_usage['products']} products but {new_plan_data['name']} allows only {new_limits['products']}. Please reduce products first."
            )
        if new_limits.get("users", -1) != -1 and current_usage["users"] > new_limits.get("users", 0):
            raise HTTPException(
                status_code=400, 
                detail=f"Cannot downgrade: You have {current_usage['users']} users but {new_plan_data['name']} allows only {new_limits['users']}. Please remove users first."
            )
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Calculate proration (simplified - for Stripe integration, use Stripe's proration)
    days_remaining = 30  # Simplified
    old_price = current_plan_data.get("price", 0)
    new_price = new_plan_data.get("price", 0)
    
    if is_downgrade:
        # Credit for unused time
        credit = (old_price - new_price) * (days_remaining / 30)
        proration_amount = -credit
    else:
        # Charge difference for remaining time
        proration_amount = (new_price - old_price) * (days_remaining / 30)
    
    # For FREE plan downgrades, apply immediately (no payment needed)
    if new_plan == "free" or (is_downgrade and new_price == 0):
        # Apply immediately for downgrades to free
        await db.users.update_one(
            {"id": admin["id"]},
            {"$set": {
                "plan": new_plan,
                "plan_changed_at": now,
                "plan_billing_cycle": request.billing_cycle
            }}
        )
        
        await db.subscriptions.update_one(
            {"tenant_id": tenant_id},
            {"$set": {
                "tenant_id": tenant_id,
                "plan": new_plan,
                "price": new_price,
                "interval": request.billing_cycle,
                "status": "free",
                "updated_at": now
            }},
            upsert=True
        )
        
        return {
            "success": True,
            "message": f"Successfully downgraded to {new_plan_data['name']}",
            "old_plan": current_plan,
            "new_plan": new_plan,
            "is_upgrade": False,
            "requires_approval": False,
            "status": "approved"
        }
    
    # For PAID upgrades, create a pending request for SuperAdmin approval
    upgrade_request = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "admin_id": admin["id"],
        "admin_email": admin.get("email", ""),
        "admin_name": admin.get("name", ""),
        "from_plan": current_plan,
        "from_plan_name": current_plan_data.get("name", current_plan.capitalize()),
        "to_plan": new_plan,
        "to_plan_name": new_plan_data.get("name", new_plan.capitalize()),
        "is_upgrade": not is_downgrade,
        "amount_due": round(new_price, 2),
        "proration_amount": round(proration_amount, 2),
        "billing_cycle": request.billing_cycle,
        "status": "pending",  # pending, approved, rejected
        "payment_status": "unpaid",  # unpaid, paid, refunded
        "created_at": now,
        "requested_by": user.get("id"),
        "requested_by_name": user.get("name", ""),
        "approved_by": None,
        "approved_at": None,
        "rejection_reason": None
    }
    
    await db.plan_upgrade_requests.insert_one(upgrade_request)
    
    return {
        "success": True,
        "message": f"Upgrade request submitted for {new_plan_data['name']}. Awaiting SuperAdmin approval after payment confirmation.",
        "request_id": upgrade_request["id"],
        "old_plan": current_plan,
        "new_plan": new_plan,
        "is_upgrade": not is_downgrade,
        "amount_due": round(new_price, 2),
        "proration_amount": round(proration_amount, 2),
        "requires_approval": True,
        "status": "pending"
    }

