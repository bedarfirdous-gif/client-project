@api_router.post("/autoheal/diagnose")
async def diagnose_error(
    request: dict,
    user: dict = Depends(require_permission("settings"))
):
    """Manually trigger error diagnosis and healing"""
    # Use enhanced autoheal agent with AI capabilities
    agent = enhanced_autoheal if enhanced_autoheal else get_autoheal_agent()
    if not agent:
        raise HTTPException(status_code=500, detail="AutoHeal agent not initialized")
    
    # Create a synthetic error for diagnosis
    error_msg = request.get("error_message") or request.get("error", "Manual diagnosis request")
    context = {
        "module": request.get("module", "manual"),
        "function": request.get("function", "diagnose"),
        "user_id": user.get("id"),
        "user_role": user.get("role"),
        "tenant_id": get_tenant_id(user),
        "request_path": request.get("request_path"),
        "response_status": request.get("status_code", 500),
        "additional_context": request.get("context", {})
    }
    
    try:
        error = Exception(error_msg)
        report = await agent.diagnose_and_heal(error, context)
        
        return {
            "report_id": report.report_id,
            "error_type": report.error_context.error_type.value,
            "severity": report.error_context.severity.value,
            "root_cause": report.root_cause,
            "root_cause_confidence": report.root_cause_confidence,
            "root_cause_category": report.root_cause_category or report.error_context.root_cause_category.value,
            "component": report.error_context.component,
            "subsystem": report.error_context.subsystem,
            "fix_applied": {
                "fix_type": report.fix_applied.fix_type if report.fix_applied else None,
                "description": report.fix_applied.description if report.fix_applied else None,
                "status": report.fix_applied.status.value if report.fix_applied else None,
                "confidence": report.fix_applied.confidence_score if report.fix_applied else None,
                "ai_reasoning": report.fix_applied.ai_reasoning if report.fix_applied else None
            } if report.fix_applied else None,
            "resolved": report.resolved,
            "escalated": report.escalated,
            "recommendations": report.recommendations,
            "alternative_fixes": report.alternative_fixes,
            "resolution_time_ms": report.resolution_time_ms
        }
    except Exception as e:
        logger.error(f"Diagnosis failed: {e}")
        raise HTTPException(status_code=500, detail=f"Diagnosis failed: {str(e)}")


