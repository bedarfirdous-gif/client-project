# ============== EMPLOYEE FILE UPLOAD ==============
import os
import shutil

ALLOWED_FILE_TYPES = {
    'application/pdf': '.pdf',
    'image/jpeg': '.jpg',
    'image/jpg': '.jpg', 
    'image/png': '.png'
}
MAX_FILE_SIZE = 5 * 1024 * 1024  # 5MB

@api_router.post("/employees/{employee_id}/upload")
async def upload_employee_file(
    employee_id: str,
    file: UploadFile = File(...),
    document_type: str = Form("document"),
    user: dict = Depends(require_permission("employees"))
):
    """
    Upload a file for an employee.
    
    - Allowed Types: pdf, jpg, jpeg, png
    - Max File Size: 5MB
    - Files are renamed before storing
    - Stored in: /uploads/employees/{employee_id}/
    """
    tenant_id = get_tenant_id(user)
    
    # Verify employee exists
    employee = await db.employees.find_one(
        {"id": employee_id, "tenant_id": tenant_id},
        {"_id": 0, "name": 1}
    )
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Validate file type
    content_type = file.content_type
    if content_type not in ALLOWED_FILE_TYPES:
        raise HTTPException(
            status_code=400, 
            detail="File type not allowed. Allowed types: pdf, jpg, jpeg, png"
        )
    
    # Read file content
    content = await file.read()
    
    # Validate file size
    file_size = len(content)
    if file_size > MAX_FILE_SIZE:
        raise HTTPException(
            status_code=400, 
            detail="File too large. Maximum size: 5MB"
        )
    
    # Create upload directory
    upload_dir = f"/app/uploads/employees/{employee_id}"
    os.makedirs(upload_dir, exist_ok=True)
    
    # Generate unique filename
    original_name = file.filename or "file"
    file_ext = ALLOWED_FILE_TYPES[content_type]
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
    unique_id = str(uuid.uuid4())[:8]
    new_filename = f"{document_type}_{timestamp}_{unique_id}{file_ext}"
    
    # Save file
    file_path = os.path.join(upload_dir, new_filename)
    with open(file_path, "wb") as f:
        f.write(content)
    
    # Store file metadata in database
    file_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "original_filename": original_name,
        "stored_filename": new_filename,
        "file_path": file_path,
        "file_url": f"/api/employees/{employee_id}/files/{new_filename}",
        "content_type": content_type,
        "file_size": file_size,
        "document_type": document_type,
        "uploaded_by": user.get("id") or user.get("sub"),
        "uploaded_at": datetime.now(timezone.utc).isoformat()
    }
    await db.employee_files.insert_one(file_doc)
    file_doc.pop("_id", None)
    
    return {
        "message": "File uploaded successfully",
        "file": file_doc
    }


@api_router.post("/employees/{employee_id}/upload-bulk")
async def upload_employee_files_bulk(
    employee_id: str,
    files: List[UploadFile] = File(...),
    document_type: str = Form("document"),
    user: dict = Depends(require_permission("employees"))
):
    """
    Upload multiple files for an employee at once.
    
    - Allowed Types: pdf, jpg, jpeg, png
    - Max File Size per file: 5MB
    - Max Files: 10
    """
    tenant_id = get_tenant_id(user)
    
    # Verify employee exists
    employee = await db.employees.find_one(
        {"id": employee_id, "tenant_id": tenant_id},
        {"_id": 0, "name": 1}
    )
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Limit number of files
    if len(files) > 10:
        raise HTTPException(status_code=400, detail="Maximum 10 files allowed at once")
    
    # Create upload directory
    upload_dir = f"/app/uploads/employees/{employee_id}"
    os.makedirs(upload_dir, exist_ok=True)
    
    uploaded_files = []
    errors = []
    
    for idx, file in enumerate(files):
        try:
            # Validate file type
            content_type = file.content_type
            if content_type not in ALLOWED_FILE_TYPES:
                errors.append({"file": file.filename, "error": "File type not allowed"})
                continue
            
            # Read file content
            content = await file.read()
            
            # Validate file size
            file_size = len(content)
            if file_size > MAX_FILE_SIZE:
                errors.append({"file": file.filename, "error": "File too large (max 5MB)"})
                continue
            
            # Generate unique filename
            original_name = file.filename or f"file_{idx}"
            file_ext = ALLOWED_FILE_TYPES[content_type]
            timestamp = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
            unique_id = str(uuid.uuid4())[:8]
            new_filename = f"{document_type}_{timestamp}_{unique_id}{file_ext}"
            
            # Save file
            file_path = os.path.join(upload_dir, new_filename)
            with open(file_path, "wb") as f:
                f.write(content)
            
            # Store file metadata in database
            file_doc = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "employee_id": employee_id,
                "original_filename": original_name,
                "stored_filename": new_filename,
                "file_path": file_path,
                "file_url": f"/api/employees/{employee_id}/files/{new_filename}",
                "content_type": content_type,
                "file_size": file_size,
                "document_type": document_type,
                "uploaded_by": user.get("id") or user.get("sub"),
                "uploaded_at": datetime.now(timezone.utc).isoformat()
            }
            await db.employee_files.insert_one(file_doc)
            file_doc.pop("_id", None)
            uploaded_files.append(file_doc)
        except Exception as e:
            errors.append({"file": file.filename, "error": str(e)})
    
    return {
        "message": f"Uploaded {len(uploaded_files)} files successfully",
        "uploaded": uploaded_files,
        "errors": errors,
        "total_uploaded": len(uploaded_files),
        "total_errors": len(errors)
    }


