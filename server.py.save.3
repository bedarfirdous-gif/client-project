# Impersonate admin (login as admin)
@api_router.post("/superadmin/impersonate/{admin_id}")
async def impersonate_admin(
    admin_id: str,
    user: dict = Depends(require_superadmin)
):
    """Generate a token to impersonate an admin user"""
    
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    if not admin.get("is_active", True):
        raise HTTPException(status_code=400, detail="Cannot impersonate inactive admin")
    
    # Create impersonation token with extra flag
    token = create_access_token({
        "sub": admin["id"],
        "tenant_id": admin.get("tenant_id"),
        "impersonated_by": user.get("id"),
        "impersonated_by_name": user.get("name")
    })
    
    # Log impersonation
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "admin_impersonated",
        "admin_id": admin_id,
        "admin_email": admin.get("email"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": datetime.now(timezone.utc).isoformat()
    })
    
    admin_data = {k: v for k, v in admin.items() if k not in ["_id", "password"]}
    admin_data["is_impersonated"] = True
    admin_data["impersonated_by"] = user.get("name")
    
    return {
        "access_token": token,
        "token_type": "bearer",
        "user": admin_data,
        "message": f"Now logged in as {admin.get('name')}"
    }

# Exit impersonation (return to super admin)
@api_router.post("/superadmin/exit-impersonation")
async def exit_impersonation(user: dict = Depends(get_current_user)):
    """Exit impersonation mode and return to super admin"""
    
    # Find the super admin user
    superadmin = await db.users.find_one({"role": "superadmin"}, {"_id": 0, "password": 0})
    if not superadmin:
        raise HTTPException(status_code=500, detail="Super admin not found")
    
    token = create_access_token({
        "sub": superadmin["id"],
        "tenant_id": "superadmin"
    })
    
    return Token(access_token=token, user=superadmin)

