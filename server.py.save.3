    }
    
    # Get total revenue
    sales_pipeline = [
        {"$match": {"tenant_id": tenant_id, "status": {"$ne": "cancelled"}}},
        {"$group": {"_id": None, "total": {"$sum": "$total"}}}
    ]
    sales_result = await db.sales.aggregate(sales_pipeline).to_list(1)
    stats["total_revenue"] = sales_result[0]["total"] if sales_result else 0
    
    # Get all users for this tenant
    tenant_users = await db.users.find(
        {"tenant_id": tenant_id},
        {"_id": 0, "password": 0}
    ).to_list(100)
    
    # Get all stores for this tenant
    stores = await db.stores.find(
        {"tenant_id": tenant_id},
        {"_id": 0}
    ).to_list(100)
    
    return {
        "admin": admin,
        "stats": stats,
        "users": tenant_users,
        "stores": stores
    }

# Update admin
@api_router.put("/superadmin/admins/{admin_id}")
async def update_admin(
    admin_id: str,
    admin_update: AdminUpdate,
    user: dict = Depends(require_superadmin)
):
    """Update admin user details"""
    
    admin = await db.users.find_one({"id": admin_id, "role": "admin"})
    if not admin:
        raise HTTPException(status_code=404, detail="Admin not found")
    
    update_data = {k: v for k, v in admin_update.model_dump().items() if v is not None}
    update_data["updated_at"] = datetime.now(timezone.utc).isoformat()
    update_data["updated_by"] = user.get("id")
    
    await db.users.update_one({"id": admin_id}, {"$set": update_data})
    
    # Log the update
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "admin_updated",
        "admin_id": admin_id,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "changes": update_data
    })
    
    updated = await db.users.find_one({"id": admin_id}, {"_id": 0, "password": 0})
    return {"message": "Admin updated", "admin": updated}

