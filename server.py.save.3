# ============== AUTONOMOUS AGENT SYSTEM ENDPOINTS ==============
# Emergent-style autonomous task execution platform

@api_router.post("/autonomous/plan")
async def create_execution_plan(
    request: Dict = Body(...),
    user: dict = Depends(require_permission("dashboard"))
):
    """
    Create an autonomous execution plan from a natural language prompt.
    
    The AI agent analyzes your request and breaks it down into
    executable steps with appropriate confirmation requirements.
    
    Example prompts:
    - "Show me all low stock items and generate a reorder report"
    - "Analyze my sales for the last month and identify trends"
    - "Create 5 new test products in inventory"
    
    Returns:
    - Execution plan with steps, confirmation requirements, and risk level
    """
    prompt = request.get("prompt", "")
    context = request.get("context", {})
    
    if not prompt:
        raise HTTPException(status_code=400, detail="Prompt is required")
    
    plan = await autonomous_agent.plan_task(
        prompt=prompt,
        user_id=user.get("id"),
        tenant_id=get_tenant_id(user),
        context=context
    )
    
    return {
        "success": True,
        "plan": plan.to_dict(),
        "requires_confirmation": plan.status == TaskStatus.AWAITING_APPROVAL,
        "pending_confirmations": [s.to_dict() for s in plan.get_pending_confirmations()]
    }


@api_router.post("/autonomous/execute/{plan_id}")
async def execute_plan(
    plan_id: str,
    auto_confirm: bool = Query(default=False, description="Auto-confirm all steps"),
    user: dict = Depends(require_permission("dashboard"))
):
    """
    Execute an autonomous plan with real-time updates.
    
    If auto_confirm=False, steps requiring confirmation will be paused.
    Use /autonomous/confirm/{plan_id}/{step_id} to confirm individual steps.
    """
    results = []
    
    async for update in autonomous_agent.execute_plan(plan_id, auto_confirm=auto_confirm):
        results.append(update)
    
    return {
        "success": True,
        "plan_id": plan_id,
        "execution_results": results
    }


