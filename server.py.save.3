@api_router.delete("/superadmin/plans/{plan_id}")
async def delete_plan(
    plan_id: str,
    user: dict = Depends(require_superadmin)
):
    """Delete a subscription plan (only if no subscribers)"""
    
    existing = await db.subscription_plans.find_one({"id": plan_id})
    if not existing:
        raise HTTPException(status_code=404, detail="Plan not found")
    
    # Check for subscribers
    subscriber_count = await db.users.count_documents({"role": "admin", "plan": plan_id})
    if subscriber_count > 0:
        raise HTTPException(
            status_code=400, 
            detail=f"Cannot delete plan with {subscriber_count} active subscriber(s). Migrate them first."
        )
    
    # Don't allow deleting free plan
    if plan_id == "free":
        raise HTTPException(status_code=400, detail="Cannot delete the Free plan")
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Soft delete - mark as inactive
    await db.subscription_plans.update_one(
        {"id": plan_id},
        {"$set": {"is_active": False, "deleted_at": now, "deleted_by": user.get("id")}}
    )
    
    # Log action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "plan_deleted",
        "plan_id": plan_id,
        "plan_name": existing.get("name"),
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    return {"message": f"Plan '{existing.get('name')}' deleted successfully"}

@api_router.post("/superadmin/plans/{plan_id}/duplicate")
async def duplicate_plan(
    plan_id: str,
    new_id: str = Body(..., embed=True),
    new_name: str = Body(..., embed=True),
    user: dict = Depends(require_superadmin)
):
    """Duplicate an existing plan with a new ID and name"""
    
    existing = await db.subscription_plans.find_one({"id": plan_id}, {"_id": 0})
    if not existing:
        raise HTTPException(status_code=404, detail="Plan not found")
    
    # Check if new ID already exists
    if await db.subscription_plans.find_one({"id": new_id.lower().replace(" ", "_")}):
        raise HTTPException(status_code=400, detail="New plan ID already exists")
    
    now = datetime.now(timezone.utc).isoformat()
    
    # Create new plan from existing
    new_plan = {
        **existing,
        "id": new_id.lower().replace(" ", "_"),
        "name": new_name,
        "created_at": now,
        "created_by": user.get("id"),
        "is_popular": False  # Reset popular flag
    }
    
    # Remove old timestamps
    new_plan.pop("updated_at", None)
    new_plan.pop("updated_by", None)
    
    await db.subscription_plans.insert_one(new_plan)
    
    # Log action
    await db.superadmin_audit.insert_one({
        "id": str(uuid.uuid4()),
        "action": "plan_duplicated",
        "source_plan_id": plan_id,
        "new_plan_id": new_plan["id"],
        "new_plan_name": new_name,
        "performed_by": user.get("id"),
        "performed_by_name": user.get("name"),
        "timestamp": now
    })
    
    del new_plan["_id"]
    return {"message": f"Plan duplicated as '{new_name}'", "plan": new_plan}

