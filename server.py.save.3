# Market Analytics
@api_router.get("/superadmin/market-analytics")
async def get_market_analytics(
    period: str = "month",  # day, week, month, year
    user: dict = Depends(require_superadmin)
):
    """Get market-wide analytics across all tenants"""
    
    # Calculate date range
    now = datetime.now(timezone.utc)
    if period == "day":
        start_date = now - timedelta(days=1)
    elif period == "week":
        start_date = now - timedelta(weeks=1)
    elif period == "month":
        start_date = now - timedelta(days=30)
    else:  # year
        start_date = now - timedelta(days=365)
    
    start_iso = start_date.isoformat()
    
    # Sales by category across all tenants
    category_pipeline = [
        {"$match": {"created_at": {"$gte": start_iso}}},
        {"$unwind": "$items"},
        {"$lookup": {
            "from": "items",
            "localField": "items.item_id",
            "foreignField": "id",
            "as": "item_info"
        }},
        {"$unwind": {"path": "$item_info", "preserveNullAndEmptyArrays": True}},
        {"$group": {
            "_id": "$item_info.category",
            "total_sales": {"$sum": {"$multiply": ["$items.quantity", "$items.price"]}},
            "total_quantity": {"$sum": "$items.quantity"}
        }},
        {"$sort": {"total_sales": -1}},
        {"$limit": 10}
    ]
    categories = await db.sales.aggregate(category_pipeline).to_list(10)
    
    # Top performing tenants
    tenant_pipeline = [
        {"$match": {"created_at": {"$gte": start_iso}, "status": {"$ne": "cancelled"}}},
        {"$group": {
            "_id": "$tenant_id",
            "total_sales": {"$sum": "$total"},
            "order_count": {"$sum": 1}
        }},
        {"$sort": {"total_sales": -1}},
        {"$limit": 10}
    ]
    top_tenants = await db.sales.aggregate(tenant_pipeline).to_list(10)
    
    # Enrich with admin info
    for tenant in top_tenants:
        admin = await db.users.find_one(
            {"tenant_id": tenant["_id"], "role": "admin"},
            {"_id": 0, "name": 1, "business_name": 1, "email": 1}
        )
        tenant["admin"] = admin
    
    # Daily sales trend
    daily_pipeline = [
        {"$match": {"created_at": {"$gte": start_iso}, "status": {"$ne": "cancelled"}}},
        {"$addFields": {
            "date": {"$dateToString": {"format": "%Y-%m-%d", "date": {"$toDate": "$created_at"}}}
        }},
        {"$group": {
            "_id": "$date",
            "total": {"$sum": "$total"},
            "count": {"$sum": 1}
        }},
        {"$sort": {"_id": 1}}
    ]
    daily_trend = await db.sales.aggregate(daily_pipeline).to_list(365)
    
    # New signups trend
    signup_pipeline = [
        {"$match": {"role": "admin", "created_at": {"$gte": start_iso}}},
        {"$addFields": {
            "date": {"$dateToString": {"format": "%Y-%m-%d", "date": {"$toDate": "$created_at"}}}
        }},
        {"$group": {
            "_id": "$date",
            "count": {"$sum": 1}
        }},
        {"$sort": {"_id": 1}}
    ]
    signup_trend = await db.users.aggregate(signup_pipeline).to_list(365)
    
    # Overall totals
    total_sales_result = await db.sales.aggregate([
        {"$match": {"created_at": {"$gte": start_iso}, "status": {"$ne": "cancelled"}}},
        {"$group": {"_id": None, "total": {"$sum": "$total"}, "count": {"$sum": 1}}}
    ]).to_list(1)
    
    return {
        "period": period,
        "start_date": start_iso,
        "summary": {
            "total_sales": total_sales_result[0]["total"] if total_sales_result else 0,
            "total_orders": total_sales_result[0]["count"] if total_sales_result else 0,
            "new_admins": await db.users.count_documents({"role": "admin", "created_at": {"$gte": start_iso}})
        },
        "categories": categories,
        "top_tenants": top_tenants,
        "daily_trend": daily_trend,
        "signup_trend": signup_trend
    }

