@api_router.post("/employment-applications/{application_id}/convert-to-employee")
async def convert_application_to_employee(
    application_id: str,
    data: dict = Body(...),
    user: dict = Depends(get_current_user)
):
    """Convert approved application to employee record"""
    tenant_id = get_tenant_id(user)
    
    application = await db.employment_applications.find_one(
        {"tenant_id": tenant_id, "id": application_id},
        {"_id": 0}
    )
    
    if not application:
        raise HTTPException(status_code=404, detail="Application not found")
    
    if application.get("status") not in ["approved", "interview_scheduled"]:
        raise HTTPException(status_code=400, detail="Application must be approved before converting to employee")
    
    # Create employee record from application
    employee = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "name": application.get("full_name", ""),
        "email": application.get("email", ""),
        "phone": application.get("contact_number", ""),
        "address": application.get("address", ""),
        "designation": application.get("position_applied", ""),
        "department": application.get("department", ""),
        "store_id": data.get("store_id") or application.get("preferred_store", ""),
        "date_of_birth": application.get("date_of_birth", ""),
        "date_of_joining": data.get("date_of_joining") or application.get("expected_start_date", ""),
        "salary": data.get("salary") or application.get("expected_salary", 0),
        "employment_type": data.get("employment_type", "full-time"),
        "status": "active",
        "application_id": application_id,
        "created_by": user.get("id"),
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Add any additional data from the conversion request
    for key in ["employee_code", "bank_account", "pan_number", "aadhaar_number"]:
        if data.get(key):
            employee[key] = data.get(key)
    
    await db.employees.insert_one(employee)
    
    # Update application status
    await db.employment_applications.update_one(
        {"tenant_id": tenant_id, "id": application_id},
        {"$set": {
            "status": "converted_to_employee",
            "converted_employee_id": employee["id"],
            "converted_at": datetime.now(timezone.utc).isoformat(),
            "converted_by": user.get("name")
        }}
    )
    
    del employee["_id"]
    
    return {
        "message": "Application converted to employee successfully",
        "employee_id": employee["id"],
        "employee": employee
    }

