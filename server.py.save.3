@api_router.get("/inventory")
async def list_inventory(
    store_id: str = "",
    item_id: str = "",
    user: dict = Depends(get_current_user)  # Changed to allow any logged-in user to view inventory
):
    """
    Get inventory records - reads from central_stock (primary source of truth)
    Only shows records with actual warehouse/store assignments (not NULL warehouse_id)
    Falls back to legacy inventory collection for backward compatibility
    """
    tenant_id = get_tenant_id(user)
    
    # Get all stores for this tenant to map IDs to names
    stores = await db.stores.find({"tenant_id": tenant_id}, {"_id": 0, "id": 1, "name": 1}).to_list(100)
    store_map = {s["id"]: s["name"] for s in stores}
    
    # Build query for central_stock - ONLY get records with actual warehouse_id (not NULL)
    cs_query = {"tenant_id": tenant_id, "warehouse_id": {"$ne": None}}
    if store_id:
        cs_query["warehouse_id"] = store_id
    if item_id:
        cs_query["item_id"] = item_id
    
    # Get stock from central_stock (primary source)
    central_stocks = await db.central_stock.find(cs_query, {"_id": 0}).to_list(5000)
    
    # If filtering by store_id and no results, also check for "default" warehouse
    if store_id and not central_stocks:
        cs_query["warehouse_id"] = {"$in": [store_id, "default", None]}
        central_stocks = await db.central_stock.find(cs_query, {"_id": 0}).to_list(5000)
    
    # Pre-fetch all items and variants for efficiency
    item_ids = list(set(s.get("item_id") for s in central_stocks if s.get("item_id")))
    variant_ids = list(set(s.get("variant_id") for s in central_stocks if s.get("variant_id")))
    
    items_list = await db.items.find({"id": {"$in": item_ids}}, {"_id": 0, "id": 1, "name": 1}).to_list(5000)
    variants_list = await db.variants.find({"id": {"$in": variant_ids}}, {"_id": 0}).to_list(5000)
    
    item_map = {i["id"]: i for i in items_list}
    variant_map = {v["id"]: v for v in variants_list}
    
    # Convert central_stock format to inventory format for compatibility
    inventory_result = []
    seen_variants = set()
    
    for stock in central_stocks:
        variant_id = stock.get("variant_id")
        warehouse_id = stock.get("warehouse_id")
        key = f"{variant_id}_{warehouse_id}"
        
        if key in seen_variants:
            continue
        seen_variants.add(key)
        
        # Get variant and item details from pre-fetched data
        variant = variant_map.get(variant_id, {})
        item = item_map.get(stock.get("item_id"), {})
        
        # Get item name - try multiple sources
        item_name = item.get("name", "") or variant.get("item_name", "") or ""
        if not item_name and variant.get("item_id"):
            # Try to get item name from variant's item_id
            item_from_variant = item_map.get(variant.get("item_id"), {})
            item_name = item_from_variant.get("name", "")
        
        # Skip if item has no name (orphaned record)
        if not item_name:
            continue
        
        # Get store name
        store_name = store_map.get(warehouse_id, "Main Store") if warehouse_id else "Main Store"
        
        inventory_result.append({
            "id": stock.get("id"),
            "tenant_id": tenant_id,
            "variant_id": variant_id,
            "item_id": stock.get("item_id"),
            "item_name": item_name,
            "store_id": warehouse_id or stores[0]["id"] if stores else "default",
            "store_name": store_name,
            "quantity": stock.get("quantity", 0),
            "purchase_rate": variant.get("cost_price", 0) or variant.get("purchase_rate", 0),
            "created_at": stock.get("created_at"),
            "updated_at": stock.get("updated_at"),
            # Include variant details
            "size": variant.get("size", ""),
            "color": variant.get("color", ""),
            "sku": variant.get("sku", "")
        })
    
    # If no central_stock records found, fall back to legacy inventory collection
    if not inventory_result:
        query = {"tenant_id": tenant_id}
        if store_id:
            query["store_id"] = store_id
        if item_id:
            query["item_id"] = item_id
        legacy_inventory = await db.inventory.find(query, {"_id": 0}).to_list(5000)
        
        # Enrich legacy inventory with store names
        for inv in legacy_inventory:
            inv["store_name"] = store_map.get(inv.get("store_id"), "Main Store")
            if not inv.get("item_name"):
                item = await db.items.find_one({"id": inv.get("item_id")}, {"_id": 0, "name": 1})
                inv["item_name"] = item.get("name", "Unknown") if item else "Unknown"
        inventory_result = legacy_inventory
    
    return inventory_result


@api_router.post("/inventory/sync-items")
async def sync_inventory_items(user: dict = Depends(require_permission("inventory"))):
    """
    Sync inventory records with items collection.
    Creates missing items from inventory records that have item_name but no matching item in items collection.
    """
    tenant_id = get_tenant_id(user)
    
    # Get all inventory records
    inventory_records = await db.inventory.find({"tenant_id": tenant_id}, {"_id": 0}).to_list(5000)
    
    # Get all existing items
    existing_items = await db.items.find({"tenant_id": tenant_id}, {"_id": 0, "id": 1, "name": 1}).to_list(5000)
    existing_item_ids = {item["id"] for item in existing_items}
    existing_item_names = {item["name"].lower(): item["id"] for item in existing_items}
    
    created_items = []
    synced_count = 0
    
    # Track unique items to create
    items_to_create = {}
    
    for inv in inventory_records:
        item_id = inv.get("item_id")
        item_name = inv.get("item_name") or inv.get("name")
        
        # Skip if item already exists by ID
        if item_id and item_id in existing_item_ids:
            continue
            
        # Skip if no item name available
        if not item_name:
            continue
            
        # Check if item with same name already exists
        if item_name.lower() in existing_item_names:
            # Update inventory record to use the existing item's ID
            existing_id = existing_item_names[item_name.lower()]
            await db.inventory.update_one(
                {"id": inv["id"]},
                {"$set": {"item_id": existing_id}}
            )
            synced_count += 1
            continue
        
        # Track unique item names to create
        if item_name.lower() not in items_to_create:
            new_item_id = str(uuid.uuid4())
            items_to_create[item_name.lower()] = {
                "id": new_item_id,
                "tenant_id": tenant_id,
                "name": item_name,
                "sku": item_name.upper().replace(" ", "-")[:20],
                "description": "",
                "category_id": "",
                "brand_id": "",
                "selling_price": inv.get("purchase_rate", 0) * 1.3,
                "cost_price": inv.get("purchase_rate", 0),
                "gst_rate": 18,
                "min_stock_alert": 5,
                "active": True,
                "current_stock": 0,
                "created_at": datetime.now(timezone.utc).isoformat()
            }
            created_items.append(items_to_create[item_name.lower()])
            existing_item_names[item_name.lower()] = new_item_id
        
        # Update inventory record with new item_id
        await db.inventory.update_one(
            {"id": inv["id"]},
            {"$set": {"item_id": items_to_create[item_name.lower()]["id"]}}
        )
        synced_count += 1
    
    # Insert all new items
    if created_items:
        await db.items.insert_many(created_items)
        
        # Create default variants for new items
        variants_to_create = []
        central_stocks_to_create = []
        for item in created_items:
            variant_id = str(uuid.uuid4())
            variant = {
                "id": variant_id,
                "item_id": item["id"],
                "tenant_id": tenant_id,
                "sku": item["sku"] + "-001",
                "size": "",
                "color": "",
                "selling_price": item["selling_price"],
                "cost_price": item["cost_price"],
                "current_stock": 0,
                "created_at": datetime.now(timezone.utc).isoformat()
            }
            variants_to_create.append(variant)
            
            # Create central_stock record for each variant
            central_stocks_to_create.append({
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "item_id": item["id"],
                "variant_id": variant_id,
                "warehouse_id": None,
                "quantity": 0,
                "created_at": datetime.now(timezone.utc).isoformat(),
                "updated_at": datetime.now(timezone.utc).isoformat()
            })
        
        if variants_to_create:
            await db.variants.insert_many(variants_to_create)
        if central_stocks_to_create:
            await db.central_stock.insert_many(central_stocks_to_create)
    
    # Update stock counts on all created items
    for item in created_items:
        total = await db.inventory.aggregate([
            {"$match": {"item_id": item["id"], "tenant_id": tenant_id}},
            {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
        ]).to_list(1)
        total_stock = total[0]["total"] if total else 0
        await db.items.update_one({"id": item["id"]}, {"$set": {"current_stock": total_stock}})
    
    # Also sync purchase invoice items that may not have been added to items
    purchase_invoices = await db.purchase_invoices.find({"tenant_id": tenant_id}, {"_id": 0, "items": 1}).to_list(1000)
    purchase_items_synced = 0
    
    for inv in purchase_invoices:
        for item in inv.get("items", []):
            item_name = item.get("name")
            if not item_name:
                continue
            if item_name.lower() in existing_item_names:
                continue
            
            # Create item from purchase
            new_item_id = str(uuid.uuid4())
            new_variant_id = str(uuid.uuid4())
            now = datetime.now(timezone.utc).isoformat()
            
            new_item = {
                "id": new_item_id,
                "tenant_id": tenant_id,
                "name": item_name,
                "sku": item_name.upper().replace(" ", "-")[:20] + "-P",
                "description": "",
                "selling_price": item.get("rate", 0) * 1.3,
                "cost_price": item.get("rate", 0),
                "active": True,
                "current_stock": item.get("quantity", 0),
                "created_at": now,
                "created_by_sync": True
            }
            await db.items.insert_one(new_item)
            
            # Create default variant for item from purchase
            variant_doc = {
                "id": new_variant_id,
                "tenant_id": tenant_id,
                "item_id": new_item_id,
                "sku": new_item["sku"] + "-001",
                "size": "",
                "color": "",
                "selling_price": new_item["selling_price"],
                "cost_price": new_item["cost_price"],
                "current_stock": item.get("quantity", 0),
                "created_at": now
            }
            await db.variants.insert_one(variant_doc)
            
            # Create central_stock record
            central_stock_doc = {
                "id": str(uuid.uuid4()),
                "tenant_id": tenant_id,
                "item_id": new_item_id,
                "variant_id": new_variant_id,
                "warehouse_id": None,
                "quantity": item.get("quantity", 0),
                "created_at": now,
                "updated_at": now
            }
            await db.central_stock.insert_one(central_stock_doc)
            
            existing_item_names[item_name.lower()] = new_item_id
            purchase_items_synced += 1
    
    return {
        "message": f"Sync complete. Created {len(created_items)} items from inventory, {purchase_items_synced} from purchases, synced {synced_count} records.",
        "created_items": len(created_items),
        "purchase_items_created": purchase_items_synced,
        "synced_records": synced_count
    }

@api_router.post("/inventory/adjust")
async def adjust_inventory(
    variant_id: str,
    store_id: str,
    quantity: int,
    purchase_rate: float = 0,
    user: dict = Depends(require_permission("inventory"))
):
    tenant_id = get_tenant_id(user)
    inv_service = get_inventory_service()
    
    # Get variant info
    variant = await db.variants.find_one({"id": variant_id})
    if not variant:
        raise HTTPException(status_code=404, detail="Variant not found")
    
    item_id = variant.get("item_id", "")
    
    # Get current quantity from central_stock
    current_qty = await inv_service.get_stock(tenant_id, variant_id=variant_id, warehouse_id=store_id)
    new_quantity = current_qty + quantity
    
    # Update central_stock through inventory service
    if quantity > 0:
        await inv_service.add_stock(
            tenant_id=tenant_id,
            item_id=item_id,
            variant_id=variant_id,
            quantity=quantity,
            movement_type=MovementType.ADJUSTMENT,
            warehouse_id=store_id,
            notes=f"Manual adjustment: +{quantity}",
            performed_by=user.get("id")
        )
    elif quantity < 0:
        await inv_service.deduct_stock(
            tenant_id=tenant_id,
            item_id=item_id,
            variant_id=variant_id,
            quantity=abs(quantity),
            movement_type=MovementType.ADJUSTMENT,
            warehouse_id=store_id,
            notes=f"Manual adjustment: {quantity}",
            performed_by=user.get("id"),
            allow_negative=True  # Allow negative adjustment
        )
    
    # Also update legacy inventory table for backward compatibility
    existing = await db.inventory.find_one({
        "tenant_id": tenant_id,
        "variant_id": variant_id,
        "store_id": store_id
    })
    
    if existing:
        await db.inventory.update_one(
            {"id": existing["id"]},
            {"$set": {
                "quantity": new_quantity,
                "purchase_rate": purchase_rate or existing.get("purchase_rate", 0),
                "updated_at": datetime.now(timezone.utc).isoformat()
            }}
        )
    else:
        inv_doc = {
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "variant_id": variant_id,
            "item_id": item_id,
            "store_id": store_id,
            "quantity": new_quantity,
            "purchase_rate": purchase_rate,
            "created_at": datetime.now(timezone.utc).isoformat()
        }
        await db.inventory.insert_one(inv_doc)
    
    # Update variant total stock
    total = await db.inventory.aggregate([
        {"$match": {"variant_id": variant_id}},
        {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
    ]).to_list(1)
    
    total_stock = total[0]["total"] if total else new_quantity
    await db.variants.update_one({"id": variant_id}, {"$set": {"current_stock": total_stock}})
    
    # Update item total stock
    item_total = await db.inventory.aggregate([
        {"$match": {"item_id": item_id}},
        {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
    ]).to_list(1)
    
    item_stock = item_total[0]["total"] if item_total else 0
    stock_status = "in_stock" if item_stock > 0 else "out_of_stock"
    await db.items.update_one(
        {"id": item_id},
        {"$set": {
            "current_stock": item_stock,
            "total_stock": item_stock,
            "stock_status": stock_status,
            "stock_updated_at": datetime.now(timezone.utc).isoformat()
        }}
    )
    
    return {"message": "Inventory adjusted", "new_quantity": new_quantity}

@api_router.delete("/inventory/{inventory_id}")
async def delete_inventory(inventory_id: str, user: dict = Depends(get_current_user)):
    """Delete an inventory record. Admins have full delete access."""
    tenant_id = get_tenant_id(user)
    
    # Admins can delete any inventory record
    if not is_admin_or_higher(user):
        permissions = user.get("permissions", {})
        if not permissions.get("inventory", {}).get("delete", False):
            raise HTTPException(status_code=403, detail="Permission denied. Admin access required for delete.")
    
    # First try to find in central_stock (primary source)
    cs_record = await db.central_stock.find_one({"id": inventory_id, "tenant_id": tenant_id})
    if cs_record:
        variant_id = cs_record.get("variant_id")
        item_id = cs_record.get("item_id")
        
        # Delete from central_stock
        await db.central_stock.delete_one({"id": inventory_id})
        
        # Update variant total stock from remaining central_stock records
        if variant_id:
            total = await db.central_stock.aggregate([
                {"$match": {"variant_id": variant_id, "tenant_id": tenant_id}},
                {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
            ]).to_list(1)
            total_stock = total[0]["total"] if total else 0
            await db.variants.update_one({"id": variant_id}, {"$set": {"current_stock": total_stock}})
        
        # Update item total stock
        if item_id:
            item_total = await db.central_stock.aggregate([
                {"$match": {"item_id": item_id, "tenant_id": tenant_id}},
                {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
            ]).to_list(1)
            item_stock = item_total[0]["total"] if item_total else 0
            await db.items.update_one({"id": item_id}, {"$set": {"current_stock": item_stock}})
        
        return {"message": "Inventory record deleted", "deleted_from": "central_stock"}
    
    # Fallback: Try to find in legacy inventory collection
    inv = await db.inventory.find_one({"id": inventory_id, "tenant_id": tenant_id})
    if not inv:
        raise HTTPException(status_code=404, detail="Inventory record not found")
    
    variant_id = inv.get("variant_id")
    item_id = inv.get("item_id")
    
    # Delete the inventory record
    await db.inventory.delete_one({"id": inventory_id})
    
    # Update variant total stock
    if variant_id:
        total = await db.inventory.aggregate([
            {"$match": {"variant_id": variant_id}},
            {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
        ]).to_list(1)
        total_stock = total[0]["total"] if total else 0
        await db.variants.update_one({"id": variant_id}, {"$set": {"current_stock": total_stock}})
    
    # Update item total stock
    if item_id:
        item_total = await db.inventory.aggregate([
            {"$match": {"item_id": item_id}},
            {"$group": {"_id": None, "total": {"$sum": "$quantity"}}}
        ]).to_list(1)
        item_stock = item_total[0]["total"] if item_total else 0
        stock_status = "in_stock" if item_stock > 0 else "out_of_stock"
        await db.items.update_one(
            {"id": item_id},
            {"$set": {
                "current_stock": item_stock,
                "total_stock": item_stock,
                "stock_status": stock_status,
                "stock_updated_at": datetime.now(timezone.utc).isoformat()
            }}
        )
    
    return {"message": "Inventory record deleted"}

# ============== STOCK AUDIT TRAIL ==============

@api_router.get("/stock-audit-trail")
async def get_stock_audit_trail(
    item_id: str = "",
    variant_id: str = "",
    store_id: str = "",
    movement_type: str = "",
    reference_type: str = "",
    start_date: str = "",
    end_date: str = "",
    limit: int = 100,
    offset: int = 0,
    user: dict = Depends(require_permission("stock_audit"))
):
    """Get stock movement audit trail with filters"""
    tenant_id = get_tenant_id(user)
    
    query = {"tenant_id": tenant_id}
    
    if item_id:
        query["item_id"] = item_id
    if variant_id:
        query["variant_id"] = variant_id
    if store_id:
        query["store_id"] = store_id
    if movement_type:
        query["movement_type"] = movement_type
    if reference_type:
        query["reference_type"] = reference_type
    if start_date:
        query["created_at"] = {"$gte": start_date}
    if end_date:
        if "created_at" in query:
            query["created_at"]["$lte"] = end_date
        else:
            query["created_at"] = {"$lte": end_date}
    
    # Get total count
    total = await db.stock_movement_audit.count_documents(query)
    
    # Get audit trail entries
    entries = await db.stock_movement_audit.find(
        query, 
        {"_id": 0}
    ).sort("created_at", -1).skip(offset).limit(limit).to_list(limit)
    
    # Enrich entries with item/variant details for display
    enriched_entries = []
    for entry in entries:
        # Get item name
        item = await db.items.find_one({"id": entry.get("item_id")}, {"_id": 0, "name": 1})
        # Get variant details
        variant = await db.variants.find_one({"id": entry.get("variant_id")}, {"_id": 0, "size": 1, "color": 1, "barcode": 1})
        # Get store name
        store = await db.stores.find_one({"id": entry.get("store_id")}, {"_id": 0, "name": 1})
        
        enriched_entry = {
            **entry,
            "item_name": item.get("name") if item else entry.get("item_id", "Unknown"),
            "variant_display": f"{variant.get('size', '')} {variant.get('color', '')}".strip() if variant else entry.get("variant_id", "-"),
            "variant_barcode": variant.get("barcode") if variant else "-",
            "store_name": store.get("name") if store else entry.get("store_id", "Default"),
            # Ensure these fields are present
            "reference_id": entry.get("reference_id") or entry.get("reference") or "-",
            "variant_id": entry.get("variant_id") or "-"
        }
        enriched_entries.append(enriched_entry)
    
    return {
        "total": total,
        "limit": limit,
        "offset": offset,
        "entries": enriched_entries
    }

@api_router.get("/stock-audit-trail/summary")
async def get_stock_audit_summary(
    item_id: str = "",
    store_id: str = "",
    start_date: str = "",
    end_date: str = "",
    user: dict = Depends(require_permission("stock_audit"))
):
    """Get summary of stock movements by type"""
    tenant_id = get_tenant_id(user)
    
    match_query = {"tenant_id": tenant_id}
    if item_id:
        match_query["item_id"] = item_id
    if store_id:
        match_query["store_id"] = store_id
    if start_date:
        match_query["created_at"] = {"$gte": start_date}
    if end_date:
        if "created_at" in match_query:
            match_query["created_at"]["$lte"] = end_date
        else:
            match_query["created_at"] = {"$lte": end_date}
    
    # Aggregate by movement type
    pipeline = [
        {"$match": match_query},
        {"$group": {
            "_id": "$movement_type",
            "total_movements": {"$sum": 1},
            "total_quantity_change": {"$sum": "$quantity_change"},
            "total_added": {"$sum": {"$cond": [{"$gt": ["$quantity_change", 0]}, "$quantity_change", 0]}},
            "total_removed": {"$sum": {"$cond": [{"$lt": ["$quantity_change", 0]}, {"$abs": "$quantity_change"}, 0]}}
        }},
        {"$sort": {"total_movements": -1}}
    ]
    
    summary = await db.stock_movement_audit.aggregate(pipeline).to_list(100)
    
    # Get top items by movements
    top_items_pipeline = [
        {"$match": match_query},
        {"$group": {
            "_id": {"item_id": "$item_id", "item_name": "$item_name"},
            "total_movements": {"$sum": 1},
            "net_change": {"$sum": "$quantity_change"}
        }},
        {"$sort": {"total_movements": -1}},
        {"$limit": 10}
    ]
    
    top_items = await db.stock_movement_audit.aggregate(top_items_pipeline).to_list(10)
    
    # Get recent activity by user
    user_activity_pipeline = [
        {"$match": match_query},
        {"$group": {
            "_id": {"user_id": "$user_id", "user_name": "$user_name"},
            "total_movements": {"$sum": 1},
            "last_activity": {"$max": "$created_at"}
        }},
        {"$sort": {"total_movements": -1}},
        {"$limit": 10}
    ]
    
    user_activity = await db.stock_movement_audit.aggregate(user_activity_pipeline).to_list(10)
    
    return {
        "by_movement_type": summary,
        "top_items": top_items,
        "user_activity": user_activity
    }

@api_router.post("/stock-audit-trail/manual-adjustment")
async def create_manual_stock_adjustment(
    data: dict,
    user: dict = Depends(require_permission("stock_audit"))
):
    """Create a manual stock adjustment with audit trail"""
    tenant_id = get_tenant_id(user)
    
    variant_id = data.get("variant_id")
    store_id = data.get("store_id")
    quantity_change = data.get("quantity_change", 0)
    adjustment_reason = data.get("reason", "adjustment_add" if quantity_change > 0 else "adjustment_remove")
    notes = data.get("notes", "")
    
    if not variant_id or not store_id:
        raise HTTPException(status_code=400, detail="variant_id and store_id are required")
    
    # Get current inventory
    inventory = await db.inventory.find_one({
        "tenant_id": tenant_id,
        "variant_id": variant_id,
        "store_id": store_id
    })
    
    quantity_before = inventory.get("quantity", 0) if inventory else 0
    quantity_after = quantity_before + quantity_change
    
    if quantity_after < 0:
        raise HTTPException(status_code=400, detail="Cannot reduce stock below 0")
    
    # Get item and store details for audit
    variant = await db.variants.find_one({"id": variant_id}, {"_id": 0})
    item = await db.items.find_one({"id": variant.get("item_id")}, {"_id": 0}) if variant else None
    store = await db.stores.find_one({"id": store_id}, {"_id": 0})
    
    # Update inventory
    if inventory:
        await db.inventory.update_one(
            {"tenant_id": tenant_id, "variant_id": variant_id, "store_id": store_id},
            {"$set": {"quantity": quantity_after}}
        )
    else:
        await db.inventory.insert_one({
            "id": str(uuid.uuid4()),
            "tenant_id": tenant_id,
            "item_id": variant.get("item_id") if variant else None,
            "variant_id": variant_id,
            "store_id": store_id,
            "quantity": quantity_after,
            "created_at": datetime.now(timezone.utc).isoformat()
        })
    
    # Log to audit trail
    movement_log = await log_stock_movement(
        tenant_id=tenant_id,
        item_id=variant.get("item_id") if variant else None,
        variant_id=variant_id,
        store_id=store_id,
        movement_type=adjustment_reason,
        quantity_change=quantity_change,
        quantity_before=quantity_before,
        quantity_after=quantity_after,
        user_id=user.get("id"),
        user_name=user.get("name"),
        reference_type="manual_adjustment",
        reference_id=None,
        notes=notes,
        item_name=item.get("name") if item else None,
        store_name=store.get("name") if store else None
    )
    
    return {
        "message": "Stock adjustment recorded",
        "quantity_before": quantity_before,
        "quantity_after": quantity_after,
        "audit_log_id": movement_log.get("id")
    }


# ============== PUBLIC STORE API (NO AUTH REQUIRED) ==============

@api_router.get("/store/products")
async def get_store_products(
    tenant_id: Optional[str] = None,
    category: Optional[str] = None,
    search: Optional[str] = None,
    limit: int = 100
):
    """
    Public API endpoint for customer-facing store.
    Returns products with variants and stock information.
    No authentication required.
    """
    # If no tenant_id provided, get a default or first available
    if not tenant_id:
        # Find tenant with most products (for demo)
        pipeline = [
            {"$group": {"_id": "$tenant_id", "count": {"$sum": 1}}},
            {"$sort": {"count": -1}},
            {"$limit": 1}
        ]
        result = await db.items.aggregate(pipeline).to_list(1)
        if result:
            tenant_id = result[0]["_id"]
        else:
            return {"products": [], "total": 0}
    
    # Build query
    query = {"tenant_id": tenant_id}
    
    if category:
        query["category"] = category
    
    if search:
        query["$or"] = [
            {"name": {"$regex": search, "$options": "i"}},
            {"description": {"$regex": search, "$options": "i"}}
        ]
    
    # Fetch items
    items = await db.items.find(query, {"_id": 0}).limit(limit).to_list(limit)
    
    if not items:
        return {"products": [], "total": 0}
    
    # Fetch variants for all items
    item_ids = [item["id"] for item in items]
    variants = await db.variants.find(
        {"item_id": {"$in": item_ids}},
        {"_id": 0}
    ).to_list(5000)
    
    # Fetch stock from central_stock
    variant_ids = [v["id"] for v in variants]
    central_stock = await db.central_stock.find(
        {"variant_id": {"$in": variant_ids}},
        {"_id": 0, "variant_id": 1, "quantity": 1}
    ).to_list(10000)
    
    # Build stock map
    stock_map = {}
    for stock in central_stock:
        vid = stock.get("variant_id")
        stock_map[vid] = stock_map.get(vid, 0) + (stock.get("quantity", 0) or 0)
    
    # Update variant stock
    for v in variants:
        v["current_stock"] = stock_map.get(v["id"], 0)
    
    # Group variants by item
    variants_by_item = {}
    for v in variants:
        item_id = v.get("item_id")
        if item_id not in variants_by_item:
            variants_by_item[item_id] = []
        variants_by_item[item_id].append(v)
    
    # Attach variants and calculate total stock
    for item in items:
        item["variants"] = variants_by_item.get(item["id"], [])
        item["current_stock"] = sum(v.get("current_stock", 0) for v in item["variants"])
    
    return {
        "products": items,
        "total": len(items),
        "tenant_id": tenant_id
    }


@api_router.get("/store/product/{product_id}")
async def get_store_product(product_id: str):
    """
    Get single product details for customer store.
    No authentication required.
    """
    item = await db.items.find_one({"id": product_id}, {"_id": 0})
    
    if not item:
        raise HTTPException(status_code=404, detail="Product not found")
    
    # Fetch variants
    variants = await db.variants.find(
        {"item_id": product_id},
        {"_id": 0}
    ).to_list(100)
    
    # Fetch stock
    variant_ids = [v["id"] for v in variants]
    central_stock = await db.central_stock.find(
        {"variant_id": {"$in": variant_ids}},
        {"_id": 0, "variant_id": 1, "quantity": 1}
    ).to_list(1000)
    
    stock_map = {s["variant_id"]: s.get("quantity", 0) for s in central_stock}
    
    for v in variants:
        v["current_stock"] = stock_map.get(v["id"], 0)
    
    item["variants"] = variants
    item["current_stock"] = sum(v.get("current_stock", 0) for v in variants)
    
    return item


