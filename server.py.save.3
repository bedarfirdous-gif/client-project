@api_router.post("/sales/sync-offline")
async def sync_offline_sale(request: Request, user: dict = Depends(require_permission("invoices"))):
    """
    Sync offline sales - more lenient than regular sales endpoint.
    Accepts sales created offline and syncs them without strict stock validation.
    """
    tenant_id = get_tenant_id(user)
    data = await request.json()
    
    # Check if this offline sale was already synced (idempotency)
    offline_id = data.get("offline_id")
    if offline_id:
        existing = await db.sales.find_one({"offline_id": offline_id, "tenant_id": tenant_id})
        if existing:
            return {"message": "Already synced", "sale_id": existing.get("id"), "invoice_number": existing.get("invoice_number")}
    
    # Generate invoice number
    count = await db.sales.count_documents({"tenant_id": tenant_id})
    invoice_number = f"INV-{count + 1:06d}"
    sale_id = str(uuid.uuid4())
    
    # Prepare sale document
    sale = {
        "id": sale_id,
        "tenant_id": tenant_id,
        "invoice_number": invoice_number,
        "offline_id": offline_id,
        "synced_from_offline": True,
        "items": data.get("items", []),
        "customer_id": data.get("customer_id"),
        "customer_name": data.get("customer_name", "Walk-in Customer"),
        "customer_phone": data.get("customer_phone"),
        "store_id": data.get("store_id"),
        "subtotal": data.get("subtotal", 0),
        "discount_amount": data.get("discount_amount", 0),
        "tax_amount": data.get("tax_amount", 0),
        "total_amount": data.get("total_amount", 0),
        "amount_paid": data.get("amount_paid", 0),
        "payment_method": data.get("payment_method", "cash"),
        "status": "completed",
        "sale_date": data.get("sale_date") or data.get("created_offline_at") or datetime.now(timezone.utc).isoformat(),
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get("id"),
        "notes": data.get("notes", "Synced from offline sale")
    }
    
    # Try to deduct stock (but don't fail if stock is insufficient - sale already happened)
    try:
        inv_service = get_inventory_service()
        for item in sale["items"]:
            if item.get("variant_id"):
                try:
                    await inv_service.record_stock_movement(
                        tenant_id=tenant_id,
                        item_id=item.get("item_id"),
                        variant_id=item.get("variant_id"),
                        movement_type="sale",
                        quantity=-abs(item.get("quantity", 1)),
                        reference_type="sale",
                        reference_id=sale_id,
                        warehouse_id=data.get("store_id"),
                        notes=f"Offline sale sync: {invoice_number}"
                    )
                except Exception as stock_err:
                    logger.warning(f"Stock deduction failed for offline sale {sale_id}: {stock_err}")
    except Exception as e:
        logger.warning(f"Stock processing failed for offline sale: {e}")
    
    # Insert sale
    await db.sales.insert_one(sale)
    
    # Update daily summary
    try:
        today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
        await db.daily_summaries.update_one(
            {"tenant_id": tenant_id, "date": today},
            {
                "$inc": {
                    "total_sales": sale["total_amount"],
                    "sales_count": 1
                }
            },
            upsert=True
        )
    except Exception as e:
        logger.warning(f"Daily summary update failed: {e}")
    
    return {
        "message": "Offline sale synced successfully",
        "sale_id": sale_id,
        "invoice_number": invoice_number
    }

@api_router.post("/sales")
async def create_sale(request: SaleCreate, user: dict = Depends(require_permission("invoices"))):
    tenant_id = get_tenant_id(user)
    inv_service = get_inventory_service()
    
    # Get invoice number
    count = await db.sales.count_documents({"tenant_id": tenant_id})
    invoice_number = f"INV-{count + 1:06d}"
    sale_id = str(uuid.uuid4())
    
    # Prepare items for stock check and GST calculation
    stock_items = []
    items_with_gst = []
    total_taxable = 0
    total_cgst = 0
    total_sgst = 0
    total_gst = 0
    
    for item in request.items:
        variant_id = item.get("variant_id")
        item_id = item.get("item_id", "")
        quantity = item.get("quantity", 1)
        rate = item.get("rate", 0)
        amount = rate * quantity
        
        if variant_id:
            stock_items.append({
                "item_id": item_id,
                "variant_id": variant_id,
                "quantity": quantity
            })
        
        # CENTRALIZED GST CALCULATION - Auto-calculate from item's GST slab
        if item_id:
            gst_calc = await calculate_gst_for_item(tenant_id, item_id, variant_id, amount, is_inclusive=False)
            items_with_gst.append({
                "item_id": item_id,
                "variant_id": variant_id,
                "item_name": item.get("item_name", ""),
                "hsn_code": item.get("hsn_code", ""),
                "quantity": quantity,
                "rate": rate,
                "amount": amount,
                **gst_calc
            })
            total_taxable += gst_calc["taxable_amount"]
            total_cgst += gst_calc["cgst"]
            total_sgst += gst_calc["sgst"]
            total_gst += gst_calc["total_gst"]
    
    # CENTRALIZED STOCK CHECK - Fail if insufficient stock (unless skipped)
    if stock_items and not request.skip_stock_check:
        availability = await inv_service.check_stock_availability(
            tenant_id, stock_items, warehouse_id=request.store_id
        )
        
        if not availability["available"]:
            insufficient = availability["insufficient"]
            error_msgs = []
            for insuff in insufficient:
                variant = await db.variants.find_one({"id": insuff["variant_id"]}, {"_id": 0, "size": 1, "color": 1})
                var_desc = f"{variant.get('size', '')} {variant.get('color', '')}".strip() if variant else insuff["variant_id"]
                error_msgs.append(f"{var_desc}: need {insuff['requested']}, have {insuff['available']}")
            raise HTTPException(
                status_code=400, 
                detail=f"Insufficient stock: {'; '.join(error_msgs)}"
            )
        
        # CENTRALIZED STOCK DEDUCTION - Process sale through inventory service
        try:
            await inv_service.process_sale(
                tenant_id=tenant_id,
                sale_id=sale_id,
                items=stock_items,
                warehouse_id=request.store_id,
                performed_by=user.get("id")
            )
        except HTTPException as e:
            raise e
        except Exception as e:
            logger.error(f"Failed to process sale stock: {e}")
            raise HTTPException(status_code=500, detail="Failed to update stock")
    
    # Also update legacy inventory table for backward compatibility
    for item in request.items:
        variant_id = item.get("variant_id")
        quantity = item.get("quantity", 0)
        if variant_id:
            await db.inventory.update_one(
                {"variant_id": variant_id, "store_id": request.store_id},
                {"$inc": {"quantity": -quantity}}
            )
    
    # Use calculated GST if not provided in request
    gst_amount = request.gst_amount if request.gst_amount > 0 else total_gst
    
    sale_doc = {
        "id": sale_id,
        "invoice_number": invoice_number,
        "tenant_id": tenant_id,
        **request.model_dump(),
        "gst_amount": round(gst_amount, 2),
        "cgst_amount": round(total_cgst, 2),
        "sgst_amount": round(total_sgst, 2),
        "taxable_amount": round(total_taxable, 2),
        "items_with_gst": items_with_gst,
        "is_finalized": True,  # Sales are immutable once created
        "created_by": user.get("id"),
        "created_by_name": user.get("name"),
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    # Update voucher usage
    if request.voucher_code:
        await db.vouchers.update_one(
            {"code": request.voucher_code.upper()},
            {"$inc": {"used_count": 1}}
        )
    
    # Update customer loyalty points
    if request.customer_id:
        points = int(request.total_amount / 100)  # 1 point per 100
        await db.customers.update_one(
            {"id": request.customer_id},
            {"$inc": {"loyalty_points": points}}
        )
    
    await db.sales.insert_one(sale_doc)
    
    # RECORD GST LEDGER ENTRY (OUTPUT GST)
    if total_gst > 0:
        await record_gst_ledger_entry(
            tenant_id=tenant_id,
            entry_type="OUTPUT",
            reference_type="sale",
            reference_id=sale_id,
            reference_number=invoice_number,
            party_name=request.customer_name or "Walk-in Customer",
            party_gstin="",  # Customer GSTIN if B2B
            items_gst=items_with_gst,
            performed_by=user.get("id"),
            is_finalized=True
        )
    
    # ============== AUTOMATIC ACCOUNTING INTEGRATION ==============
    sale_date = datetime.now(timezone.utc).isoformat()
    customer_id = request.customer_id or str(uuid.uuid4())
    customer_name = request.customer_name or "Walk-in Customer"
    
    # 1. Process Sale Accounting (Debit: Debtor, Credit: Sales)
    await process_sale_accounting(
        tenant_id=tenant_id,
        invoice_id=sale_id,
        invoice_number=invoice_number,
        customer_id=customer_id,
        customer_name=customer_name,
        total_amount=request.total_amount,
        date=sale_date,
        store_id=request.store_id
    )
    
    # 2. Process Receipt Accounting based on payment method(s)
    # This updates Cash/Bank ledger and creates receipt entry
    payment_methods = request.payment_methods or []
    
    # If no payment_methods array, use the single payment_method field
    if not payment_methods and request.payment_method:
        payment_methods = [{"method": request.payment_method, "amount": request.total_amount}]
    
    for idx, payment in enumerate(payment_methods):
        payment_mode = payment.get("method", "cash").lower()
        payment_amount = payment.get("amount", 0)
        
        if payment_amount > 0:
            receipt_number = f"RCP-{invoice_number}"
            if len(payment_methods) > 1:
                receipt_number = f"RCP-{invoice_number}-{idx + 1}"
            
            # Map payment modes to accounting modes
            if payment_mode in ["cash"]:
                accounting_mode = "cash"
            elif payment_mode in ["bank", "upi", "card", "neft", "rtgs", "imps", "cheque"]:
                accounting_mode = "bank"
            else:
                accounting_mode = "cash"  # Default to cash
            
            await process_receipt_accounting(
                tenant_id=tenant_id,
                receipt_id=f"{sale_id}-rcpt-{idx}",
                receipt_number=receipt_number,
                customer_id=customer_id,
                customer_name=customer_name,
                amount=payment_amount,
                payment_mode=accounting_mode,
                date=sale_date,
                store_id=request.store_id,
                invoice_id=sale_id
            )
            
            # Also create a receipt document for tracking
            receipt_doc = {
                "id": f"{sale_id}-rcpt-{idx}",
                "receipt_number": receipt_number,
                "tenant_id": tenant_id,
                "customer_id": customer_id,
                "customer_name": customer_name,
                "invoice_id": sale_id,
                "invoice_number": invoice_number,
                "amount": payment_amount,
                "payment_mode": payment_mode,
                "accounting_mode": accounting_mode,
                "date": sale_date,
                "store_id": request.store_id,
                "notes": f"Auto-generated receipt for {invoice_number}",
                "created_by": user.get("id"),
                "created_at": sale_date
            }
            await db.receipts.insert_one(receipt_doc)
    
    logger.info(f"Sale {invoice_number} created with automatic accounting entries")
    # ============== END ACCOUNTING INTEGRATION ==============
    
    # ============== POST GST TO LEDGERS ==============
    if sale_doc.get("gst_amount", 0) > 0:
        cgst = sale_doc.get("cgst_amount", sale_doc.get("gst_amount", 0) / 2)
        sgst = sale_doc.get("sgst_amount", sale_doc.get("gst_amount", 0) / 2)
        igst = 0  # Will be calculated if interstate
        
        # Check if interstate (customer state != seller state)
        is_interstate = False
        customer_gstin = request.customer_gstin if hasattr(request, 'customer_gstin') else ""
        if customer_gstin and len(customer_gstin) >= 2:
            # Get seller state from GST config
            gst_config = await db.gst_config.find_one({"tenant_id": tenant_id})
            seller_gstin = gst_config.get("seller_gstin", "") if gst_config else ""
            if seller_gstin and len(seller_gstin) >= 2:
                if customer_gstin[:2] != seller_gstin[:2]:
                    is_interstate = True
                    igst = sale_doc.get("gst_amount", 0)
                    cgst = 0
                    sgst = 0
        
        await post_gst_to_ledgers(
            tenant_id=tenant_id,
            transaction_type="sale",
            reference_id=sale_id,
            reference_number=invoice_number,
            cgst_amount=cgst,
            sgst_amount=sgst,
            igst_amount=igst,
            is_interstate=is_interstate,
            date=sale_date,
            party_name=customer_name,
            party_gstin=customer_gstin,
            store_id=request.store_id
        )
        logger.info(f"GST ledger posted for {invoice_number}: CGST={cgst}, SGST={sgst}, IGST={igst}")
    # ============== END GST LEDGER POSTING ==============
    
    del sale_doc["_id"]
    return sale_doc

# Cancel a sale
@api_router.put("/sales/{sale_id}/cancel")
async def cancel_sale(sale_id: str, reason: str = "", user: dict = Depends(require_permission("invoices"))):
    """Cancel a sale and restore inventory via centralized inventory service"""
    tenant_id = get_tenant_id(user)
    inv_service = get_inventory_service()
    
    # Find the sale
    sale = await db.sales.find_one({"id": sale_id, "tenant_id": tenant_id})
    if not sale:
        raise HTTPException(status_code=404, detail="Sale not found")
    
    if sale.get("status") == "cancelled":
        raise HTTPException(status_code=400, detail="Sale is already cancelled")
    
    # Restore inventory for each item via centralized service
    return_items = []
    for item in sale.get("items", []):
        variant_id = item.get("variant_id")
        quantity = item.get("quantity", 0)
        
        if variant_id and quantity > 0:
            return_items.append({
                "item_id": item.get("item_id", ""),
                "variant_id": variant_id,
                "quantity": quantity
            })
            
            # Also update legacy inventory for backward compatibility
            await db.inventory.update_one(
                {"variant_id": variant_id, "store_id": sale.get("store_id")},
                {"$inc": {"quantity": quantity}}
            )
    
    # Process return through centralized inventory service
    if return_items:
        try:
            await inv_service.process_return(
                tenant_id=tenant_id,
                return_id=sale_id,
                items=return_items,
                return_type="sale_return",
                warehouse_id=sale.get("store_id"),
                performed_by=user.get("id")
            )
        except Exception as e:
            logger.error(f"Failed to restore stock on cancel: {e}")
            # Continue with cancellation even if stock restore fails
    
    # Update sale status
    await db.sales.update_one(
        {"id": sale_id},
        {"$set": {
            "status": "cancelled",
            "cancel_reason": reason,
            "cancelled_at": datetime.now(timezone.utc).isoformat(),
            "cancelled_by": user.get("id"),
            "cancelled_by_name": user.get("name")
        }}
    )
    
    return {"message": "Sale cancelled successfully", "invoice_number": sale.get("invoice_number")}


# DELETE a sale completely (hard delete with all related records)
@api_router.delete("/sales/{sale_id}")
async def delete_sale(sale_id: str, user: dict = Depends(require_permission("invoices"))):
    """
    Permanently delete a sale and all related records.
    This includes: inventory restoration, GST ledger entries, customer loyalty points,
    voucher usage, payment records, and ledger entries.
    """
    tenant_id = get_tenant_id(user)
    inv_service = get_inventory_service()
    
    # Find the sale
    sale = await db.sales.find_one({"id": sale_id, "tenant_id": tenant_id})
    if not sale:
        raise HTTPException(status_code=404, detail="Sale not found")
    
    invoice_number = sale.get("invoice_number", "")
    deleted_items = []
    
    try:
        # 1. Restore inventory for each item (if not already cancelled)
        if sale.get("status") != "cancelled":
            for item in sale.get("items", []):
                variant_id = item.get("variant_id")
                quantity = item.get("quantity", 0)
                
                if variant_id and quantity > 0:
                    # Restore via centralized inventory service
                    try:
                        await inv_service.process_return(
                            tenant_id=tenant_id,
                            return_id=f"delete_{sale_id}",
                            items=[{
                                "item_id": item.get("item_id", ""),
                                "variant_id": variant_id,
                                "quantity": quantity
                            }],
                            return_type="sale_delete",
                            warehouse_id=sale.get("store_id"),
                            performed_by=user.get("id")
                        )
                    except Exception as e:
                        logger.warning(f"Inventory service return failed: {e}")
                    
                    # Also restore legacy inventory
                    await db.inventory.update_one(
                        {"variant_id": variant_id, "store_id": sale.get("store_id")},
                        {"$inc": {"quantity": quantity}}
                    )
                    deleted_items.append({"variant_id": variant_id, "quantity_restored": quantity})
        
        # 2. Delete GST ledger entries related to this sale
        gst_delete_result = await db.gst_ledger.delete_many({
            "tenant_id": tenant_id,
            "reference_id": sale_id
        })
        
        # 3. Reverse customer loyalty points
        customer_id = sale.get("customer_id")
        if customer_id:
            points_given = int(sale.get("total_amount", 0) / 100)  # Same calculation as creation
            if points_given > 0:
                await db.customers.update_one(
                    {"id": customer_id, "tenant_id": tenant_id},
                    {"$inc": {"loyalty_points": -points_given}}
                )
        
        # 4. Reverse voucher usage
        voucher_code = sale.get("voucher_code")
        if voucher_code:
            await db.vouchers.update_one(
                {"code": voucher_code.upper(), "tenant_id": tenant_id},
                {"$inc": {"used_count": -1}}
            )
        
        # 5. Delete related payment records
        payment_delete_result = await db.payments.delete_many({
            "tenant_id": tenant_id,
            "reference_id": sale_id,
            "reference_type": {"$in": ["sale", "invoice"]}
        })
        
        # 6. Delete ledger entries related to this sale
        ledger_delete_result = await db.ledger_entries.delete_many({
            "tenant_id": tenant_id,
            "reference_id": sale_id
        })
        
        # 7. Delete stock movements related to this sale
        stock_movements_result = await db.stock_movements.delete_many({
            "tenant_id": tenant_id,
            "reference_id": sale_id
        })
        
        # 8. Delete inventory transactions
        inv_transactions_result = await db.inventory_transactions.delete_many({
            "tenant_id": tenant_id,
            "reference_id": sale_id
        })
        
        # 9. Delete any related sales returns
        returns_result = await db.sales_returns.delete_many({
            "tenant_id": tenant_id,
            "sale_id": sale_id
        })
        
        # 10. Delete the sale document itself
        sale_delete_result = await db.sales.delete_one({"id": sale_id, "tenant_id": tenant_id})
        
        if sale_delete_result.deleted_count == 0:
            raise HTTPException(status_code=500, detail="Failed to delete sale record")
        
        logger.info(f"Sale {invoice_number} deleted completely by {user.get('email')}")
        
        return {
            "message": f"Sale {invoice_number} deleted successfully",
            "deleted": {
                "sale": True,
                "invoice_number": invoice_number,
                "gst_ledger_entries": gst_delete_result.deleted_count,
                "payment_records": payment_delete_result.deleted_count,
                "ledger_entries": ledger_delete_result.deleted_count,
                "stock_movements": stock_movements_result.deleted_count,
                "inventory_transactions": inv_transactions_result.deleted_count,
                "sales_returns": returns_result.deleted_count,
                "items_inventory_restored": deleted_items,
                "customer_loyalty_reversed": bool(customer_id),
                "voucher_usage_reversed": bool(voucher_code)
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error deleting sale {sale_id}: {e}")
        raise HTTPException(status_code=500, detail=f"Failed to delete sale: {str(e)}")

# ============== POS FAVORITES (HIGH-SPEED BILLING) ==============

@api_router.get("/pos/favorites")
async def get_pos_favorites(
    store_id: str = "",
    limit: int = 9,
    user: dict = Depends(require_permission("invoices"))
):
    """Get favorites for POS quick add - per-store shared favorites"""
    tenant_id = get_tenant_id(user)
    
    # First check if store has custom favorites (per-store, shared for all staff)
    query = {"tenant_id": tenant_id}
    if store_id:
        query["store_id"] = store_id
    else:
        # If no store specified, check for tenant-wide favorites
        query["store_id"] = {"$in": ["", None]}
    
    store_favorites = await db.store_favorites.find_one(query)
    
    # If store has a custom favorites record (even if empty), use it
    if store_favorites is not None:
        item_ids = store_favorites.get("item_ids", [])
        if not item_ids:
            # User explicitly cleared favorites - return empty list
            return {"favorites": [], "source": "store_custom_empty", "store_id": store_id}
        
        # Return store's custom favorites
        item_ids = item_ids[:limit]
        items = await db.items.find({
            "tenant_id": tenant_id,
            "id": {"$in": item_ids}
        }, {"_id": 0}).to_list(limit)
        
        # Maintain order of item_ids
        item_map = {item["id"]: item for item in items}
        ordered_items = []
        for item_id in item_ids:
            if item_id in item_map:
                item = item_map[item_id]
                # Get variants for price info
                variant = await db.variants.find_one({"item_id": item["id"]}, {"_id": 0})
                if variant:
                    item["selling_price"] = variant.get("selling_price", variant.get("price", 0))
                    item["variant_id"] = variant.get("id")
                    item["current_stock"] = variant.get("current_stock", 0)
                ordered_items.append(item)
        
        return {"favorites": ordered_items, "source": "store_custom", "store_id": store_id}
    
    # No custom favorites record - calculate top-selling items from sales
    # Aggregate sales data to find most frequently sold items
    pipeline = [
        {"$match": {"tenant_id": tenant_id}},
    ]
    
    if store_id:
        pipeline[0]["$match"]["store_id"] = store_id
    
    pipeline.extend([
        {"$unwind": "$items"},
        {"$group": {
            "_id": {"$ifNull": ["$items.item_id", "$items.id"]},
            "total_quantity": {"$sum": "$items.quantity"},
            "total_sales": {"$sum": {"$multiply": ["$items.quantity", "$items.rate"]}}
        }},
        {"$sort": {"total_quantity": -1}},
        {"$limit": limit}
    ])
    
    top_items = await db.sales.aggregate(pipeline).to_list(limit)
    
    if not top_items:
        # Return first N items if no sales data
        items = await db.items.find(
            {"tenant_id": tenant_id},
            {"_id": 0}
        ).limit(limit).to_list(limit)
        
        for item in items:
            variant = await db.variants.find_one({"item_id": item["id"]}, {"_id": 0})
            if variant:
                item["selling_price"] = variant.get("selling_price", variant.get("price", 0))
                item["variant_id"] = variant.get("id")
                item["current_stock"] = variant.get("current_stock", 0)
        
        return {"favorites": items, "source": "catalog"}
    
    # Fetch item details for top sellers
    item_ids = [item["_id"] for item in top_items if item["_id"]]
    items = await db.items.find({
        "tenant_id": tenant_id,
        "id": {"$in": item_ids}
    }, {"_id": 0}).to_list(limit)
    
    # Create a map for ordering and add sales stats
    item_map = {item["id"]: item for item in items}
    result = []
    for top in top_items:
        item_id = top["_id"]
        if item_id in item_map:
            item = item_map[item_id]
            item["total_sold"] = top["total_quantity"]
            item["total_revenue"] = top["total_sales"]
            
            # Get variant for price info
            variant = await db.variants.find_one({"item_id": item_id}, {"_id": 0})
            if variant:
                item["selling_price"] = variant.get("selling_price", variant.get("price", 0))
                item["variant_id"] = variant.get("id")
                item["current_stock"] = variant.get("current_stock", 0)
            
            result.append(item)
    
    return {"favorites": result, "source": "top_selling"}

@api_router.post("/pos/favorites")
async def save_pos_favorites(
    request: dict,
    user: dict = Depends(require_permission("invoices"))
):
    """Save custom favorites for a store (shared for all staff in store)"""
    tenant_id = get_tenant_id(user)
    item_ids = request.get("item_ids", [])
    store_id = request.get("store_id", "")
    
    if len(item_ids) > 20:
        raise HTTPException(status_code=400, detail="Maximum 20 favorites allowed")
    
    # Save to store_favorites collection (per-store, shared)
    await db.store_favorites.update_one(
        {"tenant_id": tenant_id, "store_id": store_id},
        {
            "$set": {
                "tenant_id": tenant_id,
                "store_id": store_id,
                "item_ids": item_ids,
                "updated_by": user.get("id"),
                "updated_at": datetime.now(timezone.utc).isoformat()
            }
        },
        upsert=True
    )
    
    return {"message": "Store favorites saved successfully", "count": len(item_ids), "store_id": store_id}

@api_router.post("/pos/favorites/add")
async def add_to_favorites(
    request: dict,
    user: dict = Depends(require_permission("invoices"))
):
    """Add a single item to store favorites"""
    tenant_id = get_tenant_id(user)
    item_id = request.get("item_id")
    store_id = request.get("store_id", "")
    
    if not item_id:
        raise HTTPException(status_code=400, detail="item_id is required")
    
    # Get current favorites
    store_favorites = await db.store_favorites.find_one({
        "tenant_id": tenant_id,
        "store_id": store_id
    })
    
    current_ids = store_favorites.get("item_ids", []) if store_favorites else []
    
    if item_id in current_ids:
        return {"message": "Item already in favorites", "count": len(current_ids)}
    
    if len(current_ids) >= 20:
        raise HTTPException(status_code=400, detail="Maximum 20 favorites allowed")
    
    current_ids.append(item_id)
    
    await db.store_favorites.update_one(
        {"tenant_id": tenant_id, "store_id": store_id},
        {
            "$set": {
                "tenant_id": tenant_id,
                "store_id": store_id,
                "item_ids": current_ids,
                "updated_by": user.get("id"),
                "updated_at": datetime.now(timezone.utc).isoformat()
            }
        },
        upsert=True
    )
    
    return {"message": "Added to favorites", "count": len(current_ids)}

@api_router.post("/pos/favorites/remove")
async def remove_from_favorites(
    request: dict,
    user: dict = Depends(require_permission("invoices"))
):
    """Remove a single item from store favorites"""
    tenant_id = get_tenant_id(user)
    item_id = request.get("item_id")
    store_id = request.get("store_id", "")
    
    if not item_id:
        raise HTTPException(status_code=400, detail="item_id is required")
    
    # Get current favorites
    store_favorites = await db.store_favorites.find_one({
        "tenant_id": tenant_id,
        "store_id": store_id
    })
    
    if not store_favorites:
        return {"message": "No favorites found", "count": 0}
    
    current_ids = store_favorites.get("item_ids", [])
    
    if item_id not in current_ids:
        return {"message": "Item not in favorites", "count": len(current_ids)}
    
    current_ids.remove(item_id)
    
    await db.store_favorites.update_one(
        {"tenant_id": tenant_id, "store_id": store_id},
        {"$set": {"item_ids": current_ids, "updated_at": datetime.now(timezone.utc).isoformat()}}
    )
    
    return {"message": "Removed from favorites", "count": len(current_ids)}

@api_router.delete("/pos/favorites")
async def clear_pos_favorites(
    store_id: str = "",
    user: dict = Depends(require_permission("invoices"))
):
    """Clear custom favorites to use auto-generated top sellers"""
