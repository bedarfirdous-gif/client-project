@api_router.post("/invoices")
async def create_invoice(request: InvoiceCreate, user: dict = Depends(get_current_user)):
    """Create invoice with multi-payment, vouchers, and loyalty support"""
    tenant_id = get_tenant_id(user)
    
    # Use provided invoice number or generate one
    if request.invoice_number:
        invoice_number = request.invoice_number
    else:
        count = await db.invoices.count_documents({"tenant_id": tenant_id})
        invoice_number = f"INV-{datetime.now().strftime('%y%m')}-{count+1:04d}"
    
    # Use line_items if provided (new format), otherwise use items (POS format)
    items_list = request.line_items if request.line_items else request.items
    
    # Calculate total if not provided
    total_amount = request.total if request.total else request.total_amount
    if not total_amount and items_list:
        total_amount = sum(
            (item.get("quantity", 1) * item.get("unit_price", item.get("price", 0)))
            for item in items_list
        )
    
    # Process voucher if provided
    voucher_discount = 0
    if request.voucher_code:
        voucher = await db.vouchers.find_one({
            "tenant_id": tenant_id,
            "code": request.voucher_code.upper(),
            "is_active": True
        })
        if voucher:
            if voucher.get("voucher_type") == "percent":
                voucher_discount = request.subtotal * (voucher.get("discount_value", 0) / 100)
                if voucher.get("max_discount"):
                    voucher_discount = min(voucher_discount, voucher["max_discount"])
            else:
                voucher_discount = voucher.get("discount_value", 0)
            
            await db.vouchers.update_one(
                {"id": voucher["id"]},
                {"$inc": {"used_count": 1}}
            )
    
    # Process loyalty points if customer
    loyalty_discount = 0
    loyalty_points_earned = 0
    if request.customer_id and request.loyalty_points_used > 0:
        customer = await db.customers.find_one({"id": request.customer_id})
        if customer and customer.get("loyalty_points", 0) >= request.loyalty_points_used:
            loyalty_discount = request.loyalty_points_used
            await db.customers.update_one(
                {"id": request.customer_id},
                {"$inc": {"loyalty_points": -request.loyalty_points_used}}
            )
    
    # Calculate loyalty points earned
    if request.customer_id and total_amount > 0:
        loyalty_points_earned = int(total_amount / 100)
        await db.customers.update_one(
            {"id": request.customer_id},
            {"$inc": {"loyalty_points": loyalty_points_earned, "total_purchases": total_amount}}
        )
    
    # Calculate payment status
    payments = request.payments if request.payments else request.payment_methods
    total_paid = request.amount_paid if request.amount_paid else sum(p.get("amount", 0) for p in payments)
    final_total = total_amount - voucher_discount - loyalty_discount
    balance_due = request.balance_due if request.balance_due else max(0, final_total - total_paid)
    
    # Determine status
    if request.status and request.status != "draft":
        payment_status = request.status
    elif total_paid >= final_total and final_total > 0:
        payment_status = "paid"
    elif total_paid > 0:
        payment_status = "partial"
    else:
        payment_status = request.status or "draft"
    
    invoice_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "invoice_number": invoice_number,
        "order_id": request.order_id,
        "customer_id": request.customer_id,
        "customer_name": request.customer_name,
        "customer_phone": request.customer_phone,
        "customer_email": request.customer_email,
        "customer_address": request.customer_address,
        "customer_gst": request.customer_gst,
        "items": request.items,
        "line_items": request.line_items,
        "subtotal": request.subtotal,
        "discount_amount": request.discount_amount,
        "discount_type": request.discount_type,
        "discount_value": request.discount_value,
        "totalDiscount": request.totalDiscount,
        "voucher_code": request.voucher_code,
        "voucher_discount": voucher_discount,
        "loyalty_points_used": request.loyalty_points_used,
        "loyalty_discount": loyalty_discount,
        "loyalty_points_earned": loyalty_points_earned,
        "tax_amount": request.tax_amount,
        "totalTax": request.totalTax,
        "total_amount": total_amount,
        "total": total_amount,
        "final_amount": final_total,
        "shipping": request.shipping or request.shipping_charges,
        "payment_methods": request.payment_methods,
        "payments": payments,
        "amount_paid": total_paid,
        "change_amount": max(0, total_paid - final_total),
        "balance_due": balance_due,
        "status": payment_status,
        "store_id": request.store_id,
        "notes": request.notes,
        "terms": request.terms,
        "issue_date": request.issue_date or datetime.now(timezone.utc).strftime("%Y-%m-%d"),
        "due_date": request.due_date,
        "payment_terms": request.payment_terms,
        "currency": request.currency,
        "tax_inclusive": request.tax_inclusive,
        # GST/IGST fields for proper invoice display
        "is_interstate": request.is_interstate,
        "seller_state": request.seller_state,
        "customer_state": request.customer_state,
        "cgst_amount": request.cgst_amount,
        "sgst_amount": request.sgst_amount,
        "igst_amount": request.igst_amount,
        "created_by": user.get("id"),
        "created_at": datetime.now(timezone.utc).isoformat()
    }
    
    await db.invoices.insert_one(invoice_doc)
    
    # ============== CENTRALIZED ACCOUNTING ENTRY ==============
    # Process Sale → Debtor Ledger → Central Ledger
    if request.customer_id and final_total > 0:
        customer = await db.customers.find_one({"id": request.customer_id}, {"_id": 0, "name": 1})
        customer_name = customer.get("name") if customer else request.customer_name or "Walk-in Customer"
        
        await process_sale_accounting(
            tenant_id=tenant_id,
            invoice_id=invoice_doc["id"],
            invoice_number=invoice_number,
            customer_id=request.customer_id,
            customer_name=customer_name,
            total_amount=final_total,
            date=invoice_doc.get("invoice_date") or invoice_doc.get("created_at", "").split("T")[0],
            store_id=request.store_id
        )
        
        # If payment received, process receipt accounting
        if total_paid > 0:
            receipt_number = f"RCP-{invoice_number}"
            await process_receipt_accounting(
                tenant_id=tenant_id,
                receipt_id=invoice_doc["id"],
                receipt_number=receipt_number,
                customer_id=request.customer_id,
                customer_name=customer_name,
                amount=total_paid,
                payment_mode=payments[0].get("method", "cash") if payments else "cash",
                date=invoice_doc.get("invoice_date") or invoice_doc.get("created_at", "").split("T")[0],
                store_id=request.store_id,
                invoice_id=invoice_doc["id"]
            )
    # ============== END ACCOUNTING ENTRY ==============
    
    # Update inventory for POS items (if store_id provided) and log to audit trail
    if request.store_id:
        store = await db.stores.find_one({"id": request.store_id}, {"_id": 0})
        store_name = store.get("name") if store else None
        
        for item in request.items:
            if item.get("variant_id"):
                # Get current stock before update
                current_inv = await db.inventory.find_one({
                    "tenant_id": tenant_id, 
                    "store_id": request.store_id, 
                    "variant_id": item.get("variant_id")
                })
                quantity_before = current_inv.get("quantity", 0) if current_inv else 0
                quantity_change = -item.get("quantity", 1)
                quantity_after = quantity_before + quantity_change
                
                await db.inventory.update_one(
                    {"tenant_id": tenant_id, "store_id": request.store_id, "variant_id": item.get("variant_id")},
                    {"$inc": {"quantity": quantity_change}}
                )
                
                # Log to audit trail
                await log_stock_movement(
                    tenant_id=tenant_id,
                    item_id=item.get("item_id"),
                    variant_id=item.get("variant_id"),
                    store_id=request.store_id,
                    movement_type="sale",
                    quantity_change=quantity_change,
                    quantity_before=quantity_before,
                    quantity_after=quantity_after,
                    user_id=user.get("id"),
                    user_name=user.get("name"),
                    reference_type="invoice",
                    reference_id=invoice_doc["id"],
                    notes=f"Sale: {invoice_number}",
                    item_name=item.get("name"),
                    store_name=store_name
                )
            if item.get("item_id"):
                await db.items.update_one(
                    {"id": item.get("item_id")},
                    {"$inc": {"current_stock": -item.get("quantity", 1)}}
                )
    
    del invoice_doc["_id"]
    return invoice_doc

