                "txval": inv["taxable_value"],
                "rt": inv["rate"],
                "iamt": inv["igst"],
                "camt": inv["cgst"],
                "samt": inv["sgst"],
                "csamt": inv["cess"]
            }
            for inv in gstr1_data["b2c_small"]
        ],
        "hsn": {
            "data": [
                {
                    "num": idx + 1,
                    "hsn_sc": h["hsn_code"],
                    "desc": h["description"],
                    "uqc": h["uqc"],
                    "qty": h["total_quantity"],
                    "val": h["total_value"],
                    "txval": h["taxable_value"],
