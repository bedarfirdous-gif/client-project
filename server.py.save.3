# ============== VIRTUAL TRIAL ROOM ==============

@api_router.post("/virtual-tryon")
async def virtual_tryon(
    user_photo: UploadFile = File(...),
    garment_image_url: str = Form(...),
    garment_name: str = Form("Clothing"),
    garment_type: str = Form("clothing"),
    user: dict = Depends(get_current_user)
):
    """Virtual try-on: Create side-by-side comparison and AI visualization"""
    import base64
    from io import BytesIO
    from dotenv import load_dotenv
    load_dotenv()
    
    api_key = os.environ.get("EMERGENT_LLM_KEY")
    if not api_key:
        raise HTTPException(status_code=500, detail="AI service not configured")
    
    try:
        from PIL import Image
        import cv2
        import numpy as np
        
        # Read user photo
        user_photo_content = await user_photo.read()
        user_img = Image.open(BytesIO(user_photo_content)).convert('RGB')
        
        # Read garment image
        garment_image_content = None
        if garment_image_url.startswith("/api/uploads/images/"):
            filename = garment_image_url.split("/")[-1]
            garment_path = UPLOAD_DIR / filename
            if garment_path.exists():
                async with aiofiles.open(garment_path, 'rb') as f:
                    garment_image_content = await f.read()
        
        if not garment_image_content:
            raise HTTPException(status_code=400, detail="Garment image not found")
        
        garment_img = Image.open(BytesIO(garment_image_content)).convert('RGBA')
        
        # Resize images to consistent size
        target_size = (800, 1000)  # Portrait orientation
        user_img = user_img.resize(target_size, Image.Resampling.LANCZOS)
        garment_img = garment_img.resize((400, 400), Image.Resampling.LANCZOS)
        
        # Create a professional comparison image
        # Layout: User photo on left, garment overlay preview on right
        canvas_width = 1200
        canvas_height = 1000
        canvas = Image.new('RGB', (canvas_width, canvas_height), (255, 255, 255))
        
        # Add user photo on the left
        canvas.paste(user_img, (50, 0))
        
        # Create an overlay effect - place garment on the user's torso area
        # This is a simple overlay, not a true try-on
        overlay_canvas = user_img.copy()
        
        # Position garment in the upper-body area (roughly center-chest)
        garment_x = (target_size[0] - 400) // 2
        garment_y = int(target_size[1] * 0.15)  # Start at about 15% from top
        
        # Create semi-transparent overlay
        garment_overlay = garment_img.copy()
        if garment_overlay.mode == 'RGBA':
            # Blend garment with user photo
            for x in range(garment_overlay.width):
                for y in range(garment_overlay.height):
                    px = garment_overlay.getpixel((x, y))
                    if px[3] > 50:  # If not too transparent
                        # Make it semi-transparent for overlay effect
                        garment_overlay.putpixel((x, y), (px[0], px[1], px[2], 180))
        
        overlay_canvas.paste(garment_overlay, (garment_x, garment_y), garment_overlay)
        
        # Place overlay preview on the right
        overlay_canvas = overlay_canvas.resize((500, 625), Image.Resampling.LANCZOS)
        canvas.paste(overlay_canvas, (650, 180))
        
        # Add text labels using PIL
        from PIL import ImageDraw, ImageFont
        draw = ImageDraw.Draw(canvas)
        
        # Try to use a nice font, fallback to default
        try:
            font_large = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf", 24)
            font_small = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf", 16)
        except:
            font_large = ImageFont.load_default()
            font_small = ImageFont.load_default()
        
        # Add labels
        draw.text((200, 950), "Your Photo", fill=(100, 100, 100), font=font_large, anchor="mm")
        draw.text((900, 950), f"Preview with {garment_name}", fill=(100, 100, 100), font=font_large, anchor="mm")
        
        # Add border around preview
        draw.rectangle([645, 175, 1155, 810], outline=(200, 100, 200), width=3)
        
        # Save the composite image
        file_id = str(uuid.uuid4())
        result_filename = f"tryon_{file_id}.png"
        filepath = UPLOAD_DIR / result_filename
        
        # Convert to bytes
        img_buffer = BytesIO()
        canvas.save(img_buffer, format='PNG', quality=95)
        result_image = img_buffer.getvalue()
        
        async with aiofiles.open(filepath, 'wb') as f:
            await f.write(result_image)
        
        # Return the result
        result_base64 = base64.b64encode(result_image).decode('utf-8')
        
        return {
            "success": True,
            "result_url": f"/api/uploads/images/{result_filename}",
            "result_base64": f"data:image/png;base64,{result_base64}",
            "garment_name": garment_name,
            "message": "Virtual try-on preview generated"
        }
        
    except Exception as e:
        import traceback
        traceback.print_exc()
        raise HTTPException(status_code=500, detail=f"Virtual try-on failed: {str(e)}")


