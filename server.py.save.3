@api_router.get("/employees/{employee_id}/loan-eligibility")
async def check_loan_eligibility(employee_id: str, user: dict = Depends(require_permission("employees"))):
    """Check if employee is eligible for loan (2+ years of service, max ₹10,000)"""
    tenant_id = get_tenant_id(user)
    
    employee = await db.employees.find_one({"id": employee_id, "tenant_id": tenant_id})
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Check service duration (2+ years required)
    join_date_str = employee.get("date_of_joining") or employee.get("hire_date") or employee.get("created_at")
    if not join_date_str:
        return {
            "eligible": False,
            "reason": "Join date not recorded",
            "years_of_service": 0,
            "max_loan_amount": 0,
            "existing_loan_balance": 0
        }
    
    try:
        join_date_str_fixed = join_date_str.replace('Z', '+00:00')
        join_date = datetime.fromisoformat(join_date_str_fixed)
        # Ensure timezone aware
        if join_date.tzinfo is None:
            join_date = join_date.replace(tzinfo=timezone.utc)
    except:
        join_date = datetime.now(timezone.utc)
    
    years_of_service = (datetime.now(timezone.utc) - join_date).days / 365.25
    
    # Check existing active loans
    active_loan = await db.employee_loans.find_one({
        "employee_id": employee_id,
        "tenant_id": tenant_id,
        "status": {"$in": ["pending", "approved", "active"]}
    })
    
    existing_balance = 0
    if active_loan:
        existing_balance = active_loan.get("remaining_amount", 0)
    
    # Calculate eligibility
    max_loan_amount = 10000  # ₹10,000 max
    available_amount = max(0, max_loan_amount - existing_balance)
    is_eligible = years_of_service >= 2 and available_amount > 0
    
    reason = ""
    if years_of_service < 2:
        reason = f"Minimum 2 years of service required. Current: {years_of_service:.1f} years"
    elif available_amount <= 0:
        reason = "Existing loan must be repaid first"
    
    return {
        "eligible": is_eligible,
        "reason": reason,
        "years_of_service": round(years_of_service, 2),
        "max_loan_amount": max_loan_amount,
        "available_loan_amount": available_amount,
        "existing_loan_balance": existing_balance,
        "employee_name": employee.get("name"),
        "employee_code": employee.get("employee_code")
    }

@api_router.post("/employees/{employee_id}/loans")
async def request_loan(employee_id: str, request: LoanRequest, user: dict = Depends(require_permission("employees"))):
    """Request a new loan for an employee"""
    tenant_id = get_tenant_id(user)
    
    # Check eligibility
    employee = await db.employees.find_one({"id": employee_id, "tenant_id": tenant_id})
    if not employee:
        raise HTTPException(status_code=404, detail="Employee not found")
    
    # Verify eligibility
    join_date_str = employee.get("date_of_joining") or employee.get("hire_date") or employee.get("created_at")
    if join_date_str:
        try:
            join_date = datetime.fromisoformat(join_date_str.replace('Z', '+00:00'))
            # Ensure timezone aware
            if join_date.tzinfo is None:
                join_date = join_date.replace(tzinfo=timezone.utc)
            years_of_service = (datetime.now(timezone.utc) - join_date).days / 365.25
            if years_of_service < 2:
                raise HTTPException(status_code=400, detail="Minimum 2 years of service required for loan")
        except ValueError:
            pass
    
    # Check existing active loans
    active_loan = await db.employee_loans.find_one({
        "employee_id": employee_id,
        "tenant_id": tenant_id,
        "status": {"$in": ["pending", "approved", "active"]}
    })
    
    existing_balance = active_loan.get("remaining_amount", 0) if active_loan else 0
    max_amount = 10000 - existing_balance
    
    if request.amount > max_amount:
        raise HTTPException(status_code=400, detail=f"Maximum loan amount available: ₹{max_amount}")
    
    if request.amount <= 0:
        raise HTTPException(status_code=400, detail="Loan amount must be greater than 0")
    
    # Calculate monthly EMI (0% interest)
    emi_amount = round(request.amount / request.repayment_months, 2)
    
    loan_doc = {
        "id": str(uuid.uuid4()),
        "tenant_id": tenant_id,
        "employee_id": employee_id,
        "employee_name": employee.get("name"),
        "employee_code": employee.get("employee_code"),
        "amount": request.amount,
        "remaining_amount": request.amount,
        "reason": request.reason,
        "repayment_method": request.repayment_method,
        "repayment_months": request.repayment_months,
        "emi_amount": emi_amount,
        "status": "pending",  # pending -> approved -> active -> completed
        "repayments": [],
        "created_at": datetime.now(timezone.utc).isoformat(),
        "created_by": user.get("id"),
        "approved_at": None,
        "approved_by": None
    }
    
    await db.employee_loans.insert_one(loan_doc)
    del loan_doc["_id"]
    return {"message": "Loan request submitted successfully", "loan": loan_doc}

@api_router.put("/loans/{loan_id}/approve")
async def approve_loan(loan_id: str, user: dict = Depends(require_permission("payroll"))):
    """Approve a pending loan request"""
    tenant_id = get_tenant_id(user)
    
    loan = await db.employee_loans.find_one({"id": loan_id, "tenant_id": tenant_id})
    if not loan:
        raise HTTPException(status_code=404, detail="Loan not found")
    
    if loan.get("status") != "pending":
        raise HTTPException(status_code=400, detail="Only pending loans can be approved")
    
    await db.employee_loans.update_one(
        {"id": loan_id},
        {"$set": {
            "status": "active",
            "approved_at": datetime.now(timezone.utc).isoformat(),
            "approved_by": user.get("id")
        }}
    )
    
    updated_loan = await db.employee_loans.find_one({"id": loan_id}, {"_id": 0})
    return {"message": "Loan approved successfully", "loan": updated_loan}

@api_router.put("/loans/{loan_id}/reject")
async def reject_loan(loan_id: str, reason: str = "", user: dict = Depends(require_permission("payroll"))):
    """Reject a pending loan request"""
    tenant_id = get_tenant_id(user)
    
    loan = await db.employee_loans.find_one({"id": loan_id, "tenant_id": tenant_id})
    if not loan:
        raise HTTPException(status_code=404, detail="Loan not found")
    
    if loan.get("status") != "pending":
        raise HTTPException(status_code=400, detail="Only pending loans can be rejected")
    
    await db.employee_loans.update_one(
        {"id": loan_id},
        {"$set": {
            "status": "rejected",
            "rejection_reason": reason,
            "rejected_at": datetime.now(timezone.utc).isoformat(),
            "rejected_by": user.get("id")
        }}
    )
    
    return {"message": "Loan rejected"}

@api_router.post("/loans/{loan_id}/repayment")
async def record_loan_repayment(loan_id: str, repayment: LoanRepayment, user: dict = Depends(require_permission("payroll"))):
    """Record a manual loan repayment"""
    tenant_id = get_tenant_id(user)
    
    loan = await db.employee_loans.find_one({"id": loan_id, "tenant_id": tenant_id})
    if not loan:
        raise HTTPException(status_code=404, detail="Loan not found")
    
    if loan.get("status") not in ["active", "approved"]:
        raise HTTPException(status_code=400, detail="Can only repay active loans")
    
    remaining = loan.get("remaining_amount", 0)
    if repayment.amount > remaining:
        raise HTTPException(status_code=400, detail=f"Repayment amount exceeds remaining balance: ₹{remaining}")
    
    new_remaining = remaining - repayment.amount
    new_status = "completed" if new_remaining <= 0 else loan.get("status")
    
    repayment_record = {
        "id": str(uuid.uuid4()),
        "amount": repayment.amount,
        "date": datetime.now(timezone.utc).isoformat(),
        "method": "manual",
        "notes": repayment.notes,
        "recorded_by": user.get("id")
    }
    
    await db.employee_loans.update_one(
        {"id": loan_id},
        {
            "$set": {
                "remaining_amount": new_remaining,
                "status": new_status,
                "updated_at": datetime.now(timezone.utc).isoformat()
            },
            "$push": {"repayments": repayment_record}
        }
    )
    
    return {
        "message": "Repayment recorded successfully",
        "remaining_amount": new_remaining,
        "loan_status": new_status
    }

# ============== EMPLOYEE UPGRADE MODULE ==============

class EmployeeUpgrade(BaseModel):
    designation: str
    basic_salary: float
    effective_date: str = ""
