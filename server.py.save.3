@api_router.get("/customers/{customer_id}/loyalty-card")
async def get_customer_loyalty_card(customer_id: str, user: dict = Depends(get_current_user)):
    """Get customer loyalty card data with QR code"""
    tenant_id = get_tenant_id(user)
    
    customer = await db.customers.find_one(
        {"id": customer_id, "tenant_id": tenant_id, "is_deleted": {"$ne": True}},
        {"_id": 0}
    )
    
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Get tenant info for card branding
    tenant = await db.tenants.find_one({"id": tenant_id}, {"_id": 0})
    
    # Get store info (use default store for branding)
    store = await db.stores.find_one({"tenant_id": tenant_id}, {"_id": 0, "name": 1, "address": 1, "city": 1, "state": 1, "pincode": 1, "phone": 1})
    
    # Get invoice settings for company name
    invoice_settings = await db.invoice_settings.find_one({"tenant_id": tenant_id}, {"_id": 0})
    
    # Get loyalty program info
    loyalty_program = await db.loyalty_programs.find_one({"tenant_id": tenant_id, "is_active": True}, {"_id": 0})
    
    # Calculate total purchases and loyalty points
    sales = await db.sales.find({"tenant_id": tenant_id, "customer_id": customer_id}).to_list(1000)
    total_purchases = sum(s.get("total", 0) for s in sales)
    total_visits = len(sales)
    
    # Generate QR code data (URL that will fetch customer details when scanned)
    qr_data = f"LOYALTY:{tenant_id}:{customer_id}"
    
    # Determine loyalty tier
    loyalty_points = customer.get("loyalty_points", 0)
    tier = "Bronze"
    if loyalty_points >= 5000:
        tier = "Platinum"
    elif loyalty_points >= 2000:
        tier = "Gold"
    elif loyalty_points >= 500:
        tier = "Silver"
    
    # Build store address
    store_address = ""
    if store:
        addr_parts = [store.get("address", ""), store.get("city", ""), store.get("state", ""), store.get("pincode", "")]
        store_address = ", ".join([p for p in addr_parts if p])
    
    # Get company name from invoice settings or tenant
    company_name = ""
    if invoice_settings:
        company_name = invoice_settings.get("company_name") or invoice_settings.get("business_name", "")
    if not company_name and tenant:
        company_name = tenant.get("business_name") or tenant.get("name", "")
    if not company_name and store:
        company_name = store.get("name", "")
    
    return {
        "card_data": {
            "customer_id": customer_id,
            "customer_name": customer.get("name", ""),
            "customer_phone": customer.get("phone", ""),
            "customer_email": customer.get("email", ""),
            "loyalty_points": loyalty_points,
            "tier": tier,
            "total_purchases": round(total_purchases, 2),
            "total_visits": total_visits,
            "member_since": customer.get("created_at", ""),
            "qr_code_data": qr_data
        },
        "business": {
            "name": company_name,
            "logo": tenant.get("logo", "") if tenant else "",
            "store_name": store.get("name", "") if store else "",
            "address": store_address,
            "phone": store.get("phone", "") if store else ""
        },
        "loyalty_program": loyalty_program
    }


@api_router.get("/loyalty/scan/{qr_data}")
async def scan_loyalty_card(qr_data: str, user: dict = Depends(get_current_user)):
    """Scan loyalty card QR code and get customer details for quick billing"""
    tenant_id = get_tenant_id(user)
    
    # Parse QR data: LOYALTY:tenant_id:customer_id
    parts = qr_data.split(":")
    if len(parts) != 3 or parts[0] != "LOYALTY":
        raise HTTPException(status_code=400, detail="Invalid loyalty card QR code")
    
    qr_tenant_id, customer_id = parts[1], parts[2]
    
    # Verify tenant matches (for security)
    if qr_tenant_id != tenant_id:
        raise HTTPException(status_code=403, detail="This loyalty card belongs to a different store")
    
    # Get customer details
    customer = await db.customers.find_one(
        {"id": customer_id, "tenant_id": tenant_id, "is_deleted": {"$ne": True}},
        {"_id": 0}
    )
    
    if not customer:
        raise HTTPException(status_code=404, detail="Customer not found")
    
    # Get recent purchases
    recent_sales = await db.sales.find(
        {"tenant_id": tenant_id, "customer_id": customer_id}
    ).sort("created_at", -1).limit(5).to_list(5)
    
    for sale in recent_sales:
        sale.pop("_id", None)
    
    return {
        "customer": customer,
        "recent_purchases": recent_sales,
        "quick_info": {
            "loyalty_points": customer.get("loyalty_points", 0),
            "outstanding_balance": customer.get("balance", 0),
            "last_visit": recent_sales[0].get("created_at") if recent_sales else None
        }
    }


