// Check if current path is public catalogue or storefront
const isPublicPage = () => {
  const path = window.location.pathname;
  return path === '/catalogue' || 
         path === '/catalog' || 
         path.startsWith('/store/');
};

// Check if current path is public catalogue
const isPublicCatalogue = () => {
  return window.location.pathname === '/catalogue' || window.location.pathname === '/catalog';
};

// Check if current path is storefront
const isStorefront = () => {
  return window.location.pathname.startsWith('/store/');
};

