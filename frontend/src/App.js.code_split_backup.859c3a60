    suppliers: 'Suppliers',
    'supplier-ledger': 'Supplier Ledger',
    vouchers: 'Vouchers',
    discounts: 'Discount Manager',
    loyalty: 'Loyalty Program',
    stores: 'Stores',
    employees: 'Employees',
    'employment-agreements': 'Employment Agreements',
    'task-management': 'Task Management',
    users: 'User Management',
    'rbac-permissions': 'RBAC Permissions',
    'rbac-admin': 'RBAC Admin',
    'autoheal': 'AutoHeal AI',
    'ui-blink-fix': 'UI Blink Fix Agent',
    'error-autofix': 'Error Auto-Fix Agent',
    'performance-agent': 'Performance Agent',
    'agent-collaboration': 'Agent Collaboration',
    'gst-automation': 'GST Automation',
    'security-dashboard': 'Security Center',
    'gst-master': 'GST Master',
    'invoice-settings': 'Invoice Settings',
    'accounting-reports': 'Accounting Reports',
    'backup-restore': 'Backup & Restore',
    attendance: 'Attendance',
    'employee-ratings': 'Employee Ratings',
    payroll: 'Payroll',
    'salary-calculator': 'Salary Calculator',
    'connect-hub': 'Connect Hub',
    training: 'Training Center',
    'ai-agents-dashboard': 'AI Control Center',
    'ai-agent': 'AI Business Agent',
    'ai-dashboard': 'AI Dashboard',
    'auto-poster': 'Auto Poster Studio',
    settings: 'Settings',
  };

  return (
    <div className="flex h-screen overflow-hidden">
      <Sidebar 
        currentPage={currentPage} 
        setCurrentPage={setCurrentPage}
        isOpen={sidebarOpen}
        setIsOpen={setSidebarOpen}
      />
      
      <main className="flex-1 flex flex-col overflow-hidden">
        {/* Header */}
        <header className="glass-header sticky top-0 z-30 border-b border-border px-4 lg:px-6 py-3">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-4">
              <button 
                onClick={() => setSidebarOpen(true)}
                className="lg:hidden p-2 hover:bg-accent rounded-md"
                data-testid="menu-toggle"
              >
                <Menu className="w-5 h-5" />
              </button>
              <h2 className="text-xl font-bold tracking-tight">{pageTitle[currentPage]}</h2>
              <LocationSecurityBadge />
            </div>
            <div className="flex items-center gap-2">
              {/* God Mode Return Button - Shows when impersonating */}
              {isImpersonating && (
                <Button
                  variant="destructive"
                  size="sm"
                  onClick={returnFromImpersonation}
                  className="animate-pulse bg-red-600 hover:bg-red-700 text-white"
                  data-testid="return-from-impersonation-btn"
                >
                  <RotateCcw className="w-4 h-4 mr-1" />
                  Return to Super Admin
                </Button>
              )}
              <MyProfileButton />
              <SystemHealthIndicator onClick={() => window.dispatchEvent(new CustomEvent('open-system-repair'))} />
              <StockAlertsBell api={api} />
              <CartButton onClick={() => window.dispatchEvent(new CustomEvent('open-cart'))} />
              <ThemeSelector />
              <SecurityCenter />
              <ActivityCenter />
            </div>
          </div>
        </header>

        {/* Content */}
        <div className="flex-1 overflow-auto p-4 lg:p-6">
          {children}
        </div>
      </main>
      
      {/* Cart Sidebar */}
      <CartSidebar isOpen={cartOpen} onClose={() => setCartOpen(false)} />
    </div>
  );
};

// App component
function App() {
  const [currentPage, setCurrentPage] = useState('dashboard');
  const location = useLocation();

  // Check if we're on a public storefront route
  if (location.pathname.startsWith('/store/')) {
    return (
      <ThemeProvider>
        <Toaster position="top-right" richColors />
        <Routes>
          <Route path="/store/:tenantSlug" element={<StorefrontPage />} />
          <Route path="/store/:tenantSlug/order-success" element={<OrderSuccessPage />} />
          <Route path="/store/:tenantSlug/*" element={<StorefrontPage />} />
        </Routes>
      </ThemeProvider>
    );
  }

  // If public catalogue route, render public page without auth
  if (isPublicCatalogue()) {
    return (
      <ThemeProvider>
        <Toaster position="top-right" richColors />
        <PublicCatalogue />
      </ThemeProvider>
    );
  }

  return (
    <ThemeProvider>
      <LanguageProvider>
        <CurrencyProvider>
          <AuthProvider>
            <Toaster position="top-right" richColors />
            <AppContentWithLocation currentPage={currentPage} setCurrentPage={setCurrentPage} />
          </AuthProvider>
        </CurrencyProvider>
      </LanguageProvider>
    </ThemeProvider>
  );
}

// Wrapper to pass api to LocationSecurityProvider and OfflineProvider
const AppContentWithLocation = ({ currentPage, setCurrentPage }) => {
  const { api, user, token, loading } = useAuth();
  
  // Render login page directly without providers to prevent blinking
  // This is checked FIRST before any providers are mounted
  if (!user) {
    // Show minimal loading only if actively checking auth
    if (loading) {
      return (
        <div className="min-h-screen flex items-center justify-center bg-gray-50">
          <div className="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin" />
        </div>
      );
    }
    return <LoginPage key="login-page" />;
  }
  
  // Only mount providers after user is confirmed logged in
  return (
    <OfflineProvider api={api} token={token}>
      <LocationSecurityProvider api={api} userRole={user?.role || 'staff'}>
        <PermissionProvider>
          <ReAuthProvider>
            <AppContent currentPage={currentPage} setCurrentPage={setCurrentPage} />
            <SecurityAlertPopup />
            <OfflineIndicator />
          </ReAuthProvider>
        </PermissionProvider>
      </LocationSecurityProvider>
    </OfflineProvider>
  );
};

const AppContent = ({ currentPage, setCurrentPage }) => {
  const { user, loading, logout, api } = useAuth();
  const { hasPageAccess, canPerformAction, loading: permLoading } = usePermissions();
  const { toggleTheme } = useTheme();
  const [showSystemRepair, setShowSystemRepair] = useState(false);
  const [showShortcutsModal, setShowShortcutsModal] = useState(false);

  // Safe navigation - only navigate if user has access
  const safeNavigate = useCallback((page) => {
    if (hasPageAccess(page)) {
      setCurrentPage(page);
    } else {
      toast.error(`You don't have access to this page`);
    }
  }, [hasPageAccess, setCurrentPage]);

  // Keyboard shortcuts handler
  const shortcutHandlers = useMemo(() => ({
    // Navigation shortcuts - Ctrl + key
    'dashboard': () => safeNavigate('dashboard'),
    'pos': () => safeNavigate('pos'),
    'items': () => safeNavigate('items'),
    'inventory': () => safeNavigate('inventory'),
    'customers': () => safeNavigate('customers'),
    'sales': () => safeNavigate('sales'),
    'stock-transfers': () => safeNavigate('transfers'),
    'employees': () => safeNavigate('employees'),
    'suppliers': () => safeNavigate('suppliers'),
    'settings': () => safeNavigate('settings'),
    
    // Quick actions
    'new-sale': () => safeNavigate('pos'),
    'search': () => {
      const searchInput = document.querySelector('[data-testid="global-search"], input[placeholder*="Search"]');
      if (searchInput) {
        searchInput.focus();
        searchInput.select();
      }
    },
    'refresh': () => {
      toast.info('Refreshing...');
      window.location.reload();
    },
    
    // Global shortcuts
    'show-shortcuts': () => setShowShortcutsModal(prev => !prev),
    'toggle-sidebar': () => {
      const menuBtn = document.querySelector('[data-testid="menu-toggle"], [data-testid="sidebar-toggle"]');
      if (menuBtn) menuBtn.click();
    },
    'toggle-theme': () => {
      toggleTheme();
      toast.success('Theme toggled');
    },
    'logout': () => {
      if (window.confirm('Are you sure you want to logout?')) {
        logout();
      }
    },
    
    // POS specific shortcuts
    'pos-checkout': () => {
      if (currentPage === 'pos') {
        const checkoutBtn = document.querySelector('[data-testid="checkout-btn"]');
        if (checkoutBtn && !checkoutBtn.disabled) checkoutBtn.click();
      } else {
        safeNavigate('pos');
      }
    },
    'pos-clear': () => {
      if (currentPage === 'pos') {
        const clearBtn = document.querySelector('[data-testid="clear-btn"]');
        if (clearBtn && !clearBtn.disabled) clearBtn.click();
      }
    },
    'pos-hold': () => {
      if (currentPage === 'pos') {
        const holdBtn = document.querySelector('[data-testid="hold-btn"]');
        if (holdBtn && !holdBtn.disabled) holdBtn.click();
      }
    },
  }), [safeNavigate, currentPage, toggleTheme, logout]);

  useKeyboardShortcuts(shortcutHandlers, true);

  // Listen for system repair dialog open event
  useEffect(() => {
    const handleOpenRepair = () => setShowSystemRepair(true);
    window.addEventListener('open-system-repair', handleOpenRepair);
    
    // DISABLED: Auto safe mode was causing login blinking
    // Safe mode should only be triggered manually via System Repair
    // if (!loading && user && SystemUtils.shouldEnterSafeMode() && !SystemUtils.isInSafeMode()) {
    //   toast.warning('Multiple crashes detected. Entering Safe Mode...', { duration: 5000 });
    //   SystemUtils.enterSafeMode();
    //   setTimeout(() => window.location.reload(), 2000);
    // }
    
    return () => window.removeEventListener('open-system-repair', handleOpenRepair);
  }, []);

  // Global error handler - DISABLED to prevent login issues
  // Errors will still be logged to console but won't trigger safe mode
  // useEffect(() => {
  //   const handleError = (event) => {
  //     const message = event.error?.message || event.message || '';
  //     if (!message.includes('401') && !message.includes('Network') && !message.includes('Session expired')) {
  //       SystemUtils.logCrash(event.error || event.message, 'global_error');
  //     }
  //   };
  //   const handleUnhandledRejection = (event) => {
  //     const reason = event.reason?.message || String(event.reason) || '';
  //     if (!reason.includes('401') && !reason.includes('Network') && !reason.includes('Session expired')) {
  //       SystemUtils.logCrash(event.reason, 'unhandled_rejection');
  //     }
  //   };
  //   
  //   window.addEventListener('error', handleError);
  //   window.addEventListener('unhandledrejection', handleUnhandledRejection);
  //   
  //   return () => {
  //     window.removeEventListener('error', handleError);
  //     window.removeEventListener('unhandledrejection', handleUnhandledRejection);
  //   };
  // }, []);

  // Only show loading spinner on very first permission load, not on subsequent checks
  // This prevents blinking when navigating between pages
  const [initialPermLoadDone, setInitialPermLoadDone] = useState(false);
  
  useEffect(() => {
    if (!permLoading && !initialPermLoadDone) {
      setInitialPermLoadDone(true);
    }
  }, [permLoading, initialPermLoadDone]);

  // Show loading spinner only on initial load, not after that
  if (permLoading && !initialPermLoadDone) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gray-50 dark:bg-gray-900">
        <div className="w-8 h-8 border-4 border-primary border-t-transparent rounded-full animate-spin" />
      </div>
    );
  }

  // Safe Mode - load minimal features
  const isSafeMode = SystemUtils.isInSafeMode();

  const renderPage = () => {
    // In safe mode, only allow dashboard and basic pages
    if (isSafeMode && !['dashboard', 'settings', 'items', 'pos'].includes(currentPage)) {
      return (
        <div className="min-h-[60vh] flex flex-col items-center justify-center text-center p-6">
          <div className="w-20 h-20 rounded-full bg-amber-100 dark:bg-amber-900/30 flex items-center justify-center mb-4">
            <Shield className="w-10 h-10 text-amber-500" />
          </div>
          <h2 className="text-2xl font-bold text-amber-600 mb-2">Safe Mode Active</h2>
          <p className="text-muted-foreground mb-4">
            Some features are disabled to ensure stability.
          </p>
          <button 
            onClick={() => setShowSystemRepair(true)}
            className="mt-4 px-4 py-2 bg-amber-500 text-white rounded-lg hover:bg-amber-600 transition-colors"
          >
            Open System Repair
          </button>
        </div>
      );
    }

    // Check if user has access to the current page
    if (!hasPageAccess(currentPage) && currentPage !== 'dashboard') {
      return (
        <div className="min-h-[60vh] flex flex-col items-center justify-center text-center p-6">
          <div className="w-20 h-20 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center mb-4">
            <Lock className="w-10 h-10 text-red-500" />
          </div>
          <h2 className="text-2xl font-bold text-red-600 mb-2">Access Denied</h2>
          <p className="text-muted-foreground mb-4">
            You don&apos;t have permission to access this page.
          </p>
          <p className="text-sm text-muted-foreground">
            Contact your administrator if you need access.
          </p>
          <button 
            onClick={() => setCurrentPage('dashboard')}
            className="mt-6 px-4 py-2 bg-primary text-primary-foreground rounded-lg hover:bg-primary/90 transition-colors"
          >
            Go to Dashboard
          </button>
        </div>
      );
    }

    switch (currentPage) {
      case 'superadmin-dashboard': return <SuperAdminDashboard />;
      case 'rbac-admin': return <RBACAdminPage />;
      case 'autoheal': return <AutoHealDashboard />;
      case 'ui-blink-fix': return <UIBlinkFixAgent />;
      case 'error-autofix': return <ErrorAutoFixAgent />;
      case 'performance-agent': return <PerformanceAgent />;
      case 'agent-collaboration': return <AgentCollaboration />;
      case 'gst-automation': return <GSTAutomation />;
      case 'security-dashboard': return <SecurityDashboard />;
      case 'dashboard': 
        // Regular dashboard for everyone including Super Admin
        return <DashboardPage onNavigate={setCurrentPage} />;
      case 'analytics': return <AnalyticsDashboardPage />;
      case 'pos': return <POSPage onNavigate={setCurrentPage} />;
      case 'items': return <ItemsPage onNavigate={setCurrentPage} />;
      case 'smart-scanner': return <SmartScannerPage />;
      case 'inventory': return <InventoryPage onNavigate={setCurrentPage} />;
      case 'transfers': return <StockTransfersPage />;
      case 'stock-receiver': return <StockReceiverPage />;
      case 'upload-history': return <UploadHistoryPage />;
      case 'sales': return <SalesPage />;
      case 'sales-dashboard': return <SalesDashboardPage onNavigate={setCurrentPage} />;
      case 'quotations': return <QuotationsPage />;
      case 'sales-orders': return <SalesOrdersPage />;
      case 'order-history': return <OrderHistoryPage />;
      case 'virtual-tryon': return <VirtualTrialRoomPage />;
      case 'fabric-catalogue': return <FabricCataloguePage />;
      case 'sales-invoices': return <InvoicesPage />;
      case 'sales-delivery': return <SalesDeliveryPage />;
      case 'sales-returns': return <SalesReturnsPage />;
      case 'sales-reports': return <SalesReportsPage api={api} user={user} />;
      case 'crm': return <CRMPage />;
      case 'customer-import': return <CustomerImportPage />;
      case 'purchases': return <PurchaseInvoicesPage />;
      case 'purchase-returns': return <PurchaseReturnsPage />;
      case 'purchase-reports': return <PurchaseReportsPage />;
      case 'customers': return <CustomersPage />;
      case 'customer-ledger': return <CustomerLedgerPage />;
      case 'suppliers': return <SuppliersPage />;
      case 'supplier-ledger': return <SupplierLedgerPage />;
      case 'vouchers': return <VouchersPage />;
      case 'discounts': return <DiscountManagementPage />;
      case 'stock-audit': return <StockAuditTrailPage />;
      case 'stores': return <StoresPage />;
      case 'employees': return <EmployeesPage />;
      case 'employment-agreements': return <EmploymentAgreementsPage />;
      case 'task-management': return <TaskManagementPage />;
      case 'users': return <UserManagementPage />;
      case 'rbac-permissions': return <RBACPermissionsPage />;
      case 'daily-attendance': return <DailyAttendancePage />;
      case 'face-attendance': return <FaceAttendancePage />;
      case 'attendance-sheet': return <MonthlyAttendanceSheet />;
      case 'attendance': return <AttendancePage />;
      case 'employee-ratings': return <EmployeeRatingsPage />;
      case 'payroll': return <PayrollPage onNavigate={setCurrentPage} />;
      case 'salary-calculator': return <PayrollCalculatorPage />;
      case 'employee-loans': return <EmployeeLoanPage />;
      case 'loyalty': return <LoyaltyProgramPage />;
      case 'gst-master': return <GSTMasterPage />;
      case 'invoice-settings': return <InvoiceSettingsPage />;
      case 'security-settings': return <SecuritySettingsPage />;
      case 'accounting-reports': return <AccountingReportsPage />;
      case 'backup-restore': return <BackupRestorePage />;
      case 'recycle-bin': return <RecycleBinPage />;
      case 'expenditure': return <ExpenditurePage />;
      case 'ecommerce': return <EcommercePage />;
      case 'connect-hub': return <ConnectHubPage />;
      case 'training': return <TrainingPage />;
      case 'ai-agents-dashboard': return <AIAgentsDashboard api={api} user={user} />;
      case 'ai-agent': return <AIAgentPage />;
      case 'ai-dashboard': return <AIDashboardPage />;
      case 'auto-poster': return <AutoPosterPage />;
      case 'market-analytics':
        // Super Admin market analytics
        if (user?.role === 'superadmin') {
          return <SuperAdminDashboard initialTab="analytics" />;
        }
        return <AnalyticsDashboardPage />;
      case 'subscriptions': 
        // Super Admin view of all subscriptions/plans
        if (user?.role === 'superadmin') {
          return <SuperAdminDashboard initialTab="plans" />;
        }
        return <BillingPage />;
      case 'billing': return <BillingPage />;
      case 'keyboard-shortcuts': return <KeyboardShortcutsPage />;
      case 'settings': return <SettingsPage />;
      default: 
        // Super Admin default view
        if (user?.role === 'superadmin') {
          return <SuperAdminDashboard />;
        }
        return <DashboardPage onNavigate={setCurrentPage} />;
    }
  };

  return (
    <>
      <MainLayout currentPage={currentPage} setCurrentPage={setCurrentPage}>
        <div className="main-content-with-nav">
          <Suspense fallback={<PageLoadingSpinner />}>
            {renderPage()}
          </Suspense>
        </div>
      </MainLayout>
      {/* Mobile Bottom Navigation */}
      <MobileBottomNav 
        currentPage={currentPage} 
        setCurrentPage={setCurrentPage}
        onMenuClick={() => {
          // Trigger sidebar open
          const menuBtn = document.querySelector('[data-testid="menu-toggle"]');
          if (menuBtn) menuBtn.click();
        }}
      />
      {/* PWA Install Prompt */}
      <PWAInstallPrompt />
      {/* System Repair Dialog */}
      <SystemRepairDialog isOpen={showSystemRepair} onClose={() => setShowSystemRepair(false)} />
      {/* Keyboard Shortcuts Modal */}
      <ShortcutsModal open={showShortcutsModal} onClose={() => setShowShortcutsModal(false)} />
    </>
  );
};

export default App;
