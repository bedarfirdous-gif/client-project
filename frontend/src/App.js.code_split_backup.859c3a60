                      {item.label}
                    </span>
                  </div>
                );
              }
              
              const Icon = item.icon;
              const isActive = currentPage === item.id;
              
              return (
                <button
                  key={item.id}
                  onClick={() => {
                    setCurrentPage(item.id);
                    setIsOpen(false);
                  }}
                  data-testid={`nav-${item.id}`}
                  className={`
                    w-full flex items-center gap-3 px-3 py-2.5 rounded-md text-sm font-medium
                    transition-colors duration-150
                    ${isActive 
                      ? 'bg-primary text-primary-foreground' 
                      : 'text-foreground hover:bg-accent'
                    }
                  `}
                >
                  <Icon className="w-4 h-4 flex-shrink-0" />
                  <span>{item.label}</span>
                </button>
              );
            })}
          </nav>

          {/* User section */}
          <div className="p-3 border-t border-border space-y-2">
            {/* Theme Toggle with Settings Icon */}
            <button
              onClick={toggleTheme}
              data-testid="theme-toggle"
              className="w-full flex items-center justify-between px-3 py-2.5 rounded-md bg-gradient-to-r from-indigo-500/10 to-purple-500/10 hover:from-indigo-500/20 hover:to-purple-500/20 border border-indigo-500/20 transition-all"
            >
              <div className="flex items-center gap-2">
                <Settings className="w-4 h-4 text-indigo-500" />
                <span className="text-sm font-medium">{t('theme')}</span>
              </div>
              <div className={`flex items-center gap-1.5 px-2 py-1 rounded-full text-xs font-medium ${theme === 'dark' ? 'bg-amber-500 text-white' : 'bg-slate-700 text-white'}`}>
                {theme === 'light' ? <Moon className="w-3 h-3" /> : <Sun className="w-3 h-3" />}
                {theme === 'light' ? t('light') : t('dark')}
              </div>
            </button>
            
            {/* User Info */}
            <div className="flex items-center gap-3 px-3 py-2 rounded-md bg-accent/50">
              <div className="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-primary-foreground text-sm font-bold">
                {user?.name?.charAt(0)?.toUpperCase() || 'U'}
              </div>
              <div className="flex-1 min-w-0">
                <p className="text-sm font-medium truncate">{user?.name}</p>
                <div className="flex items-center gap-1.5">
                  <span className={`inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium ${
                    user?.role === 'superadmin' ? 'bg-purple-100 text-purple-700' :
                    user?.role === 'admin' ? 'bg-blue-100 text-blue-700' :
                    user?.role === 'manager' ? 'bg-green-100 text-green-700' :
                    user?.role === 'staff' ? 'bg-amber-100 text-amber-700' :
                    user?.role === 'cashier' ? 'bg-orange-100 text-orange-700' :
                    user?.role === 'viewer' ? 'bg-gray-100 text-gray-700' :
                    'bg-gray-100 text-gray-700'
                  }`}>
                    {user?.role === 'superadmin' ? 'Super Admin' : 
                     user?.role === 'viewer' ? 'View Only' : 
                     user?.role?.charAt(0)?.toUpperCase() + user?.role?.slice(1)}
                  </span>
                  {user?.role === 'viewer' && (
                    <Eye className="w-3 h-3 text-gray-500" />
                  )}
                </div>
              </div>
              <button 
                onClick={logout}
                data-testid="logout-btn"
                className="p-1.5 hover:bg-destructive/10 hover:text-destructive rounded transition-colors"
                title={t('logout')}
              >
                <LogOut className="w-4 h-4" />
              </button>
            </div>
          </div>
        </div>
      </aside>
    </>
  );
};

// Main Layout
const MainLayout = ({ children, currentPage, setCurrentPage }) => {
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [cartOpen, setCartOpen] = useState(false);
  const { api, isImpersonating, returnFromImpersonation, user } = useAuth();
  
  // Listen for cart open event
  useEffect(() => {
    const handleOpenCart = () => setCartOpen(true);
    window.addEventListener('open-cart', handleOpenCart);
    return () => window.removeEventListener('open-cart', handleOpenCart);
  }, []);
  
  const pageTitle = {
    dashboard: 'Dashboard',
    analytics: 'Analytics Dashboard',
    pos: 'Point of Sale',
    items: 'Items Management',
    'smart-scanner': 'Smart Stock Scanner',
    inventory: 'Inventory',
