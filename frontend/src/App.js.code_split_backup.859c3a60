// Apply saved color theme on initial load (before React renders)
const applyInitialColorTheme = () => {
  const savedTheme = localStorage.getItem('colorTheme') || 'default';
  const themeColors = COLOR_THEMES[savedTheme];
  if (themeColors) {
    const root = document.documentElement;
    Object.entries(themeColors).forEach(([key, value]) => {
      root.style.setProperty(key, value);
    });
    if (savedTheme === 'dark-mode' || savedTheme === 'retail-purple') {
      root.classList.add('dark');
    }
  }
};

// Apply theme immediately on script load
applyInitialColorTheme();

const ThemeProvider = ({ children }) => {
  const [theme, setTheme] = useState(() => {
    const saved = localStorage.getItem('theme');
    return saved || 'light';
  });

  useEffect(() => {
    const root = document.documentElement;
    if (theme === 'dark') {
      root.classList.add('dark');
    } else {
      root.classList.remove('dark');
    }
    localStorage.setItem('theme', theme);
  }, [theme]);

  const toggleTheme = () => {
    setTheme(prev => prev === 'light' ? 'dark' : 'light');
  };

  return (
    <ThemeContext.Provider value={{ theme, toggleTheme }}>
      {children}
    </ThemeContext.Provider>
  );
};

// Auth Context
const AuthContext = createContext(null);

export const useAuth = () => useContext(AuthContext);

const AuthProvider = ({ children }) => {
  const [user, setUser] = useState(null);
  const [isOpen, setIsOpen] = useState(false);
  const [interval, setInterval] = useState(false);
  const [timeout, setTimeout] = useState(false);
  const [item, setItem] = useState(false);
  const [property, setProperty] = useState(false);
  const [token, setToken] = useState(localStorage.getItem('token'));
  // Only show loading if there's a token to verify
  // This prevents the blinking spinner when there's no token
  const [loading, setLoading] = useState(!!localStorage.getItem('token'));
  const [isImpersonating, setIsImpersonating] = useState(!!localStorage.getItem('originalToken'));
  const initialCheckDone = React.useRef(false);
  const isLoggingOut = React.useRef(false);
  const isLoggingIn = React.useRef(false);
  const refreshIntervalRef = React.useRef(null);
  const tokenRefreshInitialized = React.useRef(false);

  // Check for impersonation on load
  useEffect(() => {
    const originalToken = localStorage.getItem('originalToken');
    setIsImpersonating(!!originalToken);
  }, []);

  const logout = useCallback(() => {
    // Prevent logout during login only
    if (isLoggingIn.current) return;
    
    // Reset logout flag immediately to prevent stuck state
    isLoggingOut.current = true;
    tokenRefreshInitialized.current = false;
    
    // Clear storage first
    localStorage.removeItem('token');
    localStorage.removeItem('originalToken');
    localStorage.removeItem('originalUser');
    sessionStorage.clear();
    
    // Then update state
    setToken(null);
    setUser(null);
    setIsImpersonating(false);
    
    // Reset flag after short delay
    setTimeout(() => {
      isLoggingOut.current = false;
    }, 500);
    
    // Force reload to login page
    window.location.href = '/';
  }, []);

  // Return to Super Admin from impersonation
  const returnFromImpersonation = useCallback(() => {
    const originalToken = localStorage.getItem('originalToken');
    const originalUserJson = localStorage.getItem('originalUser');
    
    if (originalToken && originalUserJson) {
      try {
        const originalUser = JSON.parse(originalUserJson);
        // Restore original super admin session
        localStorage.setItem('token', originalToken);
        localStorage.removeItem('originalToken');
        localStorage.removeItem('originalUser');
        setToken(originalToken);
        setUser(originalUser);
        setIsImpersonating(false);
        toast.success('Returned to Super Admin session');
        return true;
      } catch (err) {
        console.error('Failed to restore session:', err);
        toast.error('Failed to return to Super Admin');
        return false;
      }
    }
    return false;
  }, []);

  // Start impersonation
  const startImpersonation = useCallback((newToken, newUser) => {
    // Store current super admin credentials
    const currentToken = localStorage.getItem('token');
    const currentUser = user;
    
    if (currentUser?.role === 'superadmin' && currentToken) {
      localStorage.setItem('originalToken', currentToken);
      localStorage.setItem('originalUser', JSON.stringify(currentUser));
    }
    
    // Switch to impersonated user
    localStorage.setItem('token', newToken);
    setToken(newToken);
    setUser(newUser);
    setIsImpersonating(true);
  }, [user]);

  const api = useCallback(async (endpoint, options = {}) => {
    // Get fresh token from localStorage (in case it was updated by another tab)
    const currentToken = localStorage.getItem('token');
    
    // Check if body is FormData - don't set Content-Type, let browser handle it
    const isFormData = options.body instanceof FormData;
    
    const headers = {
      ...(!isFormData && { 'Content-Type': 'application/json' }),
      ...(currentToken && { 'Authorization': `Bearer ${currentToken}` }),
      ...options.headers,
    };

    try {
      const res = await fetch(`${API_URL}${endpoint}`, {
        ...options,
        headers,
      });

      if (res.status === 401) {
        // Check if this is an auth endpoint (login/register) - these should show actual error, not "session expired"
        const isAuthEndpoint = endpoint.includes('/auth/login') || endpoint.includes('/auth/register');
        
        if (isAuthEndpoint) {
          // For auth endpoints, return the actual error message from backend
          const err = await res.json().catch(() => ({ detail: 'Invalid credentials' }));
          throw new Error(err.detail || 'Invalid credentials');
        }
        
        // For other endpoints, only logout if not already logging out
        if (!isLoggingOut.current) {
          logout();
        }
        throw new Error('Session expired. Please login again.');
      }

      if (!res.ok) {
        const err = await res.json().catch(() => ({ detail: `Request failed with status ${res.status}` }));
        throw new Error(err.detail || `Request failed with status ${res.status}`);
      }

      return res.json();
    } catch (error) {
      // Re-throw the error but don't logout on network errors
      if (error.message !== 'Session expired' && error.name === 'TypeError') {
        throw new Error('Network error. Please check your connection.');
      }
      throw error;
    }
  }, [logout]);

  useEffect(() => {
    // Only run initial auth check once
    if (initialCheckDone.current) return;
    initialCheckDone.current = true;
    
    const storedToken = localStorage.getItem('token');
    if (storedToken) {
      // Verify token with backend
      fetch(`${API_URL}/api/auth/me`, {
        headers: {
          'Authorization': `Bearer ${storedToken}`,
          'Content-Type': 'application/json'
        }
      })
        .then(res => {
          if (!res.ok) {
            throw new Error('Token invalid');
          }
          return res.json();
        })
        .then(userData => {
          setUser(userData);
          setToken(storedToken);
        })
        .catch((err) => {
          // Token is invalid, clean up silently - don't show error toast
          // This happens when user returns to app with expired token
          console.log('Initial auth check failed (token expired), clearing...');
          // Clear invalid token
          localStorage.removeItem('token');
          setToken(null);
          setUser(null);
        })
        .finally(() => setLoading(false));
    } else {
      setLoading(false);
    }
  }, []);

  // Auto-refresh token to prevent session expiration
  // Refresh every 20 hours (before 24-hour token expiry)
  useEffect(() => {
    // Only initialize token refresh once when user is logged in
    if (tokenRefreshInitialized.current || !user || !token) return;
    tokenRefreshInitialized.current = true;
    
    const refreshToken = async () => {
      const currentToken = localStorage.getItem('token');
      if (!currentToken || isLoggingOut.current) return;
      
      try {
        const response = await fetch(`${API_URL}/api/auth/refresh`, {
          method: 'POST',
          headers: {
            'Authorization': `Bearer ${currentToken}`,
            'Content-Type': 'application/json'
          }
        });
        
        if (response.ok) {
          const data = await response.json();
          localStorage.setItem('token', data.access_token);
          // Don't call setToken here to avoid re-triggering this effect
          console.log('Token refreshed successfully');
        }
      } catch (err) {
        console.log('Token refresh failed:', err.message);
      }
    };

    // Refresh token every 20 hours (72000000 ms)
    refreshIntervalRef.current = setInterval(refreshToken, 20 * 60 * 60 * 1000);
    
    // Also refresh once on initial login (after a small delay)
    setTimeout(refreshToken, 5000);

    return () => {
      if (refreshIntervalRef.current) {
        clearInterval(refreshIntervalRef.current);
      }
    };
  }, [user, token]);

  const login = useCallback(async (email, password) => {
    // Prevent multiple simultaneous login attempts
    if (isLoggingIn.current) {
      console.log('Login already in progress, skipping...');
      return;
    }
    isLoggingIn.current = true;
    
    // Reset token refresh flag for new login
    tokenRefreshInitialized.current = false;
    
    // Clear any existing invalid token before login attempt
    localStorage.removeItem('token');
    
    try {
      const response = await fetch(`${API_URL}/api/auth/login`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ email, password }),
      });
      
      if (!response.ok) {
        const err = await response.json().catch(() => ({ detail: 'Login failed' }));
        throw new Error(err.detail || 'Invalid credentials');
      }
      
      const data = await response.json();
      
      // Store new token FIRST in localStorage
      localStorage.setItem('token', data.access_token);
      
      // Clear crash log on successful login to prevent safe mode false positives
      localStorage.removeItem('bijnisbooks_crash_log');
      
      // Reset the logging out flag if it was set
      isLoggingOut.current = false;
      
      // Update state in a single batch - React will batch these together
      // Setting both at once prevents intermediate renders with mismatched state
      setToken(data.access_token);
      setUser(data.user);
      
      return data.user;
    } catch (error) {
      // Clear any partial state on error
      localStorage.removeItem('token');
      setToken(null);
      setUser(null);
      throw error;
    } finally {
      isLoggingIn.current = false;
    }
  }, []);

  const register = useCallback(async (email, password, name) => {
    const data = await api('/api/auth/register', {
      method: 'POST',
      body: JSON.stringify({ email, password, name }),
    });
    return data;
  }, [api]);

  // Memoize context value to prevent unnecessary re-renders  
  const authValue = useMemo(() => ({
    user,
    token,
    loading,
    login,
    register,
    logout,
    api,
    isImpersonating,
    returnFromImpersonation,
    startImpersonation
  }), [user, token, loading, login, register, logout, api, isImpersonating, returnFromImpersonation, startImpersonation]);

  return (
    <AuthContext.Provider value={authValue}>
      {children}
    </AuthContext.Provider>
  );
};

